        if true_base not in file_groups:
            file_groups[true_base] = []
        file_groups[true_base].append((file_name, base_name))
    
    print(f"File groups to combine: {list(file_groups.keys())}\n")
    print("="*60 + "\n")
    
    # Process each group
    for true_base, group_files in file_groups.items():
