import re
import pprint
import os

def generate_layout_file(field_layout_file, output_dir='.'):
    """Generate Python layout file from SAS field definition"""
    
    if not os.path.exists(field_layout_file):
        raise FileNotFoundError(f"Field Config File not found: {field_layout_file}")
    
    try:
        print(f"\n{'='*70}")
        print(f"Processing: {os.path.basename(field_layout_file)}")
        print('='*70)
        
        # Read file
        with open(field_layout_file, 'r', encoding='utf-8') as f:
            sas_input_code = f.read()
        
        print(f"File length: {len(sas_input_code)} characters")
        
        # Find LRECL
        lrecl_pattern = re.compile(r'lrecl\s*=\s*(\d+)', re.IGNORECASE)
        lrecl_match = lrecl_pattern.search(sas_input_code)
        
        if not lrecl_match:
            raise ValueError("Could not find LRECL in the code")
        
        lrecl = int(lrecl_match.group(1))
        print(f"✓ Found LRECL: {lrecl}")
        
        # Split by 'input' keyword (case-insensitive)
        split_result = re.split(r'input', sas_input_code, flags=re.IGNORECASE)
        
        if len(split_result) < 2:
            raise ValueError("No 'INPUT' keyword found in file")
        
        # Get content between INPUT and semicolon
        input_section = split_result[1]
        
        if ';' not in input_section:
            raise ValueError("No semicolon (;) found after INPUT keyword")
        
        input_lines = input_section.split(";")[0]
        print(f"✓ Extracted INPUT block")
        
        # Parse fields
        layout = {}
        input_line_pattern = re.compile(r'@\s*(\d+)\s+([A-Za-z0-9_]+)\s+([$\w\.]+)')
        
        field_count = 0
        skipped_count = 0
        
        for line_num, line in enumerate(input_lines.strip().splitlines(), 1):
            line = line.strip()
            
            # Skip empty lines and comments
            if not line or line.startswith('/*') or line.startswith('*'):
                continue
            
            # Remove inline comments
            if '/*' in line:
                line = line.split('/*')[0].strip()
            
            # Match INPUT line pattern
            match = input_line_pattern.match(line)
            
            if not match:
                continue
            
            start_pos, field_name, informat_str = match.groups()
            start_pos = int(start_pos)
            
            spec = {}
            byte_length = None
            
            # Clean informat string
            clean_informat = informat_str.strip('$.').upper()
            
            # Try to match different informat types
            # 1. Packed Decimal: S370FPD6., S370FPD8.2
            pd_match = re.match(r'S370FPD(\d+)(?:\.(\d+))?', clean_informat)
            if pd_match:
                spec['type'] = 'packed'
                byte_length = int(pd_match.group(1))
                if pd_match.group(2):
                    spec['decimals'] = int(pd_match.group(2))
            
            # 2. EBCDIC: EBCDIC10
            elif re.match(r'EBCDIC(\d+)', clean_informat):
                ebcdic_match = re.match(r'EBCDIC(\d+)', clean_informat)
                spec['type'] = 'ebcdic'
                byte_length = int(ebcdic_match.group(1))
            
            # 3. String formats: $10., $CHAR10., $UPCASE5., $HEX8.
            elif informat_str.startswith('$'):
                string_match = re.search(r'(\d+)', informat_str)
                if string_match:
                    spec['type'] = 'string'
                    byte_length = int(string_match.group(1))
            
            # 4. Date formats: YYMMDD8., MMDDYY8., DDMMYY8., DATE8.
            elif re.match(r'(?:YYMMDD|MMDDYY|DDMMYY|DATE)(\d+)', clean_informat):
                date_match = re.match(r'(?:YYMMDD|MMDDYY|DDMMYY|DATE)(\d+)', clean_informat)
                spec['type'] = 'integer'
                byte_length = int(date_match.group(1))
            
            # 5. Float with decimals: 8.2, 10.4
            elif re.match(r'^\d+\.\d+$', clean_informat):
                parts = clean_informat.split('.')
                spec['type'] = 'float'
                byte_length = int(parts[0])
                spec['decimals'] = int(parts[1])
            
            # 6. Simple integer: 8., 10., or just 8, 10
            elif re.match(r'^\d+\.?$', clean_informat):
                spec['type'] = 'integer'
                byte_length = int(clean_informat.rstrip('.'))
            
            # If we couldn't parse the format
            if byte_length is None:
                print(f"  ⚠ Line {line_num}: Could not parse '{informat_str}' for '{field_name}'")
                skipped_count += 1
                continue
            
            # Create slice
            spec['slice'] = slice(start_pos - 1, start_pos - 1 + byte_length)
            layout[field_name] = spec
            field_count += 1
        
        print(f"✓ Processed {field_count} fields")
        if skipped_count > 0:
            print(f"  ⚠ Skipped {skipped_count} lines")
        
        if not layout:
            raise ValueError("No fields were extracted from INPUT block")
        
        # Generate output file
        base_name = os.path.basename(field_layout_file).rsplit('.', 1)[0]
        output_filename = f"{base_name}_layout.py"
        output_layout_path = os.path.join(output_dir, output_filename)
        
        formatted_layout_string = pprint.pformat(layout, sort_dicts=False)
        
        with open(output_layout_path, 'w', encoding='utf-8') as f:
            f.write(f"LRECL = {lrecl}\n\n")
            f.write(f"LAYOUT = {formatted_layout_string}\n")
        
        print(f"✓ Successfully generated: {output_filename}")
        print(f"  Location: {output_layout_path}")
        print(f"  Fields: {len(layout)}")
        
    except Exception as e:
        print(f"\n✗ ERROR: {e}")
        import traceback
        traceback.print_exc()
        raise


# Configuration
FIELD_LAYOUT_PATH = "/sas/python/virt_edw/Data_Warehouse/MIS/Job/LOAN/FIELDS_LAYOUT"
LAYOUT_OUTPUT_DIR = "/sas/python/virt_edw/Data_Warehouse/MIS/Job/LOAN/PARQUET_LAYOUT"


if __name__ == "__main__":
    print("="*70)
    print("LAYOUT FILE GENERATOR")
    print("="*70)
    print(f"Input Path: {FIELD_LAYOUT_PATH}")
    print(f"Output Path: {LAYOUT_OUTPUT_DIR}")
    
    # Create output directory if needed
    if not os.path.exists(LAYOUT_OUTPUT_DIR):
        os.makedirs(LAYOUT_OUTPUT_DIR)
        print(f"✓ Created output directory: {LAYOUT_OUTPUT_DIR}")
    
    # Check input path exists
    if not os.path.exists(FIELD_LAYOUT_PATH):
        print(f"\n✗ ERROR: Input path does not exist!")
        exit(1)
    
    # Get all .txt files
    txt_files = [f for f in os.listdir(FIELD_LAYOUT_PATH) if f.endswith(".txt")]
    
    if not txt_files:
        print(f"\n✗ ERROR: No .txt files found in {FIELD_LAYOUT_PATH}")
        exit(1)
    
    print(f"\nFound {len(txt_files)} .txt files")
    
    # Process each file
    success_count = 0
    error_count = 0
    
    for filename in txt_files:
        file_path = os.path.join(FIELD_LAYOUT_PATH, filename)
        try:
            generate_layout_file(file_path, output_dir=LAYOUT_OUTPUT_DIR)
            success_count += 1
        except Exception as e:
            error_count += 1
    
    # Summary
    print("\n" + "="*70)
    print("SUMMARY")
    print("="*70)
    print(f"✓ Success: {success_count}")
    print(f"✗ Errors: {error_count}")
    print(f"Total: {len(txt_files)}")
    print("="*70)
