def parse_packed_date(packed_value: int, format_type: str = 'YYMMDD') -> datetime.date:
    """
    Convert packed decimal date to Python date.
    YYMMDD8.: 20241115 -> 2024-11-15
    MMDDYY8.: 11152024 -> 2024-11-15
    """
    if packed_value == 0:
        return None
    date_str = str(packed_value).zfill(8)
    
    try:
        if format_type == 'YYMMDD':
            return datetime.strptime(date_str, '%Y%m%d').date()
        elif format_type == 'MMDDYY':
            return datetime.strptime(date_str, '%m%d%Y').date()
    except:
        return None

