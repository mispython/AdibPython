@njit
def unpack_packed_decimal(pd_bytes_array):
    val = np.int64(0)

    if not pd_bytes_array.size:
        return val
    
    sign_nibble = pd_bytes_array[-1] & 0x0F
    is_negative = (sign_nibble == 0x0D or sign_nibble == 0x0B)

    for i in range(len(pd_bytes_array)):
        byte = pd_bytes_array[i]
        high_nibble = byte >> 4

        if i == len(pd_bytes_array) - 1:
            val = val * 10 + high_nibble
        else:
            low_nibble = byte & 0x0F
            val = val * 100 + high_nibble * 10 + low_nibble

    return -val if is_negative else val

def decode_records(record_bytes, layout):
    decoded_row = {}
    all_null = True
    
    for field_name, specs in layout.items():
        field_bytes = record_bytes[specs['slice']]
        field_type = specs['type']

        try:
            if field_type == 'ebcdic':
                # Try multiple EBCDIC code pages
                decoded_value = None
                for code_page in ['cp037', 'cp500', 'cp1047', 'latin-1']:
                    try:
                        decoded = field_bytes.decode(code_page).strip()
                        if decoded and not all(c in ' \x00' for c in decoded):
                            decoded_value = decoded
                            all_null = False
                            break
                    except:
                        continue
                
                if decoded_value is None:
                    # Try raw approach for problematic bytes
                    try:
                        cleaned = field_bytes.replace(b'\x00', b' ').strip()
                        decoded_value = cleaned.decode('ascii', errors='ignore').strip()
                        if decoded_value and not all(c in ' \x00' for c in decoded_value):
                            all_null = False
                        else:
                            decoded_value = None
                    except:
                        decoded_value = None
                
                decoded_row[field_name] = decoded_value
                        
            elif field_type == 'packed':
                try:
                    raw_val = unpack_packed_decimal(np.frombuffer(field_bytes, dtype=np.uint8))
                    decimals = specs.get('decimals', 0)
                    if decimals > 0:
                        decoded_row[field_name] = Decimal(raw_val) / (Decimal(10) ** decimals)
                    else:
                        decoded_row[field_name] = raw_val
                    
                    if decoded_row[field_name] not in (None, 0, ''):
                        all_null = False
                except Exception as e:
                    decoded_row[field_name] = None
                    
        except Exception as e:
            decoded_row[field_name] = None
    
    # COMMENTED OUT: Skip padding records
    # if all_null:
    #     # Check if this looks like a padding record (all zeros, spaces, or nulls)
    #     if record_bytes.strip(b'\x00\x20\xFF') == b'':
    #         return None  # Skip padding records entirely
    
    return decoded_row

def generate_records(filename, record_size, max_records):
    records_yeild = 0
    try:
        with open(filename, 'rb') as f:
            while True:
                if max_records != None and records_yeild >= max_records:
                    break
                record = f.read(record_size)
                if not record:
                    break
                if len(record) == record_size:
                    yield record
                    records_yeild += 1
    except Exception as e:
        print(f"Error file{e}:")
        return

def load_layout_file(layout_file_path):
    spec = importlib.util.spec_from_file_location("layout_module", layout_file_path)
    if spec is None:
        raise FileNotFoundError(f"Layout file not found at {layout_file_path}")
    
    layout_module = importlib.util.module_from_spec(spec)
    sys.modules['layout_module'] = layout_module
    spec.loader.exec_module(layout_module)
    return layout_module.LAYOUT, layout_module.LRECL

def is_text_file(filepath, chunksize=4096, threshold=0.3):
    """
    More robust text file detection that checks for a high percentage of printable characters
    """
    if not os.path.exists(filepath):
        return False
        
    try:
        # First check file extension as a hint
        if filepath.endswith('.txt') or '.txt' in filepath.lower():
            return True
            
        with open(filepath, 'rb') as f:
            chunk = f.read(chunksize)
            if not chunk:
                return True  # Empty file is considered text
                
            # Count printable ASCII characters (bytes 32-126 plus common whitespace)
            printable_count = sum(1 for byte in chunk if 32 <= byte <= 126 or byte in (9, 10, 13))
            total_count = len(chunk)
            
            # If more than threshold% are printable, it's likely text
            if total_count > 0 and (printable_count / total_count) > threshold:
                if b'\x00' in chunk or any(byte <32 and byte not in (9, 10, 13) for byte in chunk):
                    return False
                return True
                
        return False
        
    except Exception:
        return False

def analyze_file_format(filename, lrecl, layout):
    """Analyze file to determine its actual format"""
    try:
        with open(filename, 'rb') as f:
            # Read sample records
            samples = []
            for i in range(min(10, os.path.getsize(filename) // lrecl)):
                record = f.read(lrecl)
                if not record:
                    break
                samples.append(record)
            
            if not samples:
                return False
                
            # Check if records appear to be text
            text_like = 0
            for sample in samples:
                # Count printable characters
                printable = sum(1 for byte in sample if 32 <= byte <= 126 or byte in (9, 10, 13))
                if printable / len(sample) > 0.6:  # 60% printable = likely text
                    text_like += 1
            
            return text_like / len(samples) > 0.7  # 70% of samples text-like
    except:
        return False

def read_decode_chunk_to_df(byte_range, filename, lrecl, layout, schema):
    start_byte, end_byte = byte_range
    try:
        print(f"[Chunk Start] {filename}: {start_byte}-{end_byte}, size={end_byte-start_byte} bytes")

        with open(filename, 'rb') as f:
            f.seek(start_byte)
            record_count = 0
            success_count = 0
            skipped_count = 0

            while f.tell() < end_byte:
                record_byte = f.read(lrecl)
                if not record_byte or len(record_byte) < lrecl:
                    break

                decoded = decode_records(record_byte, layout)
                
                # COMMENTED OUT: Skip records that decoded to None (padding)
                # if decoded is None:
                #     skipped_count += 1
                #     continue
                    
                yield decoded
                record_count += 1
                success_count += 1

                if record_count % 100000 == 0:
                    print(f"   Processed {record_count} records, {success_count} success, {skipped_count} skipped")

        print(f"[Chunk Done] {filename}: {start_byte}-{end_byte}, total={record_count}, success={success_count}, skipped={skipped_count}")

    except Exception as e:
        print(f"Error file {filename}: {e}")
        return pd.DataFrame(columns=schema.keys()).astype(schema)
    
def create_status_file(all_jobs, status_file_path):
    status = {}
    if os.path.exists(status_file_path):
        print(f"Rerun detected. Loading job status fom {status_file_path}")
        with open(status_file_path, 'r') as f:
            data = json.load(f)
        for file_path, current_status in data.items():
            if isinstance(current_status, str):
                status[file_path] = {"status": current_status, "reason": "N/A"}
            else:
                status[file_path] = current_status
    else:
        print(f"First run detected. Creating new status file {status_file_path}")
    for job in all_jobs:
        file_path = job['input_file']
        if file_path not in status:
            status[file_path] = {"status": "pending", "reason": "N/A"}
    with open(status_file_path, 'w') as f:
        json.dump(status, f, indent=4)
    return status

def update_status_file(status_file_path, file_path, new_result):
    with open(status_file_path, 'r+') as f:
        data = json.load(f)
        data[file_path] = {
            'status': new_result['status'],
            'reason': new_result.get('reason', 'Unknown Error')
        }
        f.seek(0)
        json.dump(data, f, indent=4)
        f.truncate()

def process_file(job_spec, output_dir, applname):
    file_start_time = time.time()
    input_file = job_spec['input_file']
    layout_file_path = job_spec['layout_file']
    is_text_file_flag = job_spec['is_text']

    file_base_name = os.path.splitext(os.path.basename(input_file))[0]
    base_name = file_base_name.rsplit('_', 1)[0]

    os.makedirs(output_dir, exist_ok=True)

    final_parquet_output = os.path.join(output_dir, f"STG_{applname}_{base_name}.parquet")

    if os.path.exists(final_parquet_output) and os.path.isdir(final_parquet_output):
        final_parquet_output = os.path.join(final_parquet_output, f"STG_{applname}_{base_name}.parquet")

    print(f"\n---- START Processing for file: {input_file} ----")

    try:
        FILE_LAYOUT, INPUT_LRECL = load_layout_file(layout_file_path)

        meta_schema = {}
        for name, spec in FILE_LAYOUT.items():
            if spec['type'] == 'packed':
                meta_schema[name] = float if 'decimals' in spec else int
            elif spec['type'] == 'ebcdic':
                meta_schema[name] = str
            elif spec['type'] == 'string':
                meta_schema[name] = str
            elif spec['type'] == 'integer':
                if is_text_file_flag:
                    meta_schema[name] = float
                else:
                    meta_schema[name] = int
            elif spec['type'] == 'float':
                meta_schema[name] = float

        # ============ FILE ANALYSIS ============
        print(f"=== FILE ANALYSIS ===")
        file_size = os.path.getsize(input_file)
        print(f"File size: {file_size} bytes")
        print(f"Record length from layout: {INPUT_LRECL} bytes")
        print(f"Expected records: {file_size // INPUT_LRECL if file_size else 0}")
        
        # Read first few records to diagnose
        with open(input_file, 'rb') as f:
            first_record = f.read(INPUT_LRECL)
            second_record = f.read(INPUT_LRECL)
            
            print(f"First record hex (first 50 bytes): {first_record[:50].hex() if first_record else 'None'}")
            
            # Try decoding first record
            if first_record and len(first_record) == INPUT_LRECL:
                test_decode = decode_records(first_record, FILE_LAYOUT)
                print(f"First record decode test: {test_decode}")
                
                # Check if it's all NULL
                if test_decode and all(v is None for v in test_decode.values()):
                    print("WARNING: First record decoded to all NULL values!")
                    # Try alternative code pages
                    print("Trying alternative decoding...")
                    for code_page in ['cp500', 'cp1047', 'latin-1']:
                        try:
                            test_text = first_record.decode(code_page)
                            print(f"  As {code_page}: {repr(test_text)}")
                        except:
                            print(f"  {code_page}: Failed")
        # ============ END FILE ANALYSIS ============

        # if not input_file.endswith('.txt') and not input_file.lower().endswith('.txt'):
        #     print(f"File {input_file} has no .txt extension, forcing binary processing.")
        #     is_text_file_flag = False

        # Check if binary file might actually be text
        # if not is_text_file_flag:
        #     might_be_text = analyze_file_format(input_file, INPUT_LRECL, FILE_LAYOUT)
        #     if might_be_text:
        #         print(f"File {input_file} appears to be text format, trying text processing...")
        #         is_text_file_flag = True

        if is_text_file_flag:
            print(f"The file {input_file} is detected as Text File / Non-Binary.")

            colspecs = [(spec['slice'].start, spec['slice'].stop) for spec in FILE_LAYOUT.values()]
            names = list(FILE_LAYOUT.keys())

            try:
                ddf = dd.read_fwf(
                    input_file,
                    colspecs=colspecs,
                    names=names,
                    dtype={k: v for k, v in meta_schema.items() if v != 'object'},
                    blocksize='128MB',
                    na_values=['.'],  # Only dots as NA, not spaces or empty strings
                    engine='python',
                    encoding='latin-1'
                )
                df = ddf.compute()
                
                # ============ TEXT DIAGNOSTICS ============
                print("=== TEXT PROCESSING DIAGNOSTICS ===")
                print(f"Raw DataFrame shape: {df.shape}")
                print(f"Null value counts:")
                print(df.isnull().sum())
                
                # COMMENTED OUT: Remove only completely empty rows
                # initial_count = len(df)
                # df = df[~df.isnull().all(axis=1)]
                # final_count = len(df)
                
                # if initial_count != final_count:
                #     print(f"Removed {initial_count - final_count} completely empty rows")
                print(f"Final text record count: {len(df)}")
                # ============ END DIAGNOSTICS ============
                
                print(f"Successfully processed as text file")

            except UnicodeDecodeError as e:
                print(f"Text processing failed with encoding error: {e}")
                print("Falling back to binary processing...")
                is_text_file_flag = False
            except Exception as e:
                print(f"Text processing failed: {e}")
                print("Falling back to binary processing...")
                is_text_file_flag = False

        if not is_text_file_flag:
            print(f"Processing {input_file} as Binary File.")
            file_size = os.path.getsize(input_file)

            if file_size % INPUT_LRECL != 0:
                print(f"Warning: File size {file_size} not divisible by record length {INPUT_LRECL}")
                print(f"Will process {file_size // INPUT_LRECL} complete records")

            if file_size == 0:
                print(f"Warning: Empty file {input_file}")
                return {"file": input_file, "status": "completed"}

            # TEST MODE: Process first 1000 records only for debugging
            TEST_MODE = False
            if TEST_MODE:
                print("=== TEST MODE: Processing first 1000 records only ===")
                test_records = []
                with open(input_file, 'rb') as f:
                    for i in range(1000):
                        record_bytes = f.read(INPUT_LRECL)
                        if not record_bytes or len(record_bytes) < INPUT_LRECL:
                            break
                        decoded = decode_records(record_bytes, FILE_LAYOUT)
                        # COMMENTED OUT: Skip padding
                        # if decoded is not None:  # Skip padding
                        test_records.append(decoded)
                
                df = pd.DataFrame(test_records)
                print("Test results shape:", df.shape)
                print("Non-null counts:", df.notnull().sum())
                print("First 10 records:")
                print(df.head(10))
                
            else:
                # Full processing
                chunk_size = 128 * 1024 * 1024
                chunks = []
                start = 0

                while start < file_size:
                    remaining_bytes = file_size - start
                    
                    if remaining_bytes >= chunk_size:
                        records_in_chunk = chunk_size // INPUT_LRECL
                        end = start + (records_in_chunk * INPUT_LRECL)
                    else:
                        records_in_chunk = remaining_bytes // INPUT_LRECL
                        end = start + (records_in_chunk * INPUT_LRECL)
                    
                    if records_in_chunk > 0:
                        chunks.append((start, end))
                        print(f"Created chunk: {start}-{end} ({records_in_chunk} records)")
                    
                    if end > start:
                        start = end
                    else:
                        start = file_size
                        print(f"Advancing past {remaining_bytes} remaining bytes")

                if not chunks:
                    print(f"Warning: No valid chunks found for file {input_file}")
                    return {"file": input_file, "status": "completed"}
                
                print(f"Total chunks created: {len(chunks)}")
                    
                chunks_bag = db.from_sequence(chunks)
                df_bag = chunks_bag.map(read_decode_chunk_to_df, filename=input_file, lrecl=INPUT_LRECL, layout=FILE_LAYOUT, schema=meta_schema).flatten()
                df = df_bag.to_dataframe(meta=meta_schema).compute()

        # ============ FINAL VALIDATION ============
        print("=== FINAL VALIDATION ===")
        print(f"Final DataFrame shape: {df.shape}")
        print(f"Null value counts:")
        null_counts = df.isnull().sum()
        print(null_counts)
        
        # COMMENTED OUT: Remove rows that are 100% empty
        # initial_count = len(df)
        # df = df[~df.isnull().all(axis=1)]
        # final_count = len(df)
        
        # if initial_count != final_count:
        #     print(f"Removed {initial_count - final_count} completely empty rows")
        
        print(f"Final row count: {len(df)}")
        
        # Verify against expected count for binary files
        if not is_text_file_flag:
            expected_records = file_size // INPUT_LRECL
            print(f"Expected records from binary file: {expected_records}")
            if expected_records != len(df):
                print(f"WARNING: Record count mismatch! Expected: {expected_records}, Got: {len(df)}")
        # ============ END VALIDATION ============

        df.to_parquet(final_parquet_output, index=False, overwrite=True)
        
        row_count = len(df)
        file_end_time = time.time()
        print(f"Successfully processed {input_file}. Saved to {final_parquet_output}")
        print(f"Time taken to complete file {input_file}: {file_end_time - file_start_time}")
        print(f"Total Row Count for {input_file}: {row_count}")
        return {"file": input_file, "status": "completed", "reason":"Success"}
    except FileNotFoundError as e:
        error_msg = f"Data File Not Found: {input_file}"
        return {"file": input_file, "status": "failed", "reason":error_msg}
    except Exception as e:
        print(f"Failed to process {input_file}: {e}")
        error_msg = f"ERROR: {type(e).__name__} - {str(e)}..."
        return {"file": input_file, "status": "failed", "reason":error_msg}
    finally:
        print(f"\n---- END Processing for file: {input_file} ----")
    
def run_file_reader(input_dir, output_dir, layout_dir, batch_dt_str, status_file_dir, applname, batch_mode):
    all_jobs = []
    unique_files = set()
    for layout_file_name in os.listdir(layout_dir):
        if not layout_file_name.endswith("_layout.py"):
            continue

        base_name = os.path.splitext(layout_file_name)[0].rsplit("_layout", 1)[0]

        binary_input_path = os.path.join(input_dir, f"{base_name}_{batch_dt_str}")
        text_input_path = os.path.join(input_dir, f"{base_name}_{batch_dt_str}.txt")
        binary_input_path_x = os.path.join(input_dir, f"{base_name}{batch_dt_str}")
        text_input_path_x = os.path.join(input_dir, f"{base_name}{batch_dt_str}.txt")

        try:
            temp_layout, _ = load_layout_file(os.path.join(layout_dir, layout_file_name))
            is_text_flag = any(spec['type'] in ('string') for spec in temp_layout.values())
        except Exception as e:
            print(f"Failed to load layout file '{layout_dir}'. Skipping")
            continue

        input_file_path = None
        if os.path.exists(binary_input_path):
            input_file_path = binary_input_path
            print(f"==========================={input_file_path}=====================================")
        elif os.path.exists(text_input_path):
            input_file_path = text_input_path
            print(f"==========================={input_file_path}=====================================")
        elif os.path.exists(binary_input_path_x):
            input_file_path = binary_input_path_x
            print(f"==========================={input_file_path}=====================================")
        elif os.path.exists(text_input_path_x):
            input_file_path = text_input_path_x
            print(f"==========================={input_file_path}=====================================")            
        else:
            print(f"Warning: Input file not found for layout {layout_file_name}")

        all_jobs.append({
            "input_file": input_file_path if input_file_path else f"{binary_input_path}",
            "layout_file": os.path.join(layout_dir, layout_file_name),
            "is_text": is_text_flag
        })
        unique_files.add(input_file_path)

    if not os.path.exists(status_file_dir):
        os.makedirs(status_file_dir)

    status_file_path = os.path.join(status_file_dir, f"{batch_mode}_status_{batch_dt_str}.json")
    job_status = create_status_file(all_jobs, status_file_path)

    jobs_to_run = [
        job for job in all_jobs
        if job_status.get(job['input_file'], {}).get("status") in ("pending", "failed")
    ]

    if not jobs_to_run:
        print("All the files for today's batch are completed.")
        return

    lazy_tasks = [dask.delayed(process_file)(job_spec, output_dir, applname) for job_spec in jobs_to_run]

    results = dask.compute(*lazy_tasks)
    for result in results:
        if result:
            update_status_file(status_file_path, result['file'], result)

    with open(status_file_path, 'r') as f:
        final_status = json.load(f)

    failed_files = [file for file, data in final_status.items() if isinstance(data, dict) and data.get("status") == "failed"]

    if failed_files:
        error_msg = (
            f"ERROR: The batch job failed {len(failed_files)} file(s) failed to process:\n"
            f"{', '.join(failed_files)}"
        )
        raise RuntimeError(error_msg)


def decode_single_file(layout_file, input_file):
    if not os.path.exists(input_file):
        raise FileNotFoundError(f"Data file not found {input_file}")
    
    is_text_flag = is_text_file(input_file)

    file_base_name = os.path.splitext(os.path.basename(input_file))[0]
    base_name = file_base_name.rsplit('_', 1)[0]
    final_parquet_output = f"/parquet/dwh/CC/staging/{base_name}.parquet"

    FILE_LAYOUT, INPUT_LRECL = load_layout_file(layout_file)

    meta_schema = {}
    for name, spec in FILE_LAYOUT.items():
        if spec['type'] == 'packed':
            meta_schema[name] = float if 'decimals' in spec else int
        elif spec['type'] == 'ebcdic':
            meta_schema[name] = str
        elif spec['type'] == 'string':
            meta_schema[name] = str
        elif spec['type'] == 'integer':
            if is_text_flag:
                meta_schema[name] = float
            else:
                meta_schema[name] = int
        elif spec['type'] == 'float':
            meta_schema[name] = float

    if os.path.getsize(input_file) == 0:
        print(f"The data file '{input_file}' is empty, return empty Dataframe")
        return pd.DataFrame({col: pd.Series(dtype=dtype) for col, dtype in meta_schema.items()})

    if is_text_flag:

        colspecs = [(spec['slice'].start, spec['slice'].stop) for spec in FILE_LAYOUT.values()]
        names = list(FILE_LAYOUT.keys())

        ddf = dd.read_fwf(
            input_file,
            colspecs=colspecs,
            names=names,
            dtype={k: v for k, v in meta_schema.items() if v != 'object'},
            blocksize='128MB',
            na_values=['.'],  # Only dots as NA, not spaces or empty strings
            engine='python'
        )
        for name, spec in FILE_LAYOUT.items():
            if spec['type'] == 'integer':
                ddf[name] = dd.to_numeric(ddf[name], errors='coerce')
            elif spec['type'] == 'float' and 'decimals' in spec and spec['decimals'] > 0:
                decimals = spec['decimals']
                numeric_col = dd.to_numeric(ddf[name], errors='coerce')
                ddf[name] = numeric_col / (10**decimals)
        df = ddf
    else:
        file_size = os.path.getsize(input_file)
        chunk_size = 128 * 1024 * 1024
        chunks = []
        start = 0

        while start < file_size:
            end = min(start + chunk_size, file_size)
            if end < file_size and end % INPUT_LRECL != 0:
                end -= (end % INPUT_LRECL)
            if start < end:
                chunks.append((start, end))
            start = end

        chunks_bag = db.from_sequence(chunks)

        df_bag = chunks_bag.map(read_decode_chunk_to_df, filename=input_file, lrecl=INPUT_LRECL, layout=FILE_LAYOUT, schema=meta_schema).flatten()

        df = df_bag.to_dataframe(meta=meta_schema)
    df.to_parquet(final_parquet_output, overwrite=True)
    return df
