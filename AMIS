# preprocess_mst.py
import os
import shutil

source_dir = "/sasdata/rawdata/ln"
date = "20251114"

# Find all MST files for this date
mst_files = [f"BILL_MST{i:02d}_{date}" for i in range(1, 11)]

# Combine them
output_file = f"{source_dir}/BILL_MST_{date}"
with open(output_file, 'wb') as outf:
    for mst_file in mst_files:
        filepath = f"{source_dir}/{mst_file}"
        if os.path.exists(filepath):
            with open(filepath, 'rb') as inf:
                outf.write(inf.read())

print(f"Created combined file: {output_file}")
