from pathlib import Path
from datetime import datetime
import polars as pl

# 1) Paths (adjust if your folders differ)
BASE_IN  = Path("Data_Warehouse/MIS/XMIS/Outsource/input")
BASE_OUT = Path("Data_Warehouse/MIS/XMIS/output")
BASE_OUT.mkdir(parents=True, exist_ok=True)

# 2) Hardcoded batch date (replaces DATEFILE reading)
batch_dt = datetime.strptime("2025-11-20 00:00:00", '%Y-%m-%d %H:%M:%S')
batch_dt_str = batch_dt.strftime("%Y%m%d")

# Convert to REPTDATE format (MMDDYYYY)
REPTDATE = batch_dt
REPTMON = f"{REPTDATE.month:02d}"        # SAS PUT(MM, Z2.)
REPTYEAR = f"{REPTDATE.year % 100:02d}"  # SAS YEAR2.

print(f"Processing for batch date: {batch_dt_str}")
print(f"REPTDATE: {REPTDATE}, REPTMON: {REPTMON}, REPTYEAR: {REPTYEAR}")

# 3) Read report data (already Parquet), keep column names as SAS (UPPERCASE)
RPTFILE_PATH = BASE_IN / "RPTFILE.parquet"

keep_cols = [
    "COSTCT", "NOTETYPE", "PRINBAL", "PRNNACCR", "INTACCR", "INTNACCR",
    "UNERNINT", "UNERNNON", "RSRVFIN", "RSRVDLR", "NONDDA", "LATEFEES",
    "OTHERFEE", "CTPRINT", "CTPRNNAC"
]

# Read only the needed columns for better performance
R6999 = pl.read_parquet(RPTFILE_PATH, columns=keep_cols)

print(f"Processed {len(R6999)} records")

# Output path mirrors SAS library/member name
out_dir = BASE_OUT / "LNR6999"
out_dir.mkdir(parents=True, exist_ok=True)
out_name = f"R6999{REPTMON}{REPTYEAR}.parquet"
output_path = out_dir / out_name

R6999.write_parquet(output_path)
print(f"Output successfully written to: {output_path}")
