# Get file names to export Parquet
def get_file_names(config_path, directory_path):
    """
    Match data files to layout files based on base pattern.
    E.g., BILL_MST_layout.py matches BILL_MST01_date, BILL_MST02_date, etc.
    """
    file_groups = {}
    
    try:
        # Get all layout files
        layout_files = [f for f in os.listdir(config_path) if f.endswith('_layout.py')]
        
        # Extract base names from layout files
        layout_bases = {}
        for layout_file in layout_files:
            base_name = layout_file.replace('_layout.py', '')
            layout_bases[base_name] = layout_file
        
        print(f"Layout files found: {list(layout_bases.keys())}")
        print(f"Looking for files with date: {batch_dt_str}\n")
        
        # Get all data files
        data_files = [f for f in os.listdir(directory_path) 
                     if os.path.isfile(os.path.join(directory_path, f))]
        
        # Match data files to layout files
        for data_file in data_files:
            parts = data_file.rsplit('_', 1)
            if len(parts) < 2:
                continue
                
            date_part = parts[1].rsplit('.', 1)[0]
            if date_part != batch_dt_str:
                continue
            
            # Check if this file matches any layout base
            # E.g., BILL_MST01_20251114 should match BILL_MST layout
            for layout_base in layout_bases.keys():
                if parts[0].startswith(layout_base):
                    print(f"✓ Matched: {data_file} -> {layout_base}_layout.py")
                    
                    if layout_base not in file_groups:
                        file_groups[layout_base] = []
                    file_groups[layout_base].append(data_file)
                    break
        
        if not file_groups:
            raise ValueError(f"No files found with date: {batch_dt_str}")
        
        return file_groups

    except Exception as e:
        print(f"Error: {e}")
        return {}

# Load layout from _layout.py file
def load_layout(var_path, base_name):
    layout_file = os.path.join(var_path, f"{base_name}_layout.py")
    
    if not os.path.exists(layout_file):
        raise FileNotFoundError(f"Layout file not found: {layout_file}")
    
    # Read and execute the layout file
    namespace = {}
    with open(layout_file, 'r') as f:
        exec(f.read(), namespace)
    
    lrecl = namespace['LRECL']
    layout = namespace['LAYOUT']
    
    return lrecl, layout

# Check if table exists and delete if present
def check_and_delete_table(output_file):
    if os.path.exists(output_file):
        print(f"Table {output_file} exists. Deleting...")
        os.remove(output_file)
        print(f"Deleted: {output_file}")

# Packed Decimal Decoder using numba
@njit
def decode_packed_decimal(data, start, end, decimals=0):
    """Decode a single packed decimal field"""
    field = data[start:end]
    value = 0
    
    # Process all bytes except the last
    for b in field[:-1]:
        value = value * 100 + ((b >> 4) * 10 + (b & 0x0F))
    
    # Process last byte (includes sign)
    sign = field[-1] & 0x0F
    value = value * 10 + ((field[-1] >> 4) & 0x0F)
    
    # Apply sign
    if sign == 0x0D or sign == 0x0B:
        value = -value
    
    # Apply decimals
    if decimals > 0:
        value = value / (10 ** decimals)
    
    return value

# Decode EBCDIC string
def decode_ebcdic(data, start, end):
    """Decode an EBCDIC field"""
    return data[start:end].tobytes().decode('cp037').strip().rstrip('\x00')

# Read binary file to array
def load_binary_to_array(input_file, lrecl):
    with open(input_file, "rb") as f:
        mm = mmap.mmap(f.fileno(), 0, access=mmap.ACCESS_READ)
        num_records = mm.size() // lrecl
        
        data = np.frombuffer(mm, dtype=np.uint8)
        data = data[:num_records * lrecl]
        data = data.reshape((num_records, lrecl))
    
    return data

# Process all columns based on layout
def process_file(input_file, lrecl, layout):
    print(f"Loading binary file: {input_file}")
    data = load_binary_to_array(input_file, lrecl)
    num_records = data.shape[0]
    print(f"Number of records: {num_records:,}")
    
    result = {}
    
    for field_name, spec in layout.items():
        print(f"  Processing: {field_name}")
        field_type = spec['type']
        field_slice = spec['slice']
        decimals = spec.get('decimals', 0)
        
        if field_type == 'packed':
            # Decode packed decimal
            values = []
            for i in range(num_records):
                val = decode_packed_decimal(
                    data[i], 
                    field_slice.start, 
                    field_slice.stop,
                    decimals
                )
                values.append(val)
            result[field_name] = values
            
        elif field_type == 'ebcdic':
            # Decode EBCDIC string
            values = []
            for i in range(num_records):
                val = decode_ebcdic(data[i], field_slice.start, field_slice.stop)
                values.append(val)
            result[field_name] = values
            
        else:
            print(f"    Warning: Unknown type '{field_type}' for field '{field_name}'")
            result[field_name] = [None] * num_records
    
    return pd.DataFrame(result)

# Save DataFrame to Parquet
def save_to_parquet(df, output_file):
    if not df.empty:
        try:
            table = pa.Table.from_pandas(df, preserve_index=False)
            pq.write_table(table, output_file)
            print(f"✓ Data saved to {output_file}\n")
        except Exception as e:
            print(f"✗ Error saving data: {e}\n")
    else:
        print("No data to save.\n")

