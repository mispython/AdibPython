from pathlib import Path
from datetime import datetime
import polars as pl

# 1) Paths (adjust if your folders differ)
BASE_IN  = Path("Data_Warehouse/MIS/XMIS/Outsource/input")
BASE_OUT = Path("Data_Warehouse/MIS/XMIS/output")
BASE_OUT.mkdir(parents=True, exist_ok=True)

# Parquet inputs that represent SAS DATEFILE and RPTFILE DDs
DATEFILE_PATH = BASE_IN / "DATEFILE.parquet"   # must contain column EXTDATE
RPTFILE_PATH  = BASE_IN / "RPTFILE.parquet"    # must contain all listed columns

# 2) REPTDATE / REPTMON / REPTYEAR derivation (SAS: PUT(Z11.) -> SUBSTR(1,8) -> MMDDYY8.)
date_tbl = pl.read_parquet(DATEFILE_PATH)

# take first EXTDATE (SAS OBS=1)
EXTDATE_val = (
    date_tbl
    .select(pl.col("EXTDATE"))
    .to_series()
    .drop_nulls()
    .first()
)

# emulate PUT(EXTDATE, Z11.) then SUBSTR(...,1,8)
def _to_mmddyyyy_first8(val) -> str:
    # if numeric, zero-pad to width 11; if string, strip non-digits then zfill(11)
    s = None
    try:
        s = f"{int(val):011d}"
    except Exception:
        # keep only digits, then zfill to 11
        digits = "".join(ch for ch in str(val) if ch.isdigit())
        s = digits.zfill(11)
    return s[:8]  # first 8 chars

mmddyyyy_8 = _to_mmddyyyy_first8(EXTDATE_val)
REPTDATE   = datetime.strptime(mmddyyyy_8, "%m%d%Y").date()
REPTMON    = f"{REPTDATE.month:02d}"        # SAS PUT(MM, Z2.)
REPTYEAR   = f"{REPTDATE.year % 100:02d}"   # SAS YEAR2.

# 3) Read report data (already Parquet), keep column names as SAS (UPPERCASE)
L6999 = pl.read_parquet(RPTFILE_PATH)
keep_cols = [
    "COSTCT","NOTETYPE","PRINBAL","PRNNACCR","INTACCR","INTNACCR",
    "UNERNINT","UNERNNON","RSRVFIN","RSRVDLR","NONDDA","LATEFEES",
    "OTHERFEE","CTPRINT","CTPRNNAC"
]
R6999 = L6999.select(keep_cols)

# Output path mirrors SAS library/member name
out_dir  = BASE_OUT / "LNR6999"
out_dir.mkdir(parents=True, exist_ok=True)
out_name = f"R6999{REPTMON}{REPTYEAR}.parquet"

R6999.write_parquet(out_dir / out_name)
