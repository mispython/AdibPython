con.execute("""
    CREATE TABLE extracted AS
    SELECT
        ACCTNO,
        NOTENO,
        BLDATE,
        BLPDDATE,
        DAYSLATE,
        PRODUCT,
        COSTCTR,
        BILL_AMT,
        BILL_AMT_PRIN,
        BILL_AMT_INT,
        BILL_AMT_ESCROW,
        BILL_AMT_FEE,
        BILL_NOT_PAY_AMT,
        BILL_NOT_PAY_AMT_PRIN,
        BILL_NOT_PAY_AMT_INT,
        BILL_NOT_PAY_AMT_ESCROW,
        BILL_NOT_PAY_AMT_FEE,
        -- Parse BLDATE (YYMMDD format)
        CASE 
            WHEN BLDATE > 0 THEN 
                CAST(SUBSTR(LPAD(CAST(BLDATE AS VARCHAR), 11, '0'), 1, 8) AS DATE)
            ELSE NULL
            END AS BILL_DT,
            -- Parse BLPDDATE (MMDDYY format)
        CASE 
            WHEN BLPDDATE > 0 THEN
                TRY_CAST(
                    SUBSTR(LPAD(CAST(BLPDDATE AS VARCHAR), 8, '0'), 5, 4) || '-' ||
                    SUBSTR(LPAD(CAST(BLPDDATE AS VARCHAR), 8, '0'), 1, 2) || '-' ||
                    SUBSTR(LPAD(CAST(BLPDDATE AS VARCHAR), 8, '0'), 3, 2)
                    AS DATE
                )
            ELSE NULL
            END AS BILL_PAID_DT
        FROM stg_ln_bill
""")
    
