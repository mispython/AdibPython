### 6️⃣ **duckdb_utils.py** - Fast Queries

```python
from COMMON import DuckDBManager, query_parquet, merge_parquet_files

# Query single parquet
df = query_parquet('data.parquet', sql_filter="AMOUNT > 1000")

# Query multiple parquet files
df = query_parquet(
    ['file1.parquet', 'file2.parquet', 'file3.parquet'],
    sql_filter="STATUS = 'APPROVED'"
)

# Use DuckDB manager
with DuckDBManager(memory_limit='8GB', threads=8) as db:
    # Register DataFrames
    db.register(df1, 'sales')
    db.register(df2, 'customers')
    
    # Complex SQL query
    result = db.query("""
        SELECT s.*, c.NAME
        FROM sales s
        LEFT JOIN customers c ON s.CUSTOMER_ID = c.ID
        WHERE s.AMOUNT > 1000
    """)

# Merge multiple parquet files
merge_parquet_files(
    ['part1.parquet', 'part2.parquet', 'part3.parquet'],
    'merged.parquet',
    compression='zstd'
)
```

