## 💡 Complete Example: Rewriting EIWELNEX with COMMON

```python
from COMMON import *

# Setup
SKIP_DATE_VALIDATION = True
paths = PathConfig('ELDS')
logger = setup_logger('EIWELNEX', paths.log_path)

@handle_errors(exit_code=77)
def run_eiwelnex():
    # Get dates
    reptdate, reptdate1, week = get_reporting_dates()
    logger.info(f"Reporting Date: {reptdate} (Week {week})")
    
    # Create output directory
    output_path = paths.get_output_path(reptdate)
    ensure_directory(output_path)
    
    # Read files
    dfs = {}
    for key in ['ELNA1', 'ELNA2', 'ELNA3']:
        filepath = find_latest_file(paths.input_path, f'newbnm{key[-1]}')
        
        # Load config
        specs, names, _, col_types, col_subtypes, col_decimals, firstobs, is_csv = \
            load_config_file(paths.config_path, f'ELAA{key[-1]}')
        
        # Read file
        if is_csv == "True":
            df = read_csv_file(filepath, names=names, skiprows=firstobs)
        else:
            df = read_fixed_width_file(filepath, specs, names, skiprows=firstobs)
        
        # Apply formats
        df = apply_sas_formats(df, col_types, col_subtypes, col_decimals)
        
        # Filter approved
        df = filter_approved(df)
        
        dfs[key] = df
        logger.dataframe_info(df, key)
    
    # Merge datasets
    merged = merge_datasets([dfs['ELNA1'], dfs['ELNA2'], dfs['ELNA3']], on='AANO')
    
    # Deduplicate
    merged = deduplicate(merged, subset='AANO')
    
    # Save
    output_file = f"{output_path}/ELBNMAX.parquet"
    save_to_parquet(merged, output_file)
    
    logger.info("Job completed successfully!")

# Run
if __name__ == "__main__":
    run_eiwelnex()
```

