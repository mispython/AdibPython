## 🎯 Complete Real-World Example

```python
#!/usr/bin/env python3
"""
Generic ETL Job Template
Works for ANY data processing task
"""

from COMMON import *
from datetime import datetime

# ============================================
# CONFIGURATION (Customize for your project)
# ============================================

JOB_NAME = 'SalesETL'
Config.BASE_PATH = '/data/warehouse'
Config.LOG_LEVEL = 'INFO'

# ============================================
# MAIN ETL PROCESS
# ============================================

@handle_errors(exit_code=1)
def run_etl():
    # Setup
    job = JobConfig(JOB_NAME)
    logger = setup_logger(JOB_NAME, job.get_log_file())
    
    logger.section(f"Starting {JOB_NAME}")
    logger.info(f"Run Date: {datetime.now()}")
    
    # ========== STEP 1: Read Data ==========
    logger.step(1, "Reading Input Files")
    
    filepath = find_latest_file(job.input_path, prefix='sales', extension='.csv')
    if not filepath:
        raise FileError("No input file found")
    
    df = read_csv(filepath)
    logger.dataframe_summary(df, "Raw Data")
    
    # ========== STEP 2: Validate ==========
    logger.step(2, "Validating Data")
    
    is_valid, errors = validate_dataframe(
        df,
        required_columns=['ID', 'AMOUNT', 'DATE', 'STATUS'],
        check_empty=True,
        check_duplicates='ID'
    )
    
    if not is_valid:
        raise ValidationError(f"Validation failed: {errors}")
    
    logger.info("✅ Validation passed")
    
    # ========== STEP 3: Transform ==========
    logger.step(3, "Transforming Data")
    
    # Filter
    df = filter_by(df, STATUS='APPROVED')
    logger.info(f"After filter: {len(df):,} rows")
    
    # Clean data
    df['NAME'] = upcase(left(df['NAME']))
    df['AMOUNT'] = df['AMOUNT'].round(2)
    
    # Create dates
    df = create_date_from_parts(df, 'DAY', 'MONTH', 'YEAR', 'DATE')
    
    # Deduplicate
    df = deduplicate(df, subset='ID', keep='first')
    logger.info(f"After dedup: {len(df):,} rows")
    
    # ========== STEP 4: Load Historical ==========
    logger.step(4, "Loading Historical Data")
    
    prev_date = datetime.now() - timedelta(days=7)
    hist_path = job.get_dated_output_path(prev_date)
    hist_file = f"{hist_path}/output.parquet"
    
    if os.path.exists(hist_file):
        df_hist = load_parquet(hist_file)
        df = append_data([df, df_hist])
        logger.info(f"Combined with history: {len(df):,} rows")
    
    # ========== STEP 5: Save Output ==========
    logger.step(5, "Saving Output")
    
    output_path = job.get_dated_output_path()
    ensure_directory(output_path)
    
    output_file = f"{output_path}/output.parquet"
    save_parquet(df, output_file, compression='zstd')
    
    # Archive input
    archive_file(filepath, job.archive_path)
    
    logger.section("Job Completed Successfully")
    logger.info(f"Output: {output_file}")
    logger.info(f"Rows: {len(df):,}")
    logger.info(f"Size: {os.path.getsize(output_file) / 1024**2:.2f} MB")

# ============================================
# EXECUTION
# ============================================

if __name__ == "__main__":
    run_etl()
```

