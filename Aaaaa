    df,
    day_col='DD',
    month_col='MM',
    year_col='YY',
    target_col='AADATE'
)

# Format date (SAS PUT function)
formatted = format_date_sas(datetime.now(), 'DDMMYY8')  # 23102025

# Parse date (SAS INPUT function)
date_obj = parse_sas_date('23102025', 'DDMMYY8')
```

