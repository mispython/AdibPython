### 1️⃣1️⃣ **data_transform.py** - ETL Patterns

```python
from COMMON import merge_datasets, deduplicate, filter_by, append_data, DataTransformer

# Merge multiple DataFrames (SAS MERGE)
merged = merge_datasets(
    [customers, orders, products],
    on='CUSTOMER_ID',
    how='outer'
)

# Remove duplicates (SAS NODUPKEY)
df = deduplicate(
    df,
    subset='ID',
    keep='first',
    sort_by=['DATE', 'AMOUNT']
)

# Filter data
filtered = filter_by(
    df,
    STATUS='APPROVED',
    REGION=['EAST', 'WEST', 'NORTH']
)

# Append datasets (SAS SET)
combined = append_data([current_month, last_month, historical])

# Apply formatting rules
format_rules = {
    'AMOUNT': {'type': 'numeric', 'decimals': 2},
    'DATE': {'type': 'date', 'format': '%Y-%m-%d'},
    'NAME': {'type': 'string', 'format': 'upper'}
}
df = DataTransformer.apply_formats(df, format_rules)

# Create derived columns
def calculate_total(df):
    return df['QUANTITY'] * df['PRICE']

def calculate_discount(df):
    return df['TOTAL'] * 0.1

df = DataTransformer.create_derived_columns(df, {
    'TOTAL': calculate_total,
    'DISCOUNT': calculate_discount
})
```

