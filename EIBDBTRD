 /*****************************************************************/            
 /*  TO CALCULATE THE DISBURSEMENT & REPAYMENT                    */            
 /*****************************************************************/            
 DATA PRNGL (DROP=ACCTNO RENAME=(ACCTNOX=ACCTNO));                              
    SET BTRSA.COMM&REPTDAY&REPTMON(RENAME=(GLMNEMO=GLMNEM));                    
    IF CREATDS NOT IN (.,0) THEN                                                
       ISSDTE=INPUT(PUT(CREATDS,Z6.),YYMMDD6.);                                 
    IF EXPIRDS NOT IN (.,0) THEN                                                
       EXPRDATE = INPUT(PUT(EXPIRDS,Z6.),YYMMDD6.);                             
    IF GLMNEM IN ('CONI','CONM','CONP','DDA','HOE','IBS') THEN                  
       DELETE;                                                                  
    ELSE IF SUBSTR(GLMNEM,1,1) = '9' THEN DELETE;                               
    ELSE IF SUBSTR(GLMNEM,1,1) = '0' THEN GLMNEMO = GLMNEM||'0';                
    ELSE GLMNEMO = GLMNEM;                                                      
    DROP GLMNEM;                                                                
    IF PAYGRNO NE ' ' THEN TRANSREF = SUBSTR(PAYGRNO,1,7);                      
    IF ISSDTE <= &TDATE;                                                        
 RUN;                                                                           
DATA DISBURSE700;                                                               
   SET PRNGL;                                                                   
   WHERE GLMNEMO IN ('08000','09000') AND &STARTDT<=ISSDTE<= &TDATE;            
   DISBURSE = TRANSAMT;                                                         
RUN;                                                                            
DATA REPAID101;                                                                 
   SET PRNGL;                                                                   
   WHERE GLMNEMO IN ('01010','01140') AND &STARTDT<=ISSDTE<= &TDATE             
         AND TRANSAMT < 0;                                                      
   REPAID = TRANSAMT;                                                           
RUN;                                                                            
PROC SORT DATA=REPAID101; BY ACCTNO TRANSREF;                                   
PROC SUMMARY DATA=REPAID101;                                                    
   BY ACCTNO TRANSREF;                                                          
   VAR REPAID;                                                                  
   OUTPUT OUT=REPAID101 SUM=REPAID;                                             
RUN;                                                                            
PROC SORT DATA=REPAID101; BY ACCTNO TRANSREF;                                   
PROC SORT DATA=DISBURSE700; BY ACCTNO TRANSREF;                                 
DATA REPAID101;                                                                 
   MERGE REPAID101(IN=A) DISBURSE700(IN=B);                                     
   BY ACCTNO TRANSREF;                                                          
   IF A;                                                                        
   IF REPAID < 0 AND B THEN DELETE;                                             
   ELSE IF REPAID < 0 THEN DO;                                                  
      REPAID = (-1)*REPAID;                                                     
      OUTPUT;                                                                   
   END;                                                                         
RUN;                                                                            
DATA DISBPAY;                                                                   
   SET PRNGL;                                                                   
   WHERE PUT(GLMNEMO,$DISBPAY.) EQ 'Y' AND &STARTDT<=ISSDTE<= &TDATE;           
   IF TRANSAMT > 0 THEN DO;                                                     
      IF GLMNEMO NE '01010' THEN DISBURSE = TRANSAMT;                           
      * ELSE IF GLMNEMO = '01010' THEN REPAID = TRANSAMT;                       
   END;                                                                         
   ELSE REPAID = TRANSAMT * (-1);                                               
RUN;                                                                            
DATA REPAID60;                                                                  
   SET DISBPAY;                                                                 
   WHERE GLMNEMO IN ('00110','00130','00150','00800','00810','00820',           
                     '00830','00290','00300','00310') &                         
         REPAID > 0;                                                            
   KEEP ACCTNO REPAID ISSDTE;                                                   
RUN;                                                                            
PROC SORT DATA=REPAID60 NODUPKEYS;;                                             
   BY ACCTNO REPAID ISSDTE;                                                     
PROC SORT DATA=DISBPAY;                                                         
   BY ACCTNO DISBURSE ISSDTE;                                                   
DATA DISBPAY REPAID60(DROP=GLMNEMO REPAID);                                     
   MERGE DISBPAY(IN=A) REPAID60(IN=B RENAME=(REPAID=DISBURSE));                 
   BY ACCTNO DISBURSE ISSDTE;                                                   
   IF A;                                                                        
   IF GLMNEMO = '00600' & (A & B) THEN OUTPUT REPAID60;                         
   ELSE OUTPUT DISBPAY;                                                         
RUN;                                                                            
PROC SORT DATA=DISBPAY;                                                         
   BY ACCTNO REPAID ISSDTE;                                                     
PROC SORT DATA=REPAID60;                                                        
   BY ACCTNO DISBURSE ISSDTE;                                                   
DATA DISBPAY;                                                                   
   MERGE DISBPAY(IN=A) REPAID60(IN=B RENAME=(DISBURSE=REPAID));                 
   BY ACCTNO REPAID ISSDTE;                                                     
   IF A;                                                                        
   IF GLMNEMO IN ('00110','00130','00150','00800','00810','00820',              
                  '00830','00290','00300','00310')                              
      & (A & B) THEN DELETE;                                                    
RUN;                                                                            
DATA DISBURSE700;                                                               
   SET DISBURSE700;                                                             
   KEEP ACCTNO TRANSREF DISBURSE ISSDTE;                                        
RUN;                                                                            
PROC SORT DATA=DISBURSE700;                                                     
   BY TRANSREF DISBURSE ISSDTE;                                                 
PROC SORT DATA=DISBPAY;                                                         
   BY TRANSREF REPAID ISSDTE;                                                   
DATA DISBPAY DISBURSE700;                                                       
   MERGE DISBPAY(IN=A) DISBURSE700(IN=B RENAME=(DISBURSE=REPAID));              
   BY TRANSREF REPAID ISSDTE;                                                   
   IF A;                                                                        
   IF GLMNEMO NE '01010' & (A & B) THEN DELETE;                                 
   ELSE IF B THEN OUTPUT DISBURSE700;                                           
   ELSE OUTPUT DISBPAY;                                                         
RUN;                                                                            
DATA DISBPAY;                                                                   
   SET DISBPAY(IN=A) REPAID101(IN=B KEEP=ACCTNO TRANSREF REPAID);               
RUN;                                                                            
