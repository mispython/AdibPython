        IF (CRISPURP = '    ' AND  CCRICODE = .  AND SECTOLD EQ '    ' )        
        OR FISSPURP IN ('0390','0440','0470') THEN FISSPURP = '0212';           
     END;                                                                       
     ELSE DO;                                                                   
