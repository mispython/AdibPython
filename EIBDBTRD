   SECTORZ = PUT(SECTORX,Z4.);                                                  
   IF ISSDTE2 <'01APR06'D THEN SECTORZZ = PUT(SECTORZ,$RVRSE.);                 
   IF SECTORZZ NE '    ' THEN SECTORCD = SECTORZZ;                              
   IF SECTORZZ NE '    ' THEN SECTOR = SECTORZZ;                                
   ELSE SECTOR = SECTORZ;                                                       
