DATA BA (DROP=FCVALUE1 UNEARNED1 CERTNO1 UTRDF1 TRANSREF_PBA1 YIELD1);          
   MERGE NOTMATCH(KEEP=BRANCH OUTSTAND MATDATE FCVALUE UNEARNED CERTNO          
                       UTRDF TRANSREF_PBA YIELD                                 
                  RENAME=(FCVALUE=FCVALUE1 UNEARNED=UNEARNED1                   
                          TRANSREF_PBA=TRANSREF_PBA1 YIELD=YIELD1               
                          CERTNO=CERTNO1 UTRDF=UTRDF1))                         
         BA(IN=A);                                                              
   BY BRANCH OUTSTAND MATDATE;                                                  
   IF A;                                                                        
   IF TRANSREF_PBA = '' THEN DO;                                                
      IF FCVALUE1 NE . THEN FCVALUE=FCVALUE1;                                   
      IF UNEARNED1 NE . THEN UNEARNED=UNEARNED1;                                
      IF TRANSREF_PBA1 NE '' THEN TRANSREF_PBA=TRANSREF_PBA1;                   
      IF YIELD1 NE . THEN YIELD=YIELD1;                                         
      IF CERTNO1 NE . THEN CERTNO=CERTNO1;                                      
   END;                                                                         
   IF CERTNO = . THEN DO;                                                       
      BALANCE = 0;                                                              
      OUTSTAND = 0;                                                             
   END;                                                                         
   ELSE DO;                                                                     
      BALANCE=SUM(OUTSTAND,(-1)*UNEARNED);                                      
      *OUTSTAND=BALANCE;                                                        
   END;                                                                         
   *** SPECIAL MAPPING 4 SELECTED LIABCODE ***;                                 
   IF LIABCODE IN ('BAI','BAP','BAS','BAE') THEN DO;                            
      IF UTRDF = '' THEN DO;                                                    
         IF UTRDF1 NE '' THEN UTRDF = UTRDF1;                                   
         ELSE                 UTRDF = 'D';                                      
      END;                                                                      
   END;                                                                         
RUN;                                                                            
DATA TBBA;                                                                      
   SET TB BA APNBT;                                                             
RUN;                                                                            
