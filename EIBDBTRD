%INC PGM(PBBLNFMT,PBBELF);                                                      
                                                                                
%LET LOAN=(KEEP=BRANCH ACCTNO PRODUCT CUSTCD PRODCD LIABCODE                    
                SECTORCD ORIGMT COLLCD STATECD DISCOUNT_PROCEED                 
                REMAINMT APPRLIMT FIXFLT CALBASP                                
                NOTENO NOTETERM EXPRDATE INTRATE INDUSTRIAL_SECTOR_CD           
                CLOSEDTE INTAMT AMTIND CUSTCODE  CREATDS FISSPURP               
                SPREAD INTEARN FEEAMT ISSDTE ACCRUAL INTEARN4 REBATE            
                PAIDIND INTEARN2 INTEARN3 MATDATE SECTOR PURPOSES               
                SUBACCT TRANSREF GLMNEMO BTREL DIRCTIND                         
                RETAILID);                                                      
%LET BTR1=(KEEP=ACCTNO NAME);                                                   
%LET BT=(DROP= ACCPTCOM BATYPE FCONCEPT IISAMT NPLIND REIMBRID SUBLIMIT         
               TFCNTR02 TFCNTR05 TFCNTR06 TFCNTR07 TFCNTR08 TFCNTR09            
               TFCNTR10 TFCNTR11 TFCNTR12 TFDESC02 TFDESC03 TFDESC04            
               TFID TFINDR06 TFINDR07 TFINDR08 TFINDR09 TFINDR10                
               TFINDR11 TFINDR12 TOTIISR WORKERID WRITOFF);                     
%LET BTRAD=(DROP=_FREQ_ _TYPE_ ACCPTCOM ACCRUAL BATYPE CCRICODE                 
                 CLOSEDTE CRISPURP FCONCEPT FEEAMT IISAMT INTEARN               
                 INTEARN2 INTEARN3 INTEARN4 NOTENO NOTETERM NPLIND              
                 PAIDIND PRODUCT REBATE REIMBRID SECTOLD TFCNTR02               
                 TFCNTR05 TFCNTR06 TFCNTR07 TFCNTR08 TFCNTR09 TFCNTR10          
                 TFCNTR11 TFCNTR12 TFDESC02 TFDESC03 TFDESC04 TFID              
                 TFINDR06 TFINDR07 TFINDR08 TFINDR09 TFINDR10 TFINDR11          
                 TFINDR12 TOTIISR WORKERID WRITOFF);                            
                                                                                
DATA BNM.D_BTRAD&REPTDT &LOAN;                                                  
  LENGTH CUSTCD ORIGMT REMAINMT $2. PRODCD $5.                                  
         SECTORCD $4. STATECD $1. AMTIND $1. CRISPURP $4.                       
         SECTOR $4. CUSTCODE 2. PRODUCT 3.;                                     
  /* EXTRA CONDITION SET INTO THIS PROGRAM, MUST CHANGE IN EXT. */              
  SET BTRADE&REPTDT;                                                            
  PRODUCT = 0;                                                                  
  NOTENO  = 0;                                                                  
  /*  END   */                                                                  
  FISSPURP = '0470';                                                            
  REPTDATE=INPUT("&RDATE", DDMMYY8.);                                           
  SECTORCD=PUT(SECTOR, $SECTCD.);                                               
  CUSTCD=PUT(CUSTCODE, LOCUSTCD.);                                              
  STATECD=PUT(STATE, $STATECD.);                                                
  IF LIABCODE NE ' ' THEN DO;                                                   
    IF DIRCTIND EQ 'D' THEN PRODCD=PUT(LIABCODE,$BTPROD.);                      
    ELSE IF DIRCTIND EQ 'I' THEN PRODCD=PUT(LIABCODE,$BTPRODI.);                
  END;                                                                          
  AMTIND = 'D';                                                                 
  COLLCD=PUT(INPUT(COLLATER,$3.), $COLLCD.);                                    
  IF EXPRDATE - ISSDTE < 366 THEN ORIGMT = '10';                                
  ELSE ORIGMT = '20';                                                           
                                                                                
  FISSPURP = '0470';                                                            
  IF CUSTCD NOT IN ('77','78','95','96') AND SECTORCD<'1111' THEN DO;           
    SELECT(CUSTCD);                                                             
      WHEN('02','03','04','05','06','11','12','13','17','30','31',              
           '32','33','34','35','37','38','39','45')                             
           SECTORCD='8110';                                                     
      WHEN('40') SECTORCD = '8130';                                             
      WHEN('79') SECTORCD = '9203';                                             
      WHEN('71','72','73','74') SECTORCD = '9101';                              
      OTHERWISE SECTORCD = '9999';                                              
    END;                                                                        
  END;                                                                          
  IF CUSTCD IN ('79','61','62','63','75','57','59','41',                        
                '42','43','44','46','47','48','49',                             
                '51','52','53','54')                                            
     AND SECTORCD IN ('8110','8120','8130') THEN SECTORCD='9999';               
  IF CUSTCD IN ('02','03','04','05','06','11','12','13','17','30',              
                '31','32','33','34','35','37','38','39','40','45')              
  AND SECTORCD NOT IN ('8110','8120','8130') THEN SECTORCD = '8110';            
  IF CUSTCD IN ('71','72','73','74') AND                                        
    SUBSTR(SECTORCD,1,2) ^ IN ('91','92','93','94','95','96',                   
    '97','98','99') THEN SECTORCD = '9101';                                     
  IF CUSTCD IN ('77','78') AND '1111'<=SECTORCD<='9999' THEN DO;                
    IF CUSTCD = '77' THEN CUSTCD = '41';                                        
    ELSE IF CUSTCD = '78' THEN CUSTCD = '44';                                   
  END;                                                                          
  /**********************************************/                              
  /* INCLUDE ALL PAIDIND NE 'P' LOANS           */                              
  /**********************************************/                              
  IF REBIND=2 THEN DO;                                                          
    SELECT;                                                                     
      WHEN (INTAMT = 0.01) DO;                                                  
        /*********************************/                                     
        /* ZERORISED OR WRITTEN OFF A/CS */                                     
        /*********************************/                                     
        TEMP = -1 * REBATE; REBATE = TEMP;                                      
        TEMP = -1 * INTEARN4; INTEARN4 = TEMP;                                  
        INTAMT = 0; INTEARN = 0; ACCRUAL = 0;                                   
        INTEARN2 = 0; INTEARN3 = 0;                                             
      END;                                                                      
      WHEN (ROUND((REBATE + INTEARN),.01) NE INTAMT OR                          
        ROUND((INTEARN4 + INTEARN3),.01) NE INTEARN2) DO;                       
        RMM = MONTH(REPTDATE);                                                  
        RYY = YEAR(REPTDATE);                                                   
        IMM = MONTH(ISSDTE);                                                    
        IYY = YEAR(ISSDTE);                                                     
        IF DAY(THISDATE) IN (8,15,22) THEN                                      
          REMAIN = NOTETERM-(((RYY*12)+RMM)-((IYY*12)+IMM));                    
        ELSE REMAIN = NOTETERM-(((RYY*12)+RMM+1)-((IYY*12)+IMM));               
        UNEARN1=(REMAIN*(REMAIN+1)*(INTAMT))/(NOTETERM*(NOTETERM+1))    ;       
        UNEARN2=(REMAIN*(REMAIN+1)*(INTEARN2))/(NOTETERM*(NOTETERM+1    ));     
        INTAMT = 0; INTEARN = 0; ACCRUAL = 0; REBATE = 0;                       
        INTEARN2 = 0; INTEARN3 = 0; INTEARN4 = 0;                               
      END;                                                                      
      OTHERWISE DO;                                                             
        REBATE=0; INTEARN4=0;                                                   
      END;                                                                      
    END;                                                                        
  END;                                                                          
                                                                                
  IF CUSTCD = 'AA' THEN DO;                                                     
    IF ORGTYPE='C' OR ORGTYPE='P' OR ORGTYPE='I' THEN CUSTCD='66';              
    ELSE CUSTCD = '77';                                                         
  END;                                                                          
  /********************************************************/                    
  /* COMPUTE THE REMAINING MATURITY (IN NUMBER OF MONTHS) */                    
  /********************************************************/                    
  IF REPTDATE EQ 0 OR EXPRDATE EQ 0 OR EXPRDATE LT REPTDATE                     
    THEN REMAINMT='51';                                                         
  ELSE DO;                                                                      
    LINK COUNTMON;                                                              
    REMAINMT=PUT(NUMMONTH, LNRMMT.);                                            
  END;                                                                          
  OUTPUT;                                                                       
  /****************************************************/                        
  /** INCLUDE OUTSTANDING FEE AMOUNT FOR PAID LOANS  **/                        
  /****************************************************/                        
  IF PAIDIND = 'P' AND FEEAMT > 0 THEN DO;                                      
    INTAMT = 0; INTEARN = 0; REBATE = 0;                                        
    IF REPTDATE EQ 0 OR EXPRDATE EQ 0 OR EXPRDATE LT REPTDATE                   
      THEN REMAINMT='51';                                                       
    ELSE DO;                                                                    
      LINK COUNTMON;                                                            
      REMAINMT=PUT(NUMMONTH, LNRMMT.);                                          
    END;                                                                        
    OUTPUT;                                                                     
  END;                                                                          
  /****************************************************/                        
  /** INCLUDE LOANS WHICH ARE SETTLED EARLY, WITHIN  **/                        
  /** THE SAME MONTH                                 **/                        
  /****************************************************/                        
                                                                                
  CURMONTH = MONTH(REPTDATE);                                                   
  CURYEAR  = YEAR(REPTDATE);                                                    
  LNMONTH = MONTH(CLOSEDTE);                                                    
  LNYEAR  = YEAR(CLOSEDTE);                                                     
RETURN;                                                                         
COUNTMON:                                                                       
  FOLMONTH=REPTDATE; NUMMONTH=0;                                                
  DO UNTIL(EXPRDATE <= FOLMONTH);                                               
     NUMMONTH+1;                                                                
     NEXTDAY=DAY(REPTDATE);                                                     
     NEXTMON=MONTH(FOLMONTH)+1;                                                 
     NEXTYEAR=YEAR(FOLMONTH);                                                   
     IF NEXTMON > 12 THEN DO;                                                   
        NEXTMON = NEXTMON-12; NEXTYEAR=NEXTYEAR+1; END;                         
     IF NEXTDAY IN (29,30,31) AND NEXTMON EQ 2 THEN                             
        FOLMONTH=MDY(3,1,NEXTYEAR)-1;                                           
     ELSE IF NEXTDAY EQ 31                                                      
          AND NEXTMON IN (4,6,9,11) THEN                                        
              FOLMONTH=MDY(NEXTMON, 30, NEXTYEAR);                              
     ELSE IF NEXTDAY EQ 30                                                      
          AND NEXTMON IN (1,3,5,7,8,10,12) THEN                                 
              FOLMONTH=MDY(NEXTMON, 31, NEXTYEAR);                              
          ELSE                                                                  
              FOLMONTH=MDY(NEXTMON, NEXTDAY, NEXTYEAR);                         
  END;                                                                          
RETURN;                                                                         
