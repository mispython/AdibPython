//            SPACE=(CYL,(0))
//*
//SAS609  EXEC SAS609
//LOAN      DD DSN=SAP.PBB.MNILN.DAILY(0),DISP=SHR
//ACCTCRED  DD DSN=SAP.PBB.BTRADE.CCRIS2.ACCTCRED.DAILY,
