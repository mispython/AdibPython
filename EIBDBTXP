//            DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),
//            SPACE=(CYL,(5,1),RLSE),UNIT=(SYSDA,5)
//DEL04    DD DSN=SAP.PBB.BTRADE.CCRIS2.PROVISIO.DAILY,
//            DISP=(MOD,DELETE,DELETE),
//            DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),
//            SPACE=(CYL,(5,1),RLSE),UNIT=(SYSDA,5)
//DEL05    DD DSN=SAP.PBB.BTRADE.SASDATA.DAILY.WH,
