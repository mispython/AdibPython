//BTRSA     DD DSN=SAP.PBB.BTRADE.SASDATA.DAILY(0),DISP=SHR
//BNM       DD DSN=SAP.BT.SASDATA,DISP=SHR
//BNMD      DD DSN=SAP.BT.SASDATA.DAILY(0),DISP=SHR
