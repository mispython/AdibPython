//EIBDDEPF JOB MISEIS,EIBDDEPE,MSGCLASS=X,CLASS=A,REGION=8M,
//         NOTIFY=&SYSUID
//*
//*       EIBDRPTS
//*       EIBDDEPF *-RESCHEDULE
//*       FTPDMS1F
//*
//DELETE   EXEC PGM=IEFBR14
//DD1      DD DSN=SAP.PBB.DMMISR1F.DAILY,
//            DISP=(MOD,DELETE,DELETE),UNIT=SYSDA,
//            SPACE=(CYL,1,RLSE)
//*
//SAS609   EXEC SAS609
//MNITB    DD DSN=SAP.PBB.MNITB.DAILY(0),DISP=SHR
//MNIFD    DD DSN=SAP.PBB.MNIFD.DAILY(0),DISP=SHR
//IMNITB   DD DSN=SAP.PIBB.MNITB.DAILY(0),DISP=SHR
//WALK     DD DSN=SAP.PBB.DAILY.WALKER(0),DISP=SHR
//PGM      DD DSN=SAP.BNM.PROGRAM,DISP=SHR
//SASLIST  DD DSN=SAP.PBB.DMMISR1F.DAILY,DISP=(NEW,CATLG,DELETE),
//            SPACE=(CYL,(1,1),RLSE),UNIT=SYSDA,
//            DCB=(LRECL=133,RECFM=FB,BLKSIZE=0)
//SYSIN    DD *

OPTIONS YEARCUTOFF=1930 NOCENTER;
DATA REPTDATE;
  SET MNITB.REPTDATE;
  CALL SYMPUT('REPTYY',PUT(REPTDATE,YEAR2.));
  CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR4.));
  CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE), Z2.));
  CALL SYMPUT('REPTDAY',PUT(DAY(REPTDATE), Z2.));
  CALL SYMPUT('RDATE',PUT(REPTDATE,Z5.));
  CALL SYMPUT('XDATE',PUT(REPTDATE,DDMMYY8.));
RUN;

DATA TDATE;
  TDATE=TODAY()-1;
  CALL SYMPUT('TDATE',PUT(TDATE,Z5.));
RUN;

LIBNAME MIS "SAP.PBB.MIS.D&REPTYEAR" DISP=OLD;

%INC PGM(PBBDPFMT);

DATA CAFY;
  SET MNITB.CURRENT
     IMNITB.CURRENT(RENAME=(CURBAL=ICURBAL));
  CUSTCD = PUT(CUSTCODE,DDCUSTCD.);
  IF CURCODE NE 'MYR' AND
     PRODUCT IN (400:411,413,420:434,440:444,450:454);

  IF CUSTCD IN (02,03,07,10,12,81,82,83,84) OR PRODUCT = 413 THEN DO;
     FCAFIC = CURBAL;
     FCAFII = ICURBAL;
  END;
  ELSE DO;
     CURBAL1  = CURBAL;
     ICURBAL1 = ICURBAL;
  END;

  IF PRODUCT NE 413 AND CUSTCODE IN (77,78,95,96) THEN DO;
     FCAIDC = CURBAL;
     FCAIDI = ICURBAL;
  END;

  REPTDATE=&RDATE;
*;
PROC SUMMARY DATA=CAFY NWAY;
CLASS REPTDATE;
VAR   CURBAL1 ICURBAL1 FCAIDC FCAIDI FCAFIC FCAFII;
OUTPUT OUT=CAFY (DROP=_TYPE_ _FREQ_)
SUM=TOTCAFY TOTCAFYI TOFCAIDC TOFCAIDI TOFCAFIC TOFCAFII;
*;
DATA FDFY;
  SET MNITB.FD;
  IF PRODUCT IN &FCY;
  REPTDATE=&RDATE;
  CUSTCD = PUT(CUSTCODE,FDCUSTCD.);
*;
DATA FCFY;
  SET WALK.WK&REPTYY&REPTMON&REPTDAY(RENAME=(CURBAL=FCURBAL));
  IF PROD EQ 'DCM22110'; /* FOREIGN COMPANIES  GL:22110 */
  FCURBAL=(-1)*FCURBAL;
  REPTDATE=&RDATE;
*;
DATA FDFY;
  SET FDFY FCFY;
  IF CUSTCD IN (02,03,07,10,12,81,82,83,84) THEN DO;
     FFDFIC = CURBAL;
  END;
  ELSE DO;
     CURBAL1 = CURBAL;
  END;

  IF CUSTCODE IN (77,78,95,96) THEN FFDIDC = CURBAL;

*;
PROC  SUMMARY DATA=FDFY NWAY;
CLASS REPTDATE;
VAR   CURBAL1 FCURBAL FFDFIC FFDIDC;
OUTPUT OUT=FDFY (DROP=_TYPE_ _FREQ_)
SUM=TOTFDFY TOTFCFY TOFFDFIC TOFFDIDC;
*;
DATA DYPOSN;
 MERGE CAFY FDFY; BY REPTDATE;
*;
%MACRO PROCESS;
   %IF "&TDATE" NE "&RDATE" %THEN %DO;
      %PUT DATA DATE IS NOT YESTERDAY- PLS RERUN LATER;
      %DO;
          DATA A;
          ABORT 77;
      %END;
   %END;
   %ELSE %DO;
      %IF "&REPTDAY" EQ "01" %THEN %DO;
         DATA MIS.DYFCY&REPTMON;
            SET DYPOSN;
         RUN;
      %END;
      %ELSE %DO;
         DATA MIS.DYFCY&REPTMON;
            SET DYPOSN MIS.DYFCY&REPTMON;
         RUN;
      %END;
      DATA MIS.DYFCY&REPTMON;
         SET MIS.DYFCY&REPTMON;
         TOTFDFY =ROUND(TOTFDFY,1);
         TOTFCFY =ROUND(TOTFCFY,1);
         TOTFYFD =SUM(TOTFDFY,TOTFCFY);
         TOFFDFIC=ROUND(TOFFDFIC,1);          /*COL 04*/
         TOTCAFY =ROUND(TOTCAFY,1);
         TOTCAFYI=ROUND(TOTCAFYI,1);
         TOTFYCA =SUM(TOTCAFY,TOTCAFYI);
         TOTFCY  =SUM(TOTFYFD,TOTFYCA);
         TOFFDIDC=ROUND(TOFFDIDC,1);          /*COL 09*/
         TOFFDNDC=SUM(TOTFYFD,-1*TOFFDIDC);   /*COL 10*/
         TOFCAFIC=ROUND(TOFCAFIC,1);          /*COL 11*/
         TOFCAFII=ROUND(TOFCAFII,1);          /*COL 12*/
         TOTFCAFI=SUM(TOFCAFIC,TOFCAFII);     /*COL 13*/
         TOTFCYFI=SUM(TOFFDFIC,TOTFCAFI);     /*COL 14*/
         TOFCAIDC=ROUND(TOFCAIDC,1);          /*COL 15*/
         TOFCANDC=SUM(TOTCAFY,-1*TOFCAIDC);   /*COL 16*/
         TOFCAIDI=ROUND(TOFCAIDI,1);          /*COL 17*/
         TOFCANDI=SUM(TOTCAFYI,-1*TOFCAIDI);  /*COL 18*/
         TOTFCAID=SUM(TOFCAIDC,TOFCAIDI);     /*COL 19*/
         TOTFCAND=SUM(TOFCANDC,TOFCANDI);     /*COL 20*/
      RUN;
      PROC SORT DATA=MIS.DYFCY&REPTMON NODUPKEY; BY REPTDATE; RUN;
      %INC PGM(DMMISR1F);
   %END;
%MEND;
%PROCESS;
RUN;
*;
