         @235  CONTACT            $20.
         @255  TELENUM            $20.
         @275  SECTORX             $5. /* INDUSTRY */
         @280  ROCNO              $20.
         @300  BNKDESC            $20.
         @320  BNKACTNO           $20.
         @340  CURRENCY            $3.
         @343  MOCODE             $20.
         @363  RCLIMIT           14.2
         @377  INLIMIT           14.2
