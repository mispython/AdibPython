DATA FACWH.REPTDATE;
   REPTDATE=TODAY()-1;
   CALL SYMPUT('REPTYEAR', PUT(REPTDATE, YEAR2.));
   CALL SYMPUT('REPTMON', PUT(MONTH(REPTDATE), Z2.));
   CALL SYMPUT('REPTDAY', PUT(DAY(REPTDATE), Z2.));
   CALL SYMPUT('RDATE', PUT(REPTDATE, DDMMYY8.));
RUN;

DATA REPTDATX;
   SET SASD.REPTDATE;
   MM      =MONTH(REPTDATE);
   YY      = YEAR(REPTDATE);
   STDATE  = MDY(MM,01,YY);
   PREVDATE= STDATE-1;
   CALL SYMPUT('CDATE',PUT(REPTDATE,Z5.));
   CALL SYMPUT('PDATE',PUT(PREVDATE,Z5.));
RUN;

