         @417  HANDCHG            6.2
         @423  ADVRATE            5.2
         @428  STDATE               8.
         @436  PRMTHFIU          14.2 /* PREV MONTH FIU */
         @450  RESBAL            14.2
         @464  DEBBAL            14.2
         @478  FIU               14.2 /* FIU          */
         @492  RESERVES          14.2
         @506  DEBTORS           14.2
         @520  OUTSDEBT          14.2
         @534  UNAPDEBT          14.2
         @548  DISPUTE           14.2
         @562  ADRESRVE          14.2
         @576  SOCODE              $3.
         @579  TERMINTD            $1.
         @580  YTDSERVC          14.2  /* YTD SERVICE CHARGE   */
         @594  YTDHANDC          14.2  /* YTD HANDLING CHARGE  */
         @608  YTDDISCC          14.2  /* YTD DISCOUNT CHARGE  */
         @622  YTDCDELC          14.2  /* YTD DELAY CHARGE     */
         @636  YTDINVOI          14.2  /* YTD INVOICE FACTORED */
         @650  YTDBADDB          14.2  /* YTD BAD DEBTS        */
         @664  SETTLE               3. /* SETTLEMENT           */
         @667  EFFECDT              8. /* EFFECTIVE DATE       */
         @675  MCREATE              8. /* CREATE    DATE       */
         @683  MUPDATE              8. /* UPDATE DATE          */
         @691  FAXNO              $20.
         @711  CFLIMIT             10.
         @721  CFRATE             7.4
         @728  CFINTE             7.4  /* CF INTEREST          */
         @735  CFDATE               8.
         @743  ENTITY              $4.
         @747  PROFITCT             4.
         @751  ACCTNO              10.
         @761  CUSTCD               2.
         @763  RPERIOD              5.    /* NEW */
         @768  NPLGRACE             5.    /* NEW */
         @773  NPLINT            11.5     /* NEW */
         @784  NPLCLBK             $1.    /* NEW */
         @785  NPLCHRG           13.2     /* NEW    TOTAL 798 */
         ;
   IF ENTITY = 'PBBH' AND CLIENTNO NE ' ';

   CUSTCX=CUSTCD; SECTORCD=SUBSTR(SECTORX,1,4);
   SECTCD=PUT(SECTORCD,$SECTCD.);
   AMTIND='D';
   BALANCE=SUM(FIU,PRMTHFIU);
   UNDRAWN=0;
   IF INLIMIT > 0 THEN DO;
      UNDRAWN=(INLIMIT-BALANCE) * 0.2;
      IF UNDRAWN < 0 THEN UNDRAWN=0;
   END;

   CFDATES=0; MUPDATS=0; MCREATS=0; EFFECDS=0;
   STDATES=0;
   IF CFDATE  > 0  THEN
      CFDATES=INPUT(SUBSTR(PUT(CFDATE,Z8.),1,8),YYMMDD8.);
   IF MUPDATE > 0  THEN
      MUPDATS=INPUT(SUBSTR(PUT(MUPDATE,Z8.),1,8),YYMMDD8.);
   IF MCREATE > 0  THEN
      MCREATS=INPUT(SUBSTR(PUT(MCREATE,Z8.),1,8),YYMMDD8.);
   IF EFFECDT > 0  THEN
      EFFECDS=INPUT(SUBSTR(PUT(EFFECDT,Z8.),1,8),YYMMDD8.);
   IF STDATE  > 0  THEN
      STDATES=INPUT(SUBSTR(PUT(STDATE,Z8.),1,8),YYMMDD8.);

   BRANCH=PROFITCT;
   IF SUBSTR(CLIENTNO,8,2)='KL' THEN STATECD='W';
   IF SUBSTR(CLIENTNO,8,2)='PG' THEN STATECD='P';
   IF SUBSTR(CLIENTNO,8,2)='JB' THEN STATECD='J';

RUN;

