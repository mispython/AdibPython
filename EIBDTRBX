PROC SORT DATA=DEPOSIT.CURRENT OUT=CURRENT;
   BY ACCTNO;
*;
DATA DEPOSIT.CURRENT;
   SET CURRENT;
   IF CURCODE NE 'MYR' THEN DO;
      FORATE = PUT(CURCODE,$FORATE.);
      FORBAL = CURBAL;
      CURBAL = ROUND(CURBAL * FORATE,.01);
   END;
   CURBALUS = CURBAL / PUT('USD',$FORATE.);
