   INFILE ENTP TRUNCOVER;
   INPUT @01  ACCTNO          11.
         @21  PB_ENTERPRISE_PACKAGE_CD  $10.
         @31  REGDATE        $20.
         ;
   PB_ENTERPRISE_REG_DT = INPUT(REGDATE,DDMMYY10.);
   PB_ENTERPRISE_TAG    = 'Y';
RUN;
PROC SORT DATA=PBENTP NODUPKEY; BY ACCTNO; RUN;

