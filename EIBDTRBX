   INFILE MADB;
   INPUT @1     ACCTNO          PD6.
         @9     OPENDT2         $10.
         @27    CONVDT2         $10.
         ;
   OPENDATE= INPUT(OPENDT2,YYMMDD10.);
   CONVDT= INPUT(CONVDT2,YYMMDD10.);
RUN;

DATA DPACC;
   INFILE DPACC;
   INPUT @3   ACCTNO       PD6.
         @9   INTPLAN_IBCA    PD3.
         @27  E_INVOICE_IND    $1.
         @39  SOURCE_INCOME_CURRENCY_CD $3.
   ;
RUN;
PROC SORT DATA=DPACC; BY ACCTNO; RUN;

PROC SORT DATA=GETMCODE NODUPKEY;BY ACCTNO;RUN;
PROC SORT DATA=SAVING;BY ACCTNO;RUN;
PROC SORT DATA=MADT;BY ACCTNO; RUN;

DATA OMNIBUS;
   INFILE OMNI;
   INPUT @01  ACCTNO         11.
         @12  OMNILOAN       15.
         @27  OMNITRDB       10.
         @37  DSR                  PD3.2
         @40  REPAY_TYPE_CDX       PD2.
