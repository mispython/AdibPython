                 NAME OPENDT CLOSEDT OPENIND AVGAMT RACE BDATE
                 SECTOR STATE RISKCODE CUSTCODE LEDGBAL INTPAYBL
                 CURBAL PURPOSE USER3 LASTTRAN ACCYTD SCHIND BANKNO
                 COSTCTR USER2 EXODDATE TEMPODDT ORGTYPE MTDLOWBA
                 PREVBRNO INACTIVE SECOND BONUTYPE SERVICE USER5
                 ORGCODE INTPLAN INTPD INTYTD YTDAVAMT BONUSANO
                 CHQFLOAT FEEPD BENINTPD INTRATE AVGBAL INTRSTPD
                 TRACKCD TAXNO CURCODE CHGIND DNBFISME PBIND
                 STATCD POST_IND INTCYCODE DTLSTCUST INTPDPYR
                 REOPENDT ODXSAMT STMT_CYCLE NXT_STMT_CYCLE_DT
                 PRIN_ACCT AC_OPEN_STATUS_CD
                 CASH_DEPOSIT_LIMIT_IND CASH_DEPOSIT_AMOUNT_AGG);
%LET CAVAR=(KEEP=ACCTNO BRANCH OPENMH CLOSEMH PRODUCT DEPTYPE
                 FMTCODE DEBIT CREDIT DPMTDBAL BILLERIND INT1
                 NAME OPENDT CLOSEDT OPENIND AVGAMT RACE BDATE
                 SECTOR STATE RISKCODE CUSTCODE LEDGBAL INTPAYBL
                 CURBAL APPRLIMT ODPLAN RATE1 RATE2 RATE3 RATE4 RATE5
                 TODRATE FLATRATE ODSTAT LIMIT1 LIMIT2 LIMIT3 LIMIT4
                 LIMIT5 PURPOSE USER2 COL1 COL2 COL3 COL4 COL5
                 BASERATE USER3 LASTTRAN ACCYTD ODINTACC
                 TEMPODDT EXODDATE ORGTYPE MTDLOWBA COSTCTR PREVBRNO
                 CCRICODE CURCODE INACTIVE SECOND DTLSTCUST
                 BONUTYPE SERVICE USER5 ORGCODE INTPLAN INTPD
                 CRRCODE INTYTD YTDAVAMT BONUSANO FEEPD BENINTPD
                 CHQFLOAT MAXPROF ACCPROF MTDAVBAL
                 ODXSAMT INTRATE ODINTCHR FAACRR CENSUST VB
                 AVGBAL INTRSTPD TRACKCD TAXNO CHGIND
                 RETURNS_Y DATE_LST_DEP L_DEP DNBFISME IA_LRU
                 STATCD POST_IND INTCYCODE AUTHORISE_LIMIT
                 INTPDPYR REOPENDT MODIFIED_FACILITY_IND STMT_CYCLE
                 NXT_STMT_CYCLE_DT PRIN_ACCT INTPLAN_IBCA
                 CASH_DEPOSIT_LIMIT_IND SOURCE_INCOME_CURRENCY_CD
                 CASH_DEPOSIT_AMOUNT_AGG NXTREVDT LSTREVDT);
%LET FDVAR=(KEEP=ACCTNO BRANCH OPENMH CLOSEMH PRODUCT DEPTYPE
                 FMTCODE DEBIT CREDIT TRACKCD TAXNO DPMTDBAL
                 NAME OPENDT CLOSEDT OPENIND SECTOR CUSTCODE CURBAL
                 LASTTRAN ACCYTD ORGTYPE USER3 STATE BDATE RACE
                 PREVBRNO PURPOSE ORGCODE LEDGBAL AVGAMT USER2
                 RISKCODE INTPLAN INTPD SECOND INACTIVE BONUTYPE
                 SERVICE USER5 INTYTD YTDAVAMT BONUSANO FEEPD CURCODE
                 COSTCTR INTPAYBL AVGBAL INTRSTPD MTDAVBAL DNBFISME
                 STATCD POST_IND INTCYCODE INTRATE INT1 DTLSTCUST
                 INTPDPYR REOPENDT ODXSAMT STMT_CYCLE
                 NXT_STMT_CYCLE_DT PRIN_ACCT);
%LET RRVAR=(KEEP=ACCTNO RRIND RRCOUNT RRAPPRVDT RREXPIRYDT RRMAINDT
                 RRPERIOD RRCOMPLDT);

DATA SAVING &SAVAR
     UMA    &SAVAR
     CURRENT &CAVAR
     DEPOSIT.VOSTRO  &CAVAR
     FD &FDVAR;

  INFILE DPTRBL LRECL=1500;

  INPUT @3   BANKNO   PD2.
        @24  REPTNO   PD3.
        @27  FMTCODE  PD2. @;

  IF BANKNO = 33 AND REPTNO = 1001 AND FMTCODE IN (1,5,10,22);
  INPUT @106 BRANCH  PD4.
        @110 ACCTNO  PD6.
        @116 NAME    $15.
        @131 TAXNO   $11.
        @143 DEBIT   PD8.2
        @151 CREDIT  PD7.2
        @158 CLOSEDT PD6.
        @164 REOPENDT PD6.
        @176 CUSTCODE PD3.
        @193 INTPAID  PD7.2
        @200 ODPLAN PD2.
        @202 RATE1 PD3.3
        @205 RATE2 PD3.3
        @208 RATE3 PD3.3
        @211 RATE4 PD3.3
        @214 RATE5 PD3.3
        @217 TODRATE PD3.3
        @220 FLATRATE PD3.3
        @223 BASERATE PD3.3
        @226 ODSTAT $2.
        @228 ORGCODE $3.
        @231 ORGTYPE $1.
        @232 LIMIT1 PD6.
        @238 LIMIT2 PD6.
        @244 LIMIT3 PD6.
        @250 LIMIT4 PD6.
        @256 LIMIT5 PD6.
        @268 INTYTD PD6.2
        @274 FEEPD PD6.2
        @286 PURPOSE $1.
        @287 COL1 $5.
        @292 COL2 $5.
        @297 COL3 $5.
        @302 COL4 $5.
        @307 COL5 $5.
        @312 SECTOR PD3.
        @315 USER2 $1.
        @316 USER3 $1.
        @317 RISKCODE $1.
        @319 LEDGBAL PD7.2
        @326 DATELSTDEP PD5.
        @331 L_DEP PD7.2
        @338 OPENIND $1.
        @338 STATCD $10.
        @357 LASTTRAN PD5.
        @375 RETURNS_Y PD3.
        @381 STMT_CYCLEX PD2.
        @385 CHGIND 1.
        @391 AVGAMT PD6.
        @397 PRODUCT PD2.
        @399 RACE $1.
        @431 DEPTYPE $1.
        @432 INT1 PD6.2
        @438 INTPD PD6.2
        @444 INTPLAN PD2.
        @466 CURBAL PD7.2
        @474 CHQFLOAT  PD7.2
        @506 IA_LRU $1.
        @516 INT2 PD10.9
        @526 MTDLOWBA PD6.2
        @532 BENINTPD PD6.2
        @545 STATE $2.
        @563 INTCYCODE $3.
        @566 APPRLIMT PD6.
        @572 ODINTCHR PD6.2
        @578 ODINTACC PD10.9
        @588 CURCODE $3.
        @628 PBIND   $1.
        @629 INTRATE PD3.3
        @650 STMT_DT PD5.
        @671 YTDAVAMT PD8.2
        @717 BDATE PD6.
        @723 INACTIVE  $1.
        @724 SECOND   PD3.
        @727 ODXSAMT  PD7.2
        @734 BONUTYPE PD2.
        @736 SERVICE  PD2.
        @738 BONUSANO PD9.
        @756 USER5     $1.
        @776 TRACKCD  $12.
        @801 EXODDATE  PD6.
        @807 TEMPODDT  PD6.
        @813 AGENT_CD PD2.
        @816 SCHIND $2.
        @818 PREVBRNO PD4.
        @822 AVGBAL   PD8.2
        @830 COSTCTR PD4.
        @840 AUTHORISE_LIMIT  PD6.
        @846 CRRCODE   $3.
        @849 CCRICODE PD3.
        @852 FAACRR $3.
        @855 POST_IND $1.
        @856 CENSUST PD3.
        @864 ACCPROF PD10.9
        @874 MAXPROF PD6.2
        @880 INTRSTPD PD9.2
        @890 MTDAVBAL PD8.2
        @916 VB        $1.
        @917 BILLERIND $1.
        @918 MODIFIED_FACILITY_IND $4.
        @922 DTLSTCUST PD5.
        @927 INTPDPYR  PD6.2
        @933 OPENDT    PD6.
        @939 PRIN_ACCT PD6.
        @952 CASH_DEPOSIT_LIMIT_IND 1.
        @959 CASH_DEPOSIT_AMOUNT_AGG PD6.2
        @965 NXTREVDT  PD6.
        @971 LSTREVDT  PD6.
        ;

   IF STMT_DT NOT IN (0,.) THEN DO;
      STMT_DTX = PUT(STMT_DT,8.);
      YY = SUBSTR(STMT_DTX,1,4);
      MM = SUBSTR(STMT_DTX,5,2);
      DD = SUBSTR(STMT_DTX,7,2);
      NXT_STMT_CYCLE_DT = MDY(MM,DD,YY);
   END;

   STMT_CYCLE = INPUT(SUBSTR(PUT(STMT_CYCLEX,3.),1,3),$3.);

   AC_OPEN_STATUS_CD = PUT(AGENT_CD,Z3.);
   DNBFISME = '0';

   IF OPENDT = REOPENDT THEN REOPENDT = .;

   IF (0<CUSTCODE<=99) THEN DO;
        CUSTCODE = CUSTCODE;
        DNBFISME = '0';
   END;
   ELSE IF (100<=CUSTCODE<=999) THEN DO;
        CUSTCODEX = CUSTCODE;
        CUSTCODE=INPUT(SUBSTR(PUT(CUSTCODE,3.),2,2),2.);
        DNBFISME=INPUT(SUBSTR(PUT(CUSTCODEX,3.),1,1),$1.);
   END;
   ELSE IF (1000<=CUSTCODE<=9999) THEN DO;
        CUSTCODEX = CUSTCODE;
        CUSTCODE=INPUT(SUBSTR(PUT(CUSTCODE,4.),3,2),2.);
        DNBFISME=INPUT(SUBSTR(PUT(CUSTCODEX,4.),2,1),$1.);
   END;
   ELSE IF (10000<=CUSTCODE<=99999) THEN DO;
        CUSTCODEX = CUSTCODE;
        CUSTCODE=INPUT(SUBSTR(PUT(CUSTCODE,5.),4,2),2.);
        DNBFISME=INPUT(SUBSTR(PUT(CUSTCODEX,5.),3,1),$1.);
   END;

  DATE_LST_DEP = INPUT(SUBSTR(PUT(DATELSTDEP,Z9.),1,6),MMDDYY6.);

  IF FMTCODE IN (1,10,22) THEN DO;

  DPMTDBAL=MTDAVBAL;
  INTPAYBL=SUM(INT1, INT2);
  IF MTDAVBAL NOT IN (.,0) THEN MTDAVBAL = MTDAVBAL/&NODAY;

  IF PRODUCT IN (297,298)
     THEN OUTPUT UMA;
  ELSE DO;
     OPENMH=0;
     IF OPENDT NE 0 THEN DO;
     IF MONTH(INPUT(SUBSTR(PUT(OPENDT, Z11.), 1, 8), MMDDYY8.)) EQ
        MONTH(INPUT("&RDATE", DDMMYY8.)) AND
        YEAR(INPUT(SUBSTR(PUT(OPENDT, Z11.), 1, 8), MMDDYY8.)) EQ
        YEAR(INPUT("&RDATE", DDMMYY8.)) THEN
     OPENMH=1;
     END;

     CLOSEMH=0;
     IF CLOSEDT NE 0 THEN DO;
     IF MONTH(INPUT(SUBSTR(PUT(CLOSEDT, Z11.), 1, 8), MMDDYY8.)) EQ
        MONTH(INPUT("&RDATE", DDMMYY8.)) AND
        YEAR(INPUT(SUBSTR(PUT(CLOSEDT, Z11.), 1, 8), MMDDYY8.)) EQ
        YEAR(INPUT("&RDATE", DDMMYY8.)) THEN
     CLOSEMH=1;
     END;

     ACCYTD = 0;
     IF OPENDT NE 0 AND CLOSEDT EQ 0 THEN DO;
     IF YEAR(INPUT(SUBSTR(PUT(OPENDT, Z11.),1, 8), MMDDYY8.)) EQ
        YEAR(INPUT("&RDATE", DDMMYY8.)) THEN
     ACCYTD = 1;
     END;
     SELECT (DEPTYPE);
        WHEN ('S')     OUTPUT SAVING;
        WHEN ('D','N') OUTPUT CURRENT;
        WHEN ('C')     OUTPUT FD;
        OTHERWISE;
     END;
  END;
  END;

  IF PRODUCT IN (500,507,509,510,521,526,528,530,531)
     THEN OUTPUT DEPOSIT.VOSTRO;
RUN;

DATA GETMCODE(KEEP=ACCTNO MAILCODE);
  INFILE DPTRBL1;
  INPUT @1   ACCTNO    11.
        @370 MAILCODE  $1.
        ;
RUN;

DATA POSTSEG;
   INFILE FROZEN;
   INPUT @01  ACCTNO         11.
         @38  PSREASON      $20.
