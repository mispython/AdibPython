PROC SORT DATA=OMNIBUS NODUPKEY; BY ACCTNO; RUN;

DATA SAVING(DROP=OPENDATE);
   MERGE SAVING(IN=A) GETMCODE(IN=B) MADT(IN=C) POSTSEG DPACC;
   BY ACCTNO;
   IF A;
   IF PBIND = 'N' THEN DO;
      IF CONVDT > OPENDATE THEN SSADATE = CONVDT;
      ELSE SSADATE = OPENDATE;
   END;
RUN;

DATA DEPOSIT.SAVING
     IDEPOSIT.SAVING;
   SET SAVING;
   IF (3000<=COSTCTR<=4999) THEN OUTPUT IDEPOSIT.SAVING;
   ELSE                          OUTPUT  DEPOSIT.SAVING;
RUN;
*;
PROC SORT DATA=UMA;BY ACCTNO;RUN;

