PROC SORT  DATA=TUK2; BY CLASSIF STATE BRNAME BRH;
TITLE1 'REPORT NAME : EIBHTUKR - 5';
PROC PRINT DATA=TUK2 SPLIT='*';
   BY STATE BRNAME BRH;
   /* ID NUM; */
   VAR ACCTNO NAME CGCREF APPRLIMT BALANCE HSTPRIN
       HSTINT INTERB INTERCGC INTERAG;
   SUM BALANCE APPRLIMT HSTPRIN HSTINT INTERB INTERCGC INTERAG;
