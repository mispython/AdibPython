PROC SORT DATA=BNM.LOAN&REPTMON&NOWK
          OUT=LOAN3 (KEEP=ACCTNO BRANCH BALANCE PRODUCT NAME APPRLIMT
                          ISSDTE AMTIND PRODCD ORGCODE ODINTACC);
   BY ACCTNO;
   WHERE ACCTYPE = 'OD' AND (APPRLIMT >= 0 OR BALANCE < 0);
*;
PROC SORT DATA=OD.OVERDFT NODUPKEY
          OUT=OD (KEEP=ACCTNO EXCESSDT TODDATE RISKCODE REVIEWDT);
   BY ACCTNO;
   WHERE EXCESSDT > 0 OR TODDATE > 0;
*;
DATA OD;
  * MERGE OD GP3; /* THIS WILL TAKE EFFECT IF THE GP3 FIX IMPLEMENTED */
   SET OD;
   BY ACCTNO;
   WHERE EXCESSDT > 0 OR TODDATE > 0;
RUN;
DATA OD;
   KEEP BRCH BALANCE RISKRTE RISKCODE RISKBAL RISKRATE EXCESSDT TODDATE
   BLDATE TODDT ACCTNO DAYS NAME BRANCH PRODUCT ISSDTE APPRLIMT
   AMTIND PRODCD REVIEWDT CORPBIND ODINTACC;
   MERGE LOAN3(IN=AA) OD;
   BY ACCTNO;
   LENGTH RISKRTE 2;
   IF _N_ = 1 THEN SET REPTDATE;
   IF AA & BRANCH ^= . & PRODUCT NOT IN (517,500);
   BRCH = PUT(BRANCH,BRCHCD.);
   RISKRTE = RISKCODE;
   IF ORGCODE IN ('1','001','100') THEN CORPBIND = 'CB';
   IF ODINTACC > 0 THEN BALANCE = SUM(BALANCE,(-1)*ODINTACC);
   IF EXCESSDT > 0 THEN DO;
     EXCDAY = SUBSTR(PUT(EXCESSDT,Z11.),3,2);
     EXCMONTH = SUBSTR(PUT(EXCESSDT,Z11.),1,2);
     EXCYEAR = SUBSTR(PUT(EXCESSDT,Z11.),5,4);
     EXCDATE = MDY(EXCMONTH,EXCDAY,EXCYEAR);
   END;
   IF TODDATE > 0 THEN DO;
     TODDAY = INPUT(SUBSTR(PUT(TODDATE,Z11.),3,2),2.);
     TODMONTH = INPUT(SUBSTR(PUT(TODDATE,Z11.),1,2),2.);
     TODYEAR = INPUT(SUBSTR(PUT(TODDATE,Z11.),5,4),4.);
     TODDT = MDY(TODMONTH,TODDAY,TODYEAR);
   END;
   IF EXCESSDT NE 0 AND TODDATE NE 0 THEN DO;
   IF EXCDATE <= TODDT THEN
      BLDATE = INPUT(SUBSTR(PUT(EXCESSDT,Z11.),1,8),MMDDYY8.);
   IF EXCDATE > TODDT THEN
      BLDATE = INPUT(SUBSTR(PUT(TODDATE,Z11.),1,8),MMDDYY8.);
   END;
   ELSE IF EXCESSDT > 0 THEN
      BLDATE = INPUT(SUBSTR(PUT(EXCESSDT,Z11.),1,8),MMDDYY8.);
   ELSE IF TODDATE > 0 THEN
      BLDATE = INPUT(SUBSTR(PUT(TODDATE,Z11.),1,8),MMDDYY8.);
   IF BLDATE ^= . THEN DAYS = REPTDATE - BLDATE + 1;
 /********************************************************************/
 /*  GET LOANS                                                       */
 /********************************************************************/
DATA LOANS;
   KEEP BRCH BRANCH BALANCE RISKRATE RISKRTE ACCTNO DAYS NOTENO PRODUCT
        APPRLIMT BALANCE ISSDTE NAME AMTIND PRODCD CORPBIND BORSTAT;
   SET BNM.LOAN&REPTMON&NOWK;
   WHERE PRODUCT NOT IN (700,705,380,381,128,130);
   IF _N_ = 1 THEN SET REPTDATE;
   IF ACCTYPE = 'LN' AND BRANCH ^= . AND BALANCE >= 1.00 AND
      PRODCD NE 'N';
   IF BLDATE > 0 THEN DAYS = REPTDATE - BLDATE;
   IF ACCTYIND = 900 THEN CORPBIND = 'CB';
   AMTIND=PUT(PRODUCT, LNDENOM.);
RUN;
 /********************************************************************/
 /*  COMBINE LOANS & OD                                              */
 /********************************************************************/
DATA COMBINE;
   KEEP BRCH BRANCH BALANCE RISKRATE RISKRTE ACCTNO DAYS NOTENO PRODUCT
        APPRLIMT BALANCE ISSDTE NAME AMTIND PRODCD REVIEWDT CORPBIND
        BORSTAT;
   SET LOANS OD;
