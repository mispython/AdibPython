%MACRO BASE;
 %IF "&REPTMON" EQ "01" %THEN %DO;
      DATA MIS.BASECA&RYEAR;
       SET MIS.BASECA;
    DATA MIS.BASENP&RYEAR;
       SET MIS.BASENPL;
    DATA MIS.BASECAX&RYEAR;
       SET MIS.BASECAX;
    DATA CAODBASE;
       SET PREVOD.OVERDFT;
       FORMAT RISKBASE 1.;
       EXCESS = INPUT(SUBSTR(PUT(EXCESSDT,Z11.),1,8),MMDDYY8.);
       EXCESSDT = EXCESS;
       TODDAT = INPUT(SUBSTR(PUT(TODDATE,Z11.),1,8),MMDDYY8.);
       TODDATE = TODDAT;
       RISKBASE = RISKCODE;
       NOTENO = .;
       DAY1 = &PREPTDT - EXCESSDT+1 ;
       DAY2 = &PREPTDT - TODDATE +1;
       IF RISKCODE = '1' AND (1<=DAY1<=182 OR 1<=DAY2<=182);
       KEEP ACCTNO NOTENO RISKBASE;
    DATA CALNBASE;
       SET BNM.LOAN&PREVMON&NOWK;
       FORMAT RISKBASE 1.;
       DAYS = &PREPTDT - BLDATE;
       IF 2000000000 < ACCTNO < 3000000000 AND (RISKRTE = 1 AND
       DAYS >= 90)
       THEN DO;
          RISKBASE = RISKRTE;
          KEEP ACCTNO NOTENO RISKBASE;
          OUTPUT;
       END;
       ELSE IF 8000000000 < ACCTNO < 9000000000 AND 90 <=DAYS <=182
       THEN DO;
          RISKBASE = 1;
          KEEP ACCTNO NOTENO RISKBASE;
          OUTPUT;
       END;

    DATA MIS.BASECA;
       SET CAODBASE CALNBASE;

    DATA MIS.BASENPL;
       SET BNM.LOAN&PREVMON&NOWK;
       DAYS = &PREPTDT - BLDATE;
       IF 2000000000 < ACCTNO < 4000000000 AND RISKRTE IN (2,3,4)
       THEN DO;
          RISKBASE = RISKRTE;
          KEEP ACCTNO NOTENO RISKBASE BLDATE;
          OUTPUT;
       END;
       ELSE IF 8000000000 < ACCTNO < 9000000000 AND DAYS > 182 THEN DO;
          RISKBASE = 2;
          KEEP ACCTNO NOTENO RISKBASE BLDATE;
          OUTPUT;
       END;

    DATA CAODBASX;
       SET PREVOD.OVERDFT;
       FORMAT RISKBASE 1.;
       EXCESS = INPUT(SUBSTR(PUT(EXCESSDT,Z11.),1,8),MMDDYY8.);
       EXCESSDT = EXCESS;
       TODDAT = INPUT(SUBSTR(PUT(TODDATE,Z11.),1,8),MMDDYY8.);
       TODDATE = TODDAT;
       RISKBASE = 0;
       NOTENO = .;
       DAY1 = &PREPTDT - EXCESSDT+1 ;
       DAY2 = &PREPTDT - TODDATE +1;
       IF (60<=DAY1<=89 OR 60<=DAY2<=89);
       KEEP ACCTNO NOTENO RISKBASE;
    DATA CALNBASX;
       SET BNM.LOAN&PREVMON&NOWK;
       FORMAT RISKBASE 1.;
       DAYS = &PREPTDT - BLDATE;
       IF 2000000000 < ACCTNO < 3000000000 AND 60 <=DAYS <=89 THEN DO;
          RISKBASE = 0;
          KEEP ACCTNO NOTENO RISKBASE;
          OUTPUT;
       END;
       IF 8000000000 < ACCTNO < 9000000000 AND 60 <=DAYS <=89 THEN DO;
          RISKBASE = 0;
          KEEP ACCTNO NOTENO RISKBASE;
          OUTPUT;
       END;

    DATA MIS.BASECAX;
       SET CAODBASX CALNBASX;

    PROC SORT DATA=MIS.BASENPL NODUPKEYS;
       BY ACCTNO NOTENO;

    PROC SORT DATA=MIS.BASECA NODUPKEYS;
       BY ACCTNO NOTENO;

    PROC SORT DATA=MIS.BASECAX NODUPKEYS;
       BY ACCTNO NOTENO;

    DATA MIS.BILLNPLBASE;
       FORMAT ACCTNO 11.;
       SET BTRADE.BTRAD&PREVMON&NOWK(DROP=ACCTNO);
       IF MATDATE NOT IN (0,.);
       DAYS = &PREPTDT - MATDATE + 1;
       IF BALANCE > 0 AND DAYS >= 90;
       REPTDT = &PREPTDT;
       RISKBASE = 4;
       ACCTNO = ACCTNOX;
       KEEP ACCTNO TRANSREF MATDATE RISKBASE;
    DATA MIS.BILLCABASE;
       FORMAT ACCTNO 11.;
       SET BTRADE.BTRAD&PREVMON&NOWK(DROP=ACCTNO);
       IF MATDATE NOT IN (0,.);
       DAYS = &PREPTDT - MATDATE + 1;
       IF BALANCE > 0 AND 60 <= DAYS < 90;
       REPTDT = &PREPTDT;
       RISKBASE = 0;
       ACCTNO = ACCTNOX;
       KEEP ACCTNO TRANSREF MATDATE RISKBASE;

%END;
%MEND BASE;
