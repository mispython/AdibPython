PROC SORT DATA=MIS.GETCIS&REPTMON OUT=GETCIS; BY ACCTNO NOTENO;
   WHERE RISKRTE IN (1,2,3,4);
RUN;
PROC SORT DATA=MIS.GETCIS&PREVMON OUT=GETCISPRV;
   WHERE RISKRTE IN (1,2,3,4);
   BY ACCTNO NOTENO;
RUN;
DATA MIS.REDUCT&REPTMON;
   MERGE GETCIS (IN=A)
         GETCISPRV (IN=B RENAME=(RISK=PRVRISK BALANCE=PRVBAL));
   BY ACCTNO NOTENO;
   IF A & NOT B THEN REDUCT = 0;
   IF B & NOT A THEN REDUCT = PRVBAL;
   IF A & B THEN PAYMENT = SUM(PRVBAL,(-1)*BALANCE);
   TTLREDUC = SUM(REDUCT,PAYMENT);
RUN;
PROC SORT DATA=MIS.REDUCT&REPTMON;
   BY IC;
