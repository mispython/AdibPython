DATA MIS.CA&REPTMON&NOWK;
   SET LN&REPTMON&NOWK;
   BRCH = PUT(BRANCH,BRCHCD.);
   IF 2500000000<=ACCTNO<=2599999999 THEN NOTENO = TRANSREF;
   SELECT;
      WHEN (DAYS>729) MTHARR = ROUND((DAYS/365)*12);
      WHEN (DAYS>698) MTHARR = 23;
      WHEN (DAYS>668) MTHARR = 22;
      WHEN (DAYS>638) MTHARR = 21;
      WHEN (DAYS>608) MTHARR = 20;
      WHEN (DAYS>577) MTHARR = 19;
      WHEN (DAYS>547) MTHARR = 18;
      WHEN (DAYS>516) MTHARR = 17;
      WHEN (DAYS>486) MTHARR = 16;
      WHEN (DAYS>456) MTHARR = 15;
      WHEN (DAYS>424) MTHARR = 14;
      WHEN (DAYS>394) MTHARR = 13;
      WHEN (DAYS>364) MTHARR = 12;
      WHEN (DAYS>333) MTHARR = 11;
      WHEN (DAYS>303) MTHARR = 10;
      WHEN (DAYS>273) MTHARR = 9;
      WHEN (DAYS>243) MTHARR = 8;
      WHEN (DAYS>212) MTHARR = 7;
      WHEN (DAYS>182) MTHARR = 6;
      WHEN (DAYS>151) MTHARR = 5;
      WHEN (DAYS>121) MTHARR = 4;
      WHEN (DAYS>89)  MTHARR = 3;
      WHEN (DAYS>59)  MTHARR = 2;
      WHEN (DAYS>29)  MTHARR = 1;
      OTHERWISE       MTHARR = 0;
   END;
   IF BORSTAT = 'F' THEN MTHARR = 999;
   IF BORSTAT = 'W' THEN MTHARR = 0;
   DAYNPL = DAYS - 182;
   SELECT;
      WHEN (DAYNPL>729) MTHCLAS = ROUND((DAYNPL/365)*12);
      WHEN (DAYNPL>698) MTHCLASS = 23;
      WHEN (DAYNPL>668) MTHCLASS = 22;
      WHEN (DAYNPL>638) MTHCLASS = 21;
      WHEN (DAYNPL>608) MTHCLASS = 20;
      WHEN (DAYNPL>577) MTHCLASS = 19;
      WHEN (DAYNPL>547) MTHCLASS = 18;
      WHEN (DAYNPL>516) MTHCLASS = 17;
      WHEN (DAYNPL>486) MTHCLASS = 16;
      WHEN (DAYNPL>456) MTHCLASS = 15;
      WHEN (DAYNPL>424) MTHCLASS = 14;
      WHEN (DAYNPL>394) MTHCLASS = 13;
      WHEN (DAYNPL>364) MTHCLASS = 12;
      WHEN (DAYNPL>333) MTHCLASS = 11;
      WHEN (DAYNPL>303) MTHCLASS = 10;
      WHEN (DAYNPL>273) MTHCLASS = 9;
      WHEN (DAYNPL>243) MTHCLASS = 8;
      WHEN (DAYNPL>212) MTHCLASS = 7;
      WHEN (DAYNPL>182) MTHCLASS = 6;
      WHEN (DAYNPL>151) MTHCLASS = 5;
      WHEN (DAYNPL>121) MTHCLASS = 4;
      WHEN (DAYNPL>89)  MTHCLASS = 3;
      WHEN (DAYNPL>59)  MTHCLASS = 2;
      WHEN (DAYNPL>29)  MTHCLASS = 1;
      OTHERWISE         MTHCLASS = 0;
   END;
   IF TYPE NE 'BT' THEN DO;
   IF 3000000000<=ACCTNO<=3999999999 AND RISKRTE IN ('1','2','3','4')
      AND 1<=DAYS<=89 THEN ODVALID = 1;
   IF (RISKRTE = 1) AND ((90 <= DAYS <=182) OR ODVALID=1) &
   RISKBASE NOT IN ('1','2','3','4') THEN DO;
      RISK = '1C';
      IF RISKOLD NOT IN ('1C','2S','3D','4B') THEN NEW = '*';
   END;
   ELSE IF RISKRTE IN (2,3,4) &
   RISKBASE NOT IN ('1','2','3','4') THEN DO;
      IF RISKOLD NOT IN ('1C','2S','3D','4B') THEN NEW = '*';
      IF RISKRTE = 2 THEN RISK = '2S';
      ELSE IF RISKRTE = 3 THEN RISK = '3D';
      ELSE IF RISKRTE = 4 THEN RISK = '4B';
   END;
   ELSE IF (60<=DAYS<=89) & RISKBASE NOT IN ('0','1','2','3','4')
   THEN DO
      RISK = '0C';
      IF RISKOLD NE '0C' THEN NEW = '*';
   END;
   END;
   IF TYPE = 'BT' THEN DO;
   STARTDT = MDY(1,1,YEAR(TODAY()));
   LASTDATE=MDY(MONTH(&REPTDT),1,YEAR(TODAY()))-1;
   LASTDAY = LASTDATE - MATDATE + 1;
   YRDATE  = &REPTDT  - STARTDT + 92;
