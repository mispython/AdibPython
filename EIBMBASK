*------------------------------------------------*
*  GET REPTDATE                                  *
*------------------------------------------------*;
DATA REPTDATE;
   SET BNM1.REPTDATE;
   MM1 = MONTH(REPTDATE)-1;
   IF MM1= 0 THEN MM1 = 12;
   CALL SYMPUT('NOWK',PUT('4',$1.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('PREVMON',PUT(MM1,Z2.));
   CALL SYMPUT('RDATE',PUT(REPTDATE,DDMMYY8.));
   CALL SYMPUT('RMONTH',PUT(REPTDATE,WORDDATE9.));
   CALL SYMPUT('RYEAR',PUT(PUT(REPTDATE,YEAR2.)-1,Z2.));
   CALL SYMPUT('REPTDT',REPTDATE);
   IF MONTH(REPTDATE) IN (2,4,6,7,9,11,12) THEN
      CALL SYMPUT('BTCADT',61);
   ELSE IF MONTH(REPTDATE) IN (3,5,8,10) THEN CALL SYMPUT('BTCADT',62);
   ELSE DO;
      IF MONTH(REPTDATE)= 1 THEN DO;
         IF MOD(YEAR(REPTDATE),4) = 0 THEN CALL SYMPUT('BTCADT',63);
         ELSE CALL SYMPUT('BTCADT',64);
      END;
   END;

RUN;
