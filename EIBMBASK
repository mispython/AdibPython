   IF FIRST.RISK THEN
      DO BRANCH = 1 TO 267;
      BRANCH1 = PUT(BRANCH,Z3.)||'('||PUT(BRANCH,BRCHCD.)||')';
      BRANCH2 = PUT(BRANCH,BRCHCD.)||'('||PUT(BRANCH,Z3.)||')';
      OUTPUT;
      END;
RUN;
DATA NEWNPL;
   MERGE NEWNPL DUMMY;
   BY RISK BRANCH;
