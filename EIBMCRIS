   RETAIN FV 'SAP.PBCRISS.TEXT(PAGE01)';
   SET SAVE.LOAN;
   BY BRANCH ACCTNO;
   FILE OUTFLE FILEVAR=FV;
   IF FIRST.ACCTNO;
   PUT @1   '0233'             /* FI TYPE/FI CODE            */
       @5   BRANCH   Z5.       /* COST CENTRE                */
       @10  ACCTNO   10.       /* ACCOUNT NUMBER             */
       @20  REPTDTE  $8.       /* REPORTING DATE             */
       @28  NEWIC    $20.      /* NEW IC                     */
       @48  OLDIC    $20.      /* OLD IC                     */
       @68  2*' '              /* CONSTITUTION CODE          */
       @70  NAME     $60.      /* NAME                       */
       @130 ADDR1    $45.      /* ADDRESS 1                  */
       @175 ADDR2    $90.      /* ADDRESS 2 & 3 (@175,220)   */
       @265 CUSTCD   $2.       /* CUSTOMER CODE              */
       @267 'MY'               /* COUNTRY CODE               */
       @269 SIC      Z4.       /* BUSINESS ACTIVITY CODE     */
       @273 'N'                /* BUSS REG IN SABAH/SARAWAK  */
       @274 'N'                /* STATUS                     */

       @275 FITYPE   $1.       /* TYPE OF FINANCING          */
       @276 LOANOPT  $1.       /* LOAN OPTION                */
       @277 TOTLIMT  12.       /* APPROVE LIMIT (AGGREGATE)  */
       @289 LOANCNT   2.       /* NO OF LOAN                 */
       @291 'N';               /* STATUS                     */
*;
*------------------------------------------------*
*  LOAN DETAILS/CURRENCY (PAGE03)                *
*------------------------------------------------*;
DATA _NULL_;
   RETAIN FV 'SAP.PBCRISS.TEXT(PAGE03)';
   SET SAVE.LOAN;
   FILE OUTFLE FILEVAR=FV;
   PUT @1   '0233'             /* FI TYPE/FI CODE            */
       @5   BRANCH   Z5.       /* COST CENTRE                */
       @10  ACCTNO   10.       /* ACCOUNT NUMBER             */
       @20  NOTENO   Z5.       /* LOAN NOTE NUMBER           */
       @25  REPTDTE  $8.       /* REPORTING DATE             */
       @33  PRODCD   $5.       /* LOAN FACILITY CODE         */
       @38  APPRDTE  $8.       /* DATE ACCOUNT OPENED        */
       @46  CLOSDTE  $8.       /* DATE ACCOUNT CLOSED        */
       @54  8*' '              /* DATE ACCOUNT CANCELLED     */
       @62  2*' '              /* ISLAMIC CONCEPT CODE       */
       @64  SECTORCD $4.       /* LOAN SECTORAL CODE         */
       @68  NOTETERM  3.       /* ORIGINAL TENURE            */
       @71  PAYTERM  $1.       /* PRIN REPAYMENT TERM        */
       @72  MTHARR    3.       /* MTHS IN DEFAULT - PRIN O/S */
       @75  MTHARR    3.       /* MTHS IN DEFAULT - INT O/S  */
       @78  RISKC    $1.       /* LOAN CLASSIFICATION        */
       @79  SECURE   $1.       /* SECURED/CLEAN LENDING      */
       @80  'N'                /* SHARED SECURITY            */
       @81  'N'                /* LEGAL ACTION STATUS        */
       @82  'N'                /* RESTRUCTURED/RESCHED       */
       @83  CAGAMAS  $1.       /* CAGAMAS,DANAHARTA,NONE     */
       @84  'S'                /* CURRENCY                   */
       @85  'N'                /* REMARK INDICATOR           */
       @86  'N'                /* USER DEFINED FIELD IND     */
       @87  'N'                /* STATUS                     */

       @88  'MYR'              /* CURRENCY CODE              */
   /*  @91  BALANCE  12. */    /* PRINCIPAL OUTSTANDING      */
       @91  CURBAL   12.       /* PRINCIPAL OUTSTANDING      */
       @103 INTOUT   12.       /* INTEREST OUTSTANDING       */
       @115 FEEAMT   12.       /* OTHER BALANCES             */
       @127 BALANCE  12.       /* TOTAL OUTSTANDING          */
       @139 'N';               /* STATUS                     */
*;
DATA PAGE04;
   FORMAT REPTDATE Z8.;
   SET GP3KLU(IN=A);
   IF IISR = . THEN IISR = 0;
   IF IISW = . THEN IISW = 0;
   IF IIS  = . THEN IIS  = 0;
   REPTDATE = "&REPTDAY"||"&REPTMON"||"&REPTYEAR";
RUN;
PROC SORT DATA=PAGE04;
   BY BRANCH ACCTNO;
RUN;
DATA _NULL_;
   RETAIN FV 'SAP.PBCRISS.TEXT(PAGE04)';
   SET PAGE04; BY BRANCH ACCTNO;
   FILE OUTFLE FILEVAR=FV;
   PUT  @001 BRANCH     Z3.
        @004 ACCTNO    Z10.
        @014 ZERO5      Z5.
        @019 REPTDATE   Z8.
     /* @021 RPTMON     Z2.
        @023 RPTYEAR    Z4.  */
        @027 SCV       Z12.
        @039 IIS       Z12.2
        @051 IISR      Z12.2
        @063 IISW      Z12.2
        @075 PRINWOFF  Z12.2
        @087 GP3IND     $1.;
   RUN;
*;
PROC SORT DATA=PAGE04;
   BY ACCTNO;
*;
PROC SORT DATA=OD.OVERDFT
          OUT=OD (KEEP=ACCTNO EXCESSDT TODDATE RISKCODE);
   BY ACCTNO;
   WHERE EXCESSDT > 0 OR TODDATE > 0;
DATA EXCLUDE;
   MERGE PAGE04(IN=A) OD;
   BY ACCTNO;
   IF A;
   IF FIRST.ACCTNO THEN;
   ELSE OUTPUT;
PROC PRINT DATA=EXCLUDE;
TITLE 'EXCEPTIONAL REPORT ON OD';
*;
