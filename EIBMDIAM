RUN;
DATA FD.PLUSFD;
   MERGE FD FD.PLUSFD(IN=A);
   IF A;
   BY ACCTNO;
   IF OPENDATE > 0 THEN NODAYS = (REPTDATE - OPENDATE)+1;
   ELSE NODAYS = DAY("&REPTDT");
   DROP REPTDATE;
RUN;
DATA FD.FCYFD;
   INFILE FCYFD;
   INPUT @001   ACCTNO       11.
         @012   CDNO         11.
         @023   BRANCH        3.
         @026   PRODUCT       3.
         @029   INTPLAN      IB2.
         @032   CURCUM       16.2
         @048   MTDBAL       16.2;
   REPTDATE=&REPTDT;
RUN;
DATA FD.FCYFD;
   MERGE FD FD.FCYFD(IN=A);
   IF A;
   BY ACCTNO;
   IF OPENDATE > 0 THEN NODAYS = (REPTDATE - OPENDATE)+1;
   ELSE NODAYS = DAY("&REPTDT");
   DROP REPTDATE;
RUN;
FILENAME TRANFILE 'SAP.PBB.FDDAZZLE.DIAFTP' DISP=OLD;
PROC CPORT LIBRARY=FD FILE=TRANFILE;
RUN;
*;
