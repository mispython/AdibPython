//INPL     DD DSN=SAP.PIBB.NPL.HP.SASDATA,DISP=OLD
//SYSIN    DD *

OPTIONS NOCENTER YEARCUTOFF=1950;

DATA REPTDATE;
   REPTDATE = INTNX('MONTH',TODAY(),-4,'E');
   DELEDATE = INTNX('MONTH',TODAY(),-7,'E');
   DELXDATE = INTNX('MONTH',TODAY(),-12,'E');
   DEL7DATE = INTNX('YEAR' ,TODAY(),-7,'E');
   CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('REPTDT',DELEDATE);
   CALL SYMPUT('REPTYR1',PUT(DELXDATE,YEAR2.));
   CALL SYMPUT('REPTMON1',PUT(MONTH(DELXDATE),Z2.));
   CALL SYMPUT('REPTYRS',PUT(DELEDATE,YEAR2.));
   CALL SYMPUT('REPTMONS',PUT(MONTH(DELEDATE),Z2.));
   CALL SYMPUT('REPTYR7',PUT(DEL7DATE,YEAR2.));
RUN;

PROC DATASETS LIB=MTD NOLIST;
   DELETE CA&REPTMON
          SA&REPTMON
          FD&REPTMON
