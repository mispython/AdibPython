%LET PBBLIST=%STR();
PROC SQL;
   SELECT MEMNAME INTO :PBBLIST SEPARATED BY ' '
     FROM SASHELP.VTABLE
    WHERE LIBNAME='WOFF' AND DATEPART(CRDATE) < &REPTDT;
QUIT;

PROC DATASETS LIB=WOFF NOLIST NODETAILS;
   DELETE &PBBLIST TEMPDS;
RUN;

%LET PIBLIST=%STR();
PROC SQL;
   SELECT MEMNAME INTO :PIBLIST SEPARATED BY ' '
     FROM SASHELP.VTABLE
    WHERE LIBNAME='WOFFI' AND DATEPART(CRDATE) < &REPTDT;
QUIT;

PROC DATASETS LIB=WOFFI NOLIST NODETAILS;
