DATA CDMSUM;
   SET SUM ISUM;
   WHERE ITEM EQ 'CDM';
   IF IND EQ 'HC'                   THEN HC_AMT=TRANAMT1;
   IF IND EQ 'LC'                   THEN LC_AMT=TRANAMT1;
   IF IND EQ 'HC'                   THEN HC_NUM=1;
   IF IND EQ 'LC'                   THEN LC_NUM=1;
   IF IND EQ 'HC' AND ENTITY='PBB'  THEN CHC_AMT=TRANAMT1;
   IF IND EQ 'LC' AND ENTITY='PBB'  THEN CLC_AMT=TRANAMT1;
   IF IND EQ 'HC' AND ENTITY='PBB'  THEN CHC_NUM=1;
   IF IND EQ 'LC' AND ENTITY='PBB'  THEN CLC_NUM=1;
   IF IND EQ 'HC' AND ENTITY='PIBB' THEN IHC_AMT=TRANAMT1;
   IF IND EQ 'LC' AND ENTITY='PIBB' THEN ILC_AMT=TRANAMT1;
   IF IND EQ 'HC' AND ENTITY='PIBB' THEN IHC_NUM=1;
   IF IND EQ 'LC' AND ENTITY='PIBB' THEN ILC_NUM=1;
RUN;

