OPTIONS YEARCUTOFF=1930 NOCENTER NODATE;
DATA REPTDATE (KEEP=REPTDATE);
  SET LOAN.REPTDATE;
  SREPTDATE = MDY(MONTH(REPTDATE),1,YEAR(REPTDATE));
  CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
  CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));
  CALL SYMPUT('RDATE',REPTDATE);
  CALL SYMPUT('REPTMON1',PUT(MONTH(REPTDATE), Z2.)||'01');
  CALL SYMPUT('REPTMON2',PUT(MONTH(REPTDATE), Z2.)||'02');
  CALL SYMPUT('REPTMON3',PUT(MONTH(REPTDATE), Z2.)||'03');
  CALL SYMPUT('REPTMON4',PUT(MONTH(REPTDATE), Z2.)||'04');
  CALL SYMPUT('PREPTYEAR',PUT(PRVRPTDATE,YEAR2.));
  CALL SYMPUT('REPORTDT',PUT(REPTDATE,DDMMYY10.));
  CALL SYMPUT('RDATE1',SREPTDATE);
RUN;

PROC FORMAT;
   VALUE DESC
      4-7, 60-62,70,200-299,
      600,911                          = 'HL'
      15,20,71,72,380,381,700,
      705,720,725                      = 'VL'
      25-34,73-79,303,306-308,311,
      313,320-340,355-358,364,365,
      367,369,391                      = 'PL'
      .                                = 'MS'
      OTHER                            = 'OT';

   VALUE IDESC
      102,105,106,110-119,124,139,142,
      145,150-151,152,156,170,175,400,
      409,410,412-415,423,466,469,650,
      651,664                          = 'HL'
      103,104,107,108,128,130-132,196  = 'VL'
      122,135-138,194-195,419-420,422,
      424,426,464,465,468,652,653,668,
      669,672-675                      = 'PL'
      .                                = 'MS'
      OTHER                            = 'OT';

   VALUE SEQFMT
      1 = 'CASH'
      2 = 'HOUSE CHEQUE'
      3 = 'LOCAL CHEQUE'
      4 = 'ATM'
      6 = 'RENTAS'
      7 = 'CDM'
      8 = 'CDT';

   VALUE $PDESC
      'HL'       = 'HOUSING LOANS'
      'VL'       = 'VEHICLE LOANS'
      'PL'       = 'PERSONAL LOANS'
      'CC'       = 'CREDIT AND CHARGE CARDS'
      'MS','OT'  = 'OTHER TYPES OF LOANS';
RUN;

   /*  CASH - LN  */
DATA BNM.DPLP;
 SET DPLP.DPLP&REPTMON;
RUN;

DATA BNM.LNLP;
    SET LNLP1.LNTRAX&REPTYEAR&REPTMON1
        LNLP1.LNTRAX&REPTYEAR&REPTMON2
        LNLP1.LNTRAX&REPTYEAR&REPTMON3
        LNLP1.LNTRAX&REPTYEAR&REPTMON4;
    TRANDT=REPTDATE;
RUN;
PROC SORT DATA=BNM.DPLP OUT=DPLP;BY ACCTNO TRANDT TRANAMT;RUN;
PROC SORT DATA=BNM.LNLP OUT=LNLP;BY ACCTNO TRANDT TRANAMT;RUN;

DATA BNM.OTCLN;
   MERGE LNLP(IN=A) DPLP(IN=B);
   BY ACCTNO TRANDT TRANAMT;
   IF A & B;
RUN;

DATA LNNOTE;
   SET LOAN.LNNOTE(KEEP=ACCBRCH ACCTNO NOTENO LOANTYPE COSTCTR)
       ILOAN.LNNOTE(KEEP=ACCBRCH ACCTNO NOTENO LOANTYPE COSTCTR);
RUN;
PROC SORT DATA=LNNOTE;BY ACCTNO NOTENO;RUN;
PROC SORT DATA=BNM.OTCLN OUT=OTCLN;BY ACCTNO NOTENO;RUN;

DATA BNM.OTCLN IBNM.OTCLN;
   MERGE OTCLN(IN=A) LNNOTE(IN=B);
   BY ACCTNO NOTENO;
   IF A;
   ITEM = 'CASH';
   SEQ  = 1;
   IF (3000 < COSTCTR < 3999) OR COSTCTR IN (4043,4048) THEN DO;
      PROD = PUT(LOANTYPE,IDESC.);
      OUTPUT IBNM.OTCLN;
   END;
   ELSE DO;
      PROD = PUT(LOANTYPE,DESC.);
      OUTPUT BNM.OTCLN;
   END;
RUN;

  /* CASH - CC */
DATA BNM.OTCCC;
 SET DPCC.DPCC&REPTMON;
   PROD = 'CC';
   ITEM = 'CASH';
   SEQ  = 1;
RUN;

   /*  CTCS  */
DATA CTCS;
 SET CTCS.CTCS&REPTMON;
 IF IND NE 'OC'; /* TO EXCLUDE OVERSEAS CHEQUE */
RUN;
PROC SORT DATA=CTCS;BY ACCTNO NOTENO;RUN;

DATA CTCS;
   MERGE CTCS(IN=A) LNNOTE(IN=B);
   BY ACCTNO NOTENO;
   IF A;
   TRANAMT=ROUND(TRANAMT,0.01);
   IF PRODIND = 'O' THEN DO;
     IF IND='HC' THEN DO;
         ITEM = 'HOUSE CHEQUE';
         SEQ  = 2;
     END;
     IF IND='LC' THEN DO;
         ITEM = 'LOCAL CHEQUE';
         SEQ  = 3;
     END;
   END;
   ELSE IF PRODIND = 'C' THEN DO;
     ITEM = 'CDM';
     SEQ  = 7;
   END;
RUN;

DATA DPTRX(RENAME=(CHQNO=CHEQNO REPTDATE=TRANDT ACCTNO=DEBACCT));
   SET DPTRN.DPBTRAN&REPTYEAR&REPTMON1
       DPTRN.DPBTRAN&REPTYEAR&REPTMON2
       DPTRN.DPBTRAN&REPTYEAR&REPTMON3
       DPTRN.DPBTRAN&REPTYEAR&REPTMON4;
   KEEP REPTDATE TRANAMT CHQNO ACCTNO;
   IF TRANCODE=876;
   TRANAMT=ROUND(TRANAMT,0.01);
RUN;
PROC SORT DATA=CTCS ; BY TRANDT TRANAMT CHEQNO; RUN;
PROC SORT DATA=DPTRX NODUPKEYS; BY TRANDT TRANAMT CHEQNO DEBACCT;RUN;
DATA CTCS;
   MERGE CTCS(IN=A) DPTRX(IN=B);
   BY TRANDT TRANAMT CHEQNO;
   IF A;
RUN;

DATA BNM.CTCS IBNM.CTCS;
   SET CTCS;
   IF (3000 < COSTCTR < 3999) OR COSTCTR IN (4043,4048) THEN DO;
      PROD = PUT(LOANTYPE,IDESC.);
      OUTPUT IBNM.CTCS;
   END;
   ELSE DO;
      PROD = PUT(LOANTYPE,DESC.);
      OUTPUT BNM.CTCS;
   END;
RUN;

  /* ELECTRONIC FUND TRANSFER */
DATA EFT614N668;
   SET BNM.LNLP;
   IF CHANNEL IN (501,502) AND TRANCODE IN (614,668) THEN DO;
      ITEM = 'ATM';
      SEQ  =  4;
      OUTPUT;END;
   IF CHANNEL IN (521,522) AND TRANCODE IN (614,668) THEN DO;
      ITEM = 'INTERBANK';
      SEQ  =  5;
      OUTPUT;END;
   IF CHANNEL IN (513,514) AND TRANCODE IN (614,668) THEN DO;
      ITEM = 'CDT';
      SEQ  =  8;
      OUTPUT;END;
RUN;

DATA EFT614;
   SET EFT614N668;
   IF TRANCODE EQ 614;
RUN;

PROC SORT DATA=EFT614N668; BY ACCTNO NOTENO USERID CHANNEL;

PROC SUMMARY DATA=EFT614N668 NWAY; BY ACCTNO NOTENO USERID CHANNEL;
VAR TRANAMT; OUTPUT OUT=EFTAMT SUM=; RUN;

PROC SORT DATA=EFT614; BY ACCTNO NOTENO USERID CHANNEL;
PROC SORT DATA=EFTAMT; BY ACCTNO NOTENO USERID CHANNEL;
DATA BNM.EFT;
   MERGE EFT614(IN=A) EFTAMT(IN=B);
   BY ACCTNO NOTENO USERID CHANNEL;
   IF A;
RUN;

PROC SORT DATA=BNM.EFT OUT=EFT;BY ACCTNO NOTENO;RUN;
DATA BNM.EFT IBNM.EFT;
   MERGE EFT(IN=A) LNNOTE;
   BY ACCTNO NOTENO;
   IF A;
   PROD = PUT(LOANTYPE,DESC.);
   IF (3000 < COSTCTR < 3999) OR COSTCTR IN (4043,4048) THEN DO;
      PROD = PUT(LOANTYPE,IDESC.);
      OUTPUT IBNM.EFT;
   END;
   ELSE DO;
      PROD = PUT(LOANTYPE,DESC.);
      OUTPUT BNM.EFT;
   END;
RUN;

   /* RENTAS */
DATA BNM.RENCC;
  SET BNMW1.RENCC
      BNMW2.RENCC
      BNMW3.RENCC
      BNMW4.RENCC;
RUN;

DATA BNM.RENLN;
  SET BNMW1.RENLN
      BNMW2.RENLN
      BNMW3.RENLN
      BNMW4.RENLN
      IBNMW1.RENLN
      IBNMW2.RENLN
      IBNMW3.RENLN
      IBNMW4.RENLN;
RUN;

PROC SORT DATA=BNM.RENLN OUT=RENLN;BY ACCTNO NOTENO;RUN;
DATA BNM.RENLN IBNM.RENLN;
   MERGE RENLN(IN=A) LNNOTE(DROP=LOANTYPE);
   BY ACCTNO NOTENO;
   IF A;
   IF (3000 < COSTCTR < 3999) OR COSTCTR IN (4043,4048) THEN DO;
      PROD = PUT(LOANTYPE,IDESC.);
      OUTPUT IBNM.RENLN;
   END;
   ELSE DO;
      PROD = PUT(LOANTYPE,DESC.);
      OUTPUT BNM.RENLN;
   END;
RUN;

  /* CONSOLIDATION */
DATA BNM.TRANX2;
   FORMAT ENTITY $4.;
   SET BNM.CTCS BNM.RENLN BNM.RENCC BNM.OTCLN BNM.OTCCC BNM.EFT;
   *WHERE PROD NOT EQ 'OT';
   TRANAMT1 = TRANAMT/1000;
   ENTITY='PBB';
   PDESC    = PUT(PROD,$PDESC.);
   SEQFMT   = PUT(SEQ ,SEQFMT.);
RUN;
PROC SORT DATA=BNM.TRANX2;BY SEQ;RUN;

DATA IBNM.TRANX2;
