DATA FCYFD;
  INFILE DPTRBL LRECL=1752;
  INPUT @3   BANKNO   PD2.
        @24  REPTNO   PD3.
        @27  FMTCODE  PD2. @;
  IF BANKNO = 33 AND REPTNO = 4001 AND FMTCODE = 2 THEN
    DO;
      INPUT @106 BRANCH   PD4.
            @110 ACCTNO   PD6.
            @134 NAME     $15.
            @124 CUSTCODE PD3.
            @149 CDNO     PD6.
            @155 OPENIND  $1.
            @156 CURBAL   PD6.2
            @174 ORGDATE  PD5.
            @179 MATDATE  PD5.
            @203 PRODUCT  PD2.
            @205 TERM     PD2.
            @208 INTPLAN  PD2.
            @211 RENEWAL  $1.
            @240 LASTACTV PD5.
            @349 CURCODE  $3.
            @374 PRINBAL  PD6.2
            @392 LMATDATE PD6.;
  END;
RUN;
*;
DATA FCYFD;
   DROP LMDATES LMMM LMDD LMYY;
   SET FCYFD;
   IF LMATDATE > 0 THEN DO;
      LMDATES=INPUT(SUBSTR(PUT(LMATDATE,Z11.),1,8),MMDDYY8.);
      LMMM=MONTH(LMDATES);
      LMDD=DAY  (LMDATES);
      LMYY=YEAR (LMDATES);
      IF RENEWAL='N' AND (LMDATES=&XDATE) THEN
         MATDATE=PUT(LMYY,Z4.)||PUT(LMMM,Z2.)||PUT(LMDD,Z2.);
  END;
*;
DATA MNITBFD(KEEP=ACCTNO SECTOR PURPOSE);
     SET MNITB.FD;
RUN;
*;
PROC SORT DATA=FCYFD;
     BY ACCTNO;
*;
PROC SORT DATA=MNITBFD;
     BY ACCTNO;
*;
DATA FCYFD&REPTMON;
     MERGE FCYFD(IN=A) MNITBFD;
     BY ACCTNO;
     IF A;
RUN;
*;
DATA FCYFD&REPTMON;
     SET FCYFD&REPTMON;
     PURPOSE1 = SECTOR;
     WHERE PRODUCT IN &FCY;
        FORBAL = CURBAL;
        MATUREDT = INPUT(PUT(MATDATE,Z8.),YYMMDD8.);
        STARTDAT = INPUT(SUBSTR(PUT(ORGDATE,Z9.),1,6),MMDDYY6.);
        IF CURCODE NE 'MYR' THEN DO;
           FORATE = PUT(CURCODE,$FORATE.);
           CURBAL = ROUND(CURBAL * FORATE,.01);
        END;
        CURBALUS = CURBAL / PUT('USD',$FORATE.);
        CUSTCD = PUT(CUSTCODE,FDCUSTCD.);
        IF CUSTCD IN ('77','78','95','96') THEN DO;
           IF SECTOR IN (4,5) OR 40<=SECTOR<=59 THEN SECTORX = 1;
           ELSE IF NOT (10<=SECTOR<=59) OR (SECTOR NOT IN (1,2,3,4,5))
              THEN SECTORX = 1;
        END;
        ELSE DO;
           IF SECTOR IN (4,5) OR 40<=SECTOR<=59 THEN SECTORX = 1;
           ELSE IF NOT (10<=SECTOR<=59) OR (SECTOR NOT IN (1,2,3,4,5))
              THEN SECTORX = 1;
        END;
        IF OPENIND IN ('B','C','P') THEN DO;
           CLOSEDAT = INPUT(SUBSTR(PUT(LASTACTV,Z9.),1,6),MMDDYY6.);
           IF CLOSEDAT > INPUT('01'||PUT(MONTH(TODAY()), Z2.)||
                   PUT(YEAR(TODAY()), 4.), DDMMYY8.)-1 THEN OUTPUT;
        END;
     ELSE OUTPUT;
RUN;
