PROC FORMAT;
  VALUE FDXRGMT
   LOW - 1   = 'A)  1 MONTH     '
     1 - 2   = 'B) >1 - 2 MTHS  '
     2 - 3   = 'C) >2 - 3 MTHS  '
     3 - 6   = 'D) >3 - 6 MTHS  '
     6 - 9   = 'E) >6 - 9 MTHS  '
     9 - 12  = 'F) >9 - 12 MTHS '
    12 - 15  = 'G) >12 - 15 MTHS'
    15 - 18  = 'H) >15 - 18 MTHS'
    18 - 24  = 'I) >18 - 24 MTHS'
    24 - 36  = 'J) >24 - 36 MTHS'
    36 - 48  = 'K) >36 - 48 MTHS'
    48 - 60  = 'L) >48 - 60 MTHS'
    60 - HIGH ='M) > 60 MTHS    ';

   VALUE FDXMMT
     LOW - 0    = 'A) OVERDUE      '
     0   - 1    = 'B) <= 1 MTH     '
     1   - 2    = 'C) > 1 - 2 MTHS '
     2   - 3    = 'D) > 2 - 3 MTHS '
     3   - 6    = 'E) > 3 - 6 MTHS '
     6   - 9    = 'F) > 6 - 9 MTHS '
     9   - 12   = 'G) > 9 - 12 MTHS'
     12  - 24   = 'H) > 1 - 2 YEARS'
     24  - 36   = 'I) > 2 - 3 YEARS'
     36  - 48   = 'J) > 3 - 4 YEARS'
     48  - 60   = 'K) > 4 - 5 YEARS'
     60  - HIGH = 'L) > 5 YEARS    ';
%MACRO DCLVAR;
   RETAIN RD1-RD12 FD1-FD12 31 RD2 FD2 28 RD4 RD6 RD9 RD11
          FD4 FD6 FD9 FD11 30 RPYR RPMTH RPDAY;
   ARRAY RPDAYS RD1-RD12;
   ARRAY FDDAYS FD1-FD12;
%MEND DCLVAR;
*;
%MACRO REMMTH;
   FDYR  = YEAR(FDDATE);
   FDMTH = MONTH(FDDATE);
   FDDAY = DAY(FDDATE);
   IF FDMTH = 2 THEN
      IF MOD(FDYR,4) = 0 THEN FD2 = 29;
      ELSE FD2 = 28;
   IF FDDAY > RPDAYS(RPMTH) THEN FDDAY=RPDAYS(RPMTH);
   REMY = FDYR - RPYR;
   REMM = FDMTH - RPMTH;
   REMD = FDDAY - RPDAY;
   REMMTH = REMY*12 + REMM + REMD/RPDAYS(RPMTH);
%MEND REMMTH;

DATA ALM;
   FORMAT ORGMM ORGYY 2.;
   %DCLVAR;
   SET ALM;
   IF _N_ = 1 THEN DO;
      REPTDATE = INPUT("&RDATE",DDMMYY8.);
      RPYR  = YEAR(REPTDATE);
      RPMTH = MONTH(REPTDATE);
      RPDAY = DAY(REPTDATE);
      IF RPMTH = 2 THEN
         IF MOD(RPYR,4) = 0 THEN RD2 = 29;
         ELSE RD2 = 28;
   END;
      FDDATE = INPUT(PUT(MATDATE,Z8.),YYMMDD8.);
      %REMMTH;
   /*
   OM=INPUT(INTPLAN, FCYTERM.);
   RM=PUT(REMMTH,FDRMMT.);
   */
   RM=PUT(REMMTH,FDXMMT.);

   LMMM=SUBSTR(LMATDATE,2,2);
   LMYY=SUBSTR(LMATDATE,6,4);
   MATMM=MONTH(MATUREDT);
   MATYY=YEAR (MATUREDT);
   ORGMM=SUBSTR(ORGDATE,4,2);
   ORGYY=SUBSTR(ORGDATE,8,2);
   ORGYR=2000+ORGYY;
   IF LMATDATE=0 OR (LMMM=MATMM AND LMYY=MATYY) THEN DO;
      YRM=(MATYY-ORGYR)*12+MATMM;
      OM1=YRM-ORGMM;
   END;
   ELSE DO;
      YRM=(MATYY-LMYY)*12+MATMM;
      OM1=YRM-LMMM;
   END;

   OM=PUT(OM1,FDXRGMT.);
RUN;
*;
