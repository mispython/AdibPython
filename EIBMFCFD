   CURBALRM = CURBAL;
   CLASSIFI = PURPOSE;
   IF CUSTCD IN ('80','81','82','83','84',
      '85','86','90','91','92','95','96','98','99') THEN RESIDIND = 'N';
   ELSE RESIDIND = 'R';
   IF RESIDIND NE 'N' THEN DO;
      IF (SECTOR IN (1,2,3) OR 10<=SECTOR<=39 OR SECTORX=1)
         AND CUSTCD IN ('77','78') THEN CATEGORY = 'INDIVIDUAL';
      ELSE IF (SECTOR IN (4,5) OR 40<=SECTOR<=59 OR SECTORX=4) AND
      CUSTCD NOT IN ('77','78') THEN CATEGORY = 'COMPANIES ';
   END;
   ELSE DO;
      IF (SECTOR IN (1,2,3) OR 10<=SECTOR<=39 OR SECTORX=1)
          AND CUSTCD IN ('95','96') THEN
         CATEGORY = 'INDIVIDUAL';
      ELSE IF (SECTOR IN (4,5) OR 40<=SECTOR<=59 OR SECTORX=4) AND
         CUSTCD NOT IN ('95','96') THEN CATEGORY = 'COMPANIES ';
   END;
