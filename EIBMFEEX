//*                                                                             
//SAS609   EXEC SAS609,REGION=8M,WORK='240000,240000'                           
//FEEFILE  DD DSN=RBP2.B033.NFEEFILE(0),DISP=SHR                                
//FEEFILEM DD DSN=RBP2.B033.NFEEFILE.MTHEND(0),DISP=SHR                         
//ACCTFILE DD DSN=RBP2.SAS.B033.ACCTFILE,DISP=SHR                               
//BFEEFILE DD DSN=RBP2.SAS.B033.BFEEFILE,DISP=SHR                               
//LOAN     DD DSN=SAP.PBB.MNIFEE(+1),DISP=(NEW,CATLG,DELETE),                   
//            DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),                         
//            SPACE=(CYL,(300,200),RLSE),UNIT=(SYSDA,5)                         
//ILOAN    DD DSN=SAP.PIBB.MNIFEE(+1),DISP=(NEW,CATLG,DELETE),                  
//            DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),                         
//            SPACE=(CYL,(300,200),RLSE),UNIT=(SYSDA,5)                         
//FEE      DD DSN=&&TEMPFEE,                                                    
//            DISP=(NEW,CATLG,DELETE),                                          
//            DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),                         
//            SPACE=(CYL,(300,200),RLSE),UNIT=(SYSDA,5)                         
//IFEE      DD DSN=&&TEMPIFEE,                                                  
//            DISP=(NEW,CATLG,DELETE),                                          
//            DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),                         
//            SPACE=(CYL,(300,200),RLSE),UNIT=(SYSDA,5)                         
//SORTWK01 DD UNIT=SYSDA,SPACE=(CYL,(200,200))                                  
//SORTWK02 DD UNIT=SYSDA,SPACE=(CYL,(200,200))                                  
//SORTWK03 DD UNIT=SYSDA,SPACE=(CYL,(200,200))                                  
//SORTWK04 DD UNIT=SYSDA,SPACE=(CYL,(200,200))                                  
//SORTWK05 DD UNIT=SYSDA,SPACE=(CYL,(200,200))                                  
//SYSIN    DD *                                                                 
                                                                                
OPTIONS NOCENTER YEARCUTOFF=1950 LS=132;                                        
                                                                                
DATA LOAN.REPTDATE                                                              
     FEE.REPTDATE                                                               
     ILOAN.REPTDATE                                                             
     IFEE.REPTDATE;                                                             
   KEEP REPTDATE;                                                               
   DTE = TODAY();                                                               
   DD = DAY(DTE); MM = MONTH(DTE); YY = YEAR(DTE);                              
   SELECT;                                                                      
      WHEN (DD <  8) REPTDATE = MDY(MM,1,YY) - 1;                               
      WHEN (DD < 15) REPTDATE = MDY(MM,8,YY);                                   
      WHEN (DD < 22) REPTDATE = MDY(MM,15,YY);                                  
      OTHERWISE REPTDATE = MDY(MM,22,YY);                                       
   END;                                                                         
   SELECT(DAY(REPTDATE));                                                       
     WHEN (8)  DO; SDD = 1;  WK = '1'; WK1 = '4'; END;                          
     WHEN(15)  DO; SDD = 9;  WK = '2'; WK1 = '1'; END;                          
     WHEN(22)  DO; SDD = 16; WK = '3'; WK1 = '2'; END;                          
     OTHERWISE DO; SDD = 23; WK = '4'; WK1 = '3'; END;                          
   END;                                                                         
   MM = MONTH(REPTDATE);                                                        
   IF WK = '1' THEN DO;                                                         
      MM1 = MM - 1;                                                             
      IF MM1 = 0 THEN MM1 = 12;                                                 
   END;                                                                         
   ELSE MM1 = MM;                                                               
   SDATE = MDY(MM,SDD,YEAR(REPTDATE));                                          
   IF   WK = '4' THEN FLNAME = 'FEEFILEM'; /* MONTH-END ONLY */                 
   ELSE               FLNAME = 'FEEFILE ';                                      
   CALL SYMPUT('FILENM',FLNAME);                                                
   CALL SYMPUT('NOWK',PUT('4',$1.));                                            
   CALL SYMPUT('REPTMON',PUT(MM,Z2.));                                          
   CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));                                
   CALL SYMPUT('RDATE',REPTDATE);                                               
RUN;                                                                            
*;                                                                              
