   INFILE &FILENM;                                                              
   INPUT @001 ACCTNO    PD6.                                                    
         @007 NOTENO    PD3.                                                    
         @010 LOANTYPE  PD2.                                                    
         @012 NTBRCH    PD4.                                                    
         @016 COSTCTR   PD4.                                                    
         @020 PAIDIND    $1.                                                    
         @021 REVERSED   $1.                                                    
         @022 FEEPLAN    $2.                                                    
         @024 FEENO     PD2.                                                    
         @026 FEEDEL     $1.                                                    
         @027 STOPIND    $1.                                                    
         @028 NEWTODAY   $1.                                                    
         @029 NEWPRD     $1.                                                    
         @030 AUTOWAIV   $1.                                                    
         @031 FEETYPE    $1.                                                    
         @032 FEECAT     $2.                                                    
         @034 FEEBASIS    1.                                                    
         @035 ASSESCUR  PD8.2                                                   
         @043 ASSESYTD  PD8.2                                                   
         @051 ORIASSES  PD8.2                                                   
         @059 WAIVEYTD  PD8.2                                                   
         @067 DUECURR   PD8.2                                                   
         @075 DUETOTAL  PD8.2                                                   
         @083 PAIDYTD   PD8.2                                                   
         @091 ASSESMTD  PD8.2                                                   
         @099 WAIVEMTD  PD8.2                                                   
         @107 PAIDMTD   PD8.2                                                   
         @115 ASSESTRT  PD6.                                                    
         @121 ASSESEND  PD6.                                                    
         @127 EARNDYTD  PD8.2                                                   
         @135 EARNDMTD  PD8.2                                                   
         @143 EARNDLTD  PD8.2                                                   
         @151 PRIUNERN  PD8.2                                                   
         @159 CURUNERN  PD8.2                                                   
         @167 NEXUNERN  PD8.2                                                   
         @175 BEGBAL    PD8.2                                                   
         @183 PTDNONAC  PD8.2                                                   
         @191 RATEONE   PD8.2;                                                  
RUN;                                                                            
PROC SORT DATA=LNFEE&REPTMON&NOWK&REPTYEAR;BY FEEPLAN;RUN;                      
                                                                                
DATA NEWFPLAN(DROP=DD MM YY EFFDATE);                                           
   INFILE BFEEFILE;                                                             
   INPUT @001 FEEPLAN   $2.                                                     
         @016 EFFDATE  PD6.                                                     
         @066 BFEEBASIS $1.;                                                    
   FEEBASIS = BFEEBASIS*1;                                                      
   IF EFFDATE GT 0 THEN DO;                                                     
      DD=SUBSTR(PUT(EFFDATE,Z11.),3,2);                                         
      MM=SUBSTR(PUT(EFFDATE,Z11.),1,2);                                         
      YY=SUBSTR(PUT(EFFDATE,Z11.),5,4);                                         
   END;                                                                         
   EFFDT=MDY(MM,DD,YY);                                                         
   IF EFFDT < &RDATE;                                                           
RUN;                                                                            
PROC SORT DATA=NEWFPLAN;BY FEEPLAN DESCENDING EFFDT;RUN;                        
PROC SORT DATA=NEWFPLAN NODUPKEYS;BY FEEPLAN;RUN;                               
                                                                                
DATA LNFEE&REPTMON&NOWK&REPTYEAR;                                               
     MERGE LNFEE&REPTMON&NOWK&REPTYEAR(IN=A DROP=FEEBASIS)                      
           NEWFPLAN(IN=B DROP=BFEEBASIS);                                       
     BY FEEPLAN;                                                                
     IF A;                                                                      
RUN;                                                                            
                                                                                
