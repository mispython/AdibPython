   CURRBAL = BALANCE - ACCRUAL;
   ISSDTE = INPUT(SUBSTR(PUT(ISSUEDT,Z11.),1,8),MMDDYY8.);
   CENSUS7 = SUBSTR(PUT(CENSUS,8.2),7,1);
   %SPRO

   IF LOANTYPE IN (320,330,364,505,506) OR
