DATA NPL.TOTIIS&REPTMON;
   MERGE NPL.IIS&REPTMON (IN=A) LNNOTE PRVNPL;
   BY ACCTNO NOTENO;
   IF A;
   FORMAT CLASSNEW $3.;
   REPTDATE = &REPTDAT;
   /* KEEP ACCTNO NOTENO NTBRCH NAME LOANTYPE CLASSOLD AGE CLASSNEW
        OUTSTBAL OPENBAL IIS IISR IISW CLOSEBAL NPLIND AGEING; */
   CLASSOLD = ' ';
   IF BLDATE > 0 THEN AGEING = REPTDATE - BLDATE;
   IF OLDNOTEDAYARR > 0 AND 98000<=NOTENO<=98999 THEN DO;
      IF AGEING < 0 THEN AGEING = 0;
      AGEING = SUM(AGEING,OLDNOTEDAYARR);
   END;
   IF RISKRATE NE ' ' THEN CLASSNEW = PUT(RISKRATE,$RISKFMT.);
   ELSE CLASSNEW = ' ';
   BRANCH = PUT(NTBRCH,Z3.)||' '||PUT(NTBRCH,BRCHCD.);
   DIFFBAL = SUM(PREVBAL,(-1)*CURBAL,(-1)*SPWOF,(-1)*IISW,(-1)*ADJUST);
   IISP = PREVIIS;
   OIP = PREVOI;

   IF NPLIND IN ('O','P')
      THEN IIS = SUM(IISR,IISW,(-1)*IISP);
   IF LOANTYPE IN (517,521,522,523,528) AND NPLIND = 'N' AND
      LSTTRNCD = 166 THEN LSTTRNAM = LSTTRNAM / 100000;
   ELSE LSTTRNAM = 0;
   IF NTINT = 'A' THEN DO;
      IF IISCLS NE . THEN IISP = SUM(IISCLS,(-1)*OIP);
      IF NPLIND IN ('O','P') THEN IIS = SUM(IISR,IISW,(-1)*IISP);
      IIS = ADONIIS;
      OI = FEEASSES - FEEWAIVE;
      IF OI < 0 THEN OI = 0;
      OIREC = FEEPAY;
      IF BORSTAT IN ('W','X') AND NPLIND NE 'P' THEN DO;
         IIS = 0;
         OI = FEELWTOT;
      *  OIREC = OIP;
      END;
      IF NPLIND = 'E' & BORSTAT = 'P' OR LSTTRNCD = 652 THEN IISR = 0;
      ELSE IF LOANSTAT = 1 OR DIFFBAL >= IISP THEN
         IISR = SUM(IISP,(-1)*IISW);
      ELSE IF DIFFBAL < IISP THEN IISR = SUM(DIFFBAL,(-1)*IISW);
      IF NPLIND = 'O' THEN DO;
       *  IISR = SUM(IISP,(-1)*IISW);
         IIS = 0;
         OIREC = SUM(FEEPAY,FEELWTOT);
      END;
      IF IISR < 0 THEN IISR = 0;
      IF NPLIND = 'P' THEN DO;
       *  IISR = SUM(IISR,IIS);
         IIS = SUM(IIS,IISR,IISW,(-1)*IISP);
      END;
      IISCLOSE = SUM(IISP,IIS,(-1)*IISR,(-1)*IISW);
      IF IISCLOSE < 0 THEN IISCLOSE = 0;
      IF NPLIND = 'O' THEN OICLOSE = 0;
      ELSE OICLOSE = FEELWTOT;
      TOTOPEN = SUM(IISP,OIP);
      TOTIIS = SUM(IIS,OI);
      TOTIISR = SUM(IISR,OIREC);
      TOTWOF  = SUM(IISW);
      IF NPLIND = 'N' THEN DO;
         TOTIIS = SUM(IISCLOSE,TOTIISR,TOTWOF);
         TOTOPEN = 0;
      END;
      TOTCLOSE = SUM(IISCLOSE,OICLOSE);
      IF BORSTAT IN ('W','X') AND NPLIND NE 'P' THEN
         TOTCLOSE = SUM(TOTOPEN,(-1)*TOTIISR,(-1)*TOTWOF);
   END;
   ELSE DO;
      IF NPLIND = 'O' THEN DO;
        IF ACTIACCR = 0 THEN DO;
          IF INTACTIV < 0 THEN IISR = SUM(IISR,FEELWTOT,(-1)*INTACTIV);
          ELSE IISR = SUM(IISR,FEELWTOT);
          IIS = SUM(IISR,IISW,(-1)*IISP);
      *   IIS = SUM(IIS,FEELWTOT);
        END;
        ELSE DO;
          IIS =  SUM(IISR,IISW,ACTIACCR,(-1)*IISP); ;
          OIREC = SUM(FEEPAY,FEELWTOT);
        END;
      END;
      TOTOPEN = IISP;
      TOTIISR = IISR;
      TOTWOF = IISW;
      TOTIIS = IIS;
      IF NPLIND = 'N' THEN DO;
         TOTIIS = SUM(IISCLOSE,TOTIISR,TOTWOF);
         TOTOPEN = 0;
      END;
      IF NPLIND = 'O' THEN TOTCLOSE = SUM(IISP,IIS,(-1)*IISR,(-1)*IISW);
      ELSE TOTCLOSE = IISCLOSE;
   END;
