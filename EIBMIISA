%MACRO SPRO;
   IF DLIVRYDT NE 0 THEN
     LASTUPDT = INPUT(SUBSTR(PUT(DLIVRYDT,Z11.),1,8),MMDDYY8.);
   ELSE IF APPRDATE NE 0 THEN
     LASTUPDT = INPUT(SUBSTR(PUT(APPRDATE,Z11.),1,8),MMDDYY8.);
   ELSE LASTUPDT = ISSDTE;
IF FLAG1 = 'F' THEN DO;
 /* IF LIABCODE IN ('D1','D2','D3','D4','D5','D6','D7') THEN DO; */
   IF LIABCODE IN ('50','C2') THEN DO;
      IF MARKETVL > 0 AND APPVALUE > 0 THEN DO;
         IF MARKETVL = APPVALUE THEN DO;
            REALISVL = MARKETVL;
            IF (REPTDATE - LASTUPDT) >= 730 THEN DO;
               IF LIABCODE = '50' THEN
                  REALISVL = REALISVL - (REALISVL * 0.1);
               ELSE REALISVL = REALISVL - (REALISVL * 0.2);
            END;
         END;
         IF MARKETVL NE APPVALUE THEN DO;;
            IF DLIVRYDT > 0 THEN REALISVL = MARKETVL;
            ELSE DO;
               IF MARKETVL < APPVALUE THEN REALISVL = MARKETVL;
               ELSE REALISVL = APPVALUE;
            END;
            IF (REPTDATE - LASTUPDT) >= 730 THEN DO;
               IF LIABCODE = '50' THEN
                  REALISVL = REALISVL - (REALISVL * 0.1);
               ELSE REALISVL = REALISVL - (REALISVL * 0.2);
            END;
         END;
      END;

      IF MARKETVL > 0 AND APPVALUE = 0 THEN DO;
         REALISVL = MARKETVL;
         IF (REPTDATE - LASTUPDT) >= 730 THEN DO;
            IF LIABCODE = '50' THEN
               REALISVL = REALISVL - (REALISVL * 0.1);
            ELSE REALISVL = REALISVL - (REALISVL * 0.2);
         END;
      END;
      IF MARKETVL = 0 AND APPVALUE > 0 THEN DO;
         REALISVL = APPVALUE;
         IF (REPTDATE - LASTUPDT) >= 730 THEN DO;
            IF LIABCODE = '50' THEN
               REALISVL = REALISVL - (REALISVL * 0.1);
            ELSE REALISVL = REALISVL - (REALISVL * 0.2);
         END;
      END;
   END;
 ELSE IF
 /* LIABCODE IN ('C1','C2','C3','C4','C5','C6','C7','C8','C9') THEN DO;
   */
     LIABCODE IN ('B8','B9','33','37','34','32','C1') THEN DO;
      IF MARKETVL > 0 AND APPVALUE > 0 THEN DO;
         IF MARKETVL = APPVALUE THEN DO;
            REALISVL = MARKETVL;
            IF (REPTDATE - LASTUPDT) >= 730 THEN
               REALISVL = REALISVL - (REALISVL * 0.25);
         END;
         IF MARKETVL NE APPVALUE THEN DO;;
            IF DLIVRYDT > 0 THEN REALISVL = MARKETVL;
            ELSE DO;
               IF MARKETVL < APPVALUE THEN REALISVL = MARKETVL;
               ELSE REALISVL = APPVALUE;
            END;
            IF (REPTDATE - LASTUPDT) >= 730 THEN
               REALISVL = REALISVL - (REALISVL * 0.25);
         END;
      END;

      IF MARKETVL > 0 AND APPVALUE = 0 THEN DO;
         REALISVL = MARKETVL;
         IF (REPTDATE - LASTUPDT) >= 730 THEN
            REALISVL = REALISVL - (REALISVL * 0.25);
      END;
      IF MARKETVL = 0 AND APPVALUE > 0 THEN DO;
         REALISVL = APPVALUE;
         IF (REPTDATE - LASTUPDT) >= 730 THEN
            REALISVL = REALISVL - (REALISVL * 0.25);
      END;
   END;
   ELSE DO REALISVL = MARKETVL;
           IF LOANTYPE IN (300,301) THEN DO;
              IF (REPTDATE - LASTUPDT) >= 730 THEN
                 REALISVL = REALISVL - (REALISVL * 0.1);
           END;
   END;
END;
IF FLAG1 IN ('P','I') THEN DO;
  /*  IF LIABCODE IN ('D1','D2','D3','D4','D5','D6','D7') THEN DO; */
      IF LIABCODE IN ('50','C2') THEN DO;
      IF UNDRAWN > 0 THEN DO;
      IF APPRDATE NE 0 THEN
         APPRDT = INPUT(SUBSTR(PUT(APPRDATE,Z11.),1,8),MMDDYY8.);
      ELSE APPRDT = 0;
      IF (REPTDATE - APPRDT) <= 730 THEN
      /* REALISVL = APPVALUE - UNDRAWN; SMR A503 */
         REALISVL = CUSEDAMT;
      ELSE DO;
         IF LIABCODE = '50' THEN
         /*   REALISVL=APPVALUE - UNDRAWN -((APPVALUE - UNDRAWN) * 0.1);
         ELSE REALISVL=APPVALUE - UNDRAWN -((APPVALUE - UNDRAWN) * 0.2);
         SMR-A503 */
              REALISVL=CUSEDAMT - (CUSEDAMT * 0.1);
         ELSE REALISVL=CUSEDAMT - (CUSEDAMT * 0.2);
      END;
      END;
      ELSE DO;
         IF MARKETVL > 0 THEN DO REALISVL = MARKETVL;
             IF (REPTDATE - LASTUPDT) >= 730 THEN DO;
                IF LIABCODE = '50' THEN
                   REALISVL = REALISVL - (REALISVL * 0.1);
                ELSE REALISVL = REALISVL - (REALISVL * 0.2);
             END;
         END;
         ELSE DO REALISVL = APPVALUE;
            IF (REPTDATE - LASTUPDT) >= 730 THEN DO;
               IF LIABCODE = '50' THEN
                  REALISVL = REALISVL - (REALISVL * 0.1);
               ELSE REALISVL = REALISVL - (REALISVL * 0.2);
            END;
         END;
       END;
   END;
   ELSE DO REALISVL = MARKETVL;
           IF LOANTYPE IN (300,301) THEN DO;
              IF (REPTDATE - LASTUPDT) >= 730 THEN
                 REALISVL = REALISVL - (REALISVL * 0.1);
           END;
   END;
END;
   IF LOANTYPE = 521 THEN REALISVL = CURRBAL;
   IF BORSTAT = 'F' THEN REALISVL = 0;
%MEND;
