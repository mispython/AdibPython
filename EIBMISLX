//EIBMISLX JOB MSGCLASS=X,MSGLEVEL=(1,1),REGION=8M                      JOB34042
//*
//* BEFORE EIBMISLM.
//*
//DELETE  EXEC PGM=IEFBR14
//DEL01    DD DSN=SAP.PIBB.ISLM.SASDATA.BKUP,
//            DISP=(MOD,DELETE,DELETE),
//            SPACE=(CYL,(0))
//*
//COPYFILE EXEC PGM=ICEGENER
//SYSPRINT DD SYSOUT=*
//SYSUT1   DD DISP=SHR,DSN=SAP.PIBB.ISLM.SASDATA
//SYSUT2   DD DSN=SAP.PIBB.ISLM.SASDATA.BKUP,
//            DISP=(NEW,CATLG,DELETE),
//            UNIT=SYSDA,LIKE=SAP.PIBB.ISLM.SASDATA
//SYSIN    DD DUMMY
//*
//EIBMISLX EXEC SAS609
//DEP       DD DSN=SAP.PIBB.MNITB(-5),DISP=SHR
//ISLM      DD DSN=SAP.PIBB.ISLM.SASDATA,DISP=OLD
//PGM       DD DSN=SAP.BNM.PROGRAM,DISP=SHR
//SASLIST   DD SYSOUT=X
//SYSIN     DD *

OPTIONS YEARCUTOFF=1930 NOCENTER;
DATA REPTDATE;
  SET DEP.REPTDATE;
  MM = MONTH(REPTDATE);
  MM1= MM+1;
  IF MM=12 THEN MM1=01;
  XDATE=TODAY();
  XMON=MONTH(XDATE);
  CALL SYMPUT('REPTMON', PUT(MM1,Z2.));
  CALL SYMPUT('EDATE', PUT(REPTDATE,Z5.));
  CALL SYMPUT('XMON', PUT(XMON,Z2.));
RUN;

            DATA DYIBU; SET  ISLM.DYIBU&REPTMON;
                 IF REPTDATE > &EDATE;

            DATA ALWSA; SET  ISLM.AWSA&REPTMON;
                 IF REPTDATE > &EDATE;

            DATA ALWSB; SET  ISLM.AWSB&REPTMON;
                 IF REPTDATE > &EDATE;

            DATA ALWSC; SET  ISLM.AWSC&REPTMON;
                 IF REPTDATE > &EDATE;

            DATA ALWCA; SET  ISLM.AWCA&REPTMON;
                 IF REPTDATE > &EDATE;

            DATA ALWCB; SET  ISLM.AWCB&REPTMON;
                 IF REPTDATE > &EDATE;

            DATA MUDHA; SET  ISLM.MUDH&REPTMON;
                 IF REPTDATE > &EDATE;

*;
DATA ISLM.DYIBU&REPTMON; SET DYIBU;
DATA ISLM.AWSA&REPTMON;  SET ALWSA;
DATA ISLM.AWSB&REPTMON;  SET ALWSB;
DATA ISLM.AWSC&REPTMON;  SET ALWSC;
DATA ISLM.AWCA&REPTMON;  SET ALWCA;
DATA ISLM.AWCB&REPTMON;  SET ALWCB;
DATA ISLM.MUDH&REPTMON;  SET MUDHA;
*;
   /*
PROC DATASETS LIB=ISLM NOLIST;
   DELETE DYIBU&XMON
          AWSA&XMON
          AWSB&XMON
          AWSC&XMON
          AWCA&XMON
          AWCB&XMON
          MUDH&XMON;
   */
RUN;
