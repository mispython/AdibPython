OPTIONS YEARCUTOFF=1950 NOCENTER;
DATA REPTDATE;
   REPTDATE = TODAY()-1;
   PREVDATE = REPTDATE-1;
  CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));
  CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
  CALL SYMPUT('REPTDAY', PUT(DAY(REPTDATE), Z2.));
  CALL SYMPUT('REPTYEAR1',PUT(PREVDATE,YEAR2.));
  CALL SYMPUT('REPTMON1',PUT(MONTH(PREVDATE),Z2.));
  CALL SYMPUT('REPTDAY1', PUT(DAY(PREVDATE), Z2.));
  CALL SYMPUT('RDATE', REPTDATE);
RUN;

DATA SUMM1;
  INFILE FILE1 DELIMITER=',' MISSOVER DSD LRECL=4500 FIRSTOBS=2 END=EOF;
  INPUT MAANO               : $15.      /*MAANO                     */
        STAGE               : $2.        /*STAGE                     */
        APPLICATION         : $10.       /*APPLICATION               */
        DTECOMPLETE         : $10.       /*DATE COMPLETED            */
        AANO                : $15.       /*AANO                      */
        APPKEY              : $20.       /*APP KEY                   */
        PRIORITY_SECTOR     : $2.        /*PRIORITY SECTOR           */
        DSRISS3             : 10.        /*DEBT SERVICE RATIO        */
        FIN_CONCEPT         : $3.        /*FIN CONCEPT               */
        LN_UTILISE_LOCAT_CD : $10.       /*LOCATION                  */
        SPECIALFUND         : 5.         /*SPECIAL FUND              */
        ASSET_PURCH_AMT     : COMMA20.   /*ASSET PURCHASE            */
        PURPOSE_LOAN        : 5.         /* PURPOSE OF LOAN          */
        STRUPCO_3YR         : $2.        /*STARTUP FINANCING         */
        FACICODE            : 10.        /*FACILITY TYPE             */
        AMTAPPLY            : COMMA20.   /*AMOUNT                    */
        AMOUNT              : COMMA20.   /*AMT APPROVED              */
        APPTYPE             : $1.        /*APP TYPE                  */
        REJREASON           : $5.        /*REJECT REASON             */
        DATEXT              : $10.       /*DATE                      */
        ACCTNO              : 15.        /*ACCOUNT NUMBER            */
        EIR                 : 10.        /*EIR                       */
        EREQNO              : $15.       /*EREQNO                    */
        REFIN_FLG           : $3.        /*refinancing               */
        STATUS              : $1.        /*STATUS                    */
        CCPT_TAG            : $5.
        CIR                 : 10.
        PRICING_TYPE        : $5.
        LU_ADD1             : $40.
        LU_ADD2             : $40.
        LU_ADD3             : $40.
        LU_ADD4             : $40.
        LU_TOWN_CITY        : $20.
        LU_POSTCODE         : $5.
        LU_STATE_CD         : $2.
        LU_COUNTRY_CD       : $2.
        PROP_STATUS         : $5.
        DTCOMPLETE          : $25.
        LU_SOURCE           : $5.
        ;
        INDINTERIM = 'Y';
        DATE = &RDATE;
        IF NOT EOF THEN OUTPUT;
        /* RECORD CHECKSUM -1 EXCLUDE FT */
        IF EOF & SUBSTRN(MAANO,3,8) NE SUM(_N_,-1) THEN ABORT 77;
   RUN;

