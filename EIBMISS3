RUN;

%MACRO PROCESS1;
%IF %SYSFUNC(EXIST(ELDS.SUMM1&REPTYEAR&REPTMON&REPTDAY)) %THEN %DO;
   DATA ELDS.SUMM1&REPTYEAR&REPTMON&REPTDAY;
      SET ELDS.SUMM1&REPTYEAR&REPTMON&REPTDAY;
      IF DATE = &RDATE THEN DELETE;
   RUN;
%END;
%MEND;
%PROCESS1;

DATA ELDS.SUMM1&REPTYEAR&REPTMON&REPTDAY;
