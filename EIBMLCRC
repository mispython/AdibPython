//EIBMLCRC JOB MSGCLASS=X,MSGLEVEL=(1,1),REGION=64M,NOTIFY=&SYSUID
/*JOBPARM S=S1M1
//*--------------------------------------------------------------------
//* PROGRAM  : EIBMLCRC
//* ESMR     : 2015-894 (AAB)
//* DESC     : CREATE NEW REPORT FOR LIQUIDITY COVERAGE RATIO (LCR)
//*            OUTFLOW - TRANSACTIONAL/RELATIONSHIP/OPERATIONAL DEPOSIT
//*--------------------------------------------------------------------
//EIBMLCRC EXEC SAS609
//PGM      DD DSN=SAP.BNM.PROGRAM,DISP=SHR
//DP       DD DSN=SAP.PBB.MNITB(0),DISP=SHR
//IDP      DD DSN=SAP.PIBB.MNITB(0),DISP=SHR
//LN       DD DSN=SAP.PBB.SASDATA,DISP=SHR
//ILN      DD DSN=SAP.PIBB.SASDATA,DISP=SHR
//CRM      DD DSN=SAP.PBB.CRM.DPTRNSAC(0),DISP=SHR
//CISSAFD  DD DSN=SAP.PBB.CRM.CISBEXT,DISP=SHR
//CISCA    DD DSN=SAP.PBB.CISBEXT.DP,DISP=SHR
//CISLN    DD DSN=SAP.PBB.CISBEXT.LN,DISP=SHR
//CIS      DD DSN=RBP2.B033.CIS.CUST.DAILY,DISP=SHR
//SDB      DD DSN=SAP.PBB.SDBM.WEEK,DISP=SHR
//LCR      DD DSN=SAP.PBB.LCR.SASDATA,DISP=OLD
//ILCR     DD DSN=SAP.PIBB.LCR.SASDATA,DISP=OLD
//SASLIST  DD SYSOUT=X
//SORTWK01 DD UNIT=SYSDA,SPACE=(CYL,(1000))
//SORTWK02 DD UNIT=SYSDA,SPACE=(CYL,(1000))
//SORTWK03 DD UNIT=SYSDA,SPACE=(CYL,(1000))
//SORTWK04 DD UNIT=SYSDA,SPACE=(CYL,(1000))
//SYSIN    DD *

OPTIONS YEARCUTOFF=1960 NOCENTER NODATE NONUMBER MISSING=0;

DATA REPTDATE;
   SET DP.REPTDATE;
   CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('WEEKDAY',PUT(WEEKDAY(REPTDATE),1.));
   CALL SYMPUT('REPTDT',REPTDATE);
RUN;

 /* STEP 1 : PIDM AGGREGATION */

DATA CISEQ(RENAME=(CUSTNO=CISNO CUSTNAME=CISNAME));
   SET CIS.CUSTDLY;
   WHERE ACCTCODE = 'EQC' AND PRISEC=901;
   IF NEWIC = '' OR SUBSTR(NEWIC,1,5) IN ('99999') THEN
      ICNO  = COMPRESS(ALIASKEY||PUT(CUSTNO,20.));
   ELSE
      ICNO =  COMPRESS(ALIASKEY||ALIAS);
   KEEP ACCTNO CUSTNO PRISEC ALIASKEY ALIAS CUSTNAME ICNO;
RUN;
PROC SORT DATA=CISEQ OUT=LCR.CISEQ; BY ACCTNO; RUN;
PROC SORT DATA=CISEQ OUT=ILCR.CISEQ; BY ACCTNO; RUN;

DATA CISDP;
   SET CISCA.DEPOSIT CISSAFD.DEPOSIT;
   WHERE NOT (CACCCODE IN ('014','017','018','019','021') AND
              SECCUST = '902');
   IF NEWIC = '' OR SUBSTR(NEWIC,1,5) IN ('99999') THEN
      ICNO  = COMPRESS(NEWICIND||PUT(CUSTNO,20.));
   ELSE
      ICNO =  COMPRESS(NEWICIND||NEWIC);
   CNT = 1;
   KEEP ACCTNO CUSTNO SECCUST NEWICIND NEWIC CUSTNAME ICNO CNT;
RUN;
PROC SORT DATA=CISDP; BY ACCTNO; RUN;

PROC SUMMARY DATA=CISDP NWAY;
   BY ACCTNO;
   VAR CNT;
   OUTPUT OUT=CISICNO(DROP=_FREQ_ _TYPE_) SUM=CNTIC;
RUN;

DATA CISICNO;
   MERGE CISICNO(IN=A) CISDP(KEEP=ACCTNO ICNO CUSTNAME);
   BY ACCTNO;
   IF A;
RUN;
PROC SORT DATA=CISICNO; BY ACCTNO CNTIC; RUN;

PROC TRANSPOSE DATA=CISICNO OUT=TRNSCISIC NAME=SOURCE;
   BY ACCTNO CNTIC;
   VAR ICNO;
RUN;
PROC DATASETS LIB=WORK NOLIST;
   DELETE CISICNO;
RUN;
DATA TRNSCISIC(KEEP=ACCTNO CNTIC ICGRP);
   SET TRNSCISIC;
   FORMAT ICGRP $400.;
   ARRAY COL{25};
   ICGRP = '';
   DO I = 1 TO CNTIC;
      IF   I = 1 THEN ICGRP = COMPRESS(COL{I});
      ELSE            ICGRP = COMPRESS(ICGRP||","||COMPRESS(COL{I}));
   END;
RUN;
PROC SORT DATA=TRNSCISIC; BY ACCTNO; RUN;

PROC SORT DATA=CISDP; BY ICNO; RUN;
PROC SUMMARY DATA=CISDP NWAY;
   WHERE SECCUST = '901';
   BY ICNO;
   VAR CNT;
   OUTPUT OUT=CISDPACC(DROP=_FREQ_ _TYPE_) SUM=CNTDPACC;
RUN;

DATA CISLN;
   SET CISLN.LOAN;
   WHERE NOT (CACCCODE IN ('014','017','018','019','021') AND
              SECCUST = '902');
   IF NEWIC = '' OR SUBSTR(NEWIC,1,5) IN ('99999') THEN
      ICNO  = COMPRESS(NEWICIND||PUT(CUSTNO,20.));
   ELSE
      ICNO =  COMPRESS(NEWICIND||NEWIC);
   CNT = 1;
   KEEP ACCTNO CUSTNO SECCUST NEWICIND NEWIC CUSTNAME ICNO CNT;
RUN;
PROC SORT; BY ACCTNO; RUN;

DATA LNACC;
   SET LN.LOAN&REPTMON.4
       LN.LNWOF&REPTMON.4;
   WHERE NOT (3000000000<=ACCTNO<=3999999999) AND BRANCH ^= 998 AND
         PAIDIND NOT IN ('P','C') AND PRODUCT NOT IN (199,983) AND
         YRDIF(ISSDTE,TODAY()-DAY(TODAY()),'ACT/ACT')*12 >= 12;
   KEEP ACCTNO;
RUN;
PROC SORT NODUPKEY; BY ACCTNO; RUN;

DATA LNACC;
   MERGE CISLN(IN=A) LNACC(IN=B);
   BY ACCTNO;
   IF A AND B;
RUN;
PROC SORT DATA=LNACC; BY ICNO; RUN;

PROC SUMMARY DATA=LNACC NWAY;
   WHERE SECCUST = '901';
   BY ICNO;
   VAR CNT;
   OUTPUT OUT=CISLNACC(DROP=_FREQ_ _TYPE_) SUM=CNTLNACC;
RUN;

DATA COMBINELNDP;
   MERGE CISLNACC CISDPACC(IN=A) CISDP(KEEP=ICNO ACCTNO SECCUST);
   BY ICNO;
   IF A;
   IF  CNTDPACC >= 1 AND CNTLNACC >= 1 THEN SIGN = 'R ';
   ELSE                                     SIGN = 'NR';
   IF SECCUST = '901';
RUN;
PROC SORT DATA=COMBINELNDP; BY ACCTNO; RUN;

DATA TRNSCISIC;
   MERGE TRNSCISIC(IN=A) COMBINELNDP;
   BY ACCTNO;
   IF A;
   KEEP ACCTNO ICGRP CNTIC SIGN;
RUN;

DATA ILNACC;
   SET ILN.LOAN&REPTMON.4
       ILN.LNWOF&REPTMON.4;
   WHERE NOT (3000000000<=ACCTNO<=3999999999) AND BRANCH ^= 998 AND
         PAIDIND NOT IN ('P','C') AND PRODUCT NOT IN (199,983) AND
         YRDIF(ISSDTE,TODAY()-DAY(TODAY()),'ACT/ACT')*12 >= 12;
   KEEP ACCTNO;
RUN;
PROC SORT NODUPKEY; BY ACCTNO; RUN;

DATA ILNACC;
   MERGE CISLN(IN=A) ILNACC(IN=B);
   BY ACCTNO;
   IF A AND B;
RUN;
PROC DATASETS LIB=WORK NOLIST;
   DELETE CISLN;
RUN;
PROC SORT DATA=ILNACC; BY ICNO; RUN;

PROC SUMMARY DATA=ILNACC NWAY;
   WHERE SECCUST = '901';
   BY ICNO;
   VAR CNT;
   OUTPUT OUT=ICISLNACC(DROP=_FREQ_ _TYPE_) SUM=CNTLNACC;
RUN;
PROC DATASETS LIB=WORK NOLIST;
   DELETE ILNACC;
RUN;

DATA ICOMBINELNDP;
   MERGE ICISLNACC CISDPACC(IN=A) CISDP(KEEP=ICNO ACCTNO SECCUST);
   BY ICNO;
   IF A;
   IF  CNTDPACC >= 1 AND CNTLNACC >= 1 THEN SIGN = 'R ';
   ELSE                                     SIGN = 'NR';
   IF SECCUST = '901';
RUN;
PROC SORT DATA=ICOMBINELNDP; BY ACCTNO; RUN;

DATA ITRNSCISIC;
   MERGE TRNSCISIC(IN=A) ICOMBINELNDP;
   BY ACCTNO;
   IF A;
   KEEP ACCTNO ICGRP CNTIC SIGN;
RUN;

 /* STEP 2 : TRANSACTIONAL ACCOUNTS */

DATA TRANXACC;
   SET CRM.DPBTRAN&REPTYEAR&REPTMON.01
       CRM.DPBTRAN&REPTYEAR&REPTMON.02
       CRM.DPBTRAN&REPTYEAR&REPTMON.03
       CRM.DPBTRAN&REPTYEAR&REPTMON.04;
   WHERE CHANNEL IN (223,224,225,226,227,228,242,284,321,322,323,324,
                     325,326,328,331,333,341,342,501,502,503,505,511,
                     512,513,515,526,527,645,648,669) OR
        (CHANNEL IN (290,296) AND TRANCODE=626);
   CNT = 1;
   INITCUST = 'Y';
   KEEP ACCTNO CNT INITCUST;
RUN;
PROC SORT DATA=TRANXACC; BY ACCTNO INITCUST; RUN;

PROC SUMMARY DATA=TRANXACC NWAY;
   BY ACCTNO INITCUST;
   VAR CNT;
   OUTPUT OUT=TRANXACC(DROP=_FREQ_ _TYPE_) SUM=;
RUN;

 /* SAFE DEPOSIT BOX 2017-2949 */

DATA LCR.SDBM;
   SET SDB.SDB&REPTMON.4&REPTYEAR(RENAME=(ACCTNO=ACCTNOC));
   ACCTNO = COMPRESS(ACCTNOC,'-')*1;
   IF YRDIF(OPENDT,&REPTDT,'ACT/ACT') >= 1 THEN SIGN = 'R ';
   ELSE                                         SIGN = 'NR';
   SDB    = 'Y';
   KEEP ACCTNO SDB SIGN OPENDT;
RUN;
PROC SORT DATA=LCR.SDBM OUT=SDB; BY ACCTNO OPENDT;
   WHERE ACCTNO > 0 AND SIGN = 'R ';
RUN;
PROC SORT DATA=SDB(KEEP=ACCTNO SDB SIGN) NODUPKEY; BY ACCTNO; RUN;

DATA LCR.TRNSCISIC;
   MERGE TRNSCISIC(IN=A) TRANXACC SDB;
   BY ACCTNO;
   IF A;
   IF CNT >= 1 THEN TRX = 1;
   IF INITCUST = '' THEN INITCUST = 'N';
RUN;

DATA ILCR.TRNSCISIC;
   MERGE ITRNSCISIC(IN=A) TRANXACC SDB;
   BY ACCTNO;
   IF A;
   IF CNT >= 1 THEN TRX = 1;
   IF INITCUST = '' THEN INITCUST = 'N';
RUN;
