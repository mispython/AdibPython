            @021 BRABBR   $UPCASE15.  /* BRANCH ABBRIEVATE           */
            @036 CUSTYPE          1.  /* 1-INDIVIDUAL 2-ORGANISATION */
            @037 NAME     $UPCASE120. /* NAME                        */
            @157 ICTYPE   $UPCASE2.   /* IDENTIFICATION TYPE         */
            @159 IC       $UPCASE15.  /* IC NO                       */
            @174 CUSTCODE $UPCASE2.   /* CUSTOMER CODE               */
            @176 CUSTDESC $UPCASE100. /* CUSTOMER CODE DESCRIPTION   */
            @276 INVSTYPE $UPCASE3.   /* INVESTOR TYPE               */
            @279 INVSDESC $UPCASE100. /* INVESTOR TYPE DESCRIPTION   */
            @379 INVSDES1 $UPCASE100. /* INVESTOR TYPE DESC FOR OTH  */
            @479 HOMENO          $12. /* CONTACT NO - HOME           */
            @491 OFFNO           $12. /* CONTACT NO - OFFICE         */
            @503 MOBILE          $12. /* CONTACT NO - MOBILE         */
            @515 INVSNO          $10. /* INVESTMENT A/C NO           */
            @525 DD1               2. /* BIRTH DATE                  */
            @528 MM1               2.
            @531 YY1               4.
            @535 GEND              1. /* GENDER                      */
            @536 ETHN              1. /* ETHNIC                      */
            @537 MARI              1. /* MARITAL STATUS              */
            @538 INCOME          $80. /* MONTHLY INCOME              */
            @618 OCCUPT          $80. /* OCCUPATION                  */
            @698 CERTNO           $8. /* CERTIFICATE NO              */
            ;
            IF IC NE '';
            IF INVSTYPE = 'OTH' THEN INVSDESC=INVSDES1;
            IF GEND=1 THEN GENDER='MALE';
            ELSE GENDER='FEMALE';

            IF ETHN=1 THEN ETHNIC='MALAY';
            ELSE IF ETHN=2 THEN ETHNIC='CHINESE';
            ELSE IF ETHN=3 THEN ETHNIC='INDIAN';
            ELSE                ETHNIC='OTHERS';

            IF MARI=1 THEN MARITAL='SINGLE';
            ELSE IF MARI=2 THEN MARITAL='MARRIED';
            ELSE IF MARI=3 THEN MARITAL='DIVORCED';
            ELSE IF MARI=4 THEN MARITAL='SEPARATED';
            ELSE IF MARI=5 THEN MARITAL='WIDOW/WIDOWER';
            ELSE                MARITAL=' ';

            IF MM1 GT 0 THEN BIRTHDT = MDY(MM1,DD1,YY1);
   RUN;

   *** INVESTMENT PROFILE ***;
   DATA PROD(DROP=DD1 MM1 YY1 DD2 MM2 YY2 DD3 MM3 YY3
                  DD4 MM4 YY4 DD5 MM5 YY5 DD6 MM6 YY6
                  DD7 MM7 YY7 DD8 MM8 YY8 DD9 MM9 YY9
                  DD10 MM10 YY10);
