//EIBNLSIP JOB MSGCLASS=X,MSGLEVEL=(1,1),REGION=8M,NOTIFY=&SYSUID
//*
//EIBNLSIP  EXEC SAS609
//SIPCUST  DD DISP=SHR,DSN=SAP.NLF.SIP.CUST.TEXT(0)
//SIPCERT  DD DISP=SHR,DSN=SAP.NLF.SIP.CERT.TEXT(0)
//SIPPROD  DD DISP=SHR,DSN=SAP.NLF.SIP.PROD.TEXT(0)
//STORE     DD DSN=SAP.PBB.NLF.DAILY,DISP=OLD
//STOREM    DD DSN=SAP.PBB.NLF.MONTH,DISP=OLD
//DEPOSIT   DD DSN=SAP.PBB.MNITB.DAILY(0),DISP=SHR
//SASLIST   DD SYSOUT=X
//SYSIN     DD *
OPTIONS NOCENTER;
PROC FORMAT;
   VALUE REMFMT
      LOW-0.1 = '01'   /*  UP TO 1 WK       */
      0.1-1   = '02'   /*  >1 WK - 1 MTH    */
      1-3     = '03'   /*  >1 MTH - 3 MTHS  */
      3-6     = '04'   /*  >3 - 6 MTHS      */
      6-12    = '05'   /*  >6 MTHS - 1 YR   */
      OTHER   = '06';  /*  > 1 YEAR         */
RUN;
%MACRO DCLVAR;
   RETAIN D1-D12 31 D4 D6 D9 D11 30
          RD1-RD12 MD1-MD12 31 RD2 MD2 28 RD4 RD6 RD9 RD11
          MD4 MD6 MD9 MD11 30 RPYR RPMTH RPDAY;
   ARRAY LDAY D1-D12;
   ARRAY RPDAYS RD1-RD12;
   ARRAY MDDAYS MD1-MD12;
%MEND DCLVAR;
%MACRO REMMTH;
   MDYR  = YEAR(MATDT);
   MDMTH = MONTH(MATDT);
   MDDAY = DAY(MATDT);
   IF MDMTH = 2 THEN
      IF MOD(MDYR,4) = 0 THEN MD2 = 29;
      ELSE MD2 = 28;
   IF MDDAY > RPDAYS(RPMTH) THEN MDDAY = RPDAYS(RPMTH);
   REMY = MDYR - RPYR;
   REMM = MDMTH - RPMTH;
   REMD = MDDAY - RPDAY;
   REMMTH = REMY*12 + REMM + REMD/RPDAYS(RPMTH);
%MEND REMMTH;
*;
DATA REPTDATE;
   SET DEPOSIT.REPTDATE;
   SELECT(DAY(REPTDATE));
      WHEN (8)  CALL SYMPUT('NOWK',PUT('1',$1.));
      WHEN (15) CALL SYMPUT('NOWK',PUT('2',$1.));
      WHEN (22) CALL SYMPUT('NOWK',PUT('3',$1.));
      OTHERWISE CALL SYMPUT('NOWK',PUT('4',$1.));
   END;
   CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR4.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('REPTDAY',PUT(DAY(REPTDATE),Z2.));
   CALL SYMPUT('RDATE',PUT(REPTDATE,DDMMYY8.));
RUN;
*;
%MACRO PROCESS;
   *** CUSTOMER PROFILE ***;
   DATA CUST(DROP=INVSDES1 DD1 MM1 YY1 GEND ETHN MARI);
      FORMAT GENDER ETHNIC MARITAL $15.;
      INFILE SIPCUST FIRSTOBS=1;
      INPUT @001 CUSTID   $UPCASE2.   /* C0-FIRST, C1-JOINT HOLDER   */
            @003 PRIMIC   $UPCASE15.  /* FOR LINK TO 1ST FOLDER IC
                                         FOR JOINT HOLDER            */
