   OUT=MASTER(RENAME=(BRANCHCODE=BRANCH)) NODUP;
   BY ACCNUM;
PROC SORT DATA=PIDM.CISDEPOSIT OUT=CIS(KEEP=ACCTNO BRANCH);
   BY ACCTNO;
RUN;
DATA PIDMWH.MASTER;
   MERGE CIS(IN=A RENAME=(ACCTNO=ACCNUM))
         MASTER(IN=B DROP=BRANCH);
   BY ACCNUM;
   DROP OPENDT;
   IF A & B;
RUN;
PROC SORT DATA=PIDMWH.MASTER NODUP; BY ACCNUM;
DATA PIDMWH.HOLDER;
   MERGE PIDM.DEPOSIT(IN=A KEEP=ACCTNO) PIDM.CISINFO;
   BY ACCTNO;
   IF A;
   KEEP ACCTNO CUSTNAME CUSTNAM1 CUSTNO NEWIC OLDIC POLICEARMYID
        PASSPORTNUM RESIDENT DATEOFBIRTH SALUTATION RACE GENDER SECCUST
        CITIZEN NEWICIND;

   RENAME ACCTNO=ACCNUM CUSTNAME=ACCNAME CUSTNAM1=HOLDERNAME
          CUSTNO=CIFNUM NEWIC=NEWIDNUM   OLDIC=OLDIDNUM;

   FORMAT SALUTE1 SALUTE2 SALUTE3 SALUTE4 SALUTE5 SALUTE6 SALUTE7 $10.
          ;

   IF NEWICIND IN ('ML','PL') THEN
      POLICEARMYID = NEWIC;
   ELSE
      POLICEARMYID = '0';

   IF NEWICIND IN ('PP') THEN
      PASSPORTNUM  = NEWIC;
   ELSE
      PASSPORTNUM  = '0';

   IF CITIZEN  IN ('MY') THEN
      RESIDENT     = 1;
   ELSE
      RESIDENT     = 2;

   IF BIRTHDAT NOT IN (.,0) THEN
      DATEOFBIRTH  = INPUT(SUBSTR(BIRTHDAT,1,8),DDMMYY10.);
   ELSE
      DATEOFBIRTH  = 0;

   IF SCAN(CUSTNAM1, 1,'') NE SCAN(CUSTNAME, 1,'') THEN DO;
     SALUTE1 = SCAN(CUSTNAM1, 1,'');
     IF SCAN(CUSTNAM1, 2,'') NE SCAN(CUSTNAME, 1,'') THEN DO;
       SALUTE2 = SCAN(CUSTNAM1, 2,'');
       IF SCAN(CUSTNAM1, 3,'') NE SCAN(CUSTNAME, 1,'') THEN DO;
         SALUTE3 = SCAN(CUSTNAM1, 3,'');
         IF SCAN(CUSTNAM1, 4,'') NE SCAN(CUSTNAME, 1,'') THEN DO;
           SALUTE4 = SCAN(CUSTNAM1, 4,'');
           IF SCAN(CUSTNAM1, 5,'') NE SCAN(CUSTNAME, 1,'') THEN DO;
             SALUTE5 = SCAN(CUSTNAM1, 5,'');
             IF SCAN(CUSTNAM1, 6,'') NE SCAN(CUSTNAME, 1,'') THEN DO;
               SALUTE6 = SCAN(CUSTNAM1, 6,'');
               IF SCAN(CUSTNAM1, 7,'') NE SCAN(CUSTNAME, 1,'') THEN
                 SALUTE7 = SCAN(CUSTNAM1, 7,'');
             END;
           END;
         END;
       END;
     END;
   END;

   SALUTATION = COMPBL(SALUTE1||SALUTE2||SALUTE3||SALUTE4||SALUTE5||
                       SALUTE6||SALUTE7);
   DROP SALUTE1 SALUTE2 SALUTE3 SALUTE4 SALUTE5 SALUTE6 SALUTE7;
RUN;
PROC SORT DATA=MISCA.FORATEBKP OUT=FORATE;
   BY CURCODE DESCENDING REPTDATE;
   WHERE REPTDATE<= &TDATE;
RUN;
PROC SORT DATA=FORATE NODUPKEY; BY CURCODE; RUN;

DATA FOFMT;
  LENGTH START $3. LABEL $13.7 FMTNAME $6. TYPE $1.;
  SET FORATE;
  START = CURCODE;
  LABEL = SPOTRATE;
  FMTNAME = 'FORATE';
  TYPE = 'C';
RUN;

PROC FORMAT CNTLIN=FOFMT;
RUN;
DATA PIDM.FDCD;
   SET IMNIFD.FD MNIFD.FD;
   KEEP ACCTNO CDNO PLACEMENTRENEWDATE MATURITYDATE GROSSRATE PSR
        TENOR LASTINTDIVPMT RATENETGIARATE AVAILABLEBAL FXAVAILABLEBAL
        CURCODE FXLEDGERBAL LEDGERBAL;
   RENAME CDNO=CERTNUM ACCTNO=ACCNUM CURCODE=CURRENCYCODE;
   FORMAT PSR 2.;

   IF (3000<=COSTCTR<=4999) THEN
      BUSSTYPE = 1;                    /* 1 - ISLAMIC      */
   ELSE
      BUSSTYPE = 2;                    /* 2 - CONVENTIONAL */

   IF MATID EQ 'M' THEN TENOR = TERM*30;
   ELSE                 TENOR = TERM;
  IF LMATDATE NOT IN (.,0) THEN
     PLACEMENTRENEWDATE=INPUT(SUBSTR(PUT(LMATDATE,Z11.),1,8),MMDDYY8.);
  ELSE
     PLACEMENTRENEWDATE=INPUT(SUBSTR(PUT(ORGDATE,Z9.),1,6),MMDDYY6.);

  IF MATDATE NOT IN (.,0) THEN
     MATURITYDATE  = INPUT(SUBSTR(PUT(MATDATE,Z8.),1,8),YYMMDD8.);

  IF INTDATE NOT IN (.,0) THEN
     LASTINTDIVPMT = INPUT(SUBSTR(PUT(INTDATE,Z9.),1,6),MMDDYY6.);


   AVAILABLEBAL   = CURBAL;            /* RM AVAILABLE DEPOSIT BALANCE*/
   LEDGERBAL      = CURBAL;            /* RM AVAILABLE DEPOSIT BALANCE*/
   IF CURCODE NE 'MYR' THEN DO;
      FXACCRUEDINT = INTPAY;
      ACCRUEDINT = INTPAY * FXRATE;
      FXRATE      = PUT(CURCODE,$FORATE.); /* CURRENCY EXCH. RATE   */
      FXAVAILABLEBAL = FORBAL;             /* FX AVAILABLE DEPOSIT  */
      FXLEDGERBAL    = FORBAL;             /* FX AVAILABLE DEPOSIT  */
   END;
   ELSE DO ;
      FXAVAILABLEBAL = 0;                 /* FX AVAILABLE DEPOSIT  */
      FXACCRUEDINT = 0;
      ACCRUEDINT   = INTPAY;
      FXLEDGERBAL  = 0;                  /* FX AVAILABLE DEPOSIT  */
   END;

   RATENETGIARATE = RATE;
   IF BUSSTYPE = 1 THEN DO;
      PSR      = SUBSTR(COMPRESS(PRORATIO),1,2);
      GROSSRATE= (RATE*100)/PSR;
   END;
   ELSE DO;
      PSR      = 0;
      GROSSRATE= 0;
   END;
RUN;

PROC SORT DATA=PIDM.FDCD; BY ACCNUM CERTNUM; RUN;


DATA PIDMWH.TIMEDEPO;
   SET PIDM.CISDEPOSIT;
   WHERE DEPTYPE IN ('3','5','6');

   RENAME ACCTNO=ACCNUM CURCODE=CURRENCYCODE;
   IF OPENDT NOT IN (.,0) THEN
      ACCOPENDATE = INPUT(SUBSTR(PUT(OPENDT,Z11.),1,8), MMDDYY8.);
   ELSE
      ACCOPENDATE = 0;

   NOMINALVALUE   = 0;               /* RM NOMINAL VALUE            */
   FXNOMINALVALUE = 0;               /* FX NOMINAL VALUE            */
   FXRATE         = 0;               /* CURRENCY EXCH. RATE         */
   FXLEDGERBAL    = 0;               /* FX LEDGER BALANCE           */
   FXAVAILABLEBAL = 0;               /* FX AVAILABLE DEPOSIT        */
   FXACCRUEDINT   = 0;               /* FX ACCRUED INT/DIV/PRO      */
   FXINTPROFTODATE= 0;               /* FX INT/DIV/PRO PD TDTE      */

   LEDGERBAL      = LEDGBAL;         /* RM LEDGER BALANCE/          */
   AVAILABLEBAL   = CURBAL;          /* RM AVAILABLE DEPOSIT BALANCE*/
   ACCRUEDINT     = INTPD;           /* RM ACCRUED INTEREST/DIV/PRO */
   INTPROFTODATE  = INTYTD;          /* RM INT/DIV/PRO PAID TODATE  */

   IF CURCODE NE 'MYR' THEN DO;
      FXRATE      = PUT(CURCODE,$FORATE.); /* CURRENCY EXCH. RATE   */
      FXLEDGERBAL = CURBAL*FXRATE;        /* FX LEDGER BALANCE     */
      FXAVAILABLEBAL = CURBAL*FXRATE;      /* FX AVAILABLE DEPOSIT  */
      FXACCRUEDINT   = INTPD*FXRATE;       /* FX ACCRUED INT/DIV/PRO*/
      FXINTPROFTODATE= INTYTD*FXRATE;      /* FX INT/DIV/PRO PD TDTE*/
   END;

                                      /* PLACEMENT DTE/RENEWAL/ISSUE */
                                      /* MATURITY DATE               */
   TENOR          = 0;                /* TENOR                       */
   RATENETGIARATE = 0;                /* INTEREST RATE/NET GIA RATE  */
   GROSSRATE      = 0;                /* GROSS RATE                  */
   PSR            = 0;                /* PROFIT SHARING RATIOS(CUST) */
   PROCEEDVALUE   = 0;                /* RM PROCEED VALUE            */
   FXPROCEEDVALUE = 0;                /* FX PROCEED VALUE            */
                                     /* LAST INT/DIV/PRO PAYMENTDATE*/
RUN;
PROC SORT; BY ACCNUM;

DATA PIDMWH.TIMEDEPO;
   MERGE PIDMWH.TIMEDEPO(IN=A DROP=LEDGERBAL) PIDM.FDCD(IN=B);
   BY ACCNUM;
   IF A & B;
   LEDGERBAL = AVAILABLEBAL;
   CURBAL = AVAILABLEBAL;
RUN;
