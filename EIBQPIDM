         @013 HOLDIND      $1.
         @015 BRANCH        3.
         ;
RUN;

DATA PIDM.POST;
   INFILE POST FIRSTOBS=1;
   INPUT @001 ACCTNO       11.
         @013 POSTIND      $1.
         @015 BRANCH        3.
         ;
RUN;

DATA PIDM.FLOAT;
   INFILE FLOAT FIRSTOBS=1;
   INPUT @001 ACCTNO       11.
         @013 FLOAT        13.2
         @027 BRANCH        3.
         ;
RUN;

PROC SORT DATA=PIDM.HOLD;  BY ACCTNO; RUN;
PROC SORT DATA=PIDM.POST;  BY ACCTNO; RUN;
PROC SORT DATA=PIDM.FLOAT; BY ACCTNO; RUN;

DATA PIDM.CISDEPOSIT;
   MERGE PIDM.CISDEPOSIT(IN=A) PIDM.HOLD PIDM.POST PIDM.FLOAT;
   BY ACCTNO;
   IF CUSTNAME = ' ' THEN CUSTNAME = NAME;
   IF A;
RUN;

*+----------------------------------------------------------------+
 | PERBADANAN INSURANS DEPOSIT MALAYSIA (PIDM) : MASTER           |
 +----------------------------------------------------------------+;

DATA COLL(KEEP=FDACCTNO COLLACCTNO);
   SET COLL.COLLATER
       ICOLL.COLLATER;
   COLLACCTNO = ACCTNO;
RUN;
*;
PROC SORT DATA=COLL NODUPKEYS; BY FDACCTNO;
*;
DATA PIDMWH.MASTER;
   MERGE PIDM.CISDEPOSIT(IN=A) COLL(RENAME=(FDACCTNO=ACCTNO));
   BY ACCTNO;
   IF A;
   KEEP ACCTNO BUSSTYPE BRANCH DEPTYPE CURCODE INSURABILITY PRODUCT
        SPECIALACC CUSTNAME CUSTNO STAFFCODE ACCTYPE ACCOPENDATE
        PRIPHONE SECPHONE MOBIPHON REGNUM ACCOPENDATE APPROVERACCOPEN
        LEDGERBAL AVAILABLEBAL BILLPAYABLE ACCRUEDINT INTPROFTODATE
        ACCRUEDINT INTPROFTODATE FXRATE FXLEDGERBAL FXAVAILABLEBAL
        FXBILLPAYABLE FXACCRUEDINT FXINTPROFTODATE UCLAIMEDMONIES
        TAGGING CONDOFTAGGING UCLAIMEDMONIES NOMINALVALUES
        FXNOMINALVALUE PROCEEDVALUE FXPROCEEDVALUE ATMCARD;

   RENAME ACCTNO=ACCNUM    CURCODE=CURRENCYCODE CUSTNAME=ACCNAME
          CUSTNO=CIFNUM    BRANCH =BRANCHCODE   PRODUCT =DEPCODE
          PRIPHONE=TELHOME SECPHONE=TELOFFICE   MOBIPHON=TELHP;

   FORMAT CONDOFTAGGING $20.;

   REGNUM = NEWIC;

   IF OPENDT NOT IN (.,0) THEN
      ACCOPENDATE = INPUT(SUBSTR(PUT(OPENDT,Z11.),1,8), MMDDYY8.);
   ELSE
      ACCOPENDATE = 0;

   APPROVERACCOPEN = '';                   /* APPROVER ACC OPEN      */
   FXRATE          = 0 ;                   /* CURRENCY EXCH. RATE    */
   FXLEDGERBAL     = 0 ;                   /* FX LEDGER BALANCE      */
   FXAVAILABLEBAL  = 0 ;                   /* FX AVAILABLE DEPOSIT   */
   FXBILLPAYABLE   = 0 ;                   /* FX BILLS PAYABLE O/S   */
   FXACCRUEDINT    = 0 ;                   /* FX ACCRUED INT/DIV/PRO */
   FXINTPROFTODATE = 0 ;                   /* FX INT/DIV/PRO PD TODT */

   LEDGERBAL       = LEDGBAL;   /* RM LEDGER BALANCE/           */
   AVAILABLEBAL    = CURBAL;    /* RM AVAILABLE DEPOSIT BALANCE */
   BILLPAYABLE     = INTPAYBL;  /* RM BILLS PAYABLE OUTSTANDING */

   ACCRUEDINT      = INTPD;     /* RM ACCRUED INTEREST/DIV/PRO  */
   INTPROFTODATE   = INTYTD;    /* RM INT/DIV/PRO PAID TODATE   */

   IF CURCODE NE 'MYR' THEN DO;
      FXRATE      = PUT(CURCODE,$FORATE.); /* CURRENCY EXCH. RATE    */
      FXLEDGERBAL = LEDGBAL*FXRATE;        /* FX LEDGER BALANCE      */
      FXAVAILABLEBAL = CURBAL/FXRATE;      /* FX AVAILABLE DEPOSIT   */
      FXBILLPAYABLE  = INTPAYBL*FXRATE;    /* FX BILLS PAYABLE O/S   */
      FXACCRUEDINT   = INTPD*FXRATE;       /* FX ACCRUED INT/DIV/PRO */
      FXINTPROFTODATE= INTYTD*FXRATE;      /* FX INT/DIV/PRO PD TODT */
   END;

   IF HOLDIND EQ 'Y' THEN DO;
      IF COLLACCTNO NOT IN (.,0) THEN DO;
         IF ACSTATUS4 = 'H' OR ACSTATUS5 = 'H' OR ACSTATUS6 = 'H'
            THEN TAGGING = 4;
         ELSE TAGGING = 1;
      END;
      ELSE IF COLLACCTNO IN (.,0) THEN DO;
         IF ACSTATUS4 = 'H' OR ACSTATUS5 = 'H' OR ACSTATUS6 = 'H'
            THEN TAGGING = 5;
         ELSE TAGGING = 2;
      END;
   END;
   ELSE IF POSTIND NE '' THEN DO;
      IF ACSTATUS4 = 'H' OR ACSTATUS5 = 'H' OR ACSTATUS6 = 'H'
         THEN TAGGING = 5;
      ELSE TAGGING = 2;                  /* TAGGING                */
   END;
   ELSE IF ACSTATUS4 = 'H' OR ACSTATUS5 = 'H' OR ACSTATUS6 = 'H'
      THEN TAGGING = 3;
   ELSE
      TAGGING = 0;

   IF        TAGGING = 1 OR TAGGING = 4 THEN
      CONDOFTAGGING  = LEFT(COLLACCTNO);   /* INTERFACE CMS LOAN/OD  */
   ELSE IF   TAGGING = 2 OR TAGGING = 5 AND HOLDIND = 'Y' THEN
      CONDOFTAGGING  = 'EARMARK';
   ELSE IF   TAGGING = 3 THEN
      CONDOFTAGGING  = 'DECEASED ACCOUNT';
   ELSE IF   POSTIND = 'A' THEN
      CONDOFTAGGING  = 'POST NO CHEQUE';
   ELSE IF   POSTIND = 'C' THEN
      CONDOFTAGGING  = 'POST NO CREDIT';
   ELSE IF   POSTIND = 'X' THEN
      CONDOFTAGGING  = 'POST NO DEBIT';
   ELSE IF   POSTIND = 'T' THEN
      CONDOFTAGGING  = 'POST NO TRANSACTION';
   ELSE
      CONDOFTAGGING  = '0';

  /* IF PRODUCT IN (297,298) THEN
      UCLAIMEDMONIES = 1;
   ELSE
      UCLAIMEDMONIES = 2; */               /* UNCLAIM MONIES         */

   NOMINALVALUES  = 0;                     /* RM NOMINAL VALUE       */
   FXNOMINALVALUE = 0;                     /* FX NOMINAL VALUE       */
   PROCEEDVALUE   = 0;                     /* RM PROCEED VALUE       */
   FXPROCEEDVALUE = 0;                     /* FX PROCEED VALUE       */
RUN;

*+----------------------------------------------------------------+
 | PERBADANAN INSURANS DEPOSIT MALAYSIA (PIDM) : ACCOUNT HOLDER   |
 +----------------------------------------------------------------+;
DATA PIDMWH.HOLDER;
   MERGE PIDM.DEPOSIT(IN=A KEEP=ACCTNO) PIDM.CISINFO;
   BY ACCTNO;
   IF A;
   KEEP ACCTNO CUSTNAME CUSTNAM1 CUSTNO NEWIC OLDIC POLICEARMYID
        PASSPORTNUM RESIDENT DATEOFBIRTH SALUTATION RACE GENDER
        CITIZEN;

   RENAME ACCTNO=ACCNUM CUSTNAME=ACCNAME CUSTNAM1=HOLDERNAME
          CUSTNO=CIFNUM NEWIC=NEWIDNUM   OLDIC=OLDIDNUM;

   FORMAT SALUTE1 SALUTE2 SALUTE3 SALUTE4 SALUTE5 SALUTE6 SALUTE7 $10.
          DATEOFBIRTH DDMMYY8.;

   IF NEWICIND IN ('ML','PL') THEN
      POLICEARMYID = NEWIC;
   ELSE
      POLICEARMYID = '0';

   IF NEWICIND IN ('PP') THEN
      PASSPORTNUM  = NEWIC;
   ELSE
      PASSPORTNUM  = '0';

   IF CITIZEN  IN ('MY') THEN
      RESIDENT     = 1;
   ELSE
      RESIDENT     = 2;

   IF BIRTHDAT NOT IN (.,0) THEN
      DATEOFBIRTH  = INPUT(SUBSTR(BIRTHDAT,1,8),DDMMYY10.);
   ELSE
      DATEOFBIRTH  = 0;

   IF SCAN(CUSTNAM1, 1,'') NE SCAN(CUSTNAME, 1,'') THEN DO;
     SALUTE1 = SCAN(CUSTNAM1, 1,'');
     IF SCAN(CUSTNAM1, 2,'') NE SCAN(CUSTNAME, 1,'') THEN DO;
       SALUTE2 = SCAN(CUSTNAM1, 2,'');
       IF SCAN(CUSTNAM1, 3,'') NE SCAN(CUSTNAME, 1,'') THEN DO;
         SALUTE3 = SCAN(CUSTNAM1, 3,'');
         IF SCAN(CUSTNAM1, 4,'') NE SCAN(CUSTNAME, 1,'') THEN DO;
           SALUTE4 = SCAN(CUSTNAM1, 4,'');
           IF SCAN(CUSTNAM1, 5,'') NE SCAN(CUSTNAME, 1,'') THEN DO;
             SALUTE5 = SCAN(CUSTNAM1, 5,'');
             IF SCAN(CUSTNAM1, 6,'') NE SCAN(CUSTNAME, 1,'') THEN DO;
               SALUTE6 = SCAN(CUSTNAM1, 6,'');
               IF SCAN(CUSTNAM1, 7,'') NE SCAN(CUSTNAME, 1,'') THEN
                 SALUTE7 = SCAN(CUSTNAM1, 7,'');
             END;
           END;
         END;
       END;
     END;
   END;

   SALUTATION = COMPBL(SALUTE1||SALUTE2||SALUTE3||SALUTE4||SALUTE5||
                       SALUTE6||SALUTE7);
   DROP SALUTE1 SALUTE2 SALUTE3 SALUTE4 SALUTE5 SALUTE6 SALUTE7;
RUN;

*+----------------------------------------------------------------+
 | PERBADANAN INSURANS DEPOSIT MALAYSIA (PIDM) : TERM DEPOSIT     |
 +----------------------------------------------------------------+;
DATA PIDMWH.TIMEDEPO;
   SET PIDM.CISDEPOSIT;
   KEEP ACCTNO CURCODE ACCOPENDATE NOMINALVALUE FXNOMINALVALUE
        LEDGERBAL AVAILABLEBAL ACCRUEDINT INTPROFTODATE FXRATE
        FXLEDGERBAL FXAVAILABLEBAL FXACCRUEDINT FXINTPROFTODATE
        PLACEMENTRENEWDATE MATURITYDATE TENOR RATENETGIARATE
        GROSSRATE PSR PROCEEDVALUE FXPROCEEDVALUE LASTINTDIVPMT;
   WHERE DEPTYPE IN ('3','5','6');

   RENAME ACCTNO=ACCNUM CURCODE=CURRENCYCODE;

   IF OPENDT NOT IN (.,0) THEN
      ACCOPENDATE = INPUT(SUBSTR(PUT(OPENDT,Z11.),1,8), MMDDYY8.);
   ELSE
      ACCOPENDATE = 0;

   NOMINALVALUE   = 0;               /* RM NOMINAL VALUE            */
   FXNOMINALVALUE = 0;               /* FX NOMINAL VALUE            */
   FXRATE         = 0;               /* CURRENCY EXCH. RATE         */
   FXLEDGERBAL    = 0;               /* FX LEDGER BALANCE           */
   FXAVAILABLEBAL = 0;               /* FX AVAILABLE DEPOSIT        */
   FXACCRUEDINT   = 0;               /* FX ACCRUED INT/DIV/PRO      */
   FXINTPROFTODATE= 0;               /* FX INT/DIV/PRO PD TDTE      */

   LEDGERBAL      = LEDGBAL;         /* RM LEDGER BALANCE/          */
   AVAILABLEBAL   = CURBAL;          /* RM AVAILABLE DEPOSIT BALANCE*/
   ACCRUEDINT     = INTPD;           /* RM ACCRUED INTEREST/DIV/PRO */
   INTPROFTODATE  = INTYTD;          /* RM INT/DIV/PRO PAID TODATE  */

   IF CURCODE NE 'MYR' THEN DO;
      FXRATE      = PUT(CURCODE,$FORATE.); /* CURRENCY EXCH. RATE   */
      FXLEDGERBAL = LEDGBAL*FXRATE;        /* FX LEDGER BALANCE     */
      FXAVAILABLEBAL = CURBAL/FXRATE;      /* FX AVAILABLE DEPOSIT  */
      FXACCRUEDINT   = INTPD*FXRATE;       /* FX ACCRUED INT/DIV/PRO*/
      FXINTPROFTODATE= INTYTD*FXRATE;      /* FX INT/DIV/PRO PD TDTE*/
   END;

   PLACEMENTRENEWDATE = 0;            /* PLACEMENT DTE/RENEWAL/ISSUE */
   MATURITYDATE   = 0;                /* MATURITY DATE               */
   TENOR          = 0;                /* TENOR                       */
   RATENETGIARATE = 0;                /* INTEREST RATE/NET GIA RATE  */
   GROSSRATE      = 0;                /* GROSS RATE                  */
   PSR            = 0;                /* PROFIT SHARING RATIOS(CUST) */
   PROCEEDVALUE   = 0;                /* RM PROCEED VALUE            */
   FXPROCEEDVALUE = 0;                /* FX PROCEED VALUE            */
   LASTINTDIVPMT  = 0;                /* LAST INT/DIV/PRO PAYMENTDATE*/
RUN;

DATA PIDMWH.TIMEDEPO;
   MERGE PIDMWH.TIMEDEPO(IN=A) PIDM.FDCD;
   BY ACCNUM;
   IF A;
RUN;
