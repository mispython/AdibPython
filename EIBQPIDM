//BNM      DD DSN=SAP.PBB.DEPOSIT.DIS(+1),
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),
//            SPACE=(CYL,(300,50),RLSE),UNIT=(SYSDA,5)
//IBNM    DD  DSN=SAP.PIBB.DEPOSIT.DIS(+1),
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),
//            SPACE=(CYL,(300,50),RLSE),UNIT=(SYSDA,5)
//PIDM     DD DSN=SAP.PBB.PIDM.SOURCE,
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),
//            SPACE=(CYL,(200,200),RLSE),UNIT=(SYSDA,5)
//PIDMWH   DD DSN=SAP.PBB.PIDM.SASDATA,
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),
//            SPACE=(CYL,(200,200),RLSE),UNIT=(SYSDA,5)
//SORTWK01 DD UNIT=SYSDA,SPACE=(CYL,(500))
//SORTWK02 DD UNIT=SYSDA,SPACE=(CYL,(500))
//SORTWK03 DD UNIT=SYSDA,SPACE=(CYL,(500))
//SORTWK04 DD UNIT=SYSDA,SPACE=(CYL,(500))
//SORTWK05 DD UNIT=SYSDA,SPACE=(CYL,(500))
//SYSIN    DD *

OPTIONS YEARCUTOFF=1960 NOCENTER NODATE COMPRESS=Y MISSING=0;

DATA PIDMWH.REPTDATE;
   REPTDATE = MDY(1,1,YEAR(TODAY()))-1;
   SELECT(DAY(REPTDATE));
      WHEN(8)   CALL SYMPUT('NOWK', PUT('1', $1.));
      WHEN(15)  CALL SYMPUT('NOWK', PUT('2', $1.));
      WHEN(22)  CALL SYMPUT('NOWK', PUT('3', $1.));
      OTHERWISE CALL SYMPUT('NOWK', PUT('4', $1.));
   END;
   CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('RDATE',PUT(REPTDATE,8.));
   CALL SYMPUT('TDATE',REPTDATE);
RUN;

   /* UNCLAIM MONEY */
DATA UMA(DROP=PRODUCT RENAME=(PRODUCT1=PRODUCT));
   SET IMNITB.UMA(IN=A) MNITB.UMA(IN=B);
   IF A THEN BNKIND='PIBB' ;
   ELSE IF B THEN BNKIND='PBB ';
   IF SCAN(INSTRUCTIONS,1) = 'CHNGE' OR SCAN(INSTRUCTIONS,-2) = 'TYP'
   THEN
    ORIPRODUCT = SUBSTR(INSTRUCTIONS,LENGTH(INSTRUCTIONS)-2,3);
   PRODUCT1 = ORIPRODUCT * 1;
   IF PRODUCT1=. AND BNKIND='PIBB' THEN PRODUCT1=204;
   ELSE IF PRODUCT1 =. AND BNKIND = 'PBB'
        THEN PRODUCT1=200;
   IF PRODUCT1 = 297 THEN PRODUCT1 = 200;
   IF PRODUCT1 = 298 THEN PRODUCT1 = 204;
   UCLAIMEDMONIES = 1;
RUN;

DATA BNM.UMA IBNM.UMA;
   SET UMA;
   IF BNKIND='PBB' THEN OUTPUT BNM.UMA;
   ELSE OUTPUT IBNM.UMA;
RUN;
  /* UMCLAIM MONEY END */


DATA PIDM.DEPOSIT;
   SET IMNITB.CURRENT IMNITB.SAVING IMNITB.FD IBNM.UMA
        MNITB.CURRENT  MNITB.SAVING  MNITB.FD BNM.UMA;
   IF (3000<=COSTCTR<=4999)  THEN
      BUSSTYPE = 1;                    /* 1 - ISLAMIC      */
   ELSE
      BUSSTYPE = 2;                    /* 2 - CONVENTIONAL */

   IF   DEPTYPE IN ('D','N') THEN      /* CURRENT          */
      DEPTYPE = 1;
   ELSE IF DEPTYPE IN  ('S') THEN      /* SAVING           */
      DEPTYPE = 2;
   ELSE IF DEPTYPE IN  ('C') THEN DO;  /* FIXED DEPOSIT    */
      IF BUSSTYPE = 2 THEN
         DEPTYPE  = 3;
      ELSE
         DEPTYPE  = 6;                /* REMOVE DEPTYPE 5 */
   END;

   IF UCLAIMEDMONIES NE 1 THEN UCLAIMEDMONIES = 2;
   INSURABILITY = 1;                   /* INSURABLE        */
   SPECIALACC   = 0;                   /* DEFAULT VALUE    */

   IF PURPOSE = '4' THEN
      STAFFCODE = 1;                   /* STAFF            */
   ELSE
      STAFFCODE = 2;                   /* NON-STAFF        */

   IF   PURPOSE IN ('1','4','I') THEN
      ACCTYPE = 1;
   ELSE IF PURPOSE IN  ('2','H') THEN
      ACCTYPE = 2;
   ELSE IF PURPOSE IN  ('5','6') THEN
      ACCTYPE = 3;
   ELSE IF PURPOSE IN  ('7')     THEN
      ACCTYPE = 4;
   ELSE IF PURPOSE IN  ('8')     THEN
      ACCTYPE = 5;
   ELSE
      ACCTYPE = 6;
      ACSTATUS4  = SUBSTR(STATCD,4,1);
      ACSTATUS5  = SUBSTR(STATCD,5,1);
      ACSTATUS6  = SUBSTR(STATCD,6,1);
RUN;

PROC SORT DATA=PIDM.DEPOSIT;
   BY ACCTNO;
RUN;

PROC SORT DATA=OCM.BANKCARD&REPTMON&REPTYEAR
          OUT =CARD(KEEP=ACCTNO1 RENAME=(ACCTNO1=ACCTNO)) NODUPKEY;
   BY ACCTNO1;
RUN;

DATA EBANK;
   INFILE EBKFILE;
   INPUT @001 ACCTNO     20.;   /* ACCOUNT NUMBER               */
   EBANK='Y';
         ;
RUN;
PROC SORT DATA=EBANK NODUPKEY;BY ACCTNO;RUN;

DATA PIDM.DEPOSIT;
   MERGE PIDM.DEPOSIT(IN=A) CARD(IN=B) EBANK(IN=C);
   BY ACCTNO;
   IF A AND B AND C THEN ATMCARD = 2;
   ELSE IF A AND B  THEN ATMCARD = 1;
   ELSE IF A AND C  THEN ATMCARD = 3;
   ELSE                  ATMCARD = 4;
   IF A;
RUN;

DATA PIDM.CISINFO;
   SET CISCA.DEPOSIT(RENAME=(GENDER=GENDER1 RACE=RACE1))
       CISDP.DEPOSIT(RENAME=(GENDER=GENDER1 RACE=RACE1));
   /* SMR 2021-4244 */
   IF SECCUST = '902' AND
      CACCCODE IN ('014','017','018','019','021') THEN DELETE;

   IF      GENDER1 = 'M' THEN
      GENDER = 1;
   ELSE IF GENDER1 = 'F' THEN
      GENDER = 2;
   ELSE
      GENDER = 0;

   IF      RACE1= '1'    THEN
      RACE = 1;
   ELSE IF RACE1= '2'    THEN
      RACE = 3;
   ELSE IF RACE1= '3'    THEN
      RACE = 4;
   ELSE IF RACE1= '4'    THEN
      RACE = 2;
   ELSE IF RACE1='OTHER' THEN
      RACE = 5;
   ELSE
      RACE = 6;

   NEWIC = COMPRESS(NEWIC);

RUN;
PROC SORT DATA=PIDM.CISINFO;
   BY ACCTNO;
RUN;

DATA PIDM.CISDEPOSIT;
   MERGE PIDM.DEPOSIT(IN=A DROP=RACE MAILCODE) PIDM.CISINFO;
   BY ACCTNO;
   IF A AND SECCUST='901';
RUN;

PROC SORT DATA=MISCA.FORATEBKP OUT=FORATE;
   BY CURCODE DESCENDING REPTDATE;
   WHERE REPTDATE<= &TDATE;
RUN;
PROC SORT DATA=FORATE NODUPKEY; BY CURCODE; RUN;

DATA FOFMT;
  LENGTH START $3. LABEL $13.7 FMTNAME $6. TYPE $1.;
  SET FORATE;
  START = CURCODE;
  LABEL = SPOTRATE;
  FMTNAME = 'FORATE';
  TYPE = 'C';
RUN;
PROC FORMAT CNTLIN=FOFMT;
RUN;

DATA PIDM.FDCD;
   SET IMNIFD.FD MNIFD.FD;
   KEEP ACCTNO CDNO PLACEMENTRENEWDATE MATURITYDATE GROSSRATE PSR
        TENOR LASTINTDIVPMT RATENETGIARATE AVAILABLEBAL FXAVAILABLEBAL
        CURCODE;
   RENAME CDNO=CERTNUM ACCTNO=ACCNUM CURCODE=CURRENCYCODE;
   FORMAT PSR 2.;

   IF (3000<=COSTCTR<=4999) THEN
      BUSSTYPE = 1;                    /* 1 - ISLAMIC      */
   ELSE
      BUSSTYPE = 2;                    /* 2 - CONVENTIONAL */

   IF MATID EQ 'M' THEN TENOR = TERM*30;
   ELSE                 TENOR = TERM;

   IF LMATDATE NOT IN (.,0) THEN
      PLACEMENTRENEWDATE=INPUT(SUBSTR(PUT(LMATDATE,Z11.),1,8),MMDDYY8.);
   ELSE
      PLACEMENTRENEWDATE=INPUT(SUBSTR(PUT(ORGDATE,Z9.),1,6),MMDDYY6.);

   IF MATDATE NOT IN (.,0) THEN
      MATURITYDATE  = INPUT(SUBSTR(PUT(MATDATE,Z8.),1,8),YYMMDD8.);

   IF INTDATE NOT IN (.,0) THEN
      LASTINTDIVPMT = INPUT(SUBSTR(PUT(INTDATE,Z9.),1,6),MMDDYY6.);

   AVAILABLEBAL   = CURBAL;          /* RM AVAILABLE DEPOSIT BALANCE*/
   FXAVAILABLEBAL = CURBAL;                /* FX AVAILABLE DEPOSIT  */
   IF CURCODE NE 'MYR' THEN DO;
      FXRATE      = PUT(CURCODE,$FORATE.); /* CURRENCY EXCH. RATE   */
      FXAVAILABLEBAL = FORBAL;             /* FX AVAILABLE DEPOSIT  */
   END;

   RATENETGIARATE = RATE;
   IF BUSSTYPE = 1 THEN DO;
      PSR      = SUBSTR(COMPRESS(PRORATIO),1,2);
      GROSSRATE= (RATE*100)/PSR;
   END;
   ELSE DO;
      PSR      = 0;
      GROSSRATE= 0;
   END;
RUN;

PROC SORT DATA=PIDM.FDCD; BY ACCNUM CERTNUM; RUN;

