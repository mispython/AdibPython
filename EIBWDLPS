OPTIONS SORTDEV=3390 YEARCUTOFF=1950;

DATA DATES;
   SET BNM.REPTDATE;
   SELECT(DAY(REPTDATE));
     WHEN (8)  DO; SDD = 1;  WK = '01'; WK1 = '04'; END;
     WHEN(15)  DO; SDD = 9;  WK = '02'; WK1 = '01'; END;
     WHEN(22)  DO; SDD = 16; WK = '03'; WK1 = '02'; END;
     OTHERWISE DO; SDD = 23; WK = '04'; WK1 = '03'; END;
   END;
   CALL SYMPUT('NOWK',PUT(WK,$2.));
   CALL SYMPUT('NOWK1',PUT(WK1,$2.));
   CALL SYMPUT('REPTDAY',PUT(DAY(REPTDATE),Z2.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));
RUN;

%LET STRING = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ=`&-/\@#*+:().,"%�!$?_ ';
%LET NUMBER = '0123456789';
%LET ZERO   = '0';
%LET FALSIC = ('1234567'
              ,'12345678'
              ,'123456789'
              ,'0123456789'
              ,'SA9999'
              ,'SA99999'
              ,'999999A'
              ,'999999W'
              ,'999999X'
              );

PROC SORT DATA=CISR.DEPOSIT
   OUT=CISRM (KEEP=ACCTNO CUSTNO NEWIC OLDIC PRIPHONE SECPHONE
                   MOBIPHON BUSSREG NEWICIND);
   BY ACCTNO;
RUN;

PROC SORT DATA=CISD.DEPOSIT
   OUT=CISDP (KEEP=ACCTNO CUSTNO NEWIC OLDIC PRIPHONE SECPHONE
                   MOBIPHON BUSSREG NEWICIND);
   BY ACCTNO;
RUN;

PROC SORT DATA=CISL.LOAN
   OUT=CISLN (KEEP=ACCTNO CUSTNO NEWIC OLDIC PRIPHONE SECPHONE
                   MOBIPHON BUSSREG NEWICIND);
   BY ACCTNO;
RUN;

PROC SORT DATA=CARD.UNICARD&REPTYEAR&REPTMON&NOWK
   OUT=CCARD(KEEP=CARDNO CUSTNBR NEWIC OLDIC BUSTELNO HOMTELNO
                  HPHONENO);
   WHERE CLOSECD IN ('',' ') AND RECLASS IN ('',' ');
   BY CUSTNBR;
RUN;

PROC SUMMARY DATA=CCARD;
   BY CUSTNBR;
   OUTPUT OUT=CARD;
RUN;
PROC SORT DATA=CARD; BY DESCENDING _FREQ_; RUN;

DATA CARD;
   SET CARD (OBS=1);
   CALL SYMPUT('C',SUM(_FREQ_,2));
   CALL SYMPUT('CARD',CAT('CARD',SUM(_FREQ_,2)));
RUN;

PROC TRANSPOSE DATA=CCARD OUT=TRANPCARD (DROP=_NAME_) PREFIX=CARD;
   VAR CARDNO;
   COPY NEWIC OLDIC BUSTELNO HOMTELNO HPHONENO;
   BY CUSTNBR;
RUN;

DATA BASECARD;
   ARRAY CARD $16. CARD1-&CARD;
   IF CARD1 NOT IN ('',' ');
RUN;

DATA TRANPCARD;
   SET TRANPCARD BASECARD;
   IF NEWIC IN ('',' ') THEN NEWIC = OLDIC;
   RENAME CUSTNBR=CUSTNO HOMTELNO=PRIPHONE
          BUSTELNO=SECPHONE HPHONENO=MOBIPHON;
RUN;

DATA COLL;
   SET ICOLL.COLLATER (KEEP=ACCTNO CCOLLNO)
        COLL.COLLATER (KEEP=ACCTNO CCOLLNO);
RUN;
PROC SORT DATA=COLL; BY ACCTNO; RUN;

DATA CISRM (DROP=ACCTNO CUSTNO CCOLLNO);
   FORMAT ACCTNO1 $10.
          CUSTNO1 $10.
          COLLNO1 $10.
          ;
   MERGE CISRM(IN=A) COLL;
   BY ACCTNO;
   IF A;
   ACCTNO1 = ACCTNO;
   CUSTNO1 = CUSTNO;
   COLLNO1 = CCOLLNO;
RUN;

DATA CISDP (DROP=ACCTNO CUSTNO CCOLLNO);
   FORMAT ACCTNO1 $10.
          CUSTNO1 $10.
          COLLNO1 $10.
          ;
   MERGE CISDP(IN=A) COLL;
   BY ACCTNO;
   IF A;
   ACCTNO1 = ACCTNO;
   CUSTNO1 = CUSTNO;
   COLLNO1 = CCOLLNO;
RUN;

DATA CISLN (DROP=ACCTNO CUSTNO CCOLLNO);
   FORMAT ACCTNO1 $10.
          CUSTNO1 $10.
          COLLNO1 $10.
          ;
   MERGE CISLN(IN=A) COLL;
   BY ACCTNO;
   IF A;
   ACCTNO1 = ACCTNO;
   CUSTNO1 = CUSTNO;
   COLLNO1 = CCOLLNO;
RUN;

DATA CIS;
   SET CISRM (RENAME=(ACCTNO1=ACCTNO CUSTNO1=CUSTNO COLLNO1=CCOLLNO))
       CISDP (RENAME=(ACCTNO1=ACCTNO CUSTNO1=CUSTNO COLLNO1=CCOLLNO))
       CISLN (RENAME=(ACCTNO1=ACCTNO CUSTNO1=CUSTNO COLLNO1=CCOLLNO))
       ;
   IF NEWIC IN ('',' ') THEN DO;
      NEWICIND = 'OC';
      NEWIC    = OLDIC;
   END;
RUN;

PROC SORT DATA=CIS; BY NEWIC; RUN;
PROC SORT DATA=TRANPCARD; BY NEWIC; RUN;

DATA CISCARD;
   MERGE CIS (IN=A) TRANPCARD (IN=B);
   BY NEWIC;
RUN;

DATA CISCARD;
   SET CISCARD;
   NEWIC    = COMPRESS(NEWIC);
   ACCTNO   = COMPRESS(ACCTNO);
   CUSTNO   = COMPRESS(CUSTNO);
   PRIPHONE = COMPRESS(PRIPHONE,&NUMBER,'K');
   SECPHONE = COMPRESS(SECPHONE,&NUMBER,'K');
   MOBIPHON = COMPRESS(MOBIPHON,&NUMBER,'K');
   BUSSREG  = COMPRESS(BUSSREG);
   CCOLLNO  = COMPRESS(CCOLLNO);
RUN;

 /*** REMOVE LEADING ZERO ***/
DATA TEMP;
   SET CISCARD;
   FORMAT PHONE1 PHONE2 PHONE3 10.;
   PHONE1 = PRIPHONE;
   PHONE2 = SECPHONE;
   PHONE3 = MOBIPHON;
RUN;

DATA CISCARD (DROP=I PHONE1 PHONE2 PHONE3);
   SET TEMP;
   FORMAT PR1PH0N3 S3CPH0N3 M0B1PH0N $10.;
   PR1PH0N3 = LEFT(PHONE1);
   S3CPH0N3 = LEFT(PHONE2);
   M0B1PH0N = LEFT(PHONE3);

   ARRAY CARD $16. CARD1-&CARD;
   DO I=1 TO &C;
      IF CARD(I) IN ('',' ') THEN CARD(I) = '###**###';
   END;

   IF NEWIC    IN ('','.') THEN NEWIC    = '###**###';
   IF ACCTNO   IN ('','.') THEN ACCTNO   = '###**###';
   IF CUSTNO   IN ('','.') THEN CUSTNO   = '###**###';
   IF PRIPHONE IN ('','.') THEN PRIPHONE = '###**###';
   IF SECPHONE IN ('','.') THEN SECPHONE = '###**###';
   IF MOBIPHON IN ('','.') THEN MOBIPHON = '###**###';
   IF BUSSREG  IN ('','.') THEN BUSSREG  = '###**###';
   IF CCOLLNO  IN ('','.') THEN CCOLLNO  = '###**###';
RUN;

DATA DLP.CUSTDATA;
   SET CISCARD;
   NUMCHECK = COMPRESS(NEWIC,&NUMBER);
   STRCHECK = COMPRESS(NEWIC,&STRING);
   ZROCHECK = COMPRESS(NEWIC,&ZERO);
   ZRCHKPRI = COMPRESS(PR1PH0N3,&ZERO);
   ZRCHKSEC = COMPRESS(S3CPH0N3,&ZERO);
   ZRCHKMOB = COMPRESS(M0B1PH0N,&ZERO);

   /*** FILTERING NEWIC ***/
   IF NEWICIND = 'IC' AND LENGTH(NEWIC) < 12 THEN
                                 NEWIC    = '###**###';
   IF NEWICIND = 'OC' AND LENGTH(NEWIC) < 7  THEN
                                 NEWIC    = '###**###';
   IF NEWICIND IN ('SA','PC','BC') THEN
                                 NEWIC    = '###**###';
   IF NUMCHECK = ' '  AND LENGTH(NEWIC) < 6  THEN
                                 NEWIC    = '###**###';
   IF STRCHECK = ' '        THEN NEWIC    = '###**###';
   IF NEWIC IN &FALSIC      THEN NEWIC    = '###**###';
   IF LENGTH(NEWIC)    < 4  THEN NEWIC    = '###**###';
   IF ZROCHECK = ' '        THEN NEWIC    = '###**###';

   /*** FILTERING CONTACT NUMBER ***/
   IF LENGTH(PR1PH0N3) < 8  THEN PRIPHONE = '###**###';
   IF LENGTH(S3CPH0N3) < 8  THEN SECPHONE = '###**###';
   IF LENGTH(M0B1PH0N) < 8  THEN MOBIPHON = '###**###';
   IF ZRCHKPRI = ' ' OR LENGTH(ZRCHKPRI) < 4 THEN
                                 PRIPHONE = '###**###';
   IF ZRCHKSEC = ' ' OR LENGTH(ZRCHKSEC) < 4 THEN
                                 SECPHONE = '###**###';
   IF ZRCHKMOB = ' ' OR LENGTH(ZRCHKMOB) < 4 THEN
                                 MOBIPHON = '###**###';

   DROP NUMCHECK STRCHECK ZROCHECK ZRCHKPRI ZRCHKSEC ZRCHKMOB
        PR1PH0N3 S3CPH0N3 M0B1PH0N;
RUN;

PROC CONTENTS DATA=DLP.CUSTDATA OUT=DLP (KEEP=NOBS); RUN;

DATA DLP;
   SET DLP (OBS=1);
   OBSTART = 1;
   OBSNUM  = 5000000;
   NUMFILE = CEIL(NOBS/OBSNUM);
   CALL SYMPUT('OBSTART', OBSTART);
   CALL SYMPUT('OBSINIT', OBSNUM);
   CALL SYMPUT('OBSNUM', OBSNUM);
   CALL SYMPUT('NUMFILE', NUMFILE);
RUN;

%MACRO PRINT;
   %DO I=1 %TO &NUMFILE;
      DATA _NULL_;
         CALL SYMPUT('NO', PUT(&I,Z3.));
      RUN;
      FILENAME CIS&I "SAP.PBB.DLP.C&NO..TEXT"
               DISP=(NEW,CATLG,DELETE) SPACE=(CYL,(100,50))
               RECFM=VB LRECL=450 BLKSIZE=0;

      DATA _NULL_;
         SET DLP.CUSTDATA (FIRSTOBS=&OBSTART OBS=&OBSNUM);
         FILE CIS&I;
         PUT @001 NEWIC    +(-1)'|'
                  PRIPHONE +(-1)'|'
                  SECPHONE +(-1)'|'
                  MOBIPHON +(-1)'|'
               /* CUSTNO   +(-1)'|' */
                  ACCTNO   +(-1)'|'
               /* CCOLLNO  +(-1)'|' */
                  BUSSREG  +(-1)'|'
                  @;

         ARRAY CARD $16. CARD1-&CARD;
         DO I=1 TO &C;
            IF I < &C THEN
               PUT CARD(I) +(-1)'|' @;
            ELSE
               PUT CARD(I);
         END;

         OBSNUM  = SUM(&OBSINIT,&OBSNUM);
         OBSTART = SUM(&OBSNUM,1);
         CALL SYMPUT('OBSTART', OBSTART);
         CALL SYMPUT('OBSNUM', OBSNUM);
      RUN;
   %END;
%MEND;
%PRINT;

DATA _NULL_;
   FILE SFTP;
   DO I=1 TO &NUMFILE;
     NO = PUT(I,Z3.);
     FILES = CAT("//SAP.PBB.DLP.C",NO,".TEXT","  DLP",NO,".CSV");
     PUT @001 'PUT'
         @005 FILES
         ;
   END;
RUN;

