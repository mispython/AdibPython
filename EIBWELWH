     PROC SORT DATA=ELN4 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=EHP4 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=ELN7 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=ELN8 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=EHP8 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=ELN10 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=EHP10 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=EHP11 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=EHP13 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=EHP18 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=EHP19 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=ELN20 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=ELN22 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=EHP21 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=EHP22 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=ELN26 NODUPRECS; BY MAANO;RUN;
     PROC SORT DATA=ELN30 NODUPRECS; BY MAANO;RUN;

     DATA PREHP;
        MERGE EHP4 EHP8 EHP10 EHP11 EHP13 EHP18 EHP19 EHP21 EHP22;
        BY MAANO;
     RUN;

     DATA PREAA;
        MERGE ELN4 ELN8 ELN22 ELN26 ELN10 ELN30;
        BY MAANO;
     RUN;

     DATA ENDCOM;
        SET PREAA PREHP;
     RUN;
     *;
     PROC SORT DATA=ELN; BY MAANO; RUN;
     PROC SORT DATA=ELN10; BY MAANO; RUN;
     PROC SORT DATA=EHP17; BY MAANO; RUN;
     PROC SORT DATA=ELN17; BY MAANO; RUN;
     *;
     DATA ELN17;
        MERGE EHP17 ELN17;
        BY MAANO;
     RUN;
     *;
     DATA ELN;
        MERGE ELN(IN=A) ELN17(IN=B) ELN20;
        BY MAANO;
        IF A;
     RUN;
     *;
     PROC SORT DATA=ENDCOM;BY MAANO;RUN;
     PROC SORT DATA=ELN;BY MAANO;RUN;
     *;
     DATA ELN;
        MERGE ELN(IN=B) ENDCOM(IN=A); BY MAANO;
        IF B;
     RUN;
     *;
     PROC SORT DATA=ELN; BY MAANO AANO;RUN;
     PROC SORT DATA=ELN7; BY MAANO AANO;RUN;
     DATA ELN;
        MERGE ELN(IN=B) ELN7(IN=A); BY MAANO AANO;
        IF B;
     RUN;
     PROC SORT DATA=ELN; BY MAANO AANO STATUS AADATE; RUN;
     *;
     DATA ELN ELNDUP;
        SET ELN;
        BY MAANO AANO STATUS AADATE;
        IF FIRST.MAANO OR FIRST.AANO OR FIRST.STATUS OR FIRST.AADATE
           THEN DO;
           OUTPUT ELN;
           END;
        ELSE OUTPUT ELNDUP;
     RUN;
     *;
     DATA ELN(DROP=MA);
        MERGE ELN(IN=A) ELN17(IN=B);
        BY MAANO;
        IF AANO = ' ' THEN DELETE;
        IF A AND B THEN DO;
           IF APVBY = 'BR' THEN MARGIN = MA;
           IF APVBY = 'HO' THEN DO;
              IF APPL NE ' ' THEN DO;
                 IF APPLMRG NE ' ' THEN MARGIN = APPLMRG;
              END;
              ELSE DO;
                 IF MRGADVE NE ' ' THEN MARGIN = MRGADVE;
              END;
           END;
           IF MA NE . THEN MARGIN = MA;
        END;
        IF A AND NOT B THEN DO;
           IF APVBY = 'BR' THEN MARGIN = MARGIN;
           IF APVBY = 'HO' THEN DO;
              IF APPL NE ' ' THEN DO;
                 IF APPLMRG NE ' ' THEN MARGIN = APPLMRG;
              END;
              ELSE DO;
                 IF MRGADVE NE ' ' THEN MARGIN = MRGADVE;
              END;
           END;
        END;
        MARGIN = COMPRESS(MARGIN);
     RUN;
     *;
     *** CONVENTIONAL + ISLAMIC ***;
     DATA ELDS1.ELN&REPTMON&NOWK&REPTYEAR;
        SET ELN; IF BRANCH LT 3000;
        DROP HALAL_ENGAGE_FLG;
     RUN;
     DATA ELDS1.ELNDUP&REPTMON&NOWK&REPTYEAR;
