*****************************************;
*            COUNT AANO                 *;
*****************************************;
DATA AA;
   INFILE ELNAA FIRSTOBS=2;
   INPUT @1 COUNT 10.;
   CALL SYMPUT('COUNT',PUT(COUNT,10.));
RUN;

DATA HP;
   INFILE ELNHP FIRSTOBS=2;
   INPUT @1 COUNTHP 10.;
RUN;

PROC SQL NOPRINT;
   SELECT PUT(SUM(COUNTHP),BEST. -L) INTO :COUNTHP
   FROM HP;
QUIT;

DATA ELNOUT(KEEP=AANO DESC);
SET ELN1(IN=A) ELN2(IN=B) ELN3(IN=C) EHP1(IN=D) EHP2(IN=E) EHP3(IN=F);
   IF A THEN DESC='ELN1';
   IF B THEN DESC='ELN2';
   IF C THEN DESC='ELN3';
   IF D THEN DESC='EHP1';
   IF E THEN DESC='EHP2';
   IF F THEN DESC='EHP3';
RUN;

PROC SUMMARY DATA=ELNOUT NWAY;
CLASS DESC;
OUTPUT OUT=ELNOUTT;
RUN;

PROC PRINT DATA=ELNOUTT;
RUN;

DATA AP;
   SET ELNOUTT;
   IF DESC='ELN1' THEN DO;
      COUNTELDS="&COUNT";
      COUNTMIS=_FREQ_;
      IF COUNTMIS=COUNTELDS THEN DO;
         STATUS="OK    ";
      END;
      ELSE STATUS="NOT OK";
   END;
   ELSE IF DESC='ELN2' THEN DO;
      COUNTELDS="&COUNT";
      COUNTMIS=_FREQ_;
      IF COUNTMIS=COUNTELDS THEN DO;
         STATUS="OK    ";
      END;
      ELSE STATUS="NOT OK";
   END;
   ELSE IF DESC='ELN3' THEN DO;
      COUNTELDS="&COUNT";
      COUNTMIS=_FREQ_;
      IF COUNTMIS=COUNTELDS THEN DO;
         STATUS="OK    ";
      END;
      ELSE STATUS="NOT OK";
   END;
   ELSE IF DESC='EHP1' THEN DO;
      COUNTELDS="&COUNTHP";
      COUNTMIS=_FREQ_;
      IF COUNTMIS=COUNTELDS THEN DO;
         STATUS="OK    ";
      END;
      ELSE STATUS="NOT OK";
   END;
   ELSE IF DESC='EHP2' THEN DO;
      COUNTELDS="&COUNTHP";
      COUNTMIS=_FREQ_;
      IF COUNTMIS=COUNTELDS THEN DO;
         STATUS="OK    ";
      END;
      ELSE STATUS='NOT OK';
   END;
   ELSE IF DESC='EHP3' THEN DO;
      COUNTELDS="&COUNTHP";
      COUNTMIS=_FREQ_;
      IF COUNTMIS=COUNTELDS THEN DO;
         STATUS="OK    ";
      END;
      ELSE STATUS="NOT OK";
   END;

   PROC PRINT DATA=AP;RUN;

DATA CHECKING;
   SET AP;
   IF (DESC='ELN1' AND STATUS='NOT OK') OR
      (DESC='EHP1' AND STATUS='NOT OK') THEN
      ABORT 77;
RUN;

