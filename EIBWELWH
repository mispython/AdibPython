     DATA IELDS1.IELN&REPTMON&NOWK&REPTYEAR;
        SET ELN; IF BRANCH GE 3000;
     RUN;
     DATA IELDS1.IELNDUP&REPTMON&NOWK&REPTYEAR;
        SET ELNDUP; IF BRANCH GE 3000;
     RUN;
     DATA IELDS2.IELN&REPTMON&NOWK&REPTYEAR;
        SET ELN; IF BRANCH GE 3000;
     RUN;
     DATA IELDS2.IELNDUP&REPTMON&NOWK&REPTYEAR;
        SET ELNDUP; IF BRANCH GE 3000;
     RUN;

     PROC PRINT DATA=IELDS1.IELN&REPTMON&NOWK&REPTYEAR (OBS=50);
        FORMAT AADATE LODATE APVDTE1 APVDTE2 DATE8.;
     RUN;
     FILENAME TRANFILE 'SAP.PIBB.ELDATAWH.IELFTP' DISP=OLD;
     PROC CPORT LIBRARY=IELDS1 FILE=TRANFILE;
     RUN;
  %END;
  %ELSE %DO;
     %IF "&ELDSDT1" NE "&RDATE" OR
         "&ELDSDT2" NE "&RDATE" OR
         "&ELHPDT1" NE "&RDATE" OR
         "&ELHPDT2" NE "&RDATE" %THEN
         %PUT THE SAP.PBB.ELDS.BNM.TEXT(0) IS NOT DATED &RDATE;
