//*
//EIBMFYCA  EXEC SAS609
//DPTRBL    DD DSN=SAP.PBB.MNITB.DAILY(0),DISP=SHR
//MNIFD     DD DSN=SAP.PBB.MNIFD.DAILY(0),DISP=SHR
//MIS       DD DSN=SAP.PBB.FCYCA,DISP=SHR
