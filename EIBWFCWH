//CISD      DD DSN=SAP.PBB.CISBEXT.DP.DAILY,DISP=SHR
//RAWFD     DD DSN=RBP2.B033.CIS.SAS.FCYFDRMK,DISP=SHR
//PGM       DD DSN=SAP.BNM.PROGRAM,DISP=SHR
