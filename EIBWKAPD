//EIBWKAPD JOB MISEIS,MSGCLASS=A,CLASS=A,NOTIFY=&SYSUID
//*
//* SMR 2005-1374.
//* WEEKLY - 9/26/23/MONTH-END. AFTER EIBDKAPD
//*
//PRINT1    OUTPUT CLASS=R,
//          NAME='MS TANG SOONG YEE (TFY)',
//          ROOM='26TH FLOOR',
//          BUILDING='MENARA PBB',
//          DEPT='FINANCE DIV',
//          ADDRESS='JALAN AMPANG',
//          DEST=S1.RMT5
//*
//EIBWKAPD EXEC SAS609
//PGM       DD DSN=SAP.BNM.PROGRAM,DISP=SHR
//LOAN      DD DSN=SAP.PBB.MNILN(0),DISP=SHR
//BNMK      DD DSN=SAP.PBB.DKAPITI.SASDATA,DISP=SHR
//ELG       DD DSN=SAP.PBB.GOLD.SASDATA,DISP=SHR
//*SASLIST   DD SYSOUT=(,),OUTPUT=(*.PRINT1)
//SASLIST   DD SYSOUT=(,)
//SYSIN     DD *

OPTIONS SORTDEV=3390 YEARCUTOFF=1950 LS=132 PS=60 NOCENTER
        NODATE MISSING=0;
*;
DATA REPTDAT1;
  SET LOAN.REPTDATE;
  SDESC='PUBLIC BANK BERHAD';
  CALL SYMPUT('RPDATE',PUT(REPTDATE,DDMMYY8.));
  CALL SYMPUT('RDATE',PUT(REPTDATE,DDMMYY8.));
  CALL SYMPUT('RYEAR',PUT(REPTDATE,YEAR4.));
  CALL SYMPUT('MTHNAM',PUT(REPTDATE,MONNAME.));
  CALL SYMPUT('SDESC',PUT(SDESC,$26.));
  CALL SYMPUT('DATE',REPTDATE);
  CALL SYMPUT('MTHEND',PUT(DAY(REPTDATE),Z2.));
*;
DATA REPTDATE;
  SET BNMK.REPTDATE;
  MM  =MONTH(SXDATE);
  SELECT;
     WHEN  (01<=DAY(SXDATE)<=08) DO; WK = '4'; END;
     WHEN  (09<=DAY(SXDATE)<=15) DO; WK = '1'; END;
     WHEN  (16<=DAY(SXDATE)<=22) DO; WK = '2'; END;
     OTHERWISE DO; WK='3'; END;
  END;
  IF WK='4'  THEN DO;
     MM1=MM-1;
     IF MM1=0  THEN MM1=12;
     MM=MM1;
     IF MM=12 THEN SXDATE=MDY(1,1,YEAR(SXDATE))-1;
  END;
  CALL SYMPUT('NOWK',PUT(WK,$1.));
  CALL SYMPUT('WK',PUT(WK,$1.));
  CALL SYMPUT('REPTMON',PUT(MM,Z2.));
  CALL SYMPUT('RPDATE',PUT(SXDATE,DDMMYY8.));
  CALL SYMPUT('RPYEAR',PUT(SXDATE,YEAR4.));
  CALL SYMPUT('REPTYEAR',PUT(SXDATE,YEAR4.));
  CALL SYMPUT('YEAR',PUT(SXDATE,YEAR2.));
RUN;
LIBNAME BNM  "SAP.PBB.D&REPTYEAR" DISP=SHR;
RUN;
*;
DATA REP2;
   SET BNMK.REP2&REPTMON&WK;
   IF  UTSTY IN ('CB1','CF1','CNT','SAC','SMC','ISB') THEN DO;
       IF UTREF NOT IN ('DLG','IDLG') THEN DELETE;
   END;
*;
DATA REP4;
   SET BNMK.REP4&REPTMON&WK;
   IF  UTSTY IN ('CB1','CF1','CNT','SAC','SMC','ISB') THEN DO;
       IF UTREF NOT IN ('DLG','IDLG') THEN DELETE;
   END;
*;
%INC PGM(PBBELQ);
*;
DATA REP2;
   SET REP2 REP4;
   IF  BNMCODE='3250000000000Y' THEN DO;
       UTSTY='REV'; UTREF='REPO '; AMOUNT=NETAMT;
   END;
   IF  BNMCODE='3752000000000Y' THEN BNMCODE='3552000000000Y';
   BNMCODG=BNMCODE||'-'||UTSTY||' '||SUBSTR(UTREF,1,5);
RUN;
*;
PROC SORT; BY BNMCODG;
*;
TITLE1 'PUBLIC BANK BERHAD -REPORT DATE ' &RDATE;
TITLE2 'SPECIFIED & NON-SPECIFIED RENTAS SECURITIES FROM TRADING BOOK';
TITLE3 '(DAILY KAPITI STOCK REPORT) WEEK' &WK &MTHNAM ' ' &RYEAR;
PROC TABULATE DATA=REP2 MISSING;
     CLASS BNMCODG ELDAY;
     VAR   AMOUNT;
     TABLE (BNMCODG='BNMCODE' ALL='TOTAL RM MARKETABLE SECURITIES'),
     ELDAY*SUM=' '*AMOUNT=' '*F=COMMA16.2
   / BOX=' ' RTS=30;
RUN;
*;
PROC   SUMMARY DATA=REP2 NWAY;
CLASS  BNMCODE ELDAY;
VAR    AMOUNT;
OUTPUT OUT=REPOV (DROP=_TYPE_ _FREQ_) SUM=;
*;
DATA WALW;
   SET BNM.ELW&REPTMON&WK;
   IF  BNMCODE='3250001000000Y' THEN BNMCODE='3250000000000Y';
   OUTPUT;
   IF  BNMCODE='3551000000000Y' THEN DO;
       BNMCODE='3552000000000Y';
       OUTPUT;
   END;
*;
PROC   SUMMARY DATA=WALW NWAY;
CLASS  BNMCODE ELDAY;
VAR    AMOUNT;
OUTPUT OUT=WALW (DROP=_TYPE_ _FREQ_) SUM=WALWAMT;
*;
DATA REP2;
   MERGE REPOV(IN=A) WALW(IN=B); BY BNMCODE ELDAY;
   IF A;
   VARIANC=AMOUNT-WALWAMT;
RUN;
*;
TITLE  'VARIANCE BETWEEN KAPITI AND WALKER';
PROC TABULATE DATA=REP2 MISSING;
     CLASS BNMCODE ELDAY;
     VAR   AMOUNT WALWAMT VARIANC;
     TABLE BNMCODE='BNMCODE' ALL='TOTAL ',ELDAY*SUM=' '*
     (AMOUNT ='KAPITI '*F=COMMA16.2
      WALWAMT='WALKER '*F=COMMA16.2
      VARIANC='VARIANCE '*F=COMMA16.2)
   / BOX=' ' RTS=34;
RUN;
*;
DATA REP2;
   SET BNMK.REP2&REPTMON&WK;
   IF  UTSTY IN ('CB1','CF1','CNT','SAC','SMC','ISB') THEN DO;
       IF UTREF NOT IN ('DLG','IDLG') THEN DELETE;
   END;
*;
DATA REP0;
   SET REP2;
   IF BNMCODE='3250000000000Y';
   BNMCODG=BNMCODE||'-'||UTSTY||' '||SUBSTR(UTREF,1,5);
*;
TITLE 'REV REPO AT PURCHASE PROCEEDS';
PROC TABULATE DATA=REP0 MISSING;
     CLASS BNMCODG ELDAY;
     VAR   AMOUNT COSTDED NETAMT;
     TABLE BNMCODG='BNMCODE' ALL='TOTAL ',ELDAY*SUM=' '*
     (AMOUNT ='AMOUNT'*F=COMMA16.2
      COSTDED='(-) PURC PROC.'*F=COMMA16.2
      NETAMT ='MARKET SEC '*F=COMMA16.2)
   / BOX=' ' RTS=30;
*;
