//EIBWLMTE JOB MISEIS,EIBWLMTE,CLASS=A,MSGCLASS=X,MSGLEVEL=(1,1),
//         NOTIFY=&SYSUID
/*JOBPARM S=S1M2
//**********************************************************************
//* EXTRACTION OF LIMIT FOR OVERDRAFT ACCOUNTS FROM FLAT FILE GIVEN
//*   BY DEPOSITS...RBP2.B033.LIMIT.DATASTOR.............
//**********************************************************************
//EIBWLMTE  EXEC SAS609,REGION=8M,WORK='6000,6000'
//*CONFIG   DD DISP=SHR,DSN=SYS3.SAS.V609.CNTL(BATCHXA)
//DPLIMIT   DD DSN=RBP2.B033.LIMIT.DATASTOR,DISP=SHR
//DPLMTEX   DD DSN=RBP2.B033.LIMIT.EXTEND.DLY,DISP=SHR
//ODREVIEW  DD DSN=RBP2.B033.ODREVIEW(0),DISP=SHR
//GP3PRO    DD DSN=RBP2.B033.GP3.DATACHG,DISP=SHR
//LIMIT     DD DSN=SAP.PBB.MNILIMT(+1),DISP=(NEW,CATLG,DELETE),
//             DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),
//             SPACE=(CYL,(40,10)),UNIT=(,6)
//ILIMIT    DD DSN=SAP.PIBB.MNILIMT(+1),DISP=(NEW,CATLG,DELETE),
//             DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),
//             SPACE=(CYL,(40,10)),UNIT=(,6)
//SYSIN     DD *
OPTIONS YEARCUTOFF=1950 ERROR=1;

DATA LIMIT.REPTDATE
     ILIMIT.REPTDATE;
  INFILE DPLIMIT MISSOVER OBS=1;
  INPUT @001 TBDATE PD6.;
  REPTDATE=INPUT(SUBSTR(PUT(TBDATE, Z11.), 1, 8), MMDDYY8.);
  SELECT;
     WHEN(1 <= DAY(REPTDATE) <= 8) CALL SYMPUT('NOWK', PUT('1', $1.));
     WHEN(9 <= DAY(REPTDATE) <= 15) CALL SYMPUT('NOWK', PUT('2', $1.));
     WHEN(16 <= DAY(REPTDATE) <= 22) CALL SYMPUT('NOWK', PUT('3', $1.));
     OTHERWISE CALL SYMPUT('NOWK', PUT('4', $1.));
  END;
  CALL SYMPUT('REPTYEAR', PUT(REPTDATE, YEAR4.));
  CALL SYMPUT('REPTMON', PUT(MONTH(REPTDATE), Z2.));
  CALL SYMPUT('REPTDAY', PUT(DAY(REPTDATE), Z2.));
  CALL SYMPUT('RDATE', PUT(REPTDATE, DDMMYY8.));
RUN;
*;

%LET LIMITVAR=(KEEP=ACCTNO BRANCH LMTID LMTDESC LMTINDEX LMTBASER
                    LMTADJF LMTRATE LMTTYPE LMTAMT LMTCOLL NAME
                    PRODUCT OPENIND STATE RISKCODE EXCESSDT TODDATE
                    ODSTATUS APPRLIMT REVIEWDT LMTSTART LMTENDDT
                    LMTTERM LMTTRMID LMTINCR ODTEMADJ ODFEECTD
                    ODLMTDTE ODLMTDD ODLMTMM ODLMTYY INTERDUE
                    COMMFERT LINEFEWV LFEEYTD INTBLYTD ODLMTDTE
                    ODFDIND FDACNO FDRCNO COSTCTR CURODDT AUTOPRIC
                    CRISPURP CRRINI CRRNOW ODBASERT ODTEMPADJ
                    REFIN_FLG OLD_FI_CD OLD_MACC_NO OLD_SUBACC_NO
                    ASCORE_PERM ASCORE_LTST ASCORE_COMM);
%LET ODREVVAR=(KEEP=ACCTNO INTINCGR AVRCRBAL);
%LET LMTEXVAR=(KEEP=ACCTNO LMTID CLF_EXP_DT
                    CLIMATE_PRIN_TAXONOMY_CLASS
                    CLIMATE_MITIGATE_GP1_FLG
                    CLIMATE_ADAPT_GP2_FLG
                    CLIMATE_ENVIRONMT_GP3_FLG
                    CLIMATE_TRANSITION_GP4_FLG
                    CLIMATE_PROHIBIT_GP5_FLG CLF_WAKLH_FLG);

DATA ODREV &ODREVVAR;
  INFILE ODREVIEW FIRSTOBS = 1 MISSOVER;
  INPUT @004 ACCTNO      10.
        @016 DAYINMTH     3.
        @054 LEDBLMTD  PD10.2
        @084 INTINCGR  PD10.2;
  IF DAYINMTH > 0 THEN AVRCRBAL = LEDBLMTD / DAYINMTH;
RUN;
PROC SORT; BY ACCTNO; RUN;

DATA LIMIT &LIMITVAR;
  INFILE DPLIMIT FIRSTOBS = 2 MISSOVER;
  INPUT @001 ACCTNO      PD6.
        @007 BRANCH      PD4.
        @011 LMTID       PD2.
        @013 LMTDESC     $20.
        @033 LMTINDEX    PD2.
        @035 LMTBASER    PD5.6
        @040 LMTADJF     PD5.6
        @045 LMTRATE     PD5.6
        @050 LMTTYPE      $1.
        @051 LMTAMT      PD6.
        @057 LMTCOLL      $5.
        @062 NAME        $24.
        @086 PRODUCT     PD2.
        @088 OPENIND      $1.
        @089 STATE        $5.
        @094 RISKCODE     $1.
        @095 EXCESSDT    PD6.
        @101 TODDATE     PD6.
        @107 ODSTATUS     $2.
        @109 APPRLIMT    PD6.
        @115 REVIEWDT    PD6.
        @121 LMTSTART    PD6.
        @127 LMTENDDT    PD6.
        @133 LMTTERM     PD2.
        @135 LMTTRMID     $1.
        @136 LMTINCR      $1.
        @137 ODTEMADJ    PD3.3
        @140 ODFEECTD    PD10.9
        @150 ODLMTDTE     $8.
        @150 ODLMTDD      $2.
        @152 ODLMTMM      $2.
        @154 ODLMTYY      $4.
        @158 INTERDUE    PD6.2
        @164 COMMFERT    PD3.3   /* SMR-A289 */
        @167 LINEFEWV     $1.    /* SMR-A289 */
        @168 LFEEYTD     PD6.2   /* SMR-A331 */
        @174 COSTCTR     PD4.
        @178 INTBLYTD    PD6.2
        @200 FDACNO      PD6.    /* FD ACC. NO    */
        @206 FDRCNO      PD6.    /* FD RECEIPT NO */
        @212 CURODDT     PD6.
        @218 AUTOPRIC     $1.
        @219 LOANPURP    PD3.    /* LOAN PURPPOSE SMR2013-508 */
        @222 CRRINI       $5.    /* CRR INITIAL               */
        @227 CRRNOW       $5.    /* CRR LATEST                */
        @232 ODBASERT    PD3.3   /* BASE OD RATE              */
        @235 ODTEMPADJ   PD3.3   /* TEMP ADJ FACTOR           */
        @238 ASCORE_PERM  $9.    /* SMR2016-317 2022-5096 */
        @247 ASCORE_LTST  $9.    /* SMR2016-317 2022-5096 */
        @256 ASCORE_COMM  $12.   /* SMR2017-4001 2022-5096 */
        @268 REFIN_FLG     $1.   /* SMR2018-4186 2022-5096 */
        @269 OLD_FI_CD     $9.   /* SMR2018-4186 2022-5096 */
        @278 OLD_MACC_NO   $30.  /* SMR2018-4186 2022-5096 */
        @308 OLD_SUBACC_NO $30.  /* SMR2018-4186 2022-5096 */
        ;
  CRRINI = COMPRESS(CRRINI);
  CRRNOW = COMPRESS(CRRNOW);
  ASCORE_PERM = TRANSLATE(ASCORE_PERM,"[]","��");
  ASCORE_LTST = TRANSLATE(ASCORE_LTST,"[]","��");
  ASCORE_COMM = TRANSLATE(ASCORE_COMM,"[]","��");
  FORMAT CRISPURP $4.;
  CRISPURP = LOANPURP;
  IF FDACNO GT 0   THEN ODFDIND = 'Y'; /* OD TIED TO FD RATE */
  IF BRANCH NE 0   THEN OUTPUT LIMIT;
  DROP LOANPURP;
RUN;
PROC SORT; BY ACCTNO LMTID; RUN;

DATA LIMITEX &LMTEXVAR;
  INFILE DPLMTEX FIRSTOBS = 1 MISSOVER;
  INPUT @001 ACCTNO      PD6.
        @007 LMTID       PD2.
        @009 CLFEXPDT    PD6.
        @015 CLIMATE_PRIN_TAXONOMY_CLASS $3.
        @018 CLIMATE_MITIGATE_GP1_FLG   $1.
        @019 CLIMATE_ADAPT_GP2_FLG      $1.
        @020 CLIMATE_ENVIRONMT_GP3_FLG  $1.
        @021 CLIMATE_TRANSITION_GP4_FLG $1.
        @022 CLIMATE_PROHIBIT_GP5_FLG   $1.
        @023 CLF_WAKLH_FLG              $1.
        ;
  CLF_EXP_DT = INPUT(SUBSTR(PUT(CLFEXPDT,Z11.),1,8),MMDDYY8.);
RUN;
PROC SORT; BY ACCTNO LMTID; RUN;

DATA LIMIT;
     MERGE LIMIT(IN=A) LIMITEX;
     BY ACCTNO LMTID;
     IF A;
     IF LMTSTART GT 0 THEN
        LMTSTDTE = INPUT(SUBSTR(PUT(LMTSTART,Z11.),1,8),MMDDYY8.);
RUN;

DATA LIMIT.OVERDFT;
     MERGE LIMIT(IN=A) ODREV; BY ACCTNO;
     IF INTINCGR = . THEN INTINCGR = 0;
     IF A THEN OUTPUT;
RUN;
*;
PROC SORT DATA=LIMIT.OVERDFT; BY ACCTNO;
PROC SUMMARY DATA=LIMIT.OVERDFT;
BY ACCTNO; VAR LMTAMT;
OUTPUT OUT=LIMIT.LIMITS (DROP=_TYPE_ _FREQ_) SUM=;
*;

DATA GP31 (KEEP=ACCTNO EXCESSDT)
     GP32 (KEEP=ACCTNO TODDATE)
     GP33 (KEEP=ACCTNO RISKCODE)
     GP34 (KEEP=ACCTNO ODSTATUS);
   INFILE GP3PRO;
   FORMAT EXCESSDT TODDATE 11.;
   INPUT @08  ACCTNO   10.
         @23  RFIELD   $6. @;
         IF RFIELD EQ 'EXCDTE' THEN DO;
            INPUT @30 DATE 8. ;
         EXCESSDT = SUBSTR(PUT(DATE,Z8.),3,2) ||
                    SUBSTR(PUT(DATE,Z8.),1,2) ||
                    SUBSTR(PUT(DATE,Z8.),5,4) || '000';
         EXCESJUL = JULDATE(INPUT(SUBSTR(PUT(EXCESSDT,Z11.),1,8),
                            MMDDYY8.));
         EXCESSDT = SUBSTR(PUT(DATE,Z8.),3,2) ||
                    SUBSTR(PUT(DATE,Z8.),1,2) ||
                    SUBSTR(PUT(DATE,Z8.),5,4) ||
                    SUBSTR(PUT(EXCESJUL,Z5.),3,3);
         OUTPUT GP31;
         END;
         ELSE IF RFIELD EQ 'TMPDTE' THEN DO;
            INPUT @30 TDATE 8.;
         TODDATE = SUBSTR(PUT(TDATE,Z8.),3,2) ||
                   SUBSTR(PUT(TDATE,Z8.),1,2) ||
                   SUBSTR(PUT(TDATE,Z8.),5,4) || '000';
         TODJUL  = JULDATE(INPUT(SUBSTR(PUT(TODDATE,Z11.),1,8),
                            MMDDYY8.));
         TODDATE = SUBSTR(PUT(TDATE,Z8.),3,2) ||
                   SUBSTR(PUT(TDATE,Z8.),1,2) ||
                   SUBSTR(PUT(TDATE,Z8.),5,4) ||
                   SUBSTR(PUT(TODJUL,Z5.),3,3);
            OUTPUT GP32;
         END;
         ELSE IF RFIELD EQ 'USRCD4' THEN DO;
            INPUT @30 RISKCODE $1.;
            OUTPUT GP33;
         END;
         ELSE IF RFIELD EQ 'ODSTAT' THEN DO;
            INPUT @30 ODSTATUS $2.;
            OUTPUT GP34;
         END;
*;
PROC SORT DATA=GP34;
   BY ACCTNO;
*;
DATA LIMIT.GP3 (KEEP=ACCTNO RISKCODE ODSTATUS EXCESSDT TODDATE);
  MERGE GP31 GP32 GP33 GP34;
BY ACCTNO;
*;
PROC SORT DATA=LIMIT.GP3 NODUPKEYS;
  BY ACCTNO;
*;

 *** ISLAMIC ***;
DATA ILIMIT.OVERDFT
      LIMIT.OVERDFT;
   SET LIMIT.OVERDFT;
   IF (3000<=COSTCTR<=4999) THEN OUTPUT ILIMIT.OVERDFT;
   ELSE                          OUTPUT  LIMIT.OVERDFT;
RUN;

PROC SORT DATA=ILIMIT.OVERDFT; BY ACCTNO;
PROC SUMMARY DATA=ILIMIT.OVERDFT;
BY ACCTNO; VAR LMTAMT;
OUTPUT OUT=ILIMIT.LIMITS (DROP=_TYPE_ _FREQ_) SUM=;

PROC SORT DATA=ILIMIT.OVERDFT OUT=OD(KEEP=ACCTNO); BY ACCTNO; RUN;
PROC SORT DATA=LIMIT.GP3 OUT=GP3; BY ACCTNO; RUN;
DATA ILIMIT.GP3;
   MERGE OD(IN=A) GP3(IN=B);
   BY ACCTNO;
   IF A AND B;
RUN;
PROC SORT DATA=ILIMIT.GP3 NODUPKEYS;
  BY ACCTNO;

%MACRO MONTHLY;
   %IF "&NOWK" EQ "4" %THEN %DO;
       DATA LIMIT.OVERDFT;
          UPDATE LIMIT.OVERDFT(IN=A) LIMIT.GP3(IN=B);
          BY ACCTNO;
          IF A;

       DATA ILIMIT.OVERDFT;
          UPDATE ILIMIT.OVERDFT(IN=A) ILIMIT.GP3(IN=B);
          BY ACCTNO;
          IF A;

   %END;
   %ELSE %DO;
       DATA LIMIT.GP3;
          SET LIMIT.GP3;
          DELETE;

       DATA ILIMIT.GP3;
          SET ILIMIT.GP3;
          DELETE;
   %END;
%MEND MONTHLY;
*;
%MONTHLY;
*;
PROC PRINT DATA=LIMIT.OVERDFT(OBS=100); RUN;
*;
PROC PRINT DATA=LIMIT.REPTDATE; RUN;
