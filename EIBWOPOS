//EIBWOPOS JOB MSGCLASS=X,MSGLEVEL=(1,1),REGION=8M                      JOB02003
/*JOBPARM S=S1M1
//*****************************************************************/
//* GENERATE WEEKLY DATASET BASED ON INFORMATION EXTRACTED
//* BY LOANS & TRADE FINANCE.
//* LATEST POSITION M&I LOANS WRITTEN-OFF/WRITTEN-DOWN A/C INFO.
//* E-SMR : 2012-180 (MFM)
//*****************************************************************/
//DELETE   EXEC PGM=IEFBR14
//DD1      DD DSN=SAP.PBB.WOF.WOPSFTP,
//            DISP=(MOD,DELETE,DELETE),UNIT=SYSDA,
//            SPACE=(CYL,1,RLSE)
//*
//CREATE   EXEC PGM=IEFBR14
//CRT01    DD DSN=SAP.PBB.WOF.WOPSFTP,
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(RECFM=FB,LRECL=80,BLKSIZE=24000),
//            SPACE=(CYL,(500,200),RLSE),UNIT=(SYSDA,5)
//*
//SAS6094  EXEC SAS609
//LNWOF    DD DISP=SHR,DSN=SAP.PBB.LOANWOF(0)
//ODWOF    DD DISP=SHR,DSN=SAP.PBB.ODWOF(0)
//WOMV     DD DISP=SHR,DSN=SAP.PBB.LNWOMOV(0)
//BNM      DD DISP=SHR,DSN=SAP.PBB.SASDATA.DAILY(0)
//BNM1     DD DISP=SHR,DSN=SAP.PBB.MNILN(0)
//BNM2     DD DISP=SHR,DSN=SAP.PBB.MNILN.DAILY(0)
//HP       DD DISP=SHR,DSN=SAP.PBB.HPDATAWH
//WOPS     DD DISP=OLD,DSN=SAP.PBB.WOF.WOPS
//TEMP     DD DSN=&&WOPS,
//            DISP=(NEW,DELETE,DELETE),
//            DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),
//            SPACE=(CYL,(400,200),RLSE),UNIT=(SYSDA,8)
//SYSIN    DD *

OPTIONS SORTDEV=3390 YEARCUTOFF=1950;

DATA DATES;
   SET BNM.REPTDATE;
   SELECT;
     WHEN(1  <= DAY(REPTDATE) <= 8)  DO; WK='1'; WK1='4'; END;
     WHEN(9  <= DAY(REPTDATE) <= 15) DO; WK='2'; WK1='1'; END;
     WHEN(16 <= DAY(REPTDATE) <= 22) DO; WK='3'; WK1='2'; END;
     OTHERWISE                       DO; WK='4'; WK1='3'; END;
   END;
   CALL SYMPUT('NOWK',PUT(WK,$1.));
   CALL SYMPUT('NOWK1',PUT(WK1,$1.));
   CALL SYMPUT('REPTDAY',PUT(DAY(REPTDATE),Z2.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));
RUN;

DATA _NULL_;
   SET BNM1.REPTDATE;
   CALL SYMPUT('WDAY',PUT(DAY(REPTDATE),Z2.));
RUN;

 /***** WRITE-OFF LATEST POSITION FOR LOAN *****/
PROC SORT DATA=LNWOF.LNWOF OUT=LNWOF
  (RENAME=(CENSUS_TRT=ORIPRODUCT WRITE_DOWN_BAL=WDB));
   BY ACCTNO NOTENO;
RUN;

PROC SORT DATA=WOMV.WOMOVE OUT=WOMOVE
  (KEEP=ACCTNO NOTENO BDR_AFT_PAY);
   BY ACCTNO NOTENO DESCENDING BDR_AFT_PAY;
RUN;
PROC SORT NODUPKEY; BY ACCTNO NOTENO; RUN;

DATA LNWOF;
   MERGE LNWOF (IN=A) WOMOVE (RENAME=BDR_AFT_PAY=BDR);
   BY ACCTNO NOTENO;
   IF A;
   IF BDR =. THEN BDR = NBDR;
RUN;

PROC SORT DATA=BNM.LOAN&REPTMON&REPTDAY
   OUT=LOAN (KEEP=ACCTNO NOTENO ORIBALANCE BRANCH);
   BY ACCTNO NOTENO;
RUN;

PROC SORT DATA=BNM2.LNNOTE
   OUT=LNNOTE (KEEP=ACCTNO NOTENO VB DIGITAL_RR_STATUS_DT
               DIGITAL_RR_STATUS_CD REPAY_PROPOSAL_CD AKPK_STATUS
               CLIMATE_PRIN_TAXONOMY_CLASS);
   BY ACCTNO NOTENO;
RUN;
DATA LNWOF;
   MERGE LNWOF(IN=A) LOAN LNNOTE;
   BY ACCTNO NOTENO;
   IF A;
   KEEP ACCTNO NOTENO PRODUCT ORIPRODUCT WDB BDR ORIBALANCE BRANCH VB
        DIGITAL_RR_STATUS_DT DIGITAL_RR_STATUS_CD REPAY_PROPOSAL_CD
        AKPK_STATUS REFNOTENO CLIMATE_PRIN_TAXONOMY_CLASS;
RUN;

DATA LNWOPS;
   SET LNWOF;
   CENSUS0 = ORIPRODUCT;
   CENSUS1 = SUBSTR(PUT(ORIPRODUCT,7.2),1,2);
   CENSUS3 = SUBSTR(PUT(ORIPRODUCT,7.2),3,1);
   CENSUS4 = SUBSTR(PUT(ORIPRODUCT,7.2),4,1);
   CENSUS5 = SUBSTR(PUT(ORIPRODUCT,7.2),6,2);
   IF WDB <= 2.00 THEN ACSTATUS ='W'; ELSE ACSTATUS ='P';
   RENAME ORIBALANCE = ACTOWE;
RUN;

 /***** WRITE-OFF LATEST POSITION FOR OVERDRAFT *****/
PROC SORT DATA=ODWOF.ODWOF OUT=ODWOF
  (RENAME=(WRITE_DOWN_BAL=WDB ACSTAT=ACSTATUS));
   BY ACCTNO;
RUN;

PROC SORT DATA=BNM.LOAN&REPTMON&REPTDAY
   OUT=OD (KEEP=ACCTNO ORIBALANCE BRANCH VB);
   BY ACCTNO;
RUN;

DATA ODWOF;
   MERGE ODWOF(IN=A) OD;
   BY ACCTNO;
   IF A;
   KEEP ACCTNO CUMWOSP CUMWOIS WDB CUMNAI BDR CUMRC CUMSC PRODUCT
        ORIPRODUCT ORIBALANCE WOTYPE WOSTAT ACSTATUS BRANCH VB;
RUN;

DATA ODWOPS;
   SET ODWOF;
   RENAME ORIBALANCE = ACTOWE
          CUMWOSP    = CUMWOSP_OD
          CUMWOIS    = CUMWOIS_OD
          CUMNAI     = CUMNAI_OD
          CUMRC      = CUMRC_OD
          CUMSC      = CUMSC_OD;
RUN;

DATA WOPS.WOPOS&REPTMON&NOWK;
   SET LNWOPS ODWOPS;
RUN;
PROC SORT DATA=WOPS.WOPOS&REPTMON&NOWK;BY ACCTNO NOTENO;RUN;

 /*** INCORPORATE FIELDS FROM HPWO INTO WOPOS ***/
%MACRO APPEND;
  %IF "&REPTDAY" EQ "&WDAY" %THEN %DO;
     PROC SORT DATA=HP.HPWO&REPTMON&NOWK&REPTYEAR OUT=HPWO
        (KEEP=ACCTNO NOTENO BALANCE PRODUCT CENSUS0 REFNOTENO
              CENSUS1 CENSUS3 CENSUS4 CENSUS5 BRANCH VB);
        BY ACCTNO NOTENO;
     RUN;
     DATA WOPS.WOPOS&REPTMON&NOWK;
        MERGE WOPS.WOPOS&REPTMON&NOWK
              HPWO (RENAME=(BALANCE=ACTOWE));
        BY ACCTNO NOTENO;
     RUN;
     PROC SORT; BY ACCTNO NOTENO; RUN;
  %END;
%MEND APPEND;
%APPEND;

DATA TEMP.WOPOS&REPTMON&NOWK&REPTYEAR;
   SET WOPS.WOPOS&REPTMON&NOWK;
RUN;

FILENAME TRANFILE 'SAP.PBB.WOF.WOPSFTP' DISP=OLD;
PROC CPORT LIBRARY=TEMP FILE=TRANFILE;
RUN;

