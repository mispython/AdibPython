   BY BRANCH DESCENDING NETBAL;
RUN;
PROC PRINTTO FILE=TEMP;
PROC REPORT DATA=RPS3M
   HEADLINE HEADSKIP NOWD SPLIT='*' MISSING;
   COLUMN BRANCH NAME ACCTNO NOTENO DAYS BORSTAT ISSDTE NETBAL
         NETPROC ACCTNO TOTIIS OSPRIN MARKETVL SP RISK ARREARS SECTORCD
         SPPL IISCHRG;    /* ESMR 2010-2463 */
   * WHERE CAC NE 'B000';
   DEFINE BRANCH    / GROUP             'BRANCH' ID;                    ;
   DEFINE ACCTNO    / DISPLAY FORMAT=10.  'A/C NO.';
   DEFINE NOTENO    / DISPLAY FORMAT=7.   'NOTE NO';
   DEFINE NAME      / DISPLAY FORMAT=$25. 'NAME';
   DEFINE DAYS      / DISPLAY FORMAT=5.  'DAYS';
   DEFINE BORSTAT   / DISPLAY FORMAT=$7. 'BORSTAT';
   DEFINE ISSDTE    / DISPLAY             'ISSUE DATE';                 ;
   DEFINE NETBAL    / ANALYSIS SUM FORMAT=COMMA15.2
                      'NET BALANCE';
   DEFINE NETPROC   / ANALYSIS FORMAT=COMMA15.2
                      'NET PROCEED';
   DEFINE TOTIIS    / ANALYSIS FORMAT=COMMA13.2
                      'TOTAL IIS';
   DEFINE IISCHRG   / ANALYSIS FORMAT=COMMA13.2   /* ESMR 2010-2463 */
                      'IIS CHARGE';
   DEFINE OSPRIN    / ANALYSIS FORMAT=COMMA15.2
                      'BALANCE';
   DEFINE MARKETVL  / ANALYSIS FORMAT=COMMA15.2
                      'MARKET VALUE';
   DEFINE SP        / ANALYSIS FORMAT=COMMA13.2
                      'SP';
   DEFINE SPPL      / ANALYSIS FORMAT=COMMA13.2   /* ESMR 2010-2463 */
                      'SA CHARGE';
   DEFINE RISK      / DISPLAY
                      'RISK';
   DEFINE ARREARS   / DISPLAY
                      'ARREARS';
   DEFINE SECTORCD  / DISPLAY FORMAT=$6.
                      'SECTOR' ;
   BREAK AFTER BRANCH/  PAGE;
 /*  COMPUTE AFTER BRANCH;
      LINE ' ';
   ENDCOMP;
   COMPUTE AFTER;
      LINE ' ';
   ENDCOMP; */
  TITLE1 'PUBLIC BANK - (NEWLY SURFACE NPL) AS AT ' &RDATE;
RUN;
*;
PROC PRINTTO FILE=PRINT;
RUN;
DATA A;
   INFILE TEMP;
   FILE OUTFILE;
   RETAIN CACIND 0 CACNUM '    ';
   INPUT @1 LINE1 $CHAR134. @;
   IF SUBSTR(LINE1,1,6) = 'PUBLIC' THEN DO;
      INPUT / @1 LINE2 $CHAR134./
              @1 LINE3 $CHAR134./
              @1 LINE4 $CHAR134./
              @1 LINE5 $CHAR134./
              @1 LINE6 $CHAR134. @7 CAC $3. @;

        IF CAC ^= CACNUM THEN CACIND = 1;
          ELSE CACIND = 0;
           IF CACIND = 1 THEN DO;
              PUT @1 'BRANCH : ' @10 CAC;

           END;
     /*    ELSE DO;
              PUT @1 'BRANCH : ' @10 CAC;
           END;  */
           CACNUM = CAC;
           LINK NEWPAGE;

        END;


   ELSE DO;
         PUT @1 _INFILE_;
   END;
   RETURN;
   NEWPAGE:
   PUT @1 LINE1 $CHAR134./
       @1 LINE2 $CHAR134./
       @1 LINE3 $CHAR134./
       @1 LINE4 $CHAR134./
       @1 LINE5 $CHAR134./
       @1 LINE6 $CHAR134.;
   RETURN;
RUN;

