//             DISP=(NEW,CATLG,DELETE),
//             DCB=(RECFM=FB,LRECL=250,BLKSIZE=28000),
//             SPACE=(CYL,(10,20),RLSE),UNIT=SYSDA
//NPL6     DD DSN=SAP.PBB.NPL.NEW.SASDATA,DISP=OLD
//NPLX     DD DSN=SAP.PBB.NPL.HP.SASDATA,DISP=SHR
//SYSIN    DD *
OPTIONS YEARCUTOFF=1950 NOCENTER;
*;
%INC PGM(PBBLNFMT,PBBELF);
PROC FORMAT;
   VALUE LNTYP 128,130,131,132         = 'HPD AITAB'
               700,705,380,381,720,725 = 'HPD CONVENTIONAL'
               OTHER                   = 'OTHERS';
*;
DATA REPTDATE;
   SET LOAN.REPTDATE;
   MM = MONTH(REPTDATE);
   MM1 = MM - 1;
   IF MM1 = 0 THEN MM1 = 12;
   PREVDATE=MDY(MONTH(REPTDATE),1,YEAR(REPTDATE))-1;
   CALL SYMPUT('PREVMON',PUT(MONTH(PREVDATE),Z2.));
   CALL SYMPUT('PREVYEAR',PUT(PREVDATE,YEAR2.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('REPTMON1',PUT(MM1,Z2.));
   CALL SYMPUT('RDATE',PUT(REPTDATE,DDMMYY8.));
RUN;
*;
 *------------------------------------------------*
 *  MACRO FOR CALCULATING NEXT BLDATE             *
 *------------------------------------------------*;
PROC SORT DATA=NPL6.LOAN3M&REPTMON OUT=THISMTH; BY ACCTNO;
PROC SORT DATA=NPL6.LOAN3M&REPTMON1 OUT=LASTMTH; BY ACCTNO;
DATA NEWCA;
   MERGE LASTMTH(IN=A) THISMTH(IN=B);
   BY ACCTNO;
   IF B AND NOT A;
RUN;
PROC SORT DATA=NEWCA; BY ACCTNO NOTENO;
PROC SORT DATA=NPLX.SP2 OUT=SP2(DROP=NETBAL); BY ACCTNO NOTENO;
PROC SORT DATA=NPLX.IIS OUT=IIS
  (KEEP=ACCTNO NOTENO TOTIIS OISUSP SUSPEND); /* ESMR 2010-2463 */
   BY ACCTNO NOTENO;
*;
DATA NEWCA;
   MERGE NEWCA(IN=A) SP2 IIS;
   BY ACCTNO NOTENO;
   IF A;
   IISCHRG = SUM (SUSPEND, OISUSP);           /* ESMR 2010-2463 */
   ARREARS=INPUT(DAYS,NDAYS.);
   IF ARREARS=24 THEN ARREARS=ROUND(NODAYS/30);
   IF LOANTYPE IN (981,982,983,991,992,993,984,985,994,995,
                   678,679,698,699) THEN DO;
      ARREARS=999;
      OSPRIN = 0;
   END;
RUN;
PROC SORT DATA=NEWCA; BY GUAREND;
PROC SUMMARY DATA=NEWCA NWAY;
   CLASS GUAREND;
   VAR NETBAL SPPL IISCHRG;                    /* ESMR 2010-2463 */
OUTPUT OUT=TOTNAME SUM=TOTNET SPPLT IISCHRGT;  /* ESMR 2010-2463 */
RUN;
PROC SUMMARY DATA=TOTNAME NWAY;
   VAR TOTNET SPPLT IISCHRGT;                  /* ESMR 2010-2463 */
OUTPUT OUT=GRAND SUM=GRANDTOT SPPLG IISCHRGG;  /* ESMR 2010-2463 */
RUN;
DATA TOTNAME;
   SET TOTNAME;
   SUBTOT = 'SUB-TOTAL  ';
   NETBAL = TOTNET;
   SPPL = SPPLT;
   IISCHRG = IISCHRGT;
*;
RUN;
DATA GRAND;
   SET GRAND;
   SUBTOT = 'GRAND TOTAL';
   NETBAL = GRANDTOT;
   SPPL = SPPLG;
   IISCHRG = IISCHRGG;
*;
DATA LOANNAME;
   MERGE NEWCA TOTNAME(IN=A DROP=SUBTOT NETBAL SPPL IISCHRG);
   BY GUAREND;
  ISSDTE = PUT(INPUT(SUBSTR(PUT(ISSUEDT,Z11.),1,8),MMDDYY8.),DDMMYY10.);
   CACNAME = PUT(NTBRCH,CACNAME.);
   REGION = PUT(NTBRCH,REGIOFF.);
RUN;
DATA TOTNAME;
   SET LOANNAME(IN=A) TOTNAME(IN=B);
   IF A OR (B &_FREQ_ > 1);
RUN;
PROC SORT; BY DESCENDING TOTNET GUAREND SUBTOT;
DATA NPL6.TOTNMN&REPTMON;
   SET TOTNAME GRAND;
RUN;
*** PROC PRINT DATA=NPL6.TOTNMN03 (OBS=10);
