      IF CERTNO1 NE . THEN CERTNO=CERTNO1;
   END;
   IF CERTNO = . THEN DO;
      BALANCE = 0;
      OUTSTAND = 0;
   END;
   ELSE DO;
      BALANCE=SUM(OUTSTAND,(-1)*UNEARNED);
      *OUTSTAND=BALANCE;
   END;
   *** SPECIAL MAPPING 4 SELECTED LIABCODE ***;
   IF LIABCODE IN ('BPI','BII','BSI','BEI') THEN DO;
      IF UTRDF = '' THEN DO;
         IF UTRDF1 NE '' THEN UTRDF = UTRDF1;
