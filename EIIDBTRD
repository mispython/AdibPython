DATA BNM.REPTDATE (KEEP=REPTDATE);
  SET BTRSA.REPTDATE;
  STARTDTE=INTNX('MONTH',REPTDATE,0,'B');
  MM = MONTH(REPTDATE);
  MM1 = MM - 1;
  IF MM1 = 0 THEN MM1 = 12;
  CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
  CALL SYMPUT('REPTDAY',PUT(DAY(REPTDATE),Z2.));
  CALL SYMPUT('RDATE',PUT(REPTDATE,DDMMYY8.));
  CALL SYMPUT('TDATE',REPTDATE);
  CALL SYMPUT('STARTDT',STARTDTE);
  CALL SYMPUT('NOWK','4');
  CALL SYMPUT('REPTMON1',PUT(MM1,Z2.));
  CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));
  CALL SYMPUT('REPTDT',PUT(REPTDATE,YYMMDDN6.));
  CALL SYMPUT('PREVDT',PUT(REPTDATE-1,YYMMDDN6.));
RUN;
