DATA BNM.D_IBTRAD&REPTDT;
   MERGE BNM.D_IBTRAD&REPTDT(IN=A)
         DISBPAY(IN=B KEEP=ACCTNO TRANSREF DISBURSE REPAID);
   BY ACCTNO TRANSREF;
   IF A;
RUN;

