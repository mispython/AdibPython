//EIIDLNAP JOB MSGCLASS=X,MSGLEVEL=(1,1),REGION=64M,NOTIFY=&SYSUID      JOB19824
//*---------------------------------------------------------------------        
//* APPEND DAILY LOAN USE FOR EIMDISRP                                          
//*---------------------------------------------------------------------        
//EIBDLNAP EXEC SAS609                                                          
//SASD     DD DSN=SAP.PIBB.SASDATA.DAILY(0),DISP=SHR                            
//APP      DD DSN=SAP.PIBB.STORE.SASDATA,DISP=OLD                               
//SASLIST  DD SYSOUT=X                                                          
//SYSIN    DD *                                                                 
                                                                                
OPTIONS YEARCUTOFF=1960 NODATE NONUMBER NOCENTER COMPRESS=YES;                  
                                                                                
DATA REPTDATE;                                                                  
   SET SASD.REPTDATE;                                                           
   CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));                                
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));                             
   CALL SYMPUT('REPTDAY',PUT(DAY(REPTDATE),Z2.));                               
   CALL SYMPUT('REPTDATE',REPTDATE);                                            
   CALL SYMPUT('NOWK',PUT('4',$1.));                                            
RUN;                                                                            
                                                                                
%MACRO APPEND;                                                                  
   %IF "&REPTDAY" EQ "01" %THEN %DO;  /*  FIRST DAY OF THE MONTH  */            
      DATA APP.LOAN&REPTMON;                                                    
      SET SASD.LOAN&REPTMON&REPTDAY                                             
      (KEEP=ACCTNO NOTENO FISSPURP PRODUCT BALANCE CENSUS DNBFISME              
            PRODCD CUSTCD AMTIND SECTORCD BRANCH ACCTYPE CCY FORATE);           
      DATE=&REPTDATE;                                                           
      RUN;                                                                      
   %END;                                                                        
   %ELSE %DO;                                                                   
      DATA APP.LOAN&REPTMON;                                                    
        SET APP.LOAN&REPTMON;                                                   
        IF DATE EQ &REPTDATE THEN DELETE;                                       
      RUN;                                                                      
                                                                                
      DATA LOAN;                                                                
         SET SASD.LOAN&REPTMON&REPTDAY                                          
         (KEEP=ACCTNO NOTENO FISSPURP PRODUCT BALANCE CENSUS DNBFISME           
            PRODCD CUSTCD AMTIND SECTORCD BRANCH ACCTYPE CCY FORATE);           
         DATE=&REPTDATE;                                                        
      RUN;                                                                      
                                                                                
      DATA LOAN2;                                                               
         SET APP.LOAN&REPTMON LOAN;                                             
      RUN;                                                                      
                                                                                
      PROC SORT DATA=LOAN2;BY ACCTNO NOTENO DESCENDING DATE;RUN;                
      PROC SORT DATA=LOAN2 NODUPKEY;BY ACCTNO NOTENO;RUN;                       
                                                                                
      DATA APP.LOAN&REPTMON;                                                    
         SET LOAN2;                                                             
      RUN;                                                                      
                                                                                
   %END;                                                                        
%MEND APPEND;                                                                   
%APPEND;                                                                        
