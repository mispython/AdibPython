TITLE2 'PUBLIC ISLAMIC BANK BERHAD - RETAIL BANKING DIVISION';
TITLE3 'REPORT TITLE : EIIDLOAN';
TITLE4 "DAILY MOVEMENT IN BANK S HP ACCOUNTS AS AT : " &RD              ATE;
