OPTIONS SORTDEV=3390 YEARCUTOFF=1950;

DATA BNM.REPTDATE;
  SELECT;
    WHEN(10 LE DAY(TODAY()) LE 14)
      REPTDATE=INPUT('10'||PUT(MONTH(TODAY()), Z2.)||
                     PUT(YEAR(TODAY()), 4.), DDMMYY8.);
    WHEN(15 LE DAY(TODAY()) LE 19)
      REPTDATE=INPUT('15'||PUT(MONTH(TODAY()), Z2.)||
                     PUT(YEAR(TODAY()), 4.), DDMMYY8.);
    WHEN(20 LE DAY(TODAY()) LE 25)
      REPTDATE=INPUT('20'||PUT(MONTH(TODAY()), Z2.)||
                     PUT(YEAR(TODAY()), 4.), DDMMYY8.);
    OTHERWISE;
  END;
  WK = DAY(REPTDATE);
  CALL SYMPUT('NOWK',PUT(WK,Z2.));
  CALL SYMPUT('RDATE', PUT(REPTDATE, DDMMYY8.));
  CALL SYMPUT('REPTYEAR', PUT(REPTDATE, YEAR4.));
  CALL SYMPUT('REPTMON', PUT(MONTH(REPTDATE), Z2.));
  CALL SYMPUT('REPTDAY', PUT(DAY(REPTDATE), Z2.));
RUN;

DATA _NULL_;
  SET LOAN.REPTDATE(OBS=1);
  CALL SYMPUT('LOAN', PUT(REPTDATE, DDMMYY8.));
RUN;

%MACRO PROCES1;
  %IF "&LOAN"="&RDATE" %THEN %DO;
      %INC PGM(LNCCD001);
      PROC DATASETS LIB=WORK KILL NOLIST; RUN;

      /**  LOANS IN ARREARS REPORT - THE 10 & 20 OF THE MTH VERSION **/
      %INC PGM(LNCCDI02);
