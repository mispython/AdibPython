cd /ftp
cd Download
put //SAP.FEFCLI.CCRIS2.ACCTCRED   FEIMAST
put //SAP.FEFCLI.CCRIS2.SUBACRED   FEISUB
put //SAP.FEFCLI.CCRIS2.CREDITPO   FEICRED
EOB
