DATA WALKER3;
   LENGTH ITEM $6.;
   SET BNM1.W1AL&REPTMON&WK4;
   REPTDATE=MDY(&REPTMON,&MTHEND,&REPTYEAR);
   AMOUNT4=AMOUNT;
   SELECT(SET_ID);
      WHEN('F137030NIDH')
         DO; ITEM='C3.06A'; OUTPUT; END;
      OTHERWISE; END;
RUN;

DATA UTMS3(KEEP=ITEM AMOUNT4);
   LENGTH ITEM $6;
   SET EQ1.IUTMS&REPTMON&WK4&YEAR;
   REPTDATE=MDY(&REPTMON,&MTHEND,&REPTYEAR);
   AMOUNT4=CAMTOWNE+INTACR-UNDISCPR-DISCPRMN;
   IF SECTYPE IN ('IDC','IDP') AND PORTREF ='PDC' AND
   VALUDATE <= BUSDATE AND (CUSTFISS IN ('01','02','03','07','12')
   OR CUSTEQTP IN ('BC','BB','BI','BJ','BM')) THEN DO;ITEM='C3.03';
      IF AMOUNT4 NE . THEN AMOUNT4=CAMTOWNE;
   END;
    IF SECTYPE IN ('SDC','SLD','SSD','SZD','LDC') AND CUSTFISS='17'
       THEN ITEM='C3.06B';
    IF SECTYPE IN ('SDC','SLD','SSD','SZD','LDC') AND CUSTFISS='33'
       AND CUSTNO IN ('BKPKSM','ISME') THEN ITEM='C3.06C';
    IF SECTYPE IN ('SDC','SLD','SSD','SZD','LDC') AND CUSTFISS='33'
       AND CUSTNO='BKRAK' THEN ITEM='C3.06D';
    IF SECTYPE IN ('SDC','SLD','SSD','SZD','LDC') AND CUSTFISS='33'
       AND CUSTNO IN ('IBSN','BSN') THEN ITEM='C3.06E';
    IF SECTYPE IN ('SDC','SLD','SSD','SZD','LDC') AND CUSTFISS='33'
       AND CUSTNO IN ('BPMB','IBPMB') THEN ITEM='C3.06F';
RUN;

