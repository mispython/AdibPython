TITLE4 'AGING OF SPTF LOANS AS AT ' &RDATE;

PROC PRINT DATA=LNAGING;
VAR BNMCODE AMOUNT;
SUM AMOUNT;
WHERE LNTYPE='I';
FORMAT AMOUNT COMMA18.2;
RUN;
      PROC DATASETS LIB=BNM NOLIST;
        DELETE BTRAD&REPTMON&NOWK;
      RUN;
DATA RDALKM;
  SET BNM.IBTRW&REPTMON&NOWK
      BNM.IBTRM&REPTMON&NOWK;
      RENAME BNMCODE=ITCODE;
RUN;
PROC SORT DATA=RDALKM; BY ITCODE; RUN;

DATA AL OB SP;
   SET RDALKM;
   IF AMTIND ^= ' ' THEN DO;
      IF SUBSTR(ITCODE,1,3) IN ('307') THEN OUTPUT SP;
      ELSE IF SUBSTR(ITCODE,1,1) ^= '5' THEN DO;
         IF SUBSTR(ITCODE,1,3) IN ('685','785') THEN OUTPUT SP;
         ELSE OUTPUT AL;
      END;
      ELSE OUTPUT OB; END;
   ELSE IF SUBSTR(ITCODE,2,1)='0' THEN OUTPUT SP;
RUN;
DATA _NULL_;
   SET AL;
   BY ITCODE AMTIND;
   PHEAD='RDAL'||"&REPTDAY"||"&REPTMON"||"&REPTYEAR";
   FILE RDALKM;
   IF _N_=1 THEN DO;
      PUT @1 PHEAD;
      PUT @1 'AL';
      AMOUNTD=0; AMOUNTI=0;
   END;
   PROCEED='Y';
   IF PROCEED='Y';
      RETAIN AMOUNTD AMOUNTI;

      AMOUNT=ROUND(AMOUNT/1000);
      IF AMTIND='D' THEN AMOUNTD+AMOUNT;
      ELSE IF AMTIND='I' THEN AMOUNTI+AMOUNT;

      IF LAST.ITCODE THEN DO;
         AMOUNTD=AMOUNTD+AMOUNTI;
         PUT @1 ITCODE +(-1) ';' AMOUNTD +(-1) ';' AMOUNTI;
         AMOUNTD=0; AMOUNTI=0;
      END;
RUN;

DATA _NULL_;
   SET OB;
   BY ITCODE AMTIND;

   FILE RDALKM MOD;
   IF _N_=1 THEN DO;
      PUT @1 'OB';
      AMOUNTI=0;
   END;

   RETAIN AMOUNTI;

   AMOUNTI+ROUND(AMOUNT/1000);

   IF LAST.ITCODE THEN DO;
      PUT @1 ITCODE +(-1) ';' AMOUNTI +(-1) ';' AMOUNTI;
      AMOUNTI=0;
   END;
RUN;

DATA _NULL_;
   SET SP;
   BY ITCODE;

   FILE RDALKM MOD;
   IF _N_=1 THEN DO;
      PUT @1 'SP';
      AMOUNTI=0;
   END;

   AMOUNTI+AMOUNT;
   IF LAST.ITCODE THEN DO;
      AMOUNTI=ROUND(AMOUNTI/1000);
      PUT @1 ITCODE +(-1) ';' AMOUNTI +(-1);
      AMOUNTI=0;
   END;
RUN;

   /** NSRS **/
DATA _NULL_;
   SET AL;
   BY ITCODE AMTIND;
   PHEAD='RDAL'||"&REPTDAY"||"&REPTMON"||"&REPTYEAR";
   FILE NSRS;
   IF _N_=1 THEN DO;
      PUT @1 PHEAD;
      PUT @1 'AL';
      AMOUNTD=0; AMOUNTI=0;
   END;
   PROCEED='Y';
   IF PROCEED='Y';
      RETAIN AMOUNTD AMOUNTI;

      IF SUBSTR(ITCODE,1,2) IN ('80') THEN
         AMOUNT=ROUND(AMOUNT/1000);
      ELSE AMOUNT=ROUND(AMOUNT);
      IF AMTIND='D' THEN AMOUNTD+AMOUNT;
      ELSE IF AMTIND='I' THEN AMOUNTI+AMOUNT;

      IF LAST.ITCODE THEN DO;
         AMOUNTD=AMOUNTD+AMOUNTI;
         PUT @1 ITCODE +(-1) ';' AMOUNTD +(-1) ';' AMOUNTI;
         AMOUNTD=0; AMOUNTI=0;
      END;
RUN;

DATA _NULL_;
   SET OB;
   BY ITCODE AMTIND;

   FILE NSRS MOD;
   IF _N_=1 THEN DO;
      PUT @1 'OB';
      AMOUNTI=0;
   END;

   RETAIN AMOUNTI;

   IF SUBSTR(ITCODE,1,2) IN ('80') THEN
      AMOUNT=ROUND(AMOUNT/1000);
   AMOUNTI+ROUND(AMOUNT);

   IF LAST.ITCODE THEN DO;
      PUT @1 ITCODE +(-1) ';' AMOUNTI +(-1) ';' AMOUNTI;
      AMOUNTI=0;
   END;
RUN;

DATA _NULL_;
   SET SP;
   BY ITCODE;

   FILE NSRS MOD;
   IF _N_=1 THEN DO;
      PUT @1 'SP';
      AMOUNTI=0;
   END;

   IF SUBSTR(ITCODE,1,2) IN ('80')
      THEN AMOUNT=ROUND(AMOUNT/1000);
   AMOUNTI+AMOUNT;
   IF LAST.ITCODE THEN DO;
      AMOUNTI=ROUND(AMOUNTI);
      PUT @1 ITCODE +(-1) ';' AMOUNTI +(-1);
      AMOUNTI=0;
   END;
RUN;

