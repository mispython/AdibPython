      PROC DATASETS LIB=WORK KILL NOLIST; RUN;                                  
                                                                                
      /**  LOANS IN NPL REPORT - THE 10 & 20 OF THE MONTH VER **/               
      %INC PGM(LNCCDBI4);                                                       
      PROC DATASETS LIB=WORK KILL NOLIST; RUN;                                  
                                                                                
      /**  LOANS CLASSIFY AS NPL REPORT **/                                     
      /* %INC PGM(LNCCDBI5);  */                                                
      PROC DATASETS LIB=WORK KILL NOLIST; RUN;                                  
  %END;                                                                         
  %ELSE %DO;                                                                    
      %PUT THE LOAN EXTRACTION IS NOT DATED &RDATE;                             
      %PUT THIS JOB IS NOT RUN !!;                                              
