OPTIONS SORTDEV=3390 YEARCUTOFF=1950;                                           
                                                                                
DATA _NULL_;                                                                    
  SET LOAN.REPTDATE;                                                            
  SELECT(DAY(REPTDATE));                                                        
    WHEN (1-8)   DO; WK = '1'; END;                                             
    WHEN(9-15)   DO; WK = '2'; END;                                             
    WHEN(16-22)  DO; WK = '3'; END;                                             
    OTHERWISE    DO; WK = '4'; END;                                             
  END;                                                                          
  CALL SYMPUT('NOWK',PUT(WK,$1.));                                              
  CALL SYMPUT('RDATE', PUT(REPTDATE, DDMMYY8.));                                
  CALL SYMPUT('REPTYEAR', PUT(REPTDATE, YEAR4.));                               
  CALL SYMPUT('REPTMON', PUT(MONTH(REPTDATE), Z2.));                            
  CALL SYMPUT('REPTDAY', PUT(DAY(REPTDATE), Z2.));                              
RUN;                                                                            
                                                                                
LIBNAME BNM "SAP.PBB.CCDTEMPB" DISP=SHR;                                        
                                                                                
DATA _NULL_;                                                                    
  SET LOAN.REPTDATE(OBS=1);                                                     
  CALL SYMPUT('LOAN', PUT(REPTDATE, DDMMYY8.));                                 
RUN;                                                                            
                                                                                
