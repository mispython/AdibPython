//EIIMCLCA JOB MISEIS,EIBMRPT1,COND=(4,LT),CLASS=A,MSGCLASS=X,
//         NOTIFY=&SYSUID
//*
//*  SMR 2010-959. AFTER EIBMRPT1
//*
//DELETE  EXEC PGM=IEFBR14
//DEL01    DD DSN=SAP.PIBB.CACLSWH.CACFTP,
//            DISP=(MOD,DELETE,DELETE),
//            SPACE=(CYL,(0))
//CREATE  EXEC PGM=IEFBR14
//CRT01    DD DSN=SAP.PIBB.CACLSWH.CACFTP,
//            DISP=(NEW,CATLG,DELETE),
//            DCB=(RECFM=FB,LRECL=80,BLKSIZE=24000),
//            SPACE=(CYL,(20,20),RLSE),UNIT=SYSDA
//*
//EIIMCLCA EXEC SAS609
//DEP      DD DSN=SAP.PIBB.MNITB(0),DISP=SHR
//MNICRM   DD DSN=SAP.PIBB.CRMCUMDP,DISP=SHR
//DRCRCA   DD DSN=SAP.PIBB.DRCRCA,DISP=SHR
//SIGNA    DD DSN=SAP.PBB.SMS.SIGNATUR,DISP=SHR
//MISMTD   DD DSN=SAP.PIBB.MTD.SASDATA,DISP=SHR
//MIS      DD DSN=SAP.PIBB.OPCL.SASDATA,DISP=SHR
//CIS      DD DSN=SAP.PBB.CISBEXT.DP,DISP=SHR
//PGM      DD DSN=SAP.BNM.PROGRAM,DISP=SHR
//PRODEV   DD DSN=SAP.PBB.CLOSED.ACCTS,DISP=SHR
//DDWH     DD DSN=&&DDWH,
//            DISP=(NEW,DELETE,DELETE),
//            DCB=(RECFM=FS,LRECL=27648,BLKSIZE=27648),
//            SPACE=(CYL,(100,100),RLSE),UNIT=SYSDA
//SASLIST  DD SYSOUT=X
//SYSIN    DD *

OPTIONS YEARCUTOFF=1950 SORTDEV=3390 NONUMBER NODATE NOCENTER;
*;
%INC PGM(PBBDPFMT,PBBELF);
*;
DATA REPTDATE;
  SET DEP.REPTDATE;
  MM=MONTH(REPTDATE);
  IF DAY(REPTDATE+1)=1 THEN MM1 = MM;
  ELSE                      MM1 = MM-1;
  IF MM1 = 0 THEN MM1 = 12;
  CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));
  CALL SYMPUT('REPTMON',PUT(MM,Z2.));
  CALL SYMPUT('REPTMON1',PUT(MM1,Z2.));
RUN;
*;
DATA CIS;
 KEEP ACCTNO DOBCIS OCCUPAT COUNTRY RACE;
 FORMAT DOBCIS 5. BMM BDD 2. BYY 4.;
 SET CIS.DEPOSIT;
 COUNTRY=CITIZEN;
 IF SECCUST='901';
 BDD=SUBSTR(BIRTHDAT,1,2);
 BMM=SUBSTR(BIRTHDAT,3,2);
 BYY=SUBSTR(BIRTHDAT,5,4);
 DOBCIS =MDY(BMM,BDD,BYY);
*;
PROC SORT DATA=CIS OUT=CIS NODUPKEY; BY ACCTNO;
PROC SORT DATA=MIS.CURRC&REPTMON OUT=CURR; BY ACCTNO;
*;
%MACRO MONTHLY;
   %IF "&NOWK" NE "4" AND "&REPTMON" EQ "01" %THEN %DO;
      DATA CURR;
         SET CURR;
         FEEYTD = 0;
      RUN;
   %END;
   %ELSE %DO;
      PROC SORT DATA=MNICRM.CA&REPTMON1 OUT=CRMCA NODUPKEY;
         BY ACCTNO; RUN;
      DATA CURR;
         MERGE CURR(IN=A) CRMCA(DROP=COSTCTR FEEPD);
         BY ACCTNO; IF A;
      RUN;
   %END;
%MEND MONTHLY;
%MONTHLY;

DATA ICA;
  MERGE CIS CURR(IN=A); BY ACCTNO;
  IF A;
  IF OPENDT  > 0 THEN
  ODATE=INPUT(SUBSTR(PUT(OPENDT,Z11.),1,8),MMDDYY8.);
  IF CLOSEDT > 0 THEN
  CDATE=INPUT(SUBSTR(PUT(CLOSEDT,Z11.),1,8),MMDDYY8.);
  DROP OPENDT CLOSEDT;
*;
DATA ICACLOSE;
  SET ICA;
  RISKRATE = PUT(RISKCODE,$1.);
  OPENDT=ODATE;
  CLOSEDT=CDATE;
  DROP ODATE CDATE;
*;

 /* KEEP LATEST & REMOVE DUPLICATE */
PROC SORT DATA=PRODEV.DPCLOS OUT=DPCLOS;
   BY DESCENDING CLOSEDT;
RUN;
PROC SORT DATA=DPCLOS; BY ACCTNO; RUN;
DATA DPCLOS;
   SET DPCLOS;
   BY ACCTNO;
   IF FIRST.ACCTNO THEN OUTPUT;
RUN;
*;
PROC SORT DATA=DPCLOS(KEEP=ACCTNO CLOSEDT RCODE);
  BY ACCTNO;
RUN;
PROC SORT DATA=DRCRCA.ACCUM OUT=ACCUM;BY ACCTNO;RUN;
PROC SORT DATA=SIGNA.SMSACC OUT=SAACC; BY ACCTNO; RUN;

DATA DDWH.ICACLOSE&REPTMON&REPTYEAR;
  MERGE ICACLOSE(IN=A) DPCLOS ACCUM SAACC
        MISMTD.CAVG&REPTMON(KEEP=ACCTNO MTDAVBAL_MIS);
  BY ACCTNO;
  IF A;
  IF ESIGNATURE = '' THEN ESIGNATURE = 'N';
RUN;
*;
FILENAME TRANFILE 'SAP.PIBB.CACLSWH.CACFTP' DISP=OLD;
PROC CPORT LIBRARY=DDWH FILE=TRANFILE;
RUN;
*;
//*------------------------------------------------------
//* FTP TO EDW
//*------------------------------------------------------
//RUNSFTP  EXEC COZBATCH
//CMD.SYSUT1 DD DISP=SHR,DSN=OPER.PBB.PARMLIB(EDW#SFTP)
//           DD *
lzopts servercp=$servercp,notrim,overflow=trunc,mode=binary
lzopts linerule=$lr
cd /stgsrcsys/host/ftpfiles
PUT //SAP.PIBB.CACLSWH.CACFTP    ICACLFTP
lzopts mode=text
cd /stgsrcsys/host/control
put //SAP.DAY.CONTROL          EIIMCLCA.TXT
EOB
/*
