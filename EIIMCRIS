*------------------------------------------------*
*  OTHER LOAN INFO                               *
*------------------------------------------------*;
PROC SORT DATA=MNICS.CIS OUT=TEMP(KEEP=ACCTNO NAME SIC) NODUPKEYS;
   BY ACCTNO;
*;
DATA SAVE.LOAN;
   DROP NAMELN2-NAMELN5;
   LENGTH ADDR1 $45 ADDR2 $90;
   MERGE LOAN(IN=AA DROP=NAME) LNADDR TEMP;
   BY ACCTNO;
   IF AA;
   IF VERIFY(NEWIC,'0 ') = 0 THEN NEWIC = ' ';
   IF VERIFY(OLDIC,'0 ') = 0 THEN OLDIC = ' ';
   ADDR1 = NAMELN2;
   ADDR2 = TRIM(NAMELN3)||' '||TRIM(NAMELN4)||' '||NAMELN5;

   IF 100 <= PRODUCT <= 199 THEN FITYPE = 'I';
   ELSE FITYPE = 'C';
   IF LOANCNT > 1 THEN LOANOPT = 'M';
   ELSE LOANOPT = 'S';
   IF APPRDATE > 0 THEN
         APPRDTE = PUT(DAY(APPRDATE),Z2.)||PUT(MONTH(APPRDATE),Z2.)||
                   PUT(APPRDATE,YEAR4.);
   IF PAIDIND = 'P' & BALANCE <= 0 THEN DO;
      IF CLOSEDTE > 0 THEN
         CLOSDTE = PUT(DAY(CLOSEDTE),Z2.)||PUT(MONTH(CLOSEDTE),Z2.)||
                   PUT(CLOSEDTE,YEAR4.);
   END;
   PRODCD = PUT(PRODUCT,LNPRODC.);
   IF PAYFREQ = ' ' THEN PAYTERM = 'M';
   ELSE PAYTERM = PUT(PAYFREQ,$PAYFQ.);
   IF SECURE ^= 'S' THEN SECURE = 'C';
   IF BORSTAT = 'S' THEN RESTRUC = 'R';
   ELSE RESTRUC = 'N';
   IF PRODUCT IN (101,210,307,709,710,910) THEN CAGAMAS = 'C';
   ELSE CAGAMAS = 'N';
   IF RISKC = ' ' THEN RISKC = 'P';
   MTHARR = FLOOR(DAYS/30.00050); *22-5723;

   IF PAIDIND NE 'P' OR
     (PAIDIND = 'P' AND PUT(CLOSEDTE,YYMMN6.)="&REPTYEAR&REPTMON");

   IF APPLDATE > 0
      THEN APPLDT=INPUT(SUBSTR(PUT(APPLDATE,Z11.),1,8),MMDDYY8.);

   CHKDT='31AUG04'D;

   IF LOANTYPE IN (981,982,983,991,992,993) OR
     (LOANTYPE IN (128,130,380,381,700,705) AND
      LSTTRNCD IN (658,662) AND APPLDT NE . )
   /* ACCTNO > 8000000000 */      THEN DO;
      IF       CHKDT > APPLDT     THEN DELETE;
   END;

   IMPAIRED = 'N';
   IF DAYS >= 90 OR
      BORSTAT IN ('F','I','R') OR
      LOANTYPE IN (983,993,678,679,698,699) OR
      USER5 = 'N' THEN IMPAIRED = 'Y';
*;
