*;
*------------------------------------------------*
*  GET TERMCHG FOR HP                            *
*------------------------------------------------*;
DATA TERMCHG;
   KEEP ACCTNO NOTENO TERMCHG VINNO;
   SET LOAN.LNNOTE;
   IF REVERSED^='Y' & NOTENO^=. & PAIDIND^='P' & NTBRCH^=. &
      LOANTYPE IN (128,130,700,705,380,381);
   IF INTAMT > 0.1 THEN TERMCHG = INTAMT + INTEARN2;
   ELSE TERMCHG = 0;
*;
PROC SORT;
   BY ACCTNO NOTENO;
*;
PROC SORT DATA=BNM.ULOAN&REPTMON&NOWK OUT=ULOAN;
   BY ACCTNO COMMNO;
PROC SORT DATA=LOAN.LNCOMM OUT=LNCOMM;
   BY ACCTNO COMMNO;
*;
DATA MERGECOM;
   MERGE ULOAN (IN=A)
         LNCOMM(KEEP=ACCTNO COMMNO CMBRCH CAPPDATE);
   BY ACCTNO COMMNO;
   IF A;
   IF CAPPDATE > 0 THEN
      APPRDATE= INPUT(SUBSTR(PUT(CAPPDATE, Z11.), 1, 8), MMDDYY8.);
   IF BRANCH = 0 OR BRANCH = . THEN BRANCH = CMBRCH;
   IF APPRLIMT >= 1000000;
*;
*------------------------------------------------*
*  BASED ON M&I LOANS DETERMINE ACCOUNTS WITHIN  *
*  TRESHOLD IE. APPRLIMT >= RM 1M OR NPL         *
*  - OMIT LOANS TO OTHER FINANCIAL INSTITUTIONS  *
*  AT THE SAME TIME COMBINE HP NPL               *
*------------------------------------------------*;
DATA LOAN;
   SET BNM.LOAN&REPTMON&NOWK MERGECOM (IN=B);
   WHERE CUSTCODE NOT IN (1,2,3,10,11,12,81,91);
   IF B THEN NOTENO = COMMNO;
   IF PRODUCT IN (128,130,700,705,380,381,709,710,750,752,760) THEN
      APPRLIMT = NETPROC;
   ELSE APPRLIMT = ORGBAL;
*;
PROC SORT; BY ACCTNO NOTENO;
*;
PROC SUMMARY DATA=LOAN;
   BY ACCTNO;
   VAR APPRLIMT;
   OUTPUT OUT=TEMP(DROP=_TYPE_ RENAME=_FREQ_=LOANCNT) SUM=TOTLIMT;
*;
DATA LOAN;
   MERGE LOAN TEMP;
   BY ACCTNO;
RUN;
DATA LOAN;
   RETAIN REPTDTE REPTDATE;
   %DCLVAR
   MERGE LOAN NPL(IN=B) TERMCHG;
   BY ACCTNO NOTENO;
   IF _N_ = 1 THEN DO;
      REPTDTE = "&REPTDAY"||"&REPTMON"||"&REPTYEAR";
      REPTDATE = INPUT("&RDATE",DDMMYY8.);
   END;
   IF DAYS = . AND BLDATE > 0 THEN DAYS = REPTDATE - BLDATE;
   IF DAYS = . AND BLDATE = 0 THEN DAYS = 0;
   IF BRANCH = . THEN BRANCH = NTBRCH;
   /***  NPL (FL/HL) NOT IN NPL DATASET  ***/
 /* THIS PART REMOVE BECAUSE HL/FL IS INCLUDED IN IISCOMB AND SPOL1 */
 /* IF PRODUCT NOT IN (128,130,700,705) & BLDATE > 0 THEN DO;
      IF DAYS > 364 THEN RISKC = 'B';
      ELSE IF DAYS > 273 THEN RISKC = 'D';
      ELSE IF DAYS > 182 THEN RISKC = 'S';
      IF BORSTAT IN ('F','I','R','T') THEN RISKC = 'B';
   END;              */

   IF B OR TOTLIMT >= 1000000;

   /***  PL (HP) - CAL PRIN & INT O/S    ***/

   IF ^B THEN DO;
      TOTIIS = 0; UHC = 0;
      IF LOANTYPE NOT IN (128,130,700,705,380,381) THEN OSPRIN = CURBAL;
      ELSE IF BLDATE > 0 THEN DO;
         IF BILPAY > 0 THEN DO;
            IF BILTOT = . THEN BILTOT = 0;
            IF BILTOT / BILPAY <= 0.01 THEN DO;
               %NXTBLDT
            END;
         END;
         DAYS=0;
         IF BLDATE > 0 THEN DAYS = REPTDATE - BLDATE;
         IF TERMCHG > 0 THEN DO;
            REMMTH1 = EARNTERM - ((YEAR(BLDATE) - YEAR(ISSDTE))*12 +
                      MONTH(BLDATE) - MONTH(ISSDTE) + 1);
            REMMTH2 = EARNTERM - ((YEAR(REPTDATE) - YEAR(ISSDTE))*12 +
                      MONTH(REPTDATE) - MONTH(ISSDTE) + 1);
            IF REMMTH2 < 0 THEN REMMTH2 = 0;
            IF LOANTYPE IN (128,130) THEN
                 REMMTH1 = REMMTH1 - 3;
            ELSE REMMTH1 = REMMTH1 - 1;
            IF REMMTH1 >= REMMTH2 THEN DO;
               DO REMMTH = REMMTH1 TO REMMTH2 BY -1;
                  TOTIIS + 2*(REMMTH+1)*TERMCHG/(EARNTERM*(EARNTERM+1));
               END;
            END;
            IF REMMTH2 > 0 THEN
               UHC = REMMTH2*(REMMTH2+1)*TERMCHG/(EARNTERM*(EARNTERM+1));
         END;
         IF CURBAL = . THEN CURBAL = 0;
         OSPRIN = CURBAL - UHC - TOTIIS;
      END;
   END;
   IF OSPRIN < 0 THEN OSPRIN = 0;
   IF LOANTYPE IN (131,132) THEN OSPRIN = CURBAL;
   IF BORSTAT = 'W' OR LOANTYPE IN (981,982,983,991,992,993) THEN
      OSPRIN = 0;
   /*
   TOTIIS = ROUND(TOTIIS);
   TOTBAL = ROUND(OSPRIN + TOTIIS);
   */
   TOTBAL = SUM(OSPRIN,TOTIIS);
*;
