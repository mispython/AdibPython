*;
DATA SAVE.LOAN;
   MERGE SLOAN(IN=A) CRSSTA(IN=B); BY ACCTNO NOTENO;
   IF A AND B THEN DELETE;
*;
   /** ESMR - 2009-161 MERGE WITH ELDS  **/
DATA ELDS;
  SET ELDS2.ELHPAX;
  IF  BRANCH GE 3000;
RUN;
DATA ELDS;
  SET ELDS         (KEEP=AANO AMOUNT AADATE RECONAME REFTYPE NMREF1
                         NMREF2 APVNME1 APVNME2 COMPLIBY COMPLIDT
                         COMPLIGR);
RUN;
DATA LOAN;
  SET SAVE.LOAN;
  AANO = SUBSTR(LEFT(VINNO),1,13);
RUN;
PROC SORT DATA=ELDS NODUPKEYS; BY AANO;
PROC SORT DATA=LOAN; BY AANO;
DATA SAVE.LOAN;
   MERGE ELDS(IN=A) LOAN(IN=B);
   BY AANO;
   IF B;
   IF B AND NOT A THEN AANO = ' ';
   IF AMOUNT NE . THEN APPRLMAA = AMOUNT;
   IF LOANTYPE IN (128,131,380,700,720,983,993)
                                             THEN FACILITY=34331;
   IF LOANTYPE IN (130,132,381,705,725)
                                             THEN FACILITY=34332;
   PURPOSES = CRISPURP;
   IF LOANTYPE IN (700,720,128,131) OR FACILITY=34331 THEN
      PURPOSES = 3100;
   IF LOANTYPE IN (705,725,130,132) OR FACILITY=34332 THEN
      PURPOSES = 3200;

   FACCODE = 0;
   IF LOANTYPE IN (128,130,131,132,380,381,700,705,709,710,720,725,
                   750,752,760,983,993,996) THEN DO;
      IF      PURPOSES IN ('3100','3101','3110','3120') THEN
         FACCODE = 34333;
      ELSE IF PURPOSES IN ('3200','3201','3300','3900','3901',
                           '4100','5100','5200')       THEN
         FACCODE = 34334;
   END;

   IF FACCODE = 0 THEN FACCODE = FACILITY;
RUN;
*;
DATA WOBACK(KEEP=ACCTNO NOTENO);
  SET LOAN.LNNOTE;
  IF LOANTYPE IN (983,993) AND BORSTAT NE 'E';
RUN;
PROC SORT DATA=WOBACK; BY ACCTNO NOTENO; RUN;
*;
DATA TRANS;
  SET TRAN.LNBTRAN&RYEAR&REPTMON&WK1
      TRAN.LNBTRAN&RYEAR&REPTMON&WK2
      TRAN.LNBTRAN&RYEAR&REPTMON&WK3
      TRAN.LNBTRAN&RYEAR&REPTMON&WK4;
RUN;
PROC SORT DATA=TRANS; BY ACCTNO NOTENO; RUN;
*;
DATA TRANS;
  MERGE WOBACK(IN=A) TRANS(IN=B); BY ACCTNO NOTENO;
  IF A AND B;
RUN;
PROC SUMMARY DATA=TRANS MISSING;
   WHERE TRANCODE IN (610,614,615,619,650,660,680);
   BY ACCTNO NOTENO;
   VAR TRANAMT;
   OUTPUT OUT=TOTAMT SUM=;
RUN;
PROC SORT DATA=TOTAMT; BY ACCTNO NOTENO; RUN;
PROC SORT DATA=SAVE.LOAN; BY ACCTNO NOTENO; RUN;
*;
DATA SAVE.LOAN;
  MERGE SAVE.LOAN(IN=A) TOTAMT(IN=B); BY ACCTNO NOTENO;
  IF A;
  TOTAL=0.00;
  IF TRANAMT = . THEN TRANAMT=0.00;
RUN;
*------------------------------------------------*
*  LOAN DETAILS/CURRENCY (PAGE03)                *
*------------------------------------------------*;
DATA SAVE.PROV(KEEP=ACCTNO NOTENO OSPRIN TOTIIS OTHERFEE TOTBAL);
   RETAIN FV 'SAP.PICRISS.TEXT(PAGE03)';
   SET SAVE.LOAN;
   IF RISKC = 'O' THEN RISKC = 'P';
   IF RISKD EQ 'S' AND BORSTAT NE 'W' AND RISKC NE 'P' THEN RISKC= ' ';
   IF RISKC EQ ' ' THEN DELETE;
   IF RISKC NE 'S' AND DAYS < 90 AND BORSTAT NOT IN ('F','I','R','W')
      AND USER5 NE 'N' THEN RISKC='P';
   IF LOANTYPE IN (983,993,698,699) THEN DO;
      IF PAIDIND NE 'P' THEN DO;
         RISKC='B';
      END;
      ELSE IF PAIDIND='P' THEN DO;
         IMPAIRED='N';
         RISKC='P';
         MTH1AA=0;
      END;
   END;
   IF IMPAIRED = 'Y' AND LOANTYPE NOT IN (983,993,698,699) THEN DO;
      PIO = ROUND(SUM(OSPRIN,TOTIIS,OTHERFEE),.01);
      IF PIO NE ROUND(BALANCE,.01) THEN DO;
         DIFF = SUM(BALANCE,-1*PIO);
         TOTIIS = SUM(TOTIIS,DIFF);
         IF TOTIIS < 0 THEN DO;
            OSPRIN = SUM(OSPRIN,TOTIIS);
            TOTIIS = 0;
            IF OSPRIN < 0 THEN DO;
               OTHERFEE = SUM(OTHERFEE,OSPRIN);
               OSPRIN = 0;
            END;
         END;
      END;
   END;
   FILE OUTFLE FILEVAR=FV;
   PUT @1   '0234'             /* FI TYPE/FI CODE            */
       @5   BRANCH   Z5.       /* COST CENTRE                */
       @10  ACCTNO   10.       /* ACCOUNT NUMBER             */
       @20  NOTENO   Z5.       /* LOAN NOTE NUMBER           */
       @25  REPTDTE  $8.       /* REPORTING DATE             */
       @33  LOANTYPE  5.       /* LOAN FACILITY CODE         */
       @38  APPRDTE  $8.       /* DATE ACCOUNT OPENED        */
       @46  CLOSDTE  $8.       /* DATE ACCOUNT CLOSED        */
       @54  8*' '              /* DATE ACCOUNT CANCELLED     */
       @62  2*' '              /* ISLAMIC CONCEPT CODE       */
       @64  SECTORCD $4.       /* LOAN SECTORAL CODE         */
       @68  NOTETERM  3.       /* ORIGINAL TENURE            */
       @71  PAYTERM  $1.       /* PRIN REPAYMENT TERM        */
       @72  MTHARR    3.       /* MTHS IN DEFAULT - PRIN O/S */
       @75  MTHARR    3.       /* MTHS IN DEFAULT - INT O/S  */
       @78  RISKC    $1.       /* LOAN CLASSIFICATION        */
       @79  SECURE   $1.       /* SECURED/CLEAN LENDING      */
       @80  'N'                /* SHARED SECURITY            */
       @81  'N'                /* LEGAL ACTION STATUS        */
       @82  RESTRUC  $1.       /* RESTRUCTURED/RESCHED       */
       @83  CAGAMAS  $1.       /* CAGAMAS,DANAHARTA,NONE     */
       @84  'S'                /* CURRENCY                   */
       @85  'N'                /* REMARK INDICATOR           */
       @86  'N'                /* USER DEFINED FIELD IND     */
       @87  'N'                /* STATUS                     */
       @88  'MYR'              /* CURRENCY CODE              */
       @91  OSPRIN   12.2      /* PRINCIPAL OUTSTANDING      */
       @103 TOTIIS   12.2      /* INTEREST OUTSTANDING       */
       @115 OTHERFEE 12.2      /* OTHER FEE                  */
       @127 TOTBAL   12.2      /* TOTAL OUTSTANDING          */
       @139 'N'                /* STATUS                     */
       @140 BORSTAT   $1.      /* BORROWER STATUS            */
       @141 COSTCTR   Z4.      /* COST CENTRE                */
       @145 AANO     $13.      /* AANO                       */
       @158 FACILITY   5.      /* FACILITY                   */
       @165 TOTAL    17.2      /* TOTAL IIS AND SP           */
       @182 TRANAMT  17.2      /* TOTAL WRITTEN OFF BACK     */
       @199 FACCODE    5.      /* NSRS FACILITY              */
       @205 IMPAIRED  $1.      /* IMPAIRED LOAN STATUS       */
       ;
*;
*------------------------------------------------*
