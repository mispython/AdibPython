*+--------------------------------------------------------------+
 |  PROGRAM : EIFMCRIS                                          |
 |  REPORT  : PREPARE TEXT FILES FOR KLUNION FOR CRISS          |
 |            (AGGREGATE APPRLIMT >= 1000000 & NPL ACCOUNTS)    |
 |  MODIFY :     ESMR 2004-720 &2004-579                        |
 |  MODIFICATION : CHANGE EXISTING NPL WHICH TURNED PERFORMING  |
 |                 CLASSIFICATION FROM 'S' INTO 'P'             |
 +--------------------------------------------------------------+;
OPTIONS SORTDEV=3390 YEARCUTOFF=1950 MISSING=0 NOCENTER;
*;
%INC PGM(PFBCRFMT);
*;
PROC FORMAT;
   VALUE $PAYFQ
     '1'   = 'M'    /* MONTHLY            */
     '2'   = 'Q'    /* QUARTERLY          */
     '3'   = 'S'    /* SEMI-ANNUALLY      */
     '4'   = 'A'    /* ANNUALLY           */
     '5'   = 'B'    /* BULLET (DUE DATE)  */
     '9'   = 'I'    /* INDEFINITE         */
     OTHER = 'O';   /* OTHERS             */
*;
*------------------------------------------------*
*  MACRO FOR CALCULATING NEXT BLDATE             *
*------------------------------------------------*;
%MACRO DCLVAR;
   RETAIN D1-D12 31 D4 D6 D9 D11 30;
   ARRAY LDAY D1-D12;
%MEND DCLVAR;
*;
%MACRO NXTBLDT;
   DD = DAY(ISSDTE);
   MM = MONTH(BLDATE) + 1;
   YY = YEAR(BLDATE);
   IF MM > 12 THEN DO;
      MM = 1; YY + 1;
   END;
   IF MM = 2 THEN
      IF MOD(YY,4) = 0 THEN D2 = 29;
      ELSE D2 = 28;
   IF DD > LDAY(MM) THEN DD = LDAY(MM);
   BLDATE = MDY(MM,DD,YY);
%MEND NXTBLDT;
*;
*------------------------------------------------*
*  BACKUP PREVIOUS SUBMISSION BEFORE THIS RUN    *
*------------------------------------------------*;
*PROC DATASETS LIB=SAVE NOLIST;
*   AGE LOAN LOAN1-LOAN8 / MEMTYPE=DATA;
*;
*------------------------------------------------*
*  GET REPTDATE                                  *
*------------------------------------------------*;
DATA _NULL_;
   SET LOAN.REPTDATE;
   SELECT(DAY(REPTDATE));
      WHEN  (8) CALL SYMPUT('NOWK',PUT('1',$1.));
      WHEN (15) CALL SYMPUT('NOWK',PUT('2',$1.));
      WHEN (22) CALL SYMPUT('NOWK',PUT('3',$1.));
      OTHERWISE CALL SYMPUT('NOWK',PUT('4',$1.));
   END;
   WK1='01';
   WK2='02';
   WK3='03';
   WK4='04';
   CALL SYMPUT('WK1',PUT(WK1,$2.));
   CALL SYMPUT('WK2',PUT(WK2,$2.));
   CALL SYMPUT('WK3',PUT(WK3,$2.));
   CALL SYMPUT('WK4',PUT(WK4,$2.));
   CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR4.));
   CALL SYMPUT('RYEAR',PUT(REPTDATE,YEAR2.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
   CALL SYMPUT('REPTDAY',PUT(DAY(REPTDATE),Z2.));
   CALL SYMPUT('RDATE',PUT(REPTDATE,DDMMYY8.));
   PREVMON = MONTH(REPTDATE)- 1;
   IF PREVMON = 0 THEN PREVMON = 12;
   CALL SYMPUT('PREVMON',PUT(PREVMON,Z2.));
RUN;
*;
*------------------------------------------------*
*  EXTRACT PERFORMING ACCOUNTS FOR ONE MONTH     *
*------------------------------------------------*;
*;
DATA PREV&PREVMON;
   SET NPL.LOAN&PREVMON; * NPOL.LOAN&PREVMON NPIL.ILOAN&PREVMON;
   PREVIND = 'OLD';
   WHERE LOANTYPE < 900;
RUN;
PROC SORT DATA=PREV&PREVMON;
  BY ACCTNO; RUN;
*;
DATA CURR&REPTMON;
   SET NPL.LOAN&REPTMON; * NPOL.LOAN&REPTMON NPIL.ILOAN&REPTMON;
  * WHERE LOANTYPE < 900;
   PREVIND = 'NEW';
RUN;
PROC SORT DATA = CURR&REPTMON;
  BY ACCTNO; RUN;
*;
DATA PERFORM;
   MERGE PREV&PREVMON CURR&REPTMON;
   BY ACCTNO;
   IF PREVIND = 'OLD';
   MARKETVL = 0;
RUN;
*------------------------------------------------*
*  EXTRACT NON-PERFORMING ACCOUNTS               *
*------------------------------------------------*;
DATA IIS;
  SET NPL.IIS; * NPOL.IIS NPIL.IIS;
RUN;
PROC SORT DATA=IIS OUT=IIS(RENAME=(RECOVER=RECIIS NTBRCH=BRANCH)
   KEEP=NTBRCH ACCTNO NOTENO BORSTAT TOTIIS IISP SUSPEND RECOVER
        IISPW RECC OI OIP OISUSP OIW OIRECC OIRECV DAYS);
   BY ACCTNO NOTENO;
*;             /*
PROC SORT DATA=NPOL.SP1 OUT=SPOL1;
   BY ACCTNO NOTENO;
*;
PROC SORT DATA=NPIL.SP1 OUT=SPIL1;
   BY ACCTNO NOTENO;
*; */
PROC SORT DATA=NPL.SP2 OUT=SP2 /* (DROP=MARKETVL) REMOVE BY JENNY */;
   BY ACCTNO NOTENO;
*;
PROC SORT DATA=NPL.SP1OPEN OUT=SP1OPEN;
   BY ACCTNO NOTENO;
*;
PROC SORT DATA=NPL.SP1 OUT=SP1;
   BY ACCTNO NOTENO;
*;
PROC SORT DATA=NPL.SP2OPEN OUT=SP2OPEN;
   BY ACCTNO NOTENO;
*;
DATA SP2;
   MERGE SP2(IN=A)
         SP2OPEN (KEEP=ACCTNO RISKOPEN);
   BY ACCTNO;
   IF A;
DATA SP2;
   MERGE SP2(IN=A)
         /* SP1 (KEEP=ACCTNO NOTENO MARKETVL SPP1) CHG BY JENNY ; */
         SP1 (KEEP=ACCTNO NOTENO SPP1);
   BY ACCTNO NOTENO;
   IF A;
DATA SP1;
   MERGE SP1(IN=A)
         SP1OPEN (KEEP=ACCTNO RISKOPEN);
   BY ACCTNO;
   IF A;
*;
DATA SP1;
   MERGE SP1(IN=A)
         SP2(KEEP=ACCTNO NOTENO SPP2 RISK);
   BY ACCTNO NOTENO;
   IF A;
*;
DATA SP;
   KEEP ACCTNO NOTENO OSPRIN MARKETVL SPP SPPL RECOVER SPPW SP RISKC
        SPMADE SPWRBACK SPP1 SPP2 RISKO OTHERFEE;
   LENGTH RISKC $1;
   * SET SP1(IN=A) SP2(IN=B) SPOL1(IN=C) SPIL1(IN=C);
   SET SP2(IN=B); * SPOL1(IN=C) SPIL1(IN=C);
   IF RISK = 'SUBSTANDARD-1' THEN RISK = 'C';
   RISKC = SUBSTR(RISK,1,1);
   RISKO = SUBSTR(RISKOPEN,1,1);
   IF RISKO EQ ' ' THEN RISKO = RISKC;
   * IF (A & (RISKO IN ('S','C'))) | (B & RISKO IN ('B','D')) | C;
   * IF RISKO IN ('S','C') THEN SPP = SPP1;
   * ELSE IF RISKO IN ('B','D') THEN SPP=SPP2;
   IF B THEN SPP = SPP2;
   /* IF C THEN SPP=SPP1;
   IF C THEN MARKETVL = REALISVL;   */  /** FOR HL/FL **/
   IF SP =. THEN SP = 0; IF SPPW =. THEN SPPW = 0;
   IF SPP1 =. THEN SPP1 = 0; IF SPP2 =. THEN SPP2 = 0;
   IF SPPL = . THEN SPPL = 0;
   IF SPP = . THEN SPP = 0;
   IF RECOVER = . THEN RECOVER= 0;
   SPMADE = SPPL;
   SPWRBACK = RECOVER;
   /*
   IF SUBSTR(RISKOPEN,1,1) NE ' ' THEN SPMADE = SP + SPPW - SPP;
   IF SPMADE <= 0 THEN SPMADE = 0;
   IF SPMADE > 0 THEN SPWRBACK = 0;
   IF SPWRBACK >= SPP THEN SPWRBACK = SPP;
   */
*;
PROC SORT;
   BY ACCTNO NOTENO;
*;
DATA NPL;
   DROP OIP OI;
   MERGE IIS(IN=A) SP;
   BY ACCTNO NOTENO;
   IF A;
   IF OIP = . THEN OIP = 0;
   IF OI = . THEN OI = 0;
   IISP + OIP;
   * SUSPEND = SUM(SUSPEND,OISUSP,(-1)*RECC,(-1)*OIRECC);
   SUSPEND = SUM(SUSPEND,OISUSP);
   * RECIIS + OIRECV;
   RECIIS = SUM(RECIIS, OIRECV, RECC, OIRECC);
   IISPW + OIW;
   IF MARKETVL = . THEN MARKETVL = 0;
   CLASSAMT = OSPRIN - MARKETVL;
*;
PROC SORT DATA=LOAN.LNNOTE OUT=LNNOTE (DROP=MARKETVL BORSTAT);
   BY ACCTNO NOTENO;
*;
DATA NPL;
   MERGE PERFORM (IN=A) NPL;
   BY ACCTNO NOTENO;
   IF A THEN DO;
      RISKC = 'O';
      MARKETVL = 0;
   END;
*;
PROC SORT DATA=NPL; BY ACCTNO NOTENO; RUN;
DATA NPL;
   MERGE NPL(IN=A) LNNOTE;
   BY ACCTNO NOTENO;
   IF GRANTDT > 0 THEN
      APPRDATE = INPUT(SUBSTR(PUT(GRANTDT, Z11.), 1, 8), MMDDYY8.);
   IF LOANTYPE IN (983,993) THEN DO;
      RISKC= 'B';
      RISKD= 'B';
   END;
   IF MORDAYARR NE . THEN DAYS = MORDAYARR;
   IF DAYS < 90 AND TOTIIS <= 0 AND SP <= 0 AND RISKC IN ('S','C') AND
   PAIDIND NE 'P' THEN DO;
      IF LOANTYPE IN (128,130,700,705,380,381) THEN DO;
         IF BORSTAT NOT IN ('F','R','I') OR USER5 NE 'N' THEN DO;
            RISKC = 'P';
            RISKD = 'P';
         END;
      END;
      ELSE DO;
         IF CENSUS7 ^= '9' THEN DO;
         RISKC = 'P';
         RISKD = 'P';
         END;
      END;
   END;
   IF PAIDIND = 'P' THEN DO;
      CLOSEDTE=INPUT(SUBSTR(PUT(LASTTRAN,Z11.),1,8),MMDDYY8.);
      RISKD = 'S';
      BRANCH=NTBRCH;
   END;
   IF A;
*;
PROC SORT DATA=NAME.LNNAME OUT=LNNAME;
   BY ACCTNO;
*;
