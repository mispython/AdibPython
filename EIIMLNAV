//EIIMLNAV JOB MSGCLASS=X,MSGLEVEL=(1,1),REGION=128M                    JOB49966
/*JOBPARM S=S1M1                                                                
//*---------------------------------------------------------------------        
//* ESMR     : 2016-1845                                                        
//* DESC     : DAILY ACCUMULATE CURBAL/FORBAL FOR LOANS                         
//*---------------------------------------------------------------------        
//EIDMLNAV EXEC SAS609                                                          
//PGM      DD DSN=SAP.BNM.PROGRAM,DISP=SHR                                      
//LN       DD DSN=SAP.PIBB.MNILN.DAILY(0),DISP=SHR                              
//MIS      DD DSN=SAP.PIBB.MLN.SASDATA,DISP=OLD                                 
//SASLIST  DD SYSOUT=X                                                          
//SORTWK01 DD UNIT=SYSDA,SPACE=(CYL,(1000))                                     
//SORTWK02 DD UNIT=SYSDA,SPACE=(CYL,(1000))                                     
//SORTWK03 DD UNIT=SYSDA,SPACE=(CYL,(1000))                                     
//SORTWK04 DD UNIT=SYSDA,SPACE=(CYL,(1000))                                     
//SORTWK05 DD UNIT=SYSDA,SPACE=(CYL,(1000))                                     
//SYSIN    DD *                                                                 
                                                                                
OPTIONS YEARCUTOFF=1960 NOCENTER NODATE NONUMBER COMPRESS=Y                     
        SORTPARM='HIPRMAX=0,MOSIZE=0';                                          
                                                                                
DATA REPTDATE;                                                                  
   SET LN.REPTDATE;                                                             
   CALL SYMPUT('PREVDAY',PUT(DAY(REPTDATE-1),Z2.));                             
   CALL SYMPUT('REPTDAY',PUT(DAY(REPTDATE),Z2.));                               
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));                             
   CALL SYMPUT('RDATE',REPTDATE);                                               
RUN;                                                                            
                                                                                
DATA TODAY_BAL;                                                                 
   SET LN.LNNOTE;                                                               
   KEEP ACCTNO NOTENO BALANCE;                                                  
RUN;                                                                            
                                                                                
%MACRO GET_AVGBAL;                                                              
%IF &REPTDAY EQ 1 %THEN %DO;                                                    
   DATA MAIN_AVGBAL;                                                            
      SET TODAY_BAL(KEEP=ACCTNO NOTENO BALANCE);                                
   RENAME BALANCE=BAL&REPTDAY;                                                  
   MTDAVBAL_MIS=BALANCE;                                                        
   LAST_AVGBAL=BALANCE;                                                         
   LAST_DAY=1;                                                                  
   RUN;                                                                         
%END;                                                                           
%ELSE %IF &REPTDAY > 1 %THEN %DO;                                               
   PROC SORT DATA=MIS.LNVG_&REPTMON OUT=MAIN_AVGBAL;                            
   BY ACCTNO NOTENO; RUN;                                                       
                                                                                
   PROC SORT DATA=TODAY_BAL(RENAME=BALANCE=BAL&REPTDAY)                         
   OUT=TEMP_BAL(KEEP=ACCTNO NOTENO BAL&REPTDAY); BY ACCTNO NOTENO; RUN;         
                                                                                
   DATA MAIN_AVGBAL;                                                            
      FORMAT CURR_BAL 25.6;                                                     
      MERGE MAIN_AVGBAL(IN=A) TEMP_BAL(IN=B);                                   
   BY ACCTNO NOTENO;                                                            
   IF B OR A;                                                                   
   IF LAST_DAY > &PREVDAY THEN DO; /*FOR RERUN*/                                
      DO UNTIL (LAST_DAY EQ &PREVDAY);                                          
         T=CATS("BAL"||PUT(LAST_DAY,Z2.));                                      
         CURR_BAL=VVALUEX(CATS("BAL"||PUT(LAST_DAY,Z2.)));                      
         LAST_AVGBAL=((LAST_AVGBAL*LAST_DAY)-CURR_BAL)                          
                     /SUM(LAST_DAY,-1);                                         
         LAST_DAY=SUM(LAST_DAY,-1);                                             
      END;                                                                      
   END;                                                                         
   MTDAVBAL_MIS=SUM(LAST_AVGBAL*LAST_DAY,BAL&REPTDAY)/&REPTDAY;                 
   LAST_AVGBAL=MTDAVBAL_MIS;                                                    
   IF LAST_DAY EQ . THEN LAST_DAY=&PREVDAY;                                     
   LAST_DAY=SUM(LAST_DAY,1);                                                    
   RUN;                                                                         
%END;                                                                           
%MEND GET_AVGBAL;                                                               
%GET_AVGBAL;                                                                    
                                                                                
DATA MIS.LNVG_&REPTMON;                                                         
   SET MAIN_AVGBAL;                                                             
RUN;                                                                            
                                                                                
PROC SORT DATA=MIS.LNVG_&REPTMON                                                
   OUT=MIS.LNVG&REPTMON(KEEP=ACCTNO NOTENO MTDAVBAL_MIS);                       
   BY ACCTNO NOTENO; RUN;                                                       
