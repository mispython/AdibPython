   LASTDT=INPUT('01'||PUT(SETMTH,Z2.)||
                PUT(SETYEAR,4.), DDMMYY8.)-1;
   CALL SYMPUT('WEEKSTDT',WEEKSTDT);
   CALL SYMPUT('WEEKEND',DATE);
   CALL SYMPUT('STATUS','WEEKLY');
   CALL SYMPUT('LASTDT',WEEKSTDT);
RUN;
