   DESC = "&PROD";
   IF ABS(WEEK1) > ABS(WEEK) THEN WEEK = ABS(WEEK1);
   ELSE WEEK = ABS(WEEK);
   IF ABS(MONTH1) > ABS(MONTH) THEN MONTH = ABS(MONTH1);
