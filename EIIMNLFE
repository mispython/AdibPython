DATA FINAL.HIGHLOWRATE&PROD;
   MERGE HIGH LOW;
   BY FINALSTAT;
   DESC = "&PROD";
   IF ABS(WEEK1) > ABS(WEEK) THEN WEEK = ABS(WEEK1);
   ELSE WEEK = ABS(WEEK);
