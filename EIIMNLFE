   ELSE HALFYR = ABS(HALFYR);
   IF ABS(YEAR1) > ABS(YEAR) THEN YEAR = ABS(YEAR1);
   ELSE YEAR = ABS(YEAR);
   WEEK   = ROUND((WEEK * &OUTSTAND / 100),1.);
   MONTH  = ROUND(((MONTH * &OUTSTAND / 100) - WEEK),1.);
   QTR    = ROUND(((QTR * &OUTSTAND / 100) - SUM(WEEK,MONTH)),1.);
