                                           PUT(SETYEAR,4.), DDMMYY8.)-1;
   ELSE IF SETDAY <=15 THEN WEEKSTDT=INPUT('08'||PUT(SETMTH,Z2.)||
                                           PUT(SETYEAR,4.), DDMMYY8.);
   ELSE IF SETDAY <=22 THEN WEEKSTDT=INPUT('15'||PUT(SETMTH,Z2.)||
                                           PUT(SETYEAR,4.), DDMMYY8.);
   ELSE                     WEEKSTDT=INPUT('22'||PUT(SETMTH,Z2.)||
