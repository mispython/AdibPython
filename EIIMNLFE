%MACRO MISAPPD;
%IF "&INSERT" EQ "Y" %THEN
    %DO;
      DATA &PROD;
         SET BASE.DEPOSIT;
         WHERE DATE = &DATE & DESC = "&PROD";
         BALANCE = BALANCE * (-1);
         KEEP DATEX DATE BALANCE;
      RUN;
      DATA BASE.&PROD;
         SET BASE.&PROD;
         IF DATE EQ "&DATE" THEN DELETE;
      RUN;
      PROC SORT; BY DATE;
    *  PROC PRINT;
      PROC APPEND DATA=&PROD BASE=BASE.&PROD; RUN;
      DATA STORE.&PROD;
         SET BASE.&PROD;
         WHERE DATE <= &DATE;
    *  PROC PRINT;
    %END;
%ELSE %DO;
      DATA &PROD;
         SET BASE.DEPOSIT;
         WHERE DATE = &DATE & DESC = "&PROD";
         BALANCE = BALANCE * (-1);
         KEEP DATEX DATE BALANCE;
      RUN;
      DATA STORE.&PROD;
         SET BASE.&PROD &PROD;
         WHERE DATE <= &DATE;
      PROC SORT; BY DATE;
    *  PROC PRINT;
      RUN;
%END;
%MEND MISAPPD;
RUN;
