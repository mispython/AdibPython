DATA TABLE;
  INFILE CRFTABL;
  INPUT @001 TFNUM    $3.
        @004 TFID     $8.
        @012 SUBACCT  $5.
        @365 TFINDR02 $1.
        @366 TFINDR03 $1.
        @368 TFINDR05 $1.
        @377 ACCTNO  $10.;
RUN;
PROC SORT DATA=TABLE NODUPKEYS; BY ACCTNO SUBACCT;
DATA PRNGL (DROP=ACCTNO RENAME=(ACCTNOX=ACCTNO));
   SET BTRSA.ICOMM&REPTDAY&REPTMON(RENAME=(GLMNEMO=GLMNEM));
   IF CREATDS NOT IN (.,0) THEN ISSDTE=INPUT(PUT(CREATDS,Z6.),YYMMDD6.);
   IF EXPIRDS NOT IN (.,0) THEN
      EXPRDATE = INPUT(PUT(EXPIRDS,Z6.),YYMMDD6.);
   IF GLMNEM IN ('CONI','CONM','CONP','DDA','HOE','IBS') THEN
      DELETE;
   ELSE IF SUBSTR(GLMNEM,1,1) = '9' THEN DELETE;
   ELSE IF SUBSTR(GLMNEM,1,1) = '0' THEN GLMNEMO = GLMNEM||'0';
   ELSE GLMNEMO = GLMNEM;
   DROP GLMNEM;
   IF PAYGRNO NE ' ' THEN TRANSREF = SUBSTR(PAYGRNO,1,7);
   IF ISSDTE <= &TDATE;
RUN;
PROC SORT DATA=PRNGL; BY TRANSREF;
DATA PRNGL;
 /* MERGE BTRWH1.ILLNCV PRNGL (IN=A) BTRWH1.PATCH (IN=B);
  BY TRANSREF; */
  SET PRNGL (IN=A);
  IF EXPIRDS IN (.,0) THEN DO;
     EXPIRDS = EXPIRDT;
     EXPRDATE = INPUT(PUT(EXPIRDT,Z6.),YYMMDD6.);
  END;
 /* IF A;
  IF A & B THEN TRANSREF = TRANSRE1; */
  DROP EXPIRDT;
  RUN;
RUN;
PROC SORT DATA=PRNGL;
   BY TRANSREF;
RUN;
