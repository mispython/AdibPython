  END;
  IF PRODCD = '34111' & FISSPURP NOT IN ('0211','0212','0200','0210',
  '0390','0430')
  THEN FISSPURP = '0212';
  IF INDUSTRIAL_SECTOR_CD NE '' & LENGTH(INDUSTRIAL_SECTOR_CD)=5 &
     INDUSTRIAL_SECTOR_CD > 0 THEN
     SECTORCD = PUT(INDUSTRIAL_SECTOR_CD,$INDSECT.); *18-2715;
  IF CUSTCD IN ('77','78','95','96') THEN SECTORCD = '9700';
