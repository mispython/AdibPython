 /*****************************************************************/
 /*  TO CALCULATE THE DISBURSEMENT & REPAYMENT                    */
 /*****************************************************************/
 DATA PRNGL (DROP=ACCTNO RENAME=(ACCTNOX=ACCTNO));
    SET BTRSA.ICOMM&REPTDAY&REPTMON(RENAME=(GLMNEMO=GLMNEM));
    IF CREATDS NOT IN (.,0) THEN
       ISSDTE=INPUT(PUT(CREATDS,Z6.),YYMMDD6.);
    IF EXPIRDS NOT IN (.,0) THEN
       EXPRDATE = INPUT(PUT(EXPIRDS,Z6.),YYMMDD6.);
    IF GLMNEM IN ('CONI','CONM','CONP','DDA','HOE','IBS') THEN
       DELETE;
    ELSE IF SUBSTR(GLMNEM,1,1) = '9' THEN DELETE;
    ELSE IF SUBSTR(GLMNEM,1,1) = '0' THEN GLMNEMO = GLMNEM||'0';
    ELSE GLMNEMO = GLMNEM;
    DROP GLMNEM;
    IF PAYGRNO NE ' ' THEN TRANSREF = SUBSTR(PAYGRNO,1,7);
    IF ISSDTE <= &TDATE;
 RUN;
DATA DISBPAY;
   SET PRNGL;
   WHERE PUT(GLMNEMO,$DISBPAY.) EQ 'Y' AND &STARTDT<=ISSDTE<= &TDATE;
   IF TRANSAMT > 0 & GLMNEMO NOT IN ('08000','09000') THEN DO;
      IF GLMNEMO NOT IN ('1101','7101','8101') THEN DISBURSE = TRANSAMT;
   END;
   ELSE DO;
      REPAID = TRANSAMT * (-1);
      IF GLMNEMO NOT IN ('1101','7101','8101') THEN REPAIDPRIN = REPAID;
   END;
   IF CURRENCY NE 'MYR' THEN DO;
      IF TRANAMT_CCY > 0 & GLMNEMO NOT IN ('08000','09000') THEN DO;
         IF GLMNEMO NOT IN ('1101','7101','8101')
            THEN DISBURSEFX = TRANAMT_CCY;
      END;
      ELSE DO;
         REPAIDFX = TRANAMT_CCY * (-1);
         IF GLMNEMO NOT IN ('1101','7101','8101')
            THEN REPAIDPRINFX = REPAIDFX;
      END;
   END;
RUN;
