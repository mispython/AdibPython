//*                                                                             
//*                                                                             
//EIMBTCOL EXEC SAS609,REGION=64M,WORK='395000,390000'                          
//BRANCH   DD DSN=SAP.RBP2.B033.PBB.BRANCH,DISP=SHR                             
//BNM      DD DSN=SAP.BT.SASDATA,DISP=SHR                                       
//BTCOLL    DD DSN=SAP.PBB.MNICOL(0),DISP=SHR                                   
//*SASLIST  DD SYSOUT=(,),OUTPUT=(*.PRINT1)                                     
//SASLIST   DD DSN=SAP.PBB.EIMBTCOL.TEXT,DISP=MOD                               
//SYSIN    DD *                                                                 
 *+--------------------------------------------------------------+              
  |  PROGRAM : EIMBTCOL                                          |              
  |  DATE    : 23.03.01                                          |              
  |  REPORT  : BANK'S TOTAL LOANS AND ADVANCES BY COLLATERALS    |              
  |            REQUESTED BY FINANCIAL ACCOUNTING, FINANCE DIV.   |              
  +--------------------------------------------------------------+              
  |  SMR/OTHERS    : A277                                        |              
  |  DATE MODIFIED : 08-09-01 (WBL)                              |              
  |  CHANGES MADE  : OUTPUT CURRENT MONTH EXTRACTION BY BRANCH   |              
  |                  INTO A FLAT FILE FOR VARIANCE REPORT BETWEEN|              
  |                  PREVIOUS & CURRENT MONTH BALANCE.           |              
  +--------------------------------------------------------------+              
  |  SMR/OTHERS    : 2008-318                                    |              
  |  DATE MODIFIED : 27-03-08 (RHA)                              |              
  |  CHANGES MADE  : GENERATE SOFTCOPY TEXT RPT & TRANSFERRED TO |              
  |                  'FIN' FOLDER (FTPBTCOL)                     |              
  +--------------------------------------------------------------+;             
%LET NPRODUCT=(500,520);                                                        
*;                                                                              
OPTIONS YEARCUTOFF=1950 SORTDEV=3390 NODATE PS=65 NOCENTER;                     
*;                                                                              
DATA REPTDATE;                                                                  
                                                                                
  SET BNM.REPTDATE;                                                             
  SELECT(DAY(REPTDATE));                                                        
    WHEN (8)  DO; SDD = 1;  WK = '1'; WK1 = '4'; END;                           
    WHEN(15)  DO; SDD = 9;  WK = '2'; WK1 = '1'; END;                           
    WHEN(22)  DO; SDD = 16; WK = '3'; WK1 = '2'; END;                           
    OTHERWISE DO; SDD = 23; WK = '4'; WK1 = '3'; END;                           
  END;                                                                          
  MM = MONTH(REPTDATE);                                                         
  IF WK = '1' THEN DO;                                                          
     MM1 = MM - 1;                                                              
     IF MM1 = 0 THEN MM1 = 12;                                                  
  END;                                                                          
  ELSE MM1 = MM;                                                                
  CALL SYMPUT('NOWK',PUT(WK,$1.));                                              
  CALL SYMPUT('REPTMON',PUT(MM,Z2.));                                           
  CALL SYMPUT('REPTMON1',PUT(MM1,Z2.));                                         
  CALL SYMPUT('RDATE',PUT(REPTDATE,DDMMYY8.));                                  
RUN;                                                                            
*;                                                                              
PROC FORMAT;                                                                    
   VALUE RISK                                                                   
      0='  0%'                                                                  
     10=' 10%'                                                                  
     20=' 20%'                                                                  
     50=' 50%'                                                                  
    100='100%';                                                                 
RUN;                                                                            
*;                                                                              
PROC SORT DATA=BNM.BTRAD&REPTMON&NOWK OUT=BTRADE; BY ACCTNO;                    
*;                                                                              
PROC SORT DATA=BNM.BTMAST&REPTMON&NOWK                                          
  OUT=BTRADE (KEEP=ACCTNO BRANCH ICURBAL DBALANCE SECTORCD) NODUPKEYS;          
  BY ACCTNO;                                                                    
  WHERE SUBACCT = 'OV' AND CUSTCD NE ' ' AND BRANCH NE 0;                       
*;                                                                              
DATA COLLATER ;                                                                 
   FORMAT ACCTNO $10.;                                                          
   SET BTCOLL.COLLATER (RENAME=(ACCTNO=ACCTNO2));                               
   ACCTNO = ACCTNO2;                                                            
*;                                                                              
PROC SORT DATA=COLLATER OUT=BTCOLL NODUPKEYS; BY ACCTNO;                        
*;                                                                              
DATA BTRADE;                                                                    
  * MERGE BTRADE (IN=A RENAME=LIABCODE=LIABCOD1);                               
    MERGE BTRADE (IN=A)                                                         
         BTCOLL (KEEP=ACCTNO CCLASSC CDOLARV RENAME=(CCLASSC=LIABCODE));        
   BY ACCTNO;                                                                   
   IF A;                                                                        
RUN;                                                                            
DATA LOAN;                                                                      
   LENGTH BNMCODE   $10.  RISKCAT  3.;                                          
   SET BTRADE;                                                                  
   AMTIND = 'D';                                                                
   SELECT (LIABCODE);                                                           
      WHEN('007','012','013','014','024','048','049','117') DO;                 
         BNMCODE = '30307';                                                     
         RISKCAT = 0;                                                           
      END;                                                                      
      WHEN('021') DO;                                                           
         BNMCODE = '30309';                                                     
         RISKCAT = 0;                                                           
      END;                                                                      
      WHEN('017','026','029') DO;                                               
         BNMCODE = '30009/17';                                                  
         RISKCAT = 10;                                                          
      END;                                                                      
      WHEN('006','016') DO;                                                     
         BNMCODE = '30323';                                                     
         RISKCAT = 20;                                                          
      END;                                                                      
      WHEN('011','030') DO;                                                     
         BNMCODE = '30325';                                                     
         RISKCAT = 20;                                                          
      END;                                                                      
      WHEN('018','027') DO;                                                     
         BNMCODE = '30327';                                                     
         RISKCAT = 20;                                                          
      END;                                                                      
      WHEN('003') DO;                                                           
         BNMCODE = '30009/10';                                                  
         RISKCAT = 20;                                                          
      END;                                                                      
      WHEN('025') DO;                                                           
         BNMCODE = '30335';                                                     
         RISKCAT = 20;                                                          
      END;                                                                      
      WHEN('050','118') DO;                                                     
        BNMCODE = '30341';                                                      
        IF SECTORCD IN ('0311','0312','0313','0314','0315','0316') THEN         
          RISKCAT = 50;                                                         
        ELSE                                                                    
          RISKCAT = 100;                                                        
      END;                                                                      
      WHEN('019','028','031') DO;                                               
         BNMCODE = '30351';                                                     
         RISKCAT = 100;                                                         
      END;                                                                      
      OTHERWISE DO;                                                             
         BNMCODE = '30359';                                                     
         RISKCAT = 100;                                                         
      END;                                                                      
   END;                                                                         
   TOTBAL = SUM(ICURBAL,DBALANCE);                                              
   COLVAL = (DBALANCE/TOTBAL) * CDOLARV;                                        
   IF (COLVAL > 0) & (DBALANCE > COLVAL) THEN DO;                               
      VBAL=DBALANCE;       /* SCENARIO 3 FOR 1 COLLATERAL ONLY */               
      XBALANCE=COLVAL; OUTPUT;                                                  
      XBALANCE=VBAL-COLVAL; BNMCODE='30359'; RISKCAT=100;                       
      OUTPUT;                                                                   
   END;                                                                         
   ELSE DO;                                                                     
      XBALANCE = DBALANCE;                                                      
      OUTPUT;                                                                   
   END;                                                                         
RUN;                                                                            
*;                                                                              
PROC SORT DATA=LOAN; BY BRANCH;                                                 
*;                                                                              
TITLE1 'REPORT ID: EIMBTCOL';                                                   
TITLE2 'PUBLIC BANK BERHAD';                                                    
TITLE3 'TOTAL TRADE BILLS BY COLLATERAL AS AT : ' "&RDATE";                     
TITLE4 'BY BRANCHES';                                                           
TITLE5;                                                                         
PROC SUMMARY DATA=LOAN NWAY;                                                    
