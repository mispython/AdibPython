//CREATE   EXEC PGM=IEFBR14                                                     
//CRT01    DD DSN=SAP.PBB.EIMBTCOL.TEXT,                                        
//             DISP=(NEW,CATLG,DELETE),                                         
//             UNIT=SYSDA,SPACE=(CYL,(1,1),RLSE),                               
