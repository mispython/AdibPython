DATA REPTDATE;
   SET LOAN.REPTDATE;
   MM = MONTH(REPTDATE);
   MM2 = MM - 1;
   IF MM2 = 0 THEN MM2 = 12;
   CALL SYMPUT('NOWK', PUT('4', $1.));
   CALL SYMPUT('NOWK1', PUT('1', $1.));
   CALL SYMPUT('NOWK2', PUT('2', $1.));
   CALL SYMPUT('NOWK3', PUT('3', $1.));
   CALL SYMPUT('REPTYEAR', PUT(REPTDATE, YEAR2.));
   CALL SYMPUT('REPTMON', PUT(MONTH(REPTDATE), Z2.));
   CALL SYMPUT('REPTDAY', PUT(DAY(REPTDATE), Z2.));
   CALL SYMPUT('REPTMON2', PUT(MM2, Z2.));
   CALL SYMPUT('RDATE', PUT(REPTDATE, DDMMYY8.));
   STDATE = MDY(MONTH(REPTDATE),01,YEAR(REPTDATE));
   STYEAR = MDY(01,01,YEAR(REPTDATE));
   CALL SYMPUT('SDATE',STDATE);
   CALL SYMPUT('TDATE',REPTDATE);
   CALL SYMPUT('STYEAR',STYEAR);
   CALL SYMPUT('LOOPDT',REPTDATE-61);
RUN;

  *DAILY FORATE 2018-2021;
DATA DATE(DROP=I);
   DO I=&LOOPDT TO &TDATE BY 1;
      REPTDATE = I; OUTPUT;
   END;
RUN;
PROC SORT DATA=DATE; BY REPTDATE;RUN;

PROC SORT DATA=FORATE.FORATEBKP OUT=FXRATE;
   BY CURCODE DESCENDING REPTDATE;
   WHERE REPTDATE >= &LOOPDT AND REPTDATE<= &TDATE;
RUN;
PROC SORT DATA=FXRATE NODUPKEY OUT=WORKDTE(KEEP=REPTDATE);
BY REPTDATE; RUN;

DATA WORKDTE;
   MERGE DATE(IN=A) WORKDTE(IN=B);
   BY REPTDATE;
   RETAIN REPXDATE;
   IF A;
   IF A AND B THEN IND = 'W';
   IF IND = 'W' THEN REPXDATE = REPTDATE;
   ELSE REPXDATE = REPXDATE;
RUN;

PROC SQL;
   CREATE TABLE DLYFORATE AS
   SELECT A.REPTDATE,
          B.CURCODE,
          B.SPOTRATE
   FROM WORKDTE A LEFT JOIN FXRATE B ON A.REPXDATE = B.REPTDATE;
QUIT;
PROC SORT DATA=DLYFORATE; BY REPTDATE;RUN;

DATA DLYFORATE(KEEP=KEY SPOTRATE);
   SET DLYFORATE;
   KEY = COMPRESS(CURCODE||REPTDATE);
   IF SPOTRATE = . THEN DELETE;
RUN;

DATA FOFMTX;
  LENGTH START $8. FMTNAME $7. TYPE $1.;
  SET DLYFORATE;
  START = KEY;
  LABEL = SPOTRATE;
  FMTNAME = 'DLYRATE';
  TYPE = 'C';
RUN;
PROC FORMAT CNTLIN=FOFMTX;RUN;

DATA DISPAY.LNHISTYR(DROP=TAMT TINT POSTDT)
     DISPAY.LNHIST  (DROP=TAMT TINT POSTDT);
   INFILE HISTFILE MISSOVER;
   INPUT @001 ACCTNO    PD6.
         @007 NOTENO    PD3.
         @010 EFFDATE   PD4.
         @014 TRANNO    PD2.
         @017 CHANNEL   PD2.
         @027 TRANCODE  PD2.
         @029 REVERSED   $1.
         @030 HISBR     PD4.
         @034 POSTDT    PD6.
         @045 HCURBAL   PD8.2
         @077 ACCRADJ   PD8.7
         @086 RATECHG   PD5.6
         @115 INDEX     PD2.
         @136 HISTPRIN  PD8.2
         @144 HISTINT   PD8.2
         @216 TAMT      PD8.2
         @216 TINT      PD8.7
         @226 HISTREB   PD8.2
         @234 HISTOREB  PD8.2
         @272 ORIRATE   PD5.6
         @462 REPAY_SOURCE_CD PD3.
         @465 REPAY_TYPE_CD    $2.
         ;

     *    IF TRANCODE IN (310,652,782,750,800,801,810;
     *                    610,614,615,619,650,660,661,668,680,754,612);

   * IF TRANCODE = 999 & POSTDATE > '01JAN10'D;
   IF TRANCODE = 660 & CHANNEL = 5 THEN DELETE; *2022-1202;

   IF TRANCODE IN (666,726) THEN DO;
      TOTAMT= ACCRADJ;
      IF TOTAMT EQ 0 THEN TOTAMT=TAMT;
   END;
   ELSE DO;
      IF TRANCODE IN (999) THEN TOTAMT= HISTINT;
      ELSE TOTAMT = TAMT;
      IF (800<=TRANCODE<=899) AND TAMT EQ 0 THEN
         TOTAMT = ACCRADJ;
   END;

   *** IDENTIFY NEGATIVE/POSITIVE VALUE ***;
   IF TRANCODE IN (310,726,750,751,752,753,754,756,758,760,761)
      THEN DO;
      IF TRANCODE IN (726) AND REVERSED = 'R' THEN
         TOTAMT = TOTAMT;
      ELSE TOTAMT = TOTAMT*(-1);
   END;

   EFFDATE=DATEJUL(EFFDATE);
   IF POSTDT NOT IN (.,0) THEN
      POSTDATE = INPUT(SUBSTR(PUT(POSTDT,Z11.),1,8),MMDDYY8.);

   IF ACCTNO GT 0 AND POSTDATE >= &STYEAR
      THEN OUTPUT DISPAY.LNHISTYR;
   IF ACCTNO GT 0 AND (EFFDATE GE &SDATE OR POSTDATE GE &SDATE)
      THEN OUTPUT DISPAY.LNHIST;
RUN;

DATA FEETRAN(RENAME=(ACTDATE=POSTDATE TRANAMT=TOTAMT));
   SET FEE.FEETRAN&REPTMON&NOWK&REPTYEAR;
   WHERE TRANCODE = 680 AND REVERSED NE 'R';
   REPAY_TYPE_CD = '10';
RUN;

DATA DISPAY.DISBMTHTEST;
  SET DISPAY.LNHISTYR FEETRAN;
  WHERE &SDATE<=POSTDATE<=&TDATE;
  REBATE   = SUM(HISTREB,HISTOREB);
  HISTPRIN = SUM(HISTPRIN,REBATE);
  IF REPAY_TYPE_CD = '10' THEN REPAID10 = TOTAMT; *2022-2926;
  TOTAMT_CNT = ABS(TOTAMT);
RUN;

