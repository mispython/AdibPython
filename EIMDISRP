     END;
     ELSE DO;
        IF (CRISPURP = '    ' AND  CCRICODE = .  AND SECTOLD EQ '    ' )
        OR FISSPURP IN ('0390','0440','0470') THEN FISSPURP = '0410';
     END;
     IF FISSPURP IN ('0110','0120','0131','0132','0139',
        '0210','0220','0230','0200','0211','0212','0311','0312','0313',
        '0314','0315','0316','0321','0322','0323','0324','0325','0326',
        '0327','0328','0329','0410','0420','0430','0990') THEN
        SECTORCD = '9700';
  END;
  IF PRODCD = '34111' & FISSPURP NOT IN ('0211','0212','0200','0210',
  '0390','0430')
  THEN FISSPURP = '0212';
  IF PRODCD = '34230' THEN DO;
     IF CUSTCD IN ('77','78','95','96') THEN SECTORCD = '9700';
     ELSE IF CUSTCD IN ('61','41','42','43','64','52','53','54')THEN DO;
