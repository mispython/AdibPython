import duckdb
import polars as pl
from pathlib import Path
from datetime import datetime

def parse_packed_date(packed_value: int, format_type: str = 'YYMMDD') -> datetime.date:
    """
    Convert packed decimal date to Python date.
    YYMMDD8.: 20241115 -> 2024-11-15
    MMDDYY8.: 11152024 -> 2024-11-15
    """
    if packed_value == 0:
        return None
    
    date_str = str(packed_value).zfill(8)
    
    try:
        if format_type == 'YYMMDD':
            return datetime.strptime(date_str, '%Y%m%d').date()
        elif format_type == 'MMDDYY':
            return datetime.strptime(date_str, '%m%d%Y').date()
    except:
        return None

def process_enrh_ln_bill(
    input_stg_path: Path,
    output_path: Path
) -> None:
    """
    ENRH_LN_BILL - Transform and load billing data.
    
    Equivalent to SAS job steps:
    1. CIMPORT_EIQBILEX - Import data (skipped, assuming already in parquet)
    2. Extract - Map columns and create derived date fields
    3. Table Loader - Replace entire target table
    """
    
    print("="*80)
    print("ENRH_LN_BILL - Transform and Load")
    print("="*80)
    
    # Check input exists
    if not input_stg_path.exists():
        print(f"ERROR: Input file not found: {input_stg_path}")
        return
    
    con = duckdb.connect(':memory:')
    
    # Step 1: Load STG_LN_BILL
    print("\nStep 1: Loading STG_LN_BILL...")
    con.execute(f"""
        CREATE TABLE stg_ln_bill AS
        SELECT * FROM read_parquet('{input_stg_path}')
    """)
    
    count = con.execute("SELECT COUNT(*) FROM stg_ln_bill").fetchone()[0]
    print(f"  Loaded {count:,} records")
    
    # Step 2: Extract - Map columns and create date fields
    print("\nStep 2: Mapping columns and creating derived dates...")
    
    con.execute("""
        CREATE TABLE extracted AS
        SELECT
            ACCTNO,
            NOTENO,
            BLDATE,
            BLPDDATE,
            DAYSLATE,
            PRODUCT,
            COSTCTR,
            BILL_AMT,
            BILL_AMT_PRIN,
            BILL_AMT_INT,
            BILL_AMT_ESCROW,
            BILL_AMT_FEE,
            BILL_NOT_PAY_AMT,
            BILL_NOT_PAY_AMT_PRIN,
            BILL_NOT_PAY_AMT_INT,
            BILL_NOT_PAY_AMT_ESCROW,
            BILL_NOT_PAY_AMT_FEE,
            -- Parse BLDATE (YYMMDD format)
            CASE 
                WHEN BLDATE > 0 THEN 
                    CAST(SUBSTR(LPAD(CAST(BLDATE AS VARCHAR), 11, '0'), 1, 8) AS DATE)
                ELSE NULL
            END AS BILL_DT,
            -- Parse BLPDDATE (MMDDYY format)
            CASE 
                WHEN BLPDDATE > 0 THEN
                    TRY_CAST(
                        SUBSTR(LPAD(CAST(BLPDDATE AS VARCHAR), 8, '0'), 5, 4) || '-' ||
                        SUBSTR(LPAD(CAST(BLPDDATE AS VARCHAR), 8, '0'), 1, 2) || '-' ||
                        SUBSTR(LPAD(CAST(BLPDDATE AS VARCHAR), 8, '0'), 3, 2)
                        AS DATE
                    )
                ELSE NULL
            END AS BILL_PAID_DT
        FROM stg_ln_bill
    """)
    
    count = con.execute("SELECT COUNT(*) FROM extracted").fetchone()[0]
    print(f"  Transformed {count:,} records")
    
    # Step 3: Table Loader - Replace entire table
    print("\nStep 3: Loading to ENRH_LN_BILL...")
    
    # Get final result
    result = con.execute("""
        SELECT 
            ACCTNO,
            NOTENO,
            BLDATE,
            BLPDDATE,
            DAYSLATE,
            PRODUCT,
            COSTCTR,
            BILL_AMT,
            BILL_AMT_PRIN,
            BILL_AMT_INT,
            BILL_AMT_ESCROW,
            BILL_AMT_FEE,
            BILL_NOT_PAY_AMT,
            BILL_NOT_PAY_AMT_PRIN,
            BILL_NOT_PAY_AMT_INT,
            BILL_NOT_PAY_AMT_ESCROW,
            BILL_NOT_PAY_AMT_FEE,
            BILL_DT,
            BILL_PAID_DT
        FROM extracted
    """).pl()
    
    # Write to parquet (Replace mode)
    result.write_parquet(output_path)
    
    output_size_mb = output_path.stat().st_size / (1024 * 1024)
    
    print(f"  ✓ Output written to: {output_path}")
    print(f"  File size: {output_size_mb:.2f} MB")
    print(f"  Final record count: {len(result):,}")
    
    # Statistics
    stats = con.execute("""
        SELECT 
            COUNT(*) as total_records,
            COUNT(DISTINCT ACCTNO) as unique_accounts,
            MIN(BILL_DT) as min_date,
            MAX(BILL_DT) as max_date,
            SUM(BILL_AMT) as total_bill_amt
        FROM extracted
        WHERE BILL_DT IS NOT NULL
    """).fetchone()
    
    print("\nData Statistics:")
    print(f"  Total Records: {stats[0]:,}")
    print(f"  Unique Accounts: {stats[1]:,}")
    print(f"  Date Range: {stats[2]} to {stats[3]}")
    print(f"  Total Bill Amount: {stats[4]:,.2f}")
    
    # Sample output
    print("\nSample output (first 5 rows):")
    print(result.head(5))
    
    con.close()
    
    print("\n" + "="*80)
    print("Processing completed successfully")
    print("="*80)

if __name__ == "__main__":
    # Input: STG_LN_BILL from staging area
    input_stg = Path("STG_LN_BILL.parquet")
    
    # Output: ENRH_LN_BILL to enrichment area
    output_enrh = Path("ENRH_LN_BILL.parquet")
    
    # Process
    process_enrh_ln_bill(input_stg, output_enrh)
