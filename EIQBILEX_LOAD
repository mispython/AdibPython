import duckdb
import polars as pl
from pathlib import Path
from datetime import datetime, timedelta

def process_load_exdwh_ln_bill(
    input_enrh_path: Path,
    input_ln_bill_path: Path,
    input_iln_bill_path: Path,
    lookup_cost_ctr_path: Path,
    output_ln_bill_path: Path,
    output_iln_bill_path: Path,
    report_date: datetime
) -> None:
    """
    LOAD_EXDWH_LN_BILL - SCD Type 2 processing for loan bills.
    
    Steps:
    1. Extract from ENRH_LN_BILL
    2. Add VALID_FROM_DT and VALID_TO_DT (SCD Type 2)
    3. Lookup ENTITY_CD from LKP_COST_CTR
    4. Split by ENTITY_CD ('' = LN_BILL, 'PIBB' = ILN_BILL)
    5. Load to target tables
    """
    
    print("="*80)
    print("LOAD_EXDWH_LN_BILL - SCD Type 2 Processing")
    print("="*80)
    print(f"Report Date: {report_date.date()}")
    print("-" * 80)
    
    con = duckdb.connect(':memory:')
    
    # Calculate dates
    rdate = report_date.date()
    
    # Step 1: Extract from ENRH_LN_BILL
    print("\nStep 1: Extracting from ENRH_LN_BILL...")
    
    if not input_enrh_path.exists():
        print(f"ERROR: Input file not found: {input_enrh_path}")
        return
    
    con.execute(f"""
        CREATE TABLE enrh_ln_bill AS
        SELECT
            ACCTNO,
            NOTENO,
            PRODUCT,
            COSTCTR,
            BILL_AMT,
            BILL_AMT_PRIN,
            BILL_AMT_INT,
            BILL_AMT_ESCROW,
            BILL_AMT_FEE,
            BILL_NOT_PAY_AMT,
            BILL_NOT_PAY_AMT_PRIN,
            BILL_NOT_PAY_AMT_INT,
            BILL_NOT_PAY_AMT_ESCROW,
            BILL_NOT_PAY_AMT_FEE,
            BILL_DT,
            BILL_PAID_DT,
            BLDATE,
            BLPDDATE,
            DAYSLATE
        FROM read_parquet('{input_enrh_path}')
    """)
    
    count = con.execute("SELECT COUNT(*) FROM enrh_ln_bill").fetchone()[0]
    print(f"  Extracted {count:,} records")
    
    # Step 2: User Written - SCD Type 2 Processing
    print("\nStep 2: Processing SCD Type 2 (VALID_FROM_DT, VALID_TO_DT)...")
    
    # Add NEW flag to input
    con.execute("""
        CREATE TABLE new_records AS
        SELECT *, 'Y' AS NEW
        FROM enrh_ln_bill
    """)
    
    # Load historical LOAN_BILL data
    historical_tables = []
    if input_ln_bill_path.exists():
        con.execute(f"""
            CREATE TABLE ln_bill_hist AS
            SELECT * FROM read_parquet('{input_ln_bill_path}')
        """)
        historical_tables.append('ln_bill_hist')
    
    if input_iln_bill_path.exists():
        con.execute(f"""
            CREATE TABLE iln_bill_hist AS
            SELECT * FROM read_parquet('{input_iln_bill_path}')
        """)
        historical_tables.append('iln_bill_hist')
    
    if historical_tables:
        # Combine historical data
        union_sql = " UNION ALL ".join([f"SELECT * FROM {t}" for t in historical_tables])
        con.execute(f"""
            CREATE TABLE loan_bill_all AS
            {union_sql}
        """)
        
        # Separate records with VALID_TO_DT = yesterday (candidates for extension)
        con.execute(f"""
            CREATE TABLE loan_bill AS
            SELECT *, 'Y' AS EXT
            FROM loan_bill_all
            WHERE VALID_TO_DT = DATE '{rdate - timedelta(days=1)}'
        """)
        
        con.execute(f"""
            CREATE TABLE loan_bill_keep AS
            SELECT *
            FROM loan_bill_all
            WHERE VALID_TO_DT != DATE '{rdate - timedelta(days=1)}'
        """)
    else:
        # No historical data - all records are new
        con.execute("""
            CREATE TABLE loan_bill AS
            SELECT 
                CAST(NULL AS BIGINT) AS ACCTNO,
                CAST(NULL AS BIGINT) AS NOTENO,
                CAST(NULL AS DATE) AS BILL_DT,
                CAST(NULL AS DATE) AS BILL_PAID_DT,
                CAST(NULL AS DOUBLE) AS BILL_AMT,
                CAST(NULL AS DOUBLE) AS BILL_AMT_PRIN,
                CAST(NULL AS DOUBLE) AS BILL_AMT_INT,
                CAST(NULL AS DOUBLE) AS BILL_AMT_ESCROW,
                CAST(NULL AS DOUBLE) AS BILL_AMT_FEE,
                CAST(NULL AS DOUBLE) AS BILL_NOT_PAY_AMT,
                CAST(NULL AS DOUBLE) AS BILL_NOT_PAY_AMT_PRIN,
                CAST(NULL AS DOUBLE) AS BILL_NOT_PAY_AMT_INT,
                CAST(NULL AS DOUBLE) AS BILL_NOT_PAY_AMT_ESCROW,
                CAST(NULL AS DOUBLE) AS BILL_NOT_PAY_AMT_FEE,
                CAST(NULL AS BIGINT) AS COSTCTR,
                CAST(NULL AS BIGINT) AS PRODUCT,
                CAST(NULL AS DATE) AS VALID_FROM_DT,
                CAST(NULL AS DATE) AS VALID_TO_DT,
                CAST(NULL AS VARCHAR) AS EXT
            WHERE 1=0
        """)
        
        con.execute("""
            CREATE TABLE loan_bill_keep AS
            SELECT * FROM loan_bill WHERE 1=0
        """)
    
    # MATCH: Records that match exactly (extend VALID_TO_DT)
    print("  Identifying matching records (extend validity)...")
    con.execute(f"""
        CREATE TABLE match AS
        SELECT 
            T1.ACCTNO,
            T1.NOTENO,
            T1.BILL_DT,
            T1.BILL_PAID_DT,
            T1.BILL_AMT,
            T1.BILL_AMT_PRIN,
            T1.BILL_AMT_INT,
            T1.BILL_AMT_ESCROW,
            T1.BILL_AMT_FEE,
            T1.BILL_NOT_PAY_AMT,
            T1.BILL_NOT_PAY_AMT_PRIN,
            T1.BILL_NOT_PAY_AMT_INT,
            T1.BILL_NOT_PAY_AMT_ESCROW,
            T1.BILL_NOT_PAY_AMT_FEE,
            T1.COSTCTR,
            T1.PRODUCT,
            T1.VALID_FROM_DT,
            DATE '{rdate}' AS VALID_TO_DT
        FROM loan_bill T1
        INNER JOIN new_records T2 
            ON T1.ACCTNO = T2.ACCTNO
            AND T1.NOTENO = T2.NOTENO
            AND T1.BILL_DT = T2.BILL_DT
            AND COALESCE(T1.BILL_PAID_DT, DATE '1900-01-01') = COALESCE(T2.BILL_PAID_DT, DATE '1900-01-01')
            AND T1.BILL_AMT = T2.BILL_AMT
            AND T1.BILL_AMT_PRIN = T2.BILL_AMT_PRIN
            AND T1.BILL_AMT_INT = T2.BILL_AMT_INT
            AND T1.BILL_AMT_ESCROW = T2.BILL_AMT_ESCROW
            AND T1.BILL_AMT_FEE = T2.BILL_AMT_FEE
            AND T1.BILL_NOT_PAY_AMT = T2.BILL_NOT_PAY_AMT
            AND T1.BILL_NOT_PAY_AMT_PRIN = T2.BILL_NOT_PAY_AMT_PRIN
            AND T1.BILL_NOT_PAY_AMT_INT = T2.BILL_NOT_PAY_AMT_INT
            AND T1.BILL_NOT_PAY_AMT_ESCROW = T2.BILL_NOT_PAY_AMT_ESCROW
            AND T1.BILL_NOT_PAY_AMT_FEE = T2.BILL_NOT_PAY_AMT_FEE
            AND T1.COSTCTR = T2.COSTCTR
            AND T1.PRODUCT = T2.PRODUCT
    """)
    
    match_count = con.execute("SELECT COUNT(*) FROM match").fetchone()[0]
    print(f"  Matched (extended): {match_count:,} records")
    
    # CHGREC: Records that changed (close old record)
    print("  Identifying changed records (close old)...")
    con.execute("""
        CREATE TABLE chgrec AS
        SELECT 
            T1.ACCTNO,
            T1.NOTENO,
            T1.BILL_DT,
            T1.BILL_PAID_DT,
            T1.BILL_AMT,
            T1.BILL_AMT_PRIN,
            T1.BILL_AMT_INT,
            T1.BILL_AMT_ESCROW,
            T1.BILL_AMT_FEE,
            T1.BILL_NOT_PAY_AMT,
            T1.BILL_NOT_PAY_AMT_PRIN,
            T1.BILL_NOT_PAY_AMT_INT,
            T1.BILL_NOT_PAY_AMT_ESCROW,
            T1.BILL_NOT_PAY_AMT_FEE,
            T1.COSTCTR,
            T1.PRODUCT,
            T1.VALID_FROM_DT,
            T1.VALID_TO_DT,
            T2.NEW
        FROM loan_bill T1
        LEFT JOIN new_records T2 
            ON T1.ACCTNO = T2.ACCTNO
            AND T1.NOTENO = T2.NOTENO
            AND T1.BILL_DT = T2.BILL_DT
            AND COALESCE(T1.BILL_PAID_DT, DATE '1900-01-01') = COALESCE(T2.BILL_PAID_DT, DATE '1900-01-01')
            AND T1.BILL_AMT = T2.BILL_AMT
            AND T1.BILL_AMT_PRIN = T2.BILL_AMT_PRIN
            AND T1.BILL_AMT_INT = T2.BILL_AMT_INT
            AND T1.BILL_AMT_ESCROW = T2.BILL_AMT_ESCROW
            AND T1.BILL_AMT_FEE = T2.BILL_AMT_FEE
            AND T1.BILL_NOT_PAY_AMT = T2.BILL_NOT_PAY_AMT
            AND T1.BILL_NOT_PAY_AMT_PRIN = T2.BILL_NOT_PAY_AMT_PRIN
            AND T1.BILL_NOT_PAY_AMT_INT = T2.BILL_NOT_PAY_AMT_INT
            AND T1.BILL_NOT_PAY_AMT_ESCROW = T2.BILL_NOT_PAY_AMT_ESCROW
            AND T1.BILL_NOT_PAY_AMT_FEE = T2.BILL_NOT_PAY_AMT_FEE
            AND T1.COSTCTR = T2.COSTCTR
            AND T1.PRODUCT = T2.PRODUCT
        WHERE T2.NEW IS NULL
    """)
    
    chg_count = con.execute("SELECT COUNT(*) FROM chgrec").fetchone()[0]
    print(f"  Changed (closed): {chg_count:,} records")
    
    # UPDATEX: New or changed records (insert with current dates)
    print("  Identifying new/updated records...")
    con.execute(f"""
        CREATE TABLE updatex AS
        SELECT 
            T2.ACCTNO,
            T2.NOTENO,
            T2.BILL_DT,
            T2.BILL_PAID_DT,
            T2.BILL_AMT,
            T2.BILL_AMT_PRIN,
            T2.BILL_AMT_INT,
            T2.BILL_AMT_ESCROW,
            T2.BILL_AMT_FEE,
            T2.BILL_NOT_PAY_AMT,
            T2.BILL_NOT_PAY_AMT_PRIN,
            T2.BILL_NOT_PAY_AMT_INT,
            T2.BILL_NOT_PAY_AMT_ESCROW,
            T2.BILL_NOT_PAY_AMT_FEE,
            T2.COSTCTR,
            T2.PRODUCT,
            DATE '{rdate}' AS VALID_FROM_DT,
            DATE '{rdate}' AS VALID_TO_DT,
            T1.EXT
        FROM loan_bill T1
        RIGHT JOIN new_records T2 
            ON T1.ACCTNO = T2.ACCTNO
            AND T1.NOTENO = T2.NOTENO
            AND T1.BILL_DT = T2.BILL_DT
            AND COALESCE(T1.BILL_PAID_DT, DATE '1900-01-01') = COALESCE(T2.BILL_PAID_DT, DATE '1900-01-01')
            AND T1.BILL_AMT = T2.BILL_AMT
            AND T1.BILL_AMT_PRIN = T2.BILL_AMT_PRIN
            AND T1.BILL_AMT_INT = T2.BILL_AMT_INT
            AND T1.BILL_AMT_ESCROW = T2.BILL_AMT_ESCROW
            AND T1.BILL_AMT_FEE = T2.BILL_AMT_FEE
            AND T1.BILL_NOT_PAY_AMT = T2.BILL_NOT_PAY_AMT
            AND T1.BILL_NOT_PAY_AMT_PRIN = T2.BILL_NOT_PAY_AMT_PRIN
            AND T1.BILL_NOT_PAY_AMT_INT = T2.BILL_NOT_PAY_AMT_INT
            AND T1.BILL_NOT_PAY_AMT_ESCROW = T2.BILL_NOT_PAY_AMT_ESCROW
            AND T1.BILL_NOT_PAY_AMT_FEE = T2.BILL_NOT_PAY_AMT_FEE
            AND T1.COSTCTR = T2.COSTCTR
            AND T1.PRODUCT = T2.PRODUCT
        WHERE T1.EXT IS NULL
    """)
    
    upd_count = con.execute("SELECT COUNT(*) FROM updatex").fetchone()[0]
    print(f"  New/Updated: {upd_count:,} records")
    
    # Combine all: MATCH + UPDATEX + CHGREC + LOAN_BILL_KEEP
    print("  Combining all records...")
    con.execute("""
        CREATE TABLE loan_bill_final AS
        SELECT * FROM match
        UNION ALL
        SELECT * FROM updatex
        UNION ALL
        SELECT * FROM chgrec
        UNION ALL
        SELECT * FROM loan_bill_keep
    """)
    
    # Sort
    con.execute("""
        CREATE TABLE loan_bill_sorted AS
        SELECT * FROM loan_bill_final
        ORDER BY ACCTNO, NOTENO, BILL_DT, VALID_FROM_DT, VALID_TO_DT
    """)
    
    final_count = con.execute("SELECT COUNT(*) FROM loan_bill_sorted").fetchone()[0]
    print(f"  Total records after SCD: {final_count:,}")
    
    # Step 3: Lookup ENTITY_CD
    print("\nStep 3: Looking up ENTITY_CD from LKP_COST_CTR...")
    
    if not lookup_cost_ctr_path.exists():
        print(f"WARNING: Lookup table not found: {lookup_cost_ctr_path}")
        print("  Setting all ENTITY_CD to NULL")
        con.execute("""
            CREATE TABLE with_entity AS
            SELECT *, CAST(NULL AS VARCHAR) AS ENTITY_CD
            FROM loan_bill_sorted
        """)
    else:
        con.execute(f"""
            CREATE TABLE lkp_cost_ctr AS
            SELECT * FROM read_parquet('{lookup_cost_ctr_path}')
        """)
        
        con.execute("""
            CREATE TABLE with_entity AS
            SELECT L.*, C.ENTITY_CD
            FROM loan_bill_sorted L
            LEFT JOIN lkp_cost_ctr C ON L.COSTCTR = C.COSTCTR
        """)
    
    # Step 4: Split by ENTITY_CD
    print("\nStep 4: Splitting by ENTITY_CD...")
    
    # Split 0: ENTITY_CD = '' or NULL (LN_BILL)
    con.execute("""
        CREATE TABLE ln_bill_split AS
        SELECT 
            ACCTNO, NOTENO, BILL_DT, BILL_PAID_DT,
            BILL_AMT, BILL_AMT_PRIN, BILL_AMT_INT, BILL_AMT_ESCROW, BILL_AMT_FEE,
            BILL_NOT_PAY_AMT, BILL_NOT_PAY_AMT_PRIN, BILL_NOT_PAY_AMT_INT,
            BILL_NOT_PAY_AMT_ESCROW, BILL_NOT_PAY_AMT_FEE,
            COSTCTR, PRODUCT, VALID_FROM_DT, VALID_TO_DT
        FROM with_entity
        WHERE ENTITY_CD IS NULL OR ENTITY_CD = ''
    """)
    
    ln_count = con.execute("SELECT COUNT(*) FROM ln_bill_split").fetchone()[0]
    print(f"  LN_BILL records: {ln_count:,}")
    
    # Split 1: ENTITY_CD = 'PIBB' (ILN_BILL)
    con.execute("""
        CREATE TABLE iln_bill_split AS
        SELECT 
            ACCTNO, NOTENO, BILL_DT, BILL_PAID_DT,
            BILL_AMT, BILL_AMT_PRIN, BILL_AMT_INT, BILL_AMT_ESCROW, BILL_AMT_FEE,
            BILL_NOT_PAY_AMT, BILL_NOT_PAY_AMT_PRIN, BILL_NOT_PAY_AMT_INT,
            BILL_NOT_PAY_AMT_ESCROW, BILL_NOT_PAY_AMT_FEE,
            COSTCTR, PRODUCT, VALID_FROM_DT, VALID_TO_DT
        FROM with_entity
        WHERE ENTITY_CD = 'PIBB'
    """)
    
    iln_count = con.execute("SELECT COUNT(*) FROM iln_bill_split").fetchone()[0]
    print(f"  ILN_BILL records: {iln_count:,}")
    
    # Step 5: Write to output files
    print("\nStep 5: Writing output files...")
    
    # LN_BILL
    ln_result = con.execute("SELECT * FROM ln_bill_split").pl()
    ln_result.write_parquet(output_ln_bill_path)
    ln_size = output_ln_bill_path.stat().st_size / (1024 * 1024)
    print(f"  ✓ LN_BILL: {output_ln_bill_path}")
    print(f"    Records: {len(ln_result):,}, Size: {ln_size:.2f} MB")
    
    # ILN_BILL
    iln_result = con.execute("SELECT * FROM iln_bill_split").pl()
    iln_result.write_parquet(output_iln_bill_path)
    iln_size = output_iln_bill_path.stat().st_size / (1024 * 1024)
    print(f"  ✓ ILN_BILL: {output_iln_bill_path}")
    print(f"    Records: {len(iln_result):,}, Size: {iln_size:.2f} MB")
    
    # Statistics
    print("\nData Statistics:")
    stats = con.execute("""
        SELECT 
            COUNT(*) as total_records,
            COUNT(DISTINCT ACCTNO) as unique_accounts,
            MIN(BILL_DT) as min_date,
            MAX(BILL_DT) as max_date,
            SUM(BILL_AMT) as total_bill_amt
        FROM with_entity
    """).fetchone()
    
    print(f"  Total Records: {stats[0]:,}")
    print(f"  Unique Accounts: {stats[1]:,}")
    print(f"  Date Range: {stats[2]} to {stats[3]}")
    print(f"  Total Bill Amount: {stats[4]:,.2f}")
    
    con.close()
    
    print("\n" + "="*80)
    print("Processing completed successfully")
    print("="*80)

if __name__ == "__main__":
    # Set report date
    report_date = datetime.now()
    
    # Input paths
    input_enrh = Path("ENRH_LN_BILL.parquet")
    input_ln_bill = Path("LOAN_BILL.parquet")  # Historical LN_BILL
    input_iln_bill = Path("ILOAN_BILL.parquet")  # Historical ILN_BILL
    lookup_cost_ctr = Path("LKP_COST_CTR.parquet")
    
    # Output paths
    output_ln_bill = Path("LOAN_BILL.parquet")
    output_iln_bill = Path("ILOAN_BILL.parquet")
    
    # Process
    process_load_exdwh_ln_bill(
        input_enrh_path=input_enrh,
        input_ln_bill_path=input_ln_bill,
        input_iln_bill_path=input_iln_bill,
        lookup_cost_ctr_path=lookup_cost_ctr,
        output_ln_bill_path=output_ln_bill,
        output_iln_bill_path=output_iln_bill,
        report_date=report_date
    )
