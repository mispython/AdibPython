            @059  USERID   $8.
            @249  NOTENO   5.
            @284  ROVER    $10.
            @294  RTIND    $1.
            @295  ROVER1   $10.
            @316  RINX     $3.
            @319  RUNDER   $10.
            @329  RUIND    $1.
            @330  RUND1    $10.
            @340  RUNDPCT  $10.
            @350  RUNDLMT  $18.
            ;
      OUTPUT;
   END;
RUN;

DATA PEND(DROP=ROVER ROVER1 RINX RUNDER RUND1 RUNDLMT);
   SET PEND;
   FORMAT RATEOVER MARGIN RTUNDER RATEUDR 8.6 RINDEX 3.
          RATELMIT 18.0 ;
   RATEOVER = ROVER;
   MARGIN = ROVER1;
   RINDEX = RINX;
   RTUNDER = RUNDER;
   RATEUDR = RUND1;
   RATELMIT = RUNDLMT;
   IF RATELMIT NOT IN (.,0) THEN RATELMIT = RATELMIT/100;
RUN;

PROC SORT DATA=LOAN.LNRATE OUT=RATE(KEEP=RINDEX CURRATE);
   BY RINDEX; RUN;
PROC SORT DATA=PEND; BY RINDEX; RUN;
DATA PEND;
   MERGE PEND(IN=A) RATE;
   BY RINDEX;
   IF A;
   IF RATEOVER IN (0, .) THEN DO;
      IF RTIND = '+' THEN ACCRATE  = SUM(CURRATE, MARGIN);
      IF RTIND = '-' THEN ACCRATE  = SUM(CURRATE, (-1)*MARGIN);
   END;
   IF RATEUDR NOT IN (0, .) THEN DO;
      IF RUIND = '+' THEN ACCUDRT  = SUM(CURRATE, RATEUDR);
      IF RUIND = '-' THEN ACCUDRT  = SUM(CURRATE, (-1)*RATEUDR);
   END;
   IF RELDTE NOT IN (.,0) THEN
      EFFDATE = INPUT(SUBSTR(PUT(RELDTE,Z11.),1,8),YYMMDD8.);
RUN;
PROC SORT DATA=LNNOTE; BY USURYIDX;
*;
DATA LNNOTE;
   MERGE LNNOTE(IN=A)
         RATE(KEEP=RINDEX CURRATE RENAME=(RINDEX=USURYIDX));
   BY USURYIDX;
   IF A;
   USLIMIT=SUM(USMARGIN,CURRATE);
RUN;
PROC SORT DATA=LNNOTE;  BY ACCTNO NOTENO;
*;

DATA LOAN.LNNOTE LOAN.RVNOTE;
   SET LNNOTE;
   IF REVERSED ^= 'Y' THEN OUTPUT LOAN.LNNOTE;
   ELSE                    OUTPUT LOAN.RVNOTE;
*;

DATA NOTE;
     KEEP ACCTNO NOTENO;
     SET LOAN.LNNOTE;
PROC SORT DATA=LIAB; BY ACCTNO NOTENO;
DATA LOAN.LIAB;
   MERGE LIAB(IN=A) NOTE(IN=B);  BY ACCTNO NOTENO;
   IF A AND B;
RUN;
PROC SORT DATA=PEND; BY ACCTNO NOTENO;
DATA LOAN.PEND;
   MERGE PEND(IN=A) NOTE(IN=B);  BY ACCTNO NOTENO;
   IF A AND B;
RUN;
PROC SORT DATA=LNCOMM; BY ACCTNO COMMNO;
PROC SORT DATA=LOAN.LNNOTE  OUT=COMM (KEEP=ACCTNO COMMNO)
NODUPKEY; BY ACCTNO COMMNO;
DATA LOAN.LNCOMM;
   MERGE LNCOMM(IN=A) COMM(IN=B); BY ACCTNO COMMNO;
   IF A AND B THEN OUTPUT;
PROC SORT DATA=NAME8; BY ACCTNO;
PROC SORT DATA=LOAN.LNNOTE  OUT=NAME (KEEP=ACCTNO)
NODUPKEY; BY ACCTNO;
DATA LOAN.NAME8;
   MERGE NAME8(IN=A) NAME(IN=B); BY ACCTNO;
   IF A AND B;
RUN;
PROC SORT DATA=NAME9; BY ACCTNO;
DATA LOAN.NAME9;
   MERGE NAME9(IN=A) NAME(IN=B); BY ACCTNO;
   IF A AND B;
PROC SORT DATA=LNNAME; BY ACCTNO;
DATA LOAN.LNNAME;
   MERGE LNNAME(IN=A) NAME(IN=B); BY ACCTNO;
   IF A AND B;
RUN;
