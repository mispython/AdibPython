          'ORDERING CUSTOMER 3 ' +(-1)DLM+(-1)
          'ORDERING CUSTOMER 4 ' +(-1)DLM+(-1)
          'AMOUNT (FCY) '        +(-1)DLM+(-1)
          'AMOUNT (MYR) '        +(-1)DLM+(-1)
          'ACCOUNT NO '          +(-1)DLM+(-1)
          'CURRENCY '            +(-1)DLM+(-1)
