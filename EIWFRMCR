          'BMR STATUS '          +(-1)DLM+(-1)
          'COUNTRY '             +(-1)DLM+(-1)
          'CBOP CODE '           +(-1)DLM+(-1);
   END;

   PUT LASTTRAN  +(-1)DLM+(-1)
       BRANCHABB +(-1)DLM+(-1)
       SERIAL    +(-1)DLM+(-1)
       BNAD1     +(-1)DLM+(-1)
       BNAD2     +(-1)DLM+(-1)
       BNAD3     +(-1)DLM+(-1)
       BNAD4     +(-1)DLM+(-1)
       ANAD1     +(-1)DLM+(-1)
       ANAD2     +(-1)DLM+(-1)
       ANAD3     +(-1)DLM+(-1)
       ANAD4     +(-1)DLM+(-1)
       FORAMT    +(-1)DLM+(-1)
       AMOUNT    +(-1)DLM+(-1)
       ACCTNO    +(-1)DLM+(-1)
       CURRENCY  +(-1)DLM+(-1)
       PAYMODE   +(-1)DLM+(-1)
       USERID    +(-1)DLM+(-1)
