//*----------------------------------------------------------------
//EIWFRMCR  EXEC SAS609
//DEPOSIT   DD DSN=SAP.PBB.MNITB(0),DISP=SHR
//RMT       DD DSN=SAP.PBB.CRM.RMTRNSAC(0),DISP=SHR
//INWREPT   DD DSN=SAP.PBB.COMP.INWARD.REPT,
//             DISP=(MOD,CATLG,DELETE),
//             DCB=(RECFM=FB,LRECL=1000,BLKSIZE=20000),
//             SPACE=(CYL,(5,2)),UNIT=SYSDA
//OUTWREPT  DD DSN=SAP.PBB.COMP.OUTWARD.REPT,
//             DISP=(MOD,CATLG,DELETE),
//             DCB=(RECFM=FB,LRECL=1000,BLKSIZE=20000),
//             SPACE=(CYL,(5,2)),UNIT=SYSDA
//SYSIN     DD *

OPTIONS YEARCUTOFF=1950 NOCENTER;

DATA REPTDATE;
   SET DEPOSIT.REPTDATE;
   SELECT(DAY(REPTDATE));
      WHEN(8)   CALL SYMPUT('NOWK', PUT('1', $1.));
      WHEN(15)  CALL SYMPUT('NOWK', PUT('2', $1.));
      WHEN(22)  CALL SYMPUT('NOWK', PUT('3', $1.));
      OTHERWISE CALL SYMPUT('NOWK', PUT('4', $1.));
   END;
   CALL SYMPUT('REPTYEAR',PUT(REPTDATE,YEAR2.));
   CALL SYMPUT('REPTMON',PUT(MONTH(REPTDATE),Z2.));
RUN;

DATA INWARD OUTWARD;
   SET RMT.REMTRAN&REPTMON&NOWK&REPTYEAR;
   WHERE REMTYPE = 'F' AND STATUS IN ('TI','TO','BR');

   IF STATUS = 'TI' THEN OUTPUT INWARD;
   ELSE OUTPUT OUTWARD;

   KEEP BRANCHABB STATUS SERIAL LASTTRAN ANAD1 ANAD2 ANAD3 ANAD4
        BNAD1 BNAD2 BNAD3 BNAD4 AMOUNT FORAMT PAYREF
        ACCTNO CURRENCY PAYMODE USERID RESIDENT APPLNATIONAL
        BMRSTATUS COUNTRY ADMIN;
RUN;

DATA _NULL_;
   SET INWARD;
   FILE INWREPT;
   DLM = '05'X;
   IF _N_ = 1 THEN DO;
      PUT 'TRANSACTION DATE '    +(-1)DLM+(-1)
          'BRANCH NAME '         +(-1)DLM+(-1)
          'REFERENCE NO '        +(-1)DLM+(-1)
          'BENEFICIARY NAME 1 '  +(-1)DLM+(-1)
          'BENEFICIARY NAME 2 '  +(-1)DLM+(-1)
          'BENEFICIARY NAME 3 '  +(-1)DLM+(-1)
